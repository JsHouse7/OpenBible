));","strongs_def":"stall-fed; often (as noun) a beeve","kjv_def":"fat (fed) beast (cattle, -ling).","pos":"masculine noun","usage":"fatling(3x)"},"H4807":{"id":"H4807","lemma":"מְרִיב בַּעַל","translit":"Mᵉrîyb Baʻal","pron":"mer-eeb' bah'-al","derivation":"from H7378 (רִיב) and H1168 (בַּעַל);","strongs_def":"quarreller of Baal, Merib-Baal, an epithet of Gideon","kjv_def":"Merib-baal. Compare H4810 (מְרִי בַעַל)."},"H4808":{"id":"H4808","lemma":"מְרִיבָה","translit":"mᵉrîybâh","pron":"mer-ee-baw'","derivation":"from H7378 (רִיב);","strongs_def":"quarrel","kjv_def":"provocation, strife.","pos":"feminine noun","usage":"strife(5x), provocation(1x)"},"H4809":{"id":"H4809","lemma":"מְרִיבָה","translit":"Mᵉrîybâh","pron":"mer-ee-baw'","derivation":"the same as H4808 (מְרִיבָה);","strongs_def":"Meribah, the name of two places in the Desert","kjv_def":"Meribah.","pos":"proper locative noun","usage":"Meribah(7x)"},"H4810":{"id":"H4810","lemma":"מְרִי בַעַל","translit":"Mᵉrîy Baʻal","pron":"mer-ee' bah'-al","derivation":"from H4805 (מְרִי) and H1168 (בַּעַל); rebellion of (i.e. against) Baal;","strongs_def":"Meri-Baal, an epithet of Gideon","kjv_def":"Meri-baal. Compare H4807 (מְרִיב בַּעַל)."},"H4811":{"id":"H4811","lemma":"מְרָיָה","translit":"Mᵉrâyâh","pron":"mer-aw-yaw'","derivation":"from H4784 (מָרָה); rebellion;","strongs_def":"Merajah, an Israelite","kjv_def":"Meraiah. Compare H3236 (יִמְרָה).","pos":"proper masculine noun","usage":"Meraiah(1x)"},"H4812":{"id":"H4812","lemma":"מְרָיוֹת","translit":"Mᵉrâyôwth","pron":"mer-aw-yohth'","derivation":"plural of H4811 (מְרָיָה); rebellious;","strongs_def":"Merajoth, the name of two Israelites","kjv_def":"Meraioth.","pos":"proper masculine plural noun","usage":"Meraioth(7x)"},"H4813":{"id":"H4813","lemma":"מִרְיָם","translit":"Miryâm","pron":"meer-yawm'","derivation":"from H4805 (מְרִי); rebelliously;","strongs_def":"Mirjam, the name of two Israelitesses","kjv_def":"Miriam.","pos":"proper feminine noun","usage":"Miriam(15x)"},"H4814":{"id":"H4814","lemma":"מְרִירוּת","translit":"mᵉrîyrûwth","pron":"mer-ee-rooth'","derivation":"from H4843 (מָרַר);","strongs_def":"bitterness, i.e. (figuratively) grief","kjv_def":"bitterness.","pos":"feminine noun","usage":"bitterness(1x)"},"H4815":{"id":"H4815","lemma":"מְרִירִי","translit":"mᵉrîyrîy","pron":"mer-ee-ree'","derivation":"from H4843 (מָרַר);","strongs_def":"bitter, i.e. poisonous","kjv_def":"bitter.","pos":"adjective","usage":"bitter(1x)"},"H4816":{"id":"H4816","lemma":"מֹרֶךְ","translit":"môrek","pron":"mo'-rek","derivation":"perhaps from H7401 (רָכַךְ);","strongs_def":"softness, i.e. (figuratively) fear","kjv_def":"faintness.","pos":"masculine noun","usage":"faintness(1x)"},"H4817":{"id":"H4817","lemma":"מֶרְכָּב","translit":"merkâb","pron":"mer-kawb'","derivation":"from H7392 (רָכַב);","strongs_def":"a chariot; also a seat (in a vehicle)","kjv_def":"chariot, covering, saddle.","pos":"masculine noun","usage":"saddle(1x), chariot(1x), covering(1x)"},"H4818":{"id":"H4818","lemma":"מֶרְכָּבָה","translit":"merkâbâh","pron":"mer-kaw-baw'","derivation":"feminine of H4817 (מֶרְכָּב);","strongs_def":"a chariot","kjv_def":"chariot. See also H1024 (בֵּית הַמַּרְכָּבוֹת).","pos":"feminine noun","usage":"chariot(44x)"},"H4819":{"id":"H4819","lemma":"מַרְכֹּלֶת","translit":"markôleth","pron":"mar-ko'-leth","derivation":"from H7402 (רָכַל);","strongs_def":"a mart","kjv_def":"merchandise."},"H4820":{"id":"H4820","lemma":"מִרְמָה","translit":"mirmâh","pron":"meer-maw'","derivation":"from H7411 (רָמָה) in the sense of deceiving;","strongs_def":"fraud","kjv_def":"craft, deceit(-ful, -fully), false, feigned, guile, subtilly, treachery.","pos":"feminine noun","usage":"deceit(20x), deceitful(8x), deceitfully(3x), false(2x), guile(2x), feigned(1x), craft(1x), subtilty(1x), treachery(1x)"},"H4821":{"id":"H4821","lemma":"מִרְמָה","translit":"Mirmâh","pron":"meer-maw'","derivation":"the same as H4820 (מִרְמָה);","strongs_def":"Mirmah, an Israelite","kjv_def":"Mirma."},"H4822":{"id":"H4822","lemma":"מְרֵמוֹת","translit":"Mᵉrêmôwth","pron":"mer-ay-mohth'","derivation":"plural from H7311 (רוּם); heights;","strongs_def":"Meremoth, the name of two Israelites","kjv_def":"Meremoth.","pos":"proper masculine plural noun","usage":"Meremoth(6x)"},"H4823":{"id":"H4823","lemma":"מִרְמָס","translit":"mirmâç","pron":"meer-mawce'","derivation":"from H7429 (רָמַס);","strongs_def":"abasement (the act or the thing)","kjv_def":"tread (down) -ing, (to be) trodden (down) under foot.","pos":"masculine noun","usage":"tread(2x)"},"H4824":{"id":"H4824","lemma":"מֵרֹנֹתִי","translit":"Mêrônôthîy","pron":"may-ro-no-thee'","derivation":"patrial from an unused noun;","strongs_def":"a Meronothite, or inhabitant of some (otherwise unknown) Meronoth.","kjv_def":"Meronothite.","pos":"adjective","usage":"Meronothite(2x)"},"H4825":{"id":"H4825","lemma":"מֶרֶס","translit":"Mereç","pron":"meh'-res","derivation":"of foreign derivation;","strongs_def":"Meres, a Persian","kjv_def":"Meres.","pos":"proper masculine noun","usage":"Meres(1x)"},"H4826":{"id":"H4826","lemma":"מַרְסְנָא","translit":"Marçᵉnâʼ","pron":"mar-sen-aw'","derivation":"of foreign derivation;","strongs_def":"Marsena, a Persian","kjv_def":"Marsena.","pos":"proper masculine noun","usage":"Marsena(1x)"},"H4827":{"id":"H4827","lemma":"מֵרַע","translit":"mêraʻ","pron":"may-rah'","derivation":"from H7489 (רָעַע);","strongs_def":"used as (abstract) noun, wickedness","kjv_def":"do mischief.","pos":"participle","usage":"mischief(1x)"},"H4828":{"id":"H4828","lemma":"מֵרֵעַ","translit":"mêrêaʻ","pron":"may-ray'-ah","derivation":"from H7462 (רָעָה) in the sense of companionship;","strongs_def":"a friend","kjv_def":"companion, friend.","pos":"masculine noun","usage":"companion(4x), friend(3x)"},"H4829":{"id":"H4829","lemma":"מִרְעֶה","translit":"mirʻeh","pron":"meer-eh'","derivation":"from H7462 (רָעָה) in the sense of feeding;","strongs_def":"pasture (the place or the act); also the haunt of wild animals","k