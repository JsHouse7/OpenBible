{"H5500":{"id":"H5500","lemma":"סָחָה","translit":"çâchâh","pron":"saw-khaw'","derivation":"a primitive root;","strongs_def":"to sweep away","kjv_def":"scrape.","pos":"verb","usage":"scrape(1x)"},"H5501":{"id":"H5501","lemma":"סְחִי","translit":"çᵉchîy","pron":"seh-khee'","derivation":"from H5500 (סָחָה);","strongs_def":"refuse (as swept off)","kjv_def":"offscouring.","pos":"masculine noun","usage":"offscouring(1x)"},"H5502":{"id":"H5502","lemma":"סָחַף","translit":"çâchaph","pron":"saw-khaf'","derivation":"a primitive root;","strongs_def":"to scrape off","kjv_def":"sweep (away).","pos":"verb"},"H5503":{"id":"H5503","lemma":"סָחַר","translit":"çâchar","pron":"saw-khar'","derivation":"a primitive root;","strongs_def":"to travel round (specifically as a pedlar); intensively, to palpitate","kjv_def":"go about, merchant(-man), occupy with, pant, trade, traffick.","pos":"verb","usage":"merchant(14x), trade(2x), about(1x), panteth(1x), traffick(1x)"},"H5504":{"id":"H5504","lemma":"סַחַר","translit":"çachar","pron":"sakh'-ar","derivation":"from H5503 (סָחַר);","strongs_def":"profit (from trade)","kjv_def":"merchandise.","pos":"masculine noun","usage":"merchandise(4x)"},"H5505":{"id":"H5505","lemma":"סָחַר","translit":"çâchar","pron":"saw-khar'","derivation":"from H5503 (סָחַר);","strongs_def":"an emporium; abstractly, profit (from trade)","kjv_def":"mart, merchandise.","pos":"masculine noun","usage":"merchandise(2x), mart(1x)"},"H5506":{"id":"H5506","lemma":"סְחֹרָה","translit":"çᵉchôrâh","pron":"sekh-o-raw'","derivation":"from H5503 (סָחַר);","strongs_def":"traffic","kjv_def":"merchandise.","pos":"feminine noun","usage":"merchandise(1x)"},"H5507":{"id":"H5507","lemma":"סֹחֵרָה","translit":"çôchêrâh","pron":"so-khay-raw'","derivation":"properly, active participle feminine of H5503 (סָחַר);","strongs_def":"something surrounding the person, i.e. a shield","kjv_def":"buckler."},"H5508":{"id":"H5508","lemma":"סֹחֵרֶת","translit":"çôchêreth","pron":"so-kheh'-reth","derivation":"similar to H5507 (סֹחֵרָה);","strongs_def":"probably a (black) tile (or tessara) forlaying borders with","kjv_def":"black marble.","pos":"feminine noun","usage":"black(1x)"},"H5509":{"id":"H5509","lemma":"סִיג","translit":"çîyg","pron":"seeg","derivation":"or סוּג; (Ezekiel 22:18), from H5472 (סוּג) in the sense of refuse;","strongs_def":"scoria","kjv_def":"dross.","pos":"masculine noun","usage":"dross(8x)"},"H5510":{"id":"H5510","lemma":"סִיוָן","translit":"Çîyvân","pron":"see-vawn'","derivation":"probably of Persian origin;","strongs_def":"Sivan, the third Hebrew month","kjv_def":"Sivan.","pos":"proper noun","usage":"Sivan(1x)"},"H5511":{"id":"H5511","lemma":"סִיחוֹן","translit":"Çîychôwn","pron":"see-khone'","derivation":"or סִיחֹן; from the same as H5477 (סוּחַ); tempestuous;","strongs_def":"Sichon, an Amoritish king","kjv_def":"Sihon.","pos":"proper masculine noun","usage":"Sihon(37x)"},"H5512":{"id":"H5512","lemma":"סִין","translit":"Çîyn","pron":"seen","derivation":"of uncertain derivation;","strongs_def":"Sin the name of an Egyptian town and (probably) desert adjoining","kjv_def":"Sin.","pos":"proper locative noun","usage":"Sin(6x)"},"H5513":{"id":"H5513","lemma":"סִינִי","translit":"Çîynîy","pron":"see-nee'","derivation":"from an otherwise unknown name of a man;","strongs_def":"a Sinite, or descendant of one of the sons of Canaan","kjv_def":"Sinite."},"H5514":{"id":"H5514","lemma":"סִינַי","translit":"Çîynay","pron":"see-nah'-ee","derivation":"of uncertain derivation;","strongs_def":"Sinai, mountain of Arabia","kjv_def":"Sinai.","pos":"proper locative noun","usage":"Sinai(35x)"},"H5515":{"id":"H5515","lemma":"סִינִים","translit":"Çîynîym","pron":"see-neem'","derivation":"plural of an otherwise unknown name;","strongs_def":"Sinim, a distant Oriental region","kjv_def":"Sinim."},"H5516":{"id":"H5516","lemma":"סִיסְרָא","translit":"Çîyçᵉrâʼ","pron":"see-ser-aw'","derivation":"of uncertain derivation;","strongs_def":"Sisera, the name of a Canaanitish king and of one of the Nethinim","kjv_def":"Sisera.","pos":"proper masculine noun","usage":"Sisera(21x)"},"H5517":{"id":"H5517","lemma":"סִיעָא","translit":"Çîyʻâʼ","pron":"see-ah'","derivation":"or סִיעֲהָא; from an unused root meaning to converse; congregation;","strongs_def":"Sia or Siaha, one of the Nethinim","kjv_def":"Sia, Siaha.","pos":"proper masculine noun","usage":"Sia(1x), Siaha(1x)"},"H5518":{"id":"H5518","lemma":"סִיר","translit":"çîyr","pron":"seer","derivation":"or (feminine) סִירָה; or סִרָה; (Jeremiah 52:18), from a primitive root meaning to boil up;","strongs_def":"a pot; also a thorn (as springing up rapidly); by implication, a hook","kjv_def":"caldron, fishhook, pan, (wash-)pot, thorn.","pos":"masculine noun","usage":"pot(21x), caldron(5x), thorns(4x), pans(1x)"},"H5519":{"id":"H5519","lemma":"סָךְ","translit":"çâk","pron":"sawk","derivation":"from H5526 (סָכַךְ);","strongs_def":"properly, a thicket of men, i.e. a crowd","kjv_def":"multitude.","pos":"masculine noun","usage":"multitude(1x)"},"H5520":{"id":"H5520","lemma":"סֹךְ","translit":"çôk","pron":"soke","derivation":"from H5526 (סָכַךְ);","strongs_def":"a hut (as of entwined boughs); also a lair","kjv_def":"covert, den, pavilion, tabernacle.","pos":"masculine noun","usage":"den(1x), pavilion(1x), tabernacle(1x), covert(1x)"},"H5521":{"id":"H5521","lemma":"סֻכָּה","translit":"çukkâh","pron":"sook-kaw'","derivation":"feminine of H5520 (סֹךְ);","strongs_def":"a hut or lair","kjv_def":"booth, cottage, covert, pavilion, tabernacle, tent.","pos":"feminine noun","usage":"tabernacle(12x), booth(11x), pavilion(5x), cottage(1x), covert(1x), tents(1x)"},"H5522":{"id":"H5522","lemma":"סִכּוּת","translit":"çikkûwth","pron":"sik-kooth'","derivation":"feminine of H5519 (סָךְ);","strongs_def":"an (idolatrous) booth","kjv_def":"tabernacle.","pos":"proper feminine noun","usage":"tabernacle(1x)"},"H5523":{"id":"H5523","lemma":"סֻכּוֹת","translit":"Çukkôwth","pron":"sook-kohth'","derivation":"or סֻכֹּת; plural of H5521 (סֻכָּה); booths;","strongs_def":"Succoth, the name of a place in Egypt and of three in Palestine","kjv_def":"Succoth.","pos":"proper plural locative noun","usage":"Succoth(18x)"},"H5524":{"id":"H5524","lemma":"סֻכּוֹת בְּנוֹת","translit":"Çukkôwth bᵉnôwth","pron":"sook-kohth' ben-ohth'","derivation":"from H5523 (סֻכּוֹת) and the (irregular) plural of H1323 (בַּת);","strongs_def":"booths of (the) daughters; brothels, i.e. idoalatrous tents forimpure purpose","kjv_def":"Succothbenoth."},"H5525":{"id":"H5525","lemma":"סֻכִּי","translit":"Çukkîy","pron":"sook-kee'","derivation":"patrial from an unknown name (perhaps H5520 (סֹךְ));","strongs_def":"a Sukkite, or inhabitant of some place near Egypt (i.e. hut-dwellers)","kjv_def":"Sukkiims."},"H5526":{"id":"H5526","lemma":"סָכַךְ","translit":"çâkak","pron":"saw-kak'","derivation":"or שָׂכַךְ; (Exodus 33:22), a primitive root;","strongs_def":"properly, to entwine as ascreen; by implication, to fence in, cover over, (figuratively) protect","kjv_def":"cover, defence, defend, hedge in, join together, set, shut up.","pos":"verb","usage":"cover(15x), covering(2x), defence(1x), defendest(1x), set(1x)"},"H5527":{"id":"H5527","lemma":"סְכָכָה","translit":"Çᵉkâkâh","pron":"sek-aw-kaw'","derivation":"from H5526 (סָכַךְ); inclosure;","strongs_def":"Secacah, a place in Palestine","kjv_def":"Secacah."},"H5528":{"id":"H5528","lemma":"סָכַל","translit":"çâkal","pron":"saw-kal'","derivation":"for H3688 (כָּסַל);","strongs_def":"to be silly","kjv_def":"do (make, play the, turn into) fool(-ish, -ishly, -ishness).","pos":"verb"},"H5529":{"id":"H5529","lemma":"סֶכֶל","translit":"çekel","pron":"seh'-kal","derivation":"from H5528 (סָכַל);","strongs_def":"silliness; concretely and collectively, dolts","kjv_def":"folly.","pos":"masculine noun","usage":"folly(1x)"},"H5530":{"id":"H5530","lemma":"סָכָל","translit":"çâkâl","pron":"saw-kawl'","derivation":"from H5528 (סָכַל);","strongs_def":"silly","kjv_def":"fool(-ish), sottish.","pos":"masculine noun","usage":"fool(4x), foolish(2x), sottish(1x)"},"H5531":{"id":"H5531","lemma":"סִכְלוּת","translit":"çiklûwth","pron":"sik-looth'","derivation":"or שִׂכְלוּת; (Ecclesiastes 1:17), from H5528 (סָכַל);","strongs_def":"silliness","kjv_def":"folly, foolishness.","pos":"masculine noun","usage":"folly(5x), foolishness(2x)"},"H5532":{"id":"H5532","lemma":"סָכַן","translit":"çâkan","pron":"saw-kan'","derivation":"a primitive root;","strongs_def":"to be familiar with; by implication, to minister to, be serviceable to, be customary","kjv_def":"acquaint (self), be advantage, [idiom] ever, (be, (un-)) profit(-able), treasurer, be wont.","pos":"verb","usage":"acquaint(2x), profitable(2x), cherish(2x), advantage(1x), ever(1x), profiteth(1x), treasurer(1x), unprofitable(1x), wont(1x)"},"H5533":{"id":"H5533","lemma":"סָכַן","translit":"çâkan","pron":"saw-kan'","derivation":"probably a denominative from H7915 (שַׂכִּין);","strongs_def":"properly, to cut, i.e. damage; also to grow (causatively, make) poor","kjv_def":"endanger, impoverish.","pos":"verb","usage":"endangered(1x), impoverished(1x)"},"H5534":{"id":"H5534","lemma":"סָכַר","translit":"çâkar","pron":"saw-kar'","derivation":"a primitive root;","strongs_def":"to shut up; by implication, to surrender","kjv_def":"stop, give over. See also H5462 (סָגַר), H7936 (שָׂכַר).","pos":"verb","usage":"stopped(2x)"},"H5535":{"id":"H5535","lemma":"סָכַת","translit":"çâkath","pron":"saw-kath'","derivation":"a primitive root to be silent;","strongs_def":"by implication, to observe quietly","kjv_def":"take heed.","pos":"verb"},"H5536":{"id":"H5536","lemma":"סַל","translit":"çal","pron":"sal","derivation":"from H5549 (סָלַל);","strongs_def":"properly, a willow twig (as pendulous), i.e. an osier; but only as woven into abasket","kjv_def":"basket.","pos":"masculine noun","usage":"basket(15x)"},"H5537":{"id":"H5537","lemma":"סָלָא","translit":"çâlâʼ","pron":"saw-law'","derivation":"a primitive root;","strongs_def":"to suspend in a balance, i.e. weigh","kjv_def":"compare.","pos":"verb","usage":"comparable(1x)"},"H5538":{"id":"H5538","lemma":"סִלָּא","translit":"Çillâʼ","pron":"sil-law'","derivation":"from H5549 (סָלַל); an embankment;","strongs_def":"Silla, a place in Jerusalem","kjv_def":"Silla."},"H5539":{"id":"H5539","lemma":"סָלַד","translit":"çâlad","pron":"saw-lad'","derivation":"a primitive root;","strongs_def":"probably to leap (with joy), i.e. exult","kjv_def":"harden self.","pos":"verb","usage":"harden(1x)"},"H5540":{"id":"H5540","lemma":"סֶלֶד","translit":"Çeled","pron":"seh'-led","derivation":"from H5539 (סָלַד); exultation;","strongs_def":"Seled, an Israelite","kjv_def":"Seled."},"H5541":{"id":"H5541","lemma":"סָלָה","translit":"çâlâh","pron":"saw-law'","derivation":"a primitive root;","strongs_def":"to hang up, i.e. weigh, or (figuratively) contemn","kjv_def":"tread down (under foot), value.","pos":"verb","usage":"valued(2x)"},"H5542":{"id":"H5542","lemma":"סֶלָה","translit":"çelâh","pron":"seh'-law","derivation":"from H5541 (סָלָה);","strongs_def":"suspension (of music), i.e. pause","kjv_def":"Selah.","pos":"verb","usage":"Selah(74x)"},"H5543":{"id":"H5543","lemma":"סַלּוּ","translit":"Çallûw","pron":"sal-loo'","derivation":"or סַלּוּא; or סָלוּא; or סַלַּי; from H5541 (סָלָה); weighed;","strongs_def":"Sallu or Sallai, the name of two Israelites","kjv_def":"Sallai, Sallu, Salu.","pos":"proper masculine noun","usage":"Sallu(3x), Sallai(2x), Salu(1x)"},"H5544":{"id":"H5544","lemma":"סִלּוֹן","translit":"çillôwn","pron":"sil-lone'","derivation":"or סַלּוֹן; from H5541 (סָלָה);","strongs_def":"a prickle (as if pendulous)","kjv_def":"brier, thorn.","pos":"masculine noun","usage":"brier(1x), thorn(1x)"},"H5545":{"id":"H5545","lemma":"סָלַח","translit":"çâlach","pron":"saw-lakh'","derivation":"a primitive root;","strongs_def":"to forgive","kjv_def":"forgive, pardon, spare.","pos":"verb","usage":"forgive(19x), forgiven(13x), pardon(13x), spare(1x)"},"H5546":{"id":"H5546","lemma":"סַלָּח","translit":"çallâch","pron":"saw-lawkh'","derivation":"from H5545 (סָלַח);","strongs_def":"placable","kjv_def":"ready to forgive.","pos":"adjective"},"H5547":{"id":"H5547","lemma":"סְלִיחָה","translit":"çᵉlîychâh","pron":"sel-ee-khaw'","derivation":"from H5545 (סָלַח);","strongs_def":"pardon","kjv_def":"forgiveness, pardon.","pos":"feminine noun","usage":"forgiveness(2x), pardon(1x)"},"H5548":{"id":"H5548","lemma":"סַלְכָה","translit":"Çalkâh","pron":"sal-kaw'","derivation":"from an unused root. meaning to walk; walking;","strongs_def":"Salcah, a place East of the Jordan","kjv_def":"Salcah, Salchah.","pos":"proper locative noun","usage":"Salchah(2x), Salcah(2x)"},"H5549":{"id":"H5549","lemma":"סָלַל","translit":"çâlal","pron":"saw-lal'","derivation":"a primitive root;","strongs_def":"to mound up (especially a turnpike); figurative, to exalt; reflexively, to oppose (as by a dam)","kjv_def":"cast up, exalt (self), extol, make plain, raise up.","pos":"verb","usage":"exalt(2x), extol(1x)"},"H5550":{"id":"H5550","lemma":"סֹלְלָה","translit":"çôlᵉlâh","pron":"so-lel-aw'","derivation":"or סוֹלְלָה; active participle feminine of H5549 (סָלַל), but used passively;","strongs_def":"a military mound, i.e. rampart of besiegers","kjv_def":"bank, mount.","pos":"feminine noun active participle","usage":"mount(8x), bank(3x)"},"H5551":{"id":"H5551","lemma":"סֻלָּם","translit":"çullâm","pron":"sool-lawm'","derivation":"from H5549 (סָלַל);","strongs_def":"a stair-case","kjv_def":"ladder.","pos":"masculine noun","usage":"ladder(1x)"},"H5552":{"id":"H5552","lemma":"סַלְסִלָּה","translit":"çalçillâh","pron":"sal-sil-law'","derivation":"from H5541 (סָלָה);","strongs_def":"a twig (as pendulous)","kjv_def":"basket."},"H5553":{"id":"H5553","lemma":"סֶלַע","translit":"çelaʻ","pron":"seh'-lah","derivation":"from an unused root meaning to be lofty;","strongs_def":"a craggy rock, literally or figuratively (a fortress)","kjv_def":"(ragged) rock, stone(-ny), strong hold.","pos":"masculine noun","usage":"rock(57x), stones(1x), stony(1x)"},"H5554":{"id":"H5554","lemma":"סֶלַע","translit":"Çelaʻ","pron":"seh'-lah","derivation":"the same as H5553 (סֶלַע);","strongs_def":"Sela, the rock-city of Idumaea","kjv_def":"rock, Sela(-h).","pos":"proper locative noun","usage":"Sela(1x), Selah(1x)"},"H5555":{"id":"H5555","lemma":"סֶלַע הַמַּחְלְקוֹת","translit":"Çelaʻ ham-machlᵉqôwth","pron":"seh'-lah hammakh-lek-oth'","derivation":"from H5553 (סֶלַע) and the plural of H4256 (מַחֲלֹקֶת) with the article interposed; rock of the divisions;","strongs_def":"Sela-ham-Machlekoth, a place in Palestine","kjv_def":"Sela-hammalekoth."},"H5556":{"id":"H5556","lemma":"סׇלְעָם","translit":"çolʻâm","pron":"sol-awm'","derivation":"apparently from the same as H5553 (סֶלַע) in the sense of crushing as with a rock, i.e. consuming;","strongs_def":"a kind of locust (from its destructiveness)","kjv_def":"bald locust.","pos":"masculine noun","usage":"locust(1x)"},"H5557":{"id":"H5557","lemma":"סָלַף","translit":"çâlaph","pron":"saw-laf'","derivation":"a primitive root;","strongs_def":"properly, to wrench, i.e. (figuratively) to subvert","kjv_def":"overthrow, pervert.","pos":"verb","usage":"overthrow(4x), pervert(3x)"},"H5558":{"id":"H5558","lemma":"סֶלֶף","translit":"çeleph","pron":"seh'-lef","derivation":"from H5557 (סָלַף);","strongs_def":"distortion, i.e. (figuratively) viciousness","kjv_def":"perverseness.","pos":"masculine noun","usage":"perverseness(2x)"},"H5559":{"id":"H5559","lemma":"סְלִק","translit":"çᵉliq","pron":"sel-eek'","derivation":"(Aramaic) a primitive root;","strongs_def":"to ascend","kjv_def":"come (up).","pos":"verb","usage":"came(1x)"},"H5560":{"id":"H5560","lemma":"סֹלֶת","translit":"çôleth","pron":"so'-leth","derivation":"from an unused root meaning to strip;","strongs_def":"flour (as chipped off)","kjv_def":"(fine) flour, meal.","pos":"feminine noun","usage":"flour(52x), fine(1x)"},"H5561":{"id":"H5561","lemma":"סַם","translit":"çam","pron":"sam","derivation":"from an unused root meaning to smell sweet;","strongs_def":"an aroma","kjv_def":"sweet (spice).","pos":"masculine noun","usage":"sweet(14x)"},"H5562":{"id":"H5562","lemma":"סַמְגַּר נְבוֹ","translit":"Çamgar Nᵉbôw","pron":"sam-gar' neb-o'","derivation":"of foreign origin;","strongs_def":"Samgar-Nebo, a Babylonian general","kjv_def":"Samgar-nebo.","pos":"proper masculine noun","usage":"Samgarnebo(1x)"},"H5563":{"id":"H5563","lemma":"סְמָדַר","translit":"çᵉmâdar","pron":"sem-aw-dar'","derivation":"of uncertain derivation;","strongs_def":"a vine blossom; used also adverbially, abloom","kjv_def":"tender grape.","pos":"masculine noun"},"H5564":{"id":"H5564","lemma":"סָמַךְ","translit":"çâmak","pron":"saw-mak'","derivation":"a primitive root;","strongs_def":"to prop (literally or figuratively); reflexively, to lean upon or take hold of (in a favorable or unfavorable sense)","kjv_def":"bear up, establish, (up-) hold, lay, lean, lie hard, put, rest self, set self, stand fast, stay (self), sustain.","pos":"verb","usage":"lay(18x), uphold(9x), put(5x), lean(3x), stay(3x), sustained(3x), established(1x), rested(1x), set(1x)"},"H5565":{"id":"H5565","lemma":"סְמַכְיָהוּ","translit":"Çᵉmakyâhûw","pron":"sem-ak-yaw'-hoo","derivation":"from H5564 (סָמַךְ) and H3050 (יָהּ); supported of Jah;","strongs_def":"Semakjah, an Israelite","kjv_def":"Semachiah."},"H5566":{"id":"H5566","lemma":"סֶמֶל","translit":"çemel","pron":"seh'-mel","derivation":"or סֵמֶל; from an unused root meaning to resemble;","strongs_def":"a likeness","kjv_def":"figure, idol, image.","pos":"masculine noun","usage":"image(2x), idol(2x), figure(1x)"},"H5567":{"id":"H5567","lemma":"סָמַן","translit":"çâman","pron":"saw-man'","derivation":"a primitive root;","strongs_def":"to designate","kjv_def":"appointed.","pos":"verb","usage":"appointed(1x)"},"H5568":{"id":"H5568","lemma":"סָמַר","translit":"çâmar","pron":"saw-mar'","derivation":"a primitive root;","strongs_def":"to be erect, i.e. bristle as hair","kjv_def":"stand up, tremble.","pos":"verb","usage":"tremble(1x)"},"H5569":{"id":"H5569","lemma":"סָמָר","translit":"çâmâr","pron":"saw-mar'","derivation":"from H5568 (סָמַר);","strongs_def":"bristling, i.e. shaggy","kjv_def":"rough.","pos":"adjective","usage":"rough(1x)"},"H5570":{"id":"H5570","lemma":"סְנָאָה","translit":"Çᵉnâʼâh","pron":"sen-aw-aw'","derivation":"from an unused root meaning to prick; thorny;","strongs_def":"Senaah, a place in Palestine","kjv_def":"Senaah, Hassenaah (with the article).","pos":"proper masculine noun","usage":"Senaah(2x), Hassenaah(1x)"},"H5571":{"id":"H5571","lemma":"סַנְבַלַּט","translit":"Çanballaṭ","pron":"san-bal-lat'","derivation":"of foreign origin;","strongs_def":"Sanballat, a Persian satrap of Samaria","kjv_def":"Sanballat.","pos":"proper masculine noun","usage":"Sanballat(10x)"},"H5572":{"id":"H5572","lemma":"סְנֶה","translit":"çᵉneh","pron":"sen-eh'","derivation":"from an unused root meaning to prick;","strongs_def":"a bramble","kjv_def":"bush.","pos":"masculine noun","usage":"bush(6x)"},"H5573":{"id":"H5573","lemma":"סֶנֶה","translit":"Çeneh","pron":"seh-neh'","derivation":"the same as H5572 (סְנֶה); thorn;","strongs_def":"Seneh, a crag in Palestine","kjv_def":"Seneh."},"H5574":{"id":"H5574","lemma":"סְנוּאָה","translit":"Çᵉnûwʼâh","pron":"sen-oo-aw'","derivation":"or סְנֻאָה from the same as H5570 (סְנָאָה);","strongs_def":"pointed; (used with the article as a proper name) Senuah, the name of two Israelites","kjv_def":"Hasenuah (including the art), Senuah.","pos":"proper masculine noun","usage":"Senuah(1x), Hasenuah(1x)"},"H5575":{"id":"H5575","lemma":"סַנְוֵר","translit":"çanvêr","pron":"san-vare'","derivation":"of uncertain derivation;","strongs_def":"(in plural) blindness","kjv_def":"blindness.","pos":"masculine noun","usage":"blindness(3x)"},"H5576":{"id":"H5576","lemma":"סַנְחֵרִיב","translit":"Çanchêrîyb","pron":"san-khay-reeb'","derivation":"of foreign origin;","strongs_def":"Sancherib, an Assyrian king","kjv_def":"Sennacherib.","pos":"proper masculine noun","usage":"Sennacherib(13x)"},"H5577":{"id":"H5577","lemma":"סַנְסִן","translit":"çançin","pron":"san-seen'","derivation":"from an unused root meaning to be pointed;","strongs_def":"a twig (as tapering)","kjv_def":"bough.","pos":"masculine noun","usage":"boughs(1x)"},"H5578":{"id":"H5578","lemma":"סַנְסַנָּה","translit":"Çançannâh","pron":"san-san-naw'","derivation":"feminine of a form of H5577 (סַנְסִן); a bough;","strongs_def":"Sansannah, a place in Palestine","kjv_def":"Sansannah."},"H5579":{"id":"H5579","lemma":"סְנַפִּיר","translit":"çᵉnappîyr","pron":"sen-ap-peer'","derivation":"of uncertain derivation;","strongs_def":"a fin (collectively)","kjv_def":"fins.","pos":"masculine noun","usage":"fin(5x)"},"H5580":{"id":"H5580","lemma":"סָס","translit":"çâç","pron":"sawce","derivation":"from the same as H5483 (סוּס);","strongs_def":"a moth (from the agility of the fly)","kjv_def":"moth.","pos":"masculine noun","usage":"worm(1x)"},"H5581":{"id":"H5581","lemma":"סִסְמַי","translit":"Çiçmay","pron":"sis-mah'-ee","derivation":"of uncertain derivation;","strongs_def":"Sismai, an Israelite","kjv_def":"Sisamai."},"H5582":{"id":"H5582","lemma":"סָעַד","translit":"çâʻad","pron":"saw-ad'","derivation":"a primitive root;","strongs_def":"to suport (mostly figurative)","kjv_def":"comfort, establish, hold up, refresh self, strengthen, be upholden.","pos":"verb","usage":"comfort(3x), strengthen(3x), upholden(1x), establish(1x), refresh(1x)"},"H5583":{"id":"H5583","lemma":"סְעַד","translit":"çᵉʻad","pron":"seh-ad'","derivation":"(Aramaic) corresponding to H5582 (סָעַד);","strongs_def":"to aid","kjv_def":"helping."},"H5584":{"id":"H5584","lemma":"סָעָה","translit":"çâʻâh","pron":"saw-aw'","derivation":"a primitive root;","strongs_def":"to rush","kjv_def":"storm.","pos":"verb","usage":"storm(1x)"},"H5585":{"id":"H5585","lemma":"סָעִיף","translit":"çâʻîyph","pron":"saw-eef'","derivation":"from H5586 (סָעַף);","strongs_def":"a fissure (of rocks); also a bough (as subdivided)","kjv_def":"(outmost) branch, clift, top.","pos":"masculine noun","usage":"top(3x), branches(2x), clifts(1x)"},"H5586":{"id":"H5586","lemma":"סָעַף","translit":"çâʻaph","pron":"saw-af'","derivation":"a primitive root; properly, to divide up; but used only as denominative from H5585 (סָעִיף),","strongs_def":"to disbranch (a tree)","kjv_def":"top.","pos":"verb","usage":"lop(1x)"},"H5587":{"id":"H5587","lemma":"סָעִף","translit":"çâʻiph","pron":"saw-eef'","derivation":"or שָׂעִף; from H5586 (סָעַף);","strongs_def":"divided (in mind), i.e. (abstractly) a sentiment","kjv_def":"opinion.","pos":"feminine noun","usage":"thoughts(2x), opinion(1x)"},"H5588":{"id":"H5588","lemma":"סֵעֵף","translit":"çêʻêph","pron":"say-afe'","derivation":"from H5586 (סָעַף);","strongs_def":"divided (in mind), i.e. (concretely) a skeptic","kjv_def":"thought.","pos":"adjective","usage":"thoughts(1x)"},"H5589":{"id":"H5589","lemma":"סְעַפָּה","translit":"çᵉʻappâh","pron":"seh-ap-paw'","derivation":"feminine of H5585 (סָעִיף);","strongs_def":"a twig","kjv_def":"bough, branch. Compare H5634 (סַרְעַפָּה).","pos":"feminine noun","usage":"boughs(2x)"},"H5590":{"id":"H5590","lemma":"סָעַר","translit":"çâʻar","pron":"saw-ar'","derivation":"a primitive root;","strongs_def":"to rush upon; by implication, to toss (transitive or intransitive, literal or figurative)","kjv_def":"be (toss with) tempest(-uous), be sore, troubled, come out as a (drive with the, scatter with a) whirlwind.","pos":"verb","usage":"whirlwind(3x), tempestuous(2x), troubled(1x)"},"H5591":{"id":"H5591","lemma":"סַעַר","translit":"çaʻar","pron":"sah'-ar","derivation":"or (feminine) סְעָרָה; from H5590 (סָעַר);","strongs_def":"a hurricane","kjv_def":"storm(-y), tempest, whirlwind.","pos":"masculine/feminine noun","usage":"whirlwind(12x), tempest(6x), stormy(4x), storm(1x)"},"H5592":{"id":"H5592","lemma":"סַף","translit":"çaph","pron":"saf","derivation":"from H5605 (סָפַף), in its original sense of containing;","strongs_def":"a vestibule (as a limit); also a dish (for holding blood or wine)","kjv_def":"bason, bowl, cup, door (post), gate, post, threshold.","pos":"masculine noun","usage":"door(12x), threshold(8x), bason(4x), posts(3x), bowls(2x), gates(2x), cup(1x)"},"H5593":{"id":"H5593","lemma":"סַף","translit":"Çaph","pron":"saf","derivation":"the same as H5592 (סַף);","strongs_def":"Saph, a Philistine","kjv_def":"Saph. Compare H5598 (סִפַּי)."},"H5594":{"id":"H5594","lemma":"סָפַד","translit":"çâphad","pron":"saw-fad'","derivation":"a primitive root;","strongs_def":"properly, to tear the hair and beat the breasts (as Orientals do in grief); generally to lament; by implication, to wail","kjv_def":"lament, mourn(-er), wail.","pos":"verb","usage":"mourn(15x), lament(13x), mourners(1x), wail(1x)"},"H5595":{"id":"H5595","lemma":"סָפָה","translit":"çâphâh","pron":"saw-faw'","derivation":"a primitive root;","strongs_def":"properly, to scrape (literally, to shave; but usually figuratively) together (i.e. to accumulate or increase) or away (i.e. to scatter, remove, or ruin; intransitively, to perish)","kjv_def":"add, augment, consume, destroy, heap, join, perish, put.","pos":"verb","usage":"consume(6x), destroy(5x), add(3x), perish(2x), augment(1x), heap(1x), joined(1x), put(1x)"},"H5596":{"id":"H5596","lemma":"סָפַח","translit":"çâphach","pron":"saw-fakh'","derivation":"or שָׂפַח; (Isaiah 3:17), a primitive root;","strongs_def":"properly, to scrape out, but in certain peculiar senses (of removal or association)","kjv_def":"abiding, gather together, cleave, smite with the scab.","pos":"verb","usage":"put(2x), abide(1x), cleave(1x)"},"H5597":{"id":"H5597","lemma":"סַפַּחַת","translit":"çappachath","pron":"sap-pakh'-ath","derivation":"from H5596 (סָפַח);","strongs_def":"the mange (as making the hair fall off)","kjv_def":"scab.","pos":"feminine noun","usage":"scab(2x)"},"H5598":{"id":"H5598","lemma":"סִפַּי","translit":"Çippay","pron":"sip-pah'-ee","derivation":"from H5592 (סַף); bason-like;","strongs_def":"Sippai, a Philistine","kjv_def":"Sippai. Compare H5593 (סַף)."},"H5599":{"id":"H5599","lemma":"סָפִיחַ","translit":"çâphîyach","pron":"saw-fee'-akh","derivation":"from H5596 (סָפַח);","strongs_def":"something (spontaneously) falling off, i.e. a self-sown crop; figuratively, a freshet","kjv_def":"(such) things as (which) grow (of themselves), which groweth of its own accord (itself).","pos":"masculine noun"}}