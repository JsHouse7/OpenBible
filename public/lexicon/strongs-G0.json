ion":"from G69 (ἀγρυπνέω);","strongs_def":"sleeplessness, i.e. a keeping awake","kjv_def":"watch"},"G72":{"id":"G72","lemma":"ἀγωγή","translit":"agōgḗ","derivation":"reduplicated from G71 (ἄγω);","strongs_def":"a bringing up, i.e. mode of living","kjv_def":"manner of life"},"G88":{"id":"G88","lemma":"ἀδιάλειπτος","translit":"adiáleiptos","derivation":"from G1 (Α) (as a negative particle) and a derivative of a compound of G1223 (διά) and G3007 (λείπω);","strongs_def":"unintermitted, i.e. permanent","kjv_def":"without ceasing, continual","pos":"adjective","usage":"continual(1x)"},"G77":{"id":"G77","lemma":"ἀδάπανος","translit":"adápanos","derivation":"from G1 (Α) (as negative particle);","strongs_def":"and G1160 (δαπάνη); costless, i.e. gratuitous","kjv_def":"without expense"},"G49":{"id":"G49","lemma":"ἁγνισμός","translit":"hagnismós","derivation":"from G48 (ἁγνίζω);","strongs_def":"a cleansing (the act), i.e. (ceremonially) lustration","kjv_def":"purification","pos":"masculine noun","usage":"purification(1x)"},"G36":{"id":"G36","lemma":"ἀγενής","translit":"agenḗs","derivation":"from G1 (Α) (as negative particle) and G1085 (γένος);","strongs_def":"properly, without kin, i.e. (of unknown descent, and by implication) ignoble","kjv_def":"base things"},"G95":{"id":"G95","lemma":"ἀδίκως","translit":"adíkōs","derivation":"adverb from G94 (ἄδικος);","strongs_def":"unjustly","kjv_def":"wrongfully"},"G29":{"id":"G29","lemma":"ἀγγαρεύω","translit":"angareúō","derivation":"of foreign origin (compare H0104);","strongs_def":"properly, to be a courier, i.e. (by implication) to press into public service","kjv_def":"compel (to go)","pos":"verb"},"G21":{"id":"G21","lemma":"ἀγαλλιάω","translit":"agalliáō","derivation":"from agan (much) and G242 (ἅλλομαι);","strongs_def":"properly, to jump for joy, i.e. exult","kjv_def":"be (exceeding) glad, with exceeding joy, rejoice (greatly)","pos":"verb","usage":"rejoice(7x)"},"G34":{"id":"G34","lemma":"ἀγέλη","translit":"agélē","derivation":"from