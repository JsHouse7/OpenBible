{"H1700":{"id":"H1700","lemma":"דִּבְרָה","translit":"dibrâh","pron":"dib-raw'","derivation":"feminine of H1697 (דָּבָר);","strongs_def":"a reason, suit or style","kjv_def":"cause, end, estate, order, regard.","pos":"masculine noun","usage":"cause(1x), order(1x), estate(1x), end(1x), regard(1x)"},"H1701":{"id":"H1701","lemma":"דִּבְרָה","translit":"dibrâh","pron":"dib-raw'","derivation":"(Aramaic) corresponding to H1700 (דִּבְרָה)","strongs_def":"{a reason, suit or style}","kjv_def":"intent, sake.","pos":"feminine noun","usage":"sakes(1x), intent(1x)"},"H1702":{"id":"H1702","lemma":"דֹּבְרָה","translit":"dôbᵉrâh","pron":"do-ber-aw'","derivation":"feminine active participle of H1696 (דָבַר) in the sense of driving (compare H1699 (דֹּבֶר));","strongs_def":"a raft","kjv_def":"float."},"H1703":{"id":"H1703","lemma":"דַּבָּרָה","translit":"dabbârâh","pron":"dab-baw-raw'","derivation":"intensive from H1696 (דָבַר);","strongs_def":"a word","kjv_def":"word."},"H1704":{"id":"H1704","lemma":"דִּבְרִי","translit":"Dibrîy","pron":"dib-ree'","derivation":"from H1697 (דָּבָר); wordy;","strongs_def":"Dibri, an Israelite","kjv_def":"Dibri.","pos":"proper masculine noun","usage":"Dibri(1x)"},"H1705":{"id":"H1705","lemma":"דֲּבְרַת","translit":"Dăbrath","pron":"daw-ber-ath'","derivation":"from H1697 (דָּבָר) (perhaps in the sense of H1699 (דֹּבֶר));","strongs_def":"Daberath, a place in Palestine","kjv_def":"Dabareh, Daberath.","pos":"proper locative noun","usage":"Daberath(2x), Dabareh(1x)"},"H1706":{"id":"H1706","lemma":"דְּבַשׁ","translit":"dᵉbash","pron":"deb-ash'","derivation":"from an unused root meaning to be gummy;","strongs_def":"honey (from its stickiness); by analogy, syrup","kjv_def":"honey(-comb).","pos":"masculine noun","usage":"honey(52x)"},"H1707":{"id":"H1707","lemma":"דַּבֶּשֶׁת","translit":"dabbesheth","pron":"dab-beh'-sheth","derivation":"intensive from the same as H1706 (דְּבַשׁ);","strongs_def":"a sticky mass, i.e. the hump of acamel","kjv_def":"hunch (of a camel).","pos":"feminine noun","usage":"bunch(1x)"},"H1708":{"id":"H1708","lemma":"דַּבֶּשֶׁת","translit":"Dabbesheth","pron":"dab-beh'-sheth","derivation":"the same as H1707 (דַּבֶּשֶׁת);","strongs_def":"Dabbesheth, a place in Palestine","kjv_def":"Dabbesheth.","pos":"proper locative noun","usage":"Dabbasheth(1x)"},"H1709":{"id":"H1709","lemma":"דָּג","translit":"dâg","pron":"dawg","derivation":"or (fully) דָּאג; (Nehemiah 13:16), from H1711 (דָּגָה); a fish (as prolific); or perhaps rather from H1672 (דָּאַג) (as timid); but still better from H1672 (דָּאַג) (in the sense of squirming, i.e. moving by the vibratory action of the tail);","strongs_def":"a fish (often used collectively)","kjv_def":"fish.","pos":"masculine noun","usage":"fish(20x)"},"H1710":{"id":"H1710","lemma":"דָּגָה","translit":"dâgâh","pron":"daw-gaw'","derivation":"feminine of H1709 (דָּג), and meaning the same","strongs_def":"{a fish (often used collectively)}","kjv_def":"fish.","pos":"feminine noun","usage":"fish(15x)"},"H1711":{"id":"H1711","lemma":"דָּגָה","translit":"dâgâh","pron":"daw-gaw'","derivation":"a primitive root; to move rapidly; used only as a denominative from H1709 (דָּג);","strongs_def":"to spawn, i.e. become numerous","kjv_def":"grow.","pos":"verb","usage":"grow(1x)"},"H1712":{"id":"H1712","lemma":"דָּגוֹן","translit":"Dâgôwn","pron":"daw-gohn'","derivation":"from H1709 (דָּג); the fish-god;","strongs_def":"Dagon, a Philistine deity","kjv_def":"Dagon.","pos":"proper masculine noun","usage":"Dagon(13x)"},"H1713":{"id":"H1713","lemma":"דָּגַל","translit":"dâgal","pron":"daw-gal'","derivation":"a primitive root;","strongs_def":"to flaunt, i.e. raise a flag; figuratively, to be conspicuous","kjv_def":"(set up, with) banners, chiefest.","pos":"verb","usage":"chiefest(1x)"},"H1714":{"id":"H1714","lemma":"דֶּגֶל","translit":"degel","pron":"deh'-gel","derivation":"from H1713 (דָּגַל);","strongs_def":"a flag","kjv_def":"banner, standard.","pos":"masculine noun","usage":"standard(13x), banner(1x)"},"H1715":{"id":"H1715","lemma":"דָּגָן","translit":"dâgân","pron":"daw-gawn'","derivation":"from H1711 (דָּגָה);","strongs_def":"properly, increase, i.e. grain","kjv_def":"corn (floor), wheat.","pos":"masculine noun","usage":"corn(37x), wheat(2x)"},"H1716":{"id":"H1716","lemma":"דָּגַר","translit":"dâgar","pron":"daw-gar'","derivation":"a primitive root,","strongs_def":"to brood over eggs or young","kjv_def":"gather, sit.","pos":"verb","usage":"gather(1x), sit(1x)"},"H1717":{"id":"H1717","lemma":"דַּד","translit":"dad","pron":"dad","derivation":"apparently from the same as H1730 (דּוֹד);","strongs_def":"the breast (as the seat of love, or from its shape)","kjv_def":"breast, teat.","pos":"masculine noun","usage":"breast(2x), teat(2x)"},"H1718":{"id":"H1718","lemma":"דָּדָה","translit":"dâdâh","pron":"daw-daw'","derivation":"a doubtful root;","strongs_def":"to walk gently","kjv_def":"go (softly, with).","pos":"verb","usage":"went(1x)"},"H1719":{"id":"H1719","lemma":"דְּדָן","translit":"Dᵉdân","pron":"ded-awn'","derivation":"or (prolonged) דְּדָנֶה; (Ezekiel 25:13), of uncertain derivation;","strongs_def":"Dedan, the name of two Cushites and of their territory","kjv_def":"Dedan.","pos":"proper locative noun, proper masculine noun","usage":"Dedan(11x)"},"H1720":{"id":"H1720","lemma":"דְּדָנִים","translit":"Dᵉdânîym","pron":"ded-aw-neem'","derivation":"plural of H1719 (דְּדָן) (as patrial);","strongs_def":"Dedanites, the descendants or inhabitants of Dedan","kjv_def":"Dedanim."},"H1721":{"id":"H1721","lemma":"דֹּדָנִים","translit":"Dôdânîym","pron":"do-daw-neem'","derivation":"or (by orthographical error) רֹדָנִים (1 Chronicles 1:7); a plural of uncertain derivation;","strongs_def":"Dodanites, or descendants of a son of Javan","kjv_def":"Dodanim."},"H1722":{"id":"H1722","lemma":"דְּהַב","translit":"dᵉhab","pron":"deh-hab'","derivation":"(Aramaic) corresponding to H2091 (זָהָב);","strongs_def":"gold","kjv_def":"gold(-en).","pos":"masculine noun","usage":"gold(14x), 