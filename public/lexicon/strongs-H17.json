ne noun","usage":"beloved(34x), uncle(16x), wellbeloved(1x)"},"H1731":{"id":"H1731","lemma":"דּוּד","translit":"dûwd","pron":"dood","derivation":"from the same as H1730 (דּוֹד);","strongs_def":"a pot (for boiling); also (by resemblance of shape) a basket","kjv_def":"basket, caldron, kettle, (seething) pot.","pos":"masculine noun","usage":"basket(3x), pot(2x), kettle(1x), caldron(1x)"},"H1732":{"id":"H1732","lemma":"דָּוִד","translit":"Dâvid","pron":"daw-veed'","derivation":"rarely (fully); דָּוִיד; from the same as H1730 (דּוֹד); loving;","strongs_def":"David, the youngest son of Jesse","kjv_def":"David.","pos":"proper masculine noun"},"H1733":{"id":"H1733","lemma":"דּוֹדָה","translit":"dôwdâh","pron":"do-daw'","derivation":"feminine of H1730 (דּוֹד);","strongs_def":"an aunt","kjv_def":"aunt, father's sister, uncle's wife.","pos":"feminine noun","usage":"aunt(1x)"},"H1734":{"id":"H1734","lemma":"דּוֹדוֹ","translit":"Dôwdôw","pron":"do-do'","derivation":"from H1730 (דּוֹד); loving;","strongs_def":"Dodo, the name of three Israelites","kjv_def":"Dodo.","pos":"proper masculine noun","usage":"Dodo(5x)"},"H1735":{"id":"H1735","lemma":"דּוֹדָוָהוּ","translit":"Dôwdâvâhûw","pron":"do-daw-vaw'-hoo","derivation":"from H1730 (דּוֹד) and H3050 (יָהּ); love of Jah;","strongs_def":"Dodavah, an Israelite","kjv_def":"Dodavah."},"H1736":{"id":"H1736","lemma":"דּוּדַי","translit":"dûwday","pron":"doo-dah'-ee","derivation":"from H1731 (דּוּד);","strongs_def":"a boiler or basket; also the mandrake (as an aphrodisiac)","kjv_def":"basket, mandrake.","pos":"masculine noun","usage":"mandrake(6x), basket(1x)"},"H1737":{"id":"H1737","lemma":"דּוֹדַי","translit":"Dôwday","pron":"do-dah'ee","derivation":"formed like H1736 (דּוּדַי); amatory;","strongs_def":"Dodai, an Israelite","kjv_def":"Dodai."},"H1738":{"id":"H1738","lemma":"דָּוָה","translit":"dâvâh","pron":"daw-vaw'","derivation":"a primitive root;","strongs_def":"to be sick (as if in menstruation)","kjv_def":"infirmity.","pos":"verb","us