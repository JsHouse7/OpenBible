sy(35x)"},"H6884":{"id":"H6884","lemma":"צָרַף","translit":"tsâraph","pron":"tsaw-raf'","derivation":"a primitive root;","strongs_def":"to fuse (metal), i.e. refine (literally or figuratively)","kjv_def":"cast, (re-) fine(-er), founder, goldsmith, melt, pure, purge away, try.","pos":"verb","usage":"try(11x), founder(5x), goldsmith(5x), refine(3x), refiner(2x), melt(2x), pure(2x), casteth(1x), finer(1x)"},"H6885":{"id":"H6885","lemma":"צֹרְפִי","translit":"Tsôrᵉphîy","pron":"tso-ref-ee'","derivation":"from H6884 (צָרַף); refiner;","strongs_def":"Tsorephi (with the article), an Israelite","kjv_def":"goldsmith's.","pos":"collective masculine noun","usage":"goldsmith(1x)"},"H6886":{"id":"H6886","lemma":"צָרְפַת","translit":"Tsârᵉphath","pron":"tsaq-ref-ath'","derivation":"from H6884 (צָרַף); refinement;","strongs_def":"Tsarephath, a place in Palestine","kjv_def":"Zarephath.","pos":"proper locative noun","usage":"Zarephath(3x)"},"H6887":{"id":"H6887","lemma":"צָרַר","translit":"tsârar","pron":"tsaw-rar'","derivation":"a primitive root;","strongs_def":"to cramp, literally or figuratively, transitive or intransitive","kjv_def":"adversary, (be in) afflict(-ion), beseige, bind (up), (be in, bring) distress, enemy, narrower, oppress, pangs, shut up, be in a strait (trouble), vex.","pos":"verb","usage":"enemy(14x), distress(7x), vex(6x), afflict(4x), besiege(4x), adversary(3x), strait(3x), trouble(2x), bound(2x), pangs(2x)"},"H6888":{"id":"H6888","lemma":"צְרֵרָה","translit":"Tsᵉrêrâh","pron":"tser-ay-raw'","derivation":"apparently by erroneous transcription for H6868 (צְרֵדָה);","strongs_def":"Tsererah for Tseredah","kjv_def":"Zererath.","pos":"proper locative noun","usage":"Zererath(1x)"},"H6889":{"id":"H6889","lemma":"צֶרֶת","translit":"Tsereth","pron":"tseh'-reth","derivation":"perhaps from H6671 (צָהַר); splendor;","strongs_def":"Tsereth, an Israelite","kjv_def":"Zereth."},"H6890":{"id":"H6890","lemma":"צֶרֶת הַשַּׁחַר","translit":"Tsereth hash-Shachar","pron":"tseh'-reth