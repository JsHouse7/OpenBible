":"verb","usage":"pluck(1x), gather(1x)"},"H718":{"id":"H718","lemma":"אֲרוּ","translit":"ʼărûw","pron":"ar-oo'","derivation":"(Aramaic) probably akin to H431 (אֲלוּ);","strongs_def":"lo!","kjv_def":"behold, lo.","pos":"interjection","usage":"behold(4x), lo(1x)"},"H719":{"id":"H719","lemma":"אַרְוַד","translit":"ʼArvad","pron":"ar-vad'","derivation":"probably from H7300 (רוּד); a refuge for the roving;","strongs_def":"Arvad, an island-city of Palestine","kjv_def":"Arvad.","pos":"proper locative noun","usage":"Arvad(2x)"},"H720":{"id":"H720","lemma":"אֲרוֹד","translit":"ʼĂrôwd","pron":"ar-ode'","derivation":"an orthographical variation of H719 (אַרְוַד); fugitive;","strongs_def":"Arod, an Israelite","kjv_def":"Arod.","pos":"proper masculine noun","usage":"Arod(1x)"},"H721":{"id":"H721","lemma":"אַרְוָדִי","translit":"ʼArvâdîy","pron":"ar-vaw-dee'","derivation":"patrial from H719 (אַרְוַד);","strongs_def":"an Arvadite or citizen of Arvad","kjv_def":"Arvadite.","pos":"adjective","usage":"Arvadite(2x)"},"H722":{"id":"H722","lemma":"אֲרוֹדִי","translit":"ʼĂrôwdîy","pron":"ar-o-dee'","derivation":"patronymic from H721 (אַרְוָדִי);","strongs_def":"an Arodite or descendant of Arod","kjv_def":"Arodi, Arodites.","pos":"adjective","usage":"Arodite(1x), Arodi(1x)"},"H723":{"id":"H723","lemma":"אֻרְוָה","translit":"ʼurvâh","pron":"oor-vaw'","derivation":"or אֲרָיָה; from H717 (אָרָה) (in the sense of feeding);","strongs_def":"a herding-place for an animal","kjv_def":"stall."},"H724":{"id":"H724","lemma":"אֲרוּכָה","translit":"ʼărûwkâh","pron":"ar-oo-kaw'","derivation":"or אֲרֻכָה; feminine passive participle of H748 (אָרַךְ) (in the sense of restoring to soundness);","strongs_def":"wholeness (literally or figuratively)","kjv_def":"health, made up, perfected.","pos":"feminine noun","usage":"health(4x), perfected(1x)"},"H725":{"id":"H725","lemma":"אֲרוּמָה","translit":"ʼĂrûwmâh","pron":"ar-oo-maw'","derivation":"a variation of H7316 (רוּמָה); height;","strongs_def":"Arumah, a place in Palestine","kjv_def":"Arumah.","pos":"proper locative noun","usage":"Arumah(1x)"},"H726":{"id":"H726","lemma":"אֲרוֹמִי","translit":"ʼĂrôwmîy","pron":"ar-o-mee'","derivation":"a clerical error for H130 (אֱדֹמִי);","strongs_def":"an Edomite (as in the margin)","kjv_def":"Syrian."},"H727":{"id":"H727","lemma":"אָרוֹן","translit":"ʼârôwn","pron":"aw-rone'","derivation":"or אָרֹן; from H717 (אָרָה) (in the sense of gathering);","strongs_def":"a box","kjv_def":"ark, chest, coffin.","pos":"masculine noun","usage":"ark(195x), chest(6x), coffin(1x)"},"H728":{"id":"H728","lemma":"אֲרַוְנָה","translit":"ʼĂravnâh","pron":"ar-av-naw'","derivation":"or (by transposition) אוֹרְנָה; or אַרְנִיָּהlemma אַנִיָּה missing resh, corrected to אַרְנִיָּה; all by orthographical variation for H771 (אׇרְנָן);","strongs_def":"Aravnah (or Arnijah or Ornah), a Jebusite","kjv_def":"Araunah."},"H729":{"id":"H729","lemma":"אָרַז","translit":"ʼâraz","pron":"aw-raz'","derivation":"a primitive root; to be firm; used only in the passive participle as a denominative from H730 (אֶרֶז);","strongs_def":"of cedar","kjv_def":"made of cedar.","pos":"adjective, verb"},"H730":{"id":"H730","lemma":"אֶרֶז","translit":"ʼerez","pron":"eh-rez'","derivation":"from H729 (אָרַז);","strongs_def":"a cedar tree (from the tenacity of its roots)","kjv_def":"cedar (tree).","pos":"masculine noun","usage":"cedar(67x)"},"H731":{"id":"H731","lemma":"אַרְזָה","translit":"ʼarzâh","pron":"ar-zaw'","derivation":"feminine of H730 (אֶרֶז);","strongs_def":"cedar wainscoating","kjv_def":"cedar work."},"H732":{"id":"H732","lemma":"אָרַח","translit":"ʼârach","pron":"aw-rakh'","derivation":"a primitive root;","strongs_def":"to travel","kjv_def":"go, wayfaring (man).","pos":"verb","usage":"goeth(1x)"},"H733":{"id":"H733","lemma":"אָרַח","translit":"ʼÂrach","pron":"aw-rakh'","derivation":"from H732 (אָרַח); way faring;","strongs_def":"Arach, the name of three Israelites","kjv_def":"Arah.","pos":"proper masculine noun","usage":"Arah(4x)"},"H734":{"id":"H734","lemma":"אֹרַח","translit":"ʼôrach","pron":"o'-rakh","derivation":"from H732 (אָרַח);","strongs_def":"a well-trodden road (literally or figuratively); also a caravan","kjv_def":"manner, path, race, rank, traveller, troop, (by-, high-) way.","pos":"masculine noun","usage":"way(26x), path(25x), highway(1x), manner(1x), race(1x), ranks(1x), traveller(1x), troops(1x)"},"H735":{"id":"H735","lemma":"אֹרַח","translit":"ʼôrach","pron":"o'-rakh","derivation":"(Aramaic) corresponding to H734 (אֹרַח);","strongs_def":"a road","kjv_def":"way.","pos":"masculine noun","usage":"way(2x)"},"H736":{"id":"H736","lemma":"אֹרְחָה","translit":"ʼôrᵉchâh","pron":"o-rekh-aw'","derivation":"feminine active participle of H732 (אָרַח);","strongs_def":"a caravan","kjv_def":"(travelling) company.","pos":"feminine noun","usage":"company(2x)"},"H737":{"id":"H737","lemma":"אֲרֻחָה","translit":"ʼăruchâh","pron":"ar-oo-khaw'","derivation":"feminine passive participle of H732 (אָרַח) (in the sense of appointing);","strongs_def":"a ration of food","kjv_def":"allowance, diet, dinner, victuals.","pos":"feminine noun","usage":"allowance(2x), diet(2x), dinner(1x), victuals(1x)"},"H738":{"id":"H738","lemma":"אֲרִי","translit":"ʼărîy","pron":"ar-ee'","derivation":"or (prolonged) []; from H717 (אָרָה) (in the sense of violence);","strongs_def":"a lion","kjv_def":"(young) lion, [phrase] pierce (from the margin).","pos":"masculine noun","usage":"lion(79x)"},"H739":{"id":"H739","lemma":"אֲרִיאֵל","translit":"ʼărîyʼêl","pron":"ar-ee-ale'","derivation":"or אֲרִאֵל; from H738 (אֲרִי) and H410 (אֵל);","strongs_def":"lion of God; i.e. heroic","kjv_def":"lionlike men."},"H740":{"id":"H740","lemma":"אֲרִיאֵל","translit":"ʼĂrîyʼêl","pron":"ar-ee-ale'","derivation":"the same as H739 (אֲרִיאֵל);","strongs_def":"Ariel, a symbolical name for Jerusalem, also the name of an Israelite","kjv_def":"Ariel.","pos":"proper masculine/feminine noun","usage":"Ariel(6x)"},"H741":{"id":"H741","lemma":"אֲרִאֵיל","t