ughter.","pos":"feminine noun","usage":"slaughter(5x)"},"H2029":{"id":"H2029","lemma":"הָרָה","translit":"hârâh","pron":"haw-raw'","derivation":"a primitive root;","strongs_def":"to be (or become) pregnant, conceive (literally or figuratively)","kjv_def":"been, be with child, conceive, progenitor.","pos":"verb","usage":"conceive(38x), again(1x), bare(1x), progenitors(1x)"},"H2030":{"id":"H2030","lemma":"הָרֶה","translit":"hâreh","pron":"haw-reh'","derivation":"or הָרִי; (Hosea 14:1), from H2029 (הָרָה);","strongs_def":"pregnant","kjv_def":"(be, woman) with child, conceive, [idiom] great.","pos":"feminine noun","usage":"conceive(3x)"},"H2031":{"id":"H2031","lemma":"הַרְהֹר","translit":"harhôr","pron":"har-hor'","derivation":"(Aramaic) from a root corresponding to H2029 (הָרָה);","strongs_def":"a mental conception","kjv_def":"thought.","pos":"masculine noun","usage":"thoughts(1x)"},"H2032":{"id":"H2032","lemma":"הֵרוֹן","translit":"hêrôwn","pron":"hay-rone'","derivation":"or הֵרָיוֹן; from H2029 (הָרָה);","strongs_def":"pregnancy","kjv_def":"conception.","pos":"masculine noun","usage":"conception(3x)"},"H2033":{"id":"H2033","lemma":"הֲרוֹרִי","translit":"Hărôwrîy","pron":"har-o-ree'","derivation":"another form for H2043 (הֲרָרִי);","strongs_def":"a Harorite or mountaineer","kjv_def":"Harorite."},"H2034":{"id":"H2034","lemma":"הֲרִיסָה","translit":"hărîyçâh","pron":"har-ee-saw'","derivation":"from H2040 (הָרַס);","strongs_def":"something demolished","kjv_def":"ruin.","pos":"feminine noun","usage":"ruin(1x)"},"H2035":{"id":"H2035","lemma":"הֲרִיסוּת","translit":"hărîyçûwth","pron":"har-ee-sooth'","derivation":"from H2040 (הָרַס);","strongs_def":"demolition","kjv_def":"destruction.","pos":"feminine noun","usage":"destruction(1x)"},"H2036":{"id":"H2036","lemma":"הֹרָם","translit":"Hôrâm","pron":"ho-rawm'","derivation":"from an unused root (meaning to tower up); high;","strongs_def":"Horam, a Canaanitish king","kjv_def":"Horam.","pos":"proper masculine noun","usage":"Horam