ation":"a primitive root;","strongs_def":"to gleam; figuratively, to enlighten (by caution)","kjv_def":"admonish, shine, teach, (give) warn(-ing).","pos":"verb","usage":"warn(18x), admonish(2x), teach(1x), shine(1x)"},"H2095":{"id":"H2095","lemma":"זְהַר","translit":"zᵉhar","pron":"zeh-har'","derivation":"(Aramaic) corresponding to H2094 (זָהַר);","strongs_def":"(passively) be admonished","kjv_def":"take heed.","pos":"verb"},"H2096":{"id":"H2096","lemma":"זֹהַר","translit":"zôhar","pron":"zo'-har","derivation":"from H2094 (זָהַר);","strongs_def":"brilliancy","kjv_def":"brightness.","pos":"masculine noun","usage":"brightness(2x)"},"H2097":{"id":"H2097","lemma":"זוֹ","translit":"zôw","pron":"zo","derivation":"for H2088 (זֶה);","strongs_def":"this or that","kjv_def":"that, this.","pos":"demonstrative pronoun, relative pronoun","usage":"that(1x), this(1x)"},"H2098":{"id":"H2098","lemma":"זוּ","translit":"zûw","pron":"zoo","derivation":"for H2088 (זֶה);","strongs_def":"this or that","kjv_def":"that, this, [idiom] wherein, which, whom.","pos":"demonstrative pronoun, relative pronoun","usage":"which(5x), this(4x), that(3x), wherein(2x), whom(1x)"},"H2099":{"id":"H2099","lemma":"זִו","translit":"Ziv","pron":"zeev'","derivation":"probably from an unused root meaning to be prominent; properly, brightness (compare H2122 (זִיו)), i.e. (figuratively) the month of flowers;","strongs_def":"Ziv (corresponding to Ijar or May)","kjv_def":"Zif."}}