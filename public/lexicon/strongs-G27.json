{"G2704":{"id":"G2704","lemma":"καταφθείρω","translit":"kataphtheírō","derivation":"from G2596 (κατά) and G5351 (φθείρω);","strongs_def":"to spoil entirely, i.e. (literally) to destroy; or (figuratively) to deprave;","kjv_def":"--corrupt, utterly perish"},"G2776":{"id":"G2776","lemma":"κεφαλή","translit":"kephalḗ","derivation":"from the primary (in the sense of seizing);","strongs_def":"the head (as the part most readily taken hold of), literally or figuratively","kjv_def":"head","pos":"feminine noun","usage":"head(76x)"},"G2779":{"id":"G2779","lemma":"κῆπος","translit":"kēpos","derivation":"of uncertain affinity;","strongs_def":"a garden","kjv_def":"garden","pos":"masculine noun","usage":"garden(5x)"},"G2700":{"id":"G2700","lemma":"κατατοξεύω","translit":"katatoxeúō","derivation":"from G2596 (κατά) and a derivative of G5115 (τόξον);","strongs_def":"to shoot down with an arrow or other missile","kjv_def":"thrust through","pos":"verb"},"G2743":{"id":"G2743","lemma":"καυτηριάζω","translit":"kautēriázō","derivation":"from a derivative of G2545 (καίω);","strongs_def":"to brand (\"cauterize\"), i.e. (by implication) to render unsensitive (figuratively)","kjv_def":"sear with a hot iron"},"G2778":{"id":"G2778","lemma":"κῆνσος","translit":"kēnsos","derivation":"of Latin origin;","strongs_def":"properly, an enrollment (\"census\"), i.e. (by implication) a tax","kjv_def":"tribute","pos":"masculine noun","usage":"tribute(4x)"},"G2787":{"id":"G2787","lemma":"κιβωτός","translit":"kibōtós","derivation":"of uncertain derivation;","strongs_def":"a box, i.e. the sacred ark and that of Noah","kjv_def":"ark","pos":"feminine noun","usage":"ark(6x)"},"G2718":{"id":"G2718","lemma":"κατέρχομαι","translit":"katérchomai","derivation":"from G2596 (κατά) and G2064 (ἔρχομαι) (including its alternate);","strongs_def":"to come (or go) down (literally or figuratively)","kjv_def":"come (down), depart, descend, go down, land","pos":"verb","usage":"come(3x), depart(1x), descend(1x), land(1x)"},"G270