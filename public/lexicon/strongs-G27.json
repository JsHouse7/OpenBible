ivation":"of uncertain affinity;","strongs_def":"a swathe, i.e. winding-sheet","kjv_def":"graveclothes","pos":"feminine noun","usage":"graveclothes(1x)"},"G2723":{"id":"G2723","lemma":"κατηγορέω","translit":"katēgoréō","derivation":"from G2725 (κατήγορος);","strongs_def":"to be a plaintiff, i.e. to charge with some offence","kjv_def":"accuse, object","pos":"verb","usage":"accuse(21x), object(1x)"},"G2742":{"id":"G2742","lemma":"καύσων","translit":"kaúsōn","derivation":"from G2741 (καυσόω);","strongs_def":"a glare","kjv_def":"(burning) heat","pos":"masculine noun","usage":"heat(2x)"},"G2746":{"id":"G2746","lemma":"καύχησις","translit":"kaúchēsis","derivation":"from G2744 (καυχάομαι);","strongs_def":"boasting (properly, the act; by implication, the object), in a good or a bad sense","kjv_def":"boasting, whereof I may glory, glorying, rejoicing","pos":"feminine noun","usage":"boasting(6x), rejoicing(4x), glorying(1x)"},"G2781":{"id":"G2781","lemma":"κηρίον","translit":"kēríon","derivation":"diminutive from (wax);","strongs_def":"a cell for honey, i.e. (collectively) the comb","kjv_def":"(honey-)comb"},"G2712":{"id":"G2712","lemma":"κατείδωλος","translit":"kateídōlos","derivation":"from G2596 (κατά) (intensively) and G1497 (εἴδωλον);","strongs_def":"utterly idolatrous","kjv_def":"wholly given to idolatry"},"G2794":{"id":"G2794","lemma":"κίνδυνος","translit":"kíndynos","derivation":"of uncertain derivation;","strongs_def":"danger","kjv_def":"peril","pos":"masculine noun","usage":"peril(9x)"},"G2739":{"id":"G2739","lemma":"καυματίζω","translit":"kaumatízō","derivation":"from G2738 (καῦμα);","strongs_def":"to burn","kjv_def":"scorch","pos":"verb","usage":"scorch(4x)"},"G2798":{"id":"G2798","lemma":"κλάδος","translit":"kládos","derivation":"from G2806 (κλάω);","strongs_def":"a twig or bough (as if broken off)","kjv_def":"branch","pos":"masculine noun","usage":"branch(11x)"},"G2731":{"id":"G2731","lemma":"κατοίκησις","translit":"katoíkēsis","derivation":"from G2730 (κατοικέω);","strongs_def":"residence (properly, the act; but by implication, concretely, the mansion)","kjv_def":"dwelling","pos":"feminine noun","usage":"dwelling(1x)"},"G2769":{"id":"G2769","lemma":"κεράτιον","translit":"kerátion","derivation":"neuter of a presumed derivative of G2768 (κέρας);","strongs_def":"something horned, i.e. (specially) the pod of the carob-tree","kjv_def":"husk","pos":"neuter noun","usage":"husk(1x)"},"G2734":{"id":"G2734","lemma":"κατοπτρίζομαι","translit":"katoptrízomai","derivation":"middle voice from a compound of G2596 (κατά) and a derivative of G3700 (ὀπτάνομαι) (compare G2072 (ἔσοπτρον));","strongs_def":"to mirror oneself, i.e. to see reflected (figuratively)","kjv_def":"behold as in a glass"},"G2733":{"id":"G2733","lemma":"κατοικία","translit":"katoikía","strongs_def":"residence (properly, the condition; but by implication, the abode itself)","kjv_def":"habitation"},"G2708":{"id":"G2708","lemma":"καταχέω","translit":"katachéō","derivation":"from G2596 (κατά) and cheo (to pour);","strongs_def":"to pour down (out)","kjv_def":"pour","pos":"verb","usage":"pour(2x)"},"G2763":{"id":"G2763","lemma":"κεραμεύς","translit":"kerameús","derivation":"from G2766 (κέραμος);","strongs_def":"a potter","kjv_def":"potter","pos":"masculine noun","usage":"potter(3x)"},"G2713":{"id":"G2713","lemma":"κατέναντι","translit":"katénanti","derivation":"from G2596 (κατά) and G1725 (ἔναντι);","strongs_def":"directly opposite","kjv_def":"before, over against","pos":"adverb","usage":"before(1x)"},"G2725":{"id":"G2725","lemma":"κατήγορος","translit":"katḗgoros","derivation":"from G2596 (κατά) and G58 (ἀγορά);","strongs_def":"against one in the assembly, i.e. a complainant at law; specially, Satan","kjv_def":"accuser","pos":"masculine noun","usage":"accuser(7x)"},"G2728":{"id":"G2728","lemma":"κατιόω","translit":"katióō","derivation":"from G2596 (κατά) and a derivative of G2447 (ἰός);","strongs_def":"to rust down, i.e. corrode","kjv_def":"canker","pos":"verb","usage":"canker(1x)"},"G2770":{"id":"G2770","lemma":"κερδαίνω","translit":"kerdaínō","derivation":"from G2771 (κέρδος);","strongs_def":"to gain (literally or figuratively)","kjv_def":"(get) gain, win","pos":"verb","usage":"gain(13x), win(2x)"},"G2729":{"id":"G2729","lemma":"κατισχύω","translit":"katischýō","derivation":"from G2596 (κατά) and G2480 (ἰσχύω);","strongs_def":"to overpower","kjv_def":"prevail (against)","pos":"verb","usage":"prevail(1x)"},"G2754":{"id":"G2754","lemma":"κενοδοξία","translit":"kenodoxía","derivation":"from G2755 (κενόδοξος);","strongs_def":"empty glorying, i.e. self-conceit","kjv_def":"vain-glory","pos":"feminine noun","usage":"vainglory(1x)"},"G2744":{"id":"G2744","lemma":"καυχάομαι","translit":"kaucháomai","derivation":"from some (obsolete) base akin to that of (to boast) and G2172 (εὔχομαι);","strongs_def":"to vaunt (in a good or a bad sense)","kjv_def":"(make) boast, glory, joy, rejoice","pos":"verb","usage":"glory(23x), boast(8x), rejoice(4x), joy(1x)"},"G2701":{"id":"G2701","lemma":"κατατρέχω","translit":"katatréchō","derivation":"from G2596 (κατά) and G5143 (τρέχω);","strongs_def":"to run down, i.e. hasten from a tower","kjv_def":"run down","pos":"verb"},"G2722":{"id":"G2722","lemma":"κατέχω","translit":"katéchō","derivation":"from G2596 (κατά) and G2192 (ἔχω);","strongs_def":"to hold down (fast), in various applications (literally or figuratively)","kjv_def":"have, hold (fast), keep (in memory), let, X make toward, possess, retain, seize on, stay, take, withhold","pos":"verb","usage":"hold(3x), keep(2x), possess(2x), stay(1x), take(1x), have(1x), make(1x)"},"G2749":{"id":"G2749","lemma":"κεῖμαι","translit":"keîmai","derivation":"middle voice of a primary verb;","strongs_def":"to lie outstretched (literally or figuratively)","kjv_def":"be (appointed, laid up, made, set), lay, lie","pos":"verb","usage":"lie(9x), be(1x), there(1x)"},"G2790":{"id":"G2790","lemma":"κιθαρῳδός","translit":"kitharōidós","derivation":"from G2788 (κιθάρα) and a derivative of the same as G5603 (ᾠδή);","strongs_def":"a lyre-singer(-player), i.e. harpist","kjv_def":"harper","pos":"masculine noun","usage":"harper(2x)"},"G2772":{"id":"G2772","lemma":"κέρμα","translit":"kérma","derivation":"from G2751 (κείρω);","strongs_def":"a clipping (bit), i.e. (specially) a coin","kjv_def":"money","pos":"neuter noun","usage":"money(1x)"},"G2737":{"id":"G2737","lemma":"κατώτερος","translit":"katṓteros","derivation":"comparative from G2736 (κάτω);","strongs_def":"inferior (locally, of Hades)","kjv_def":"lower","pos":"adjective","usage":"lower(1x)"},"G2799":{"id":"G2799","lemma":"κλαίω","translit":"klaíō","derivation":"of uncertain affinity;","strongs_def":"to sob, i.e. wail aloud (whereas 1145 is rather to cry silently)","kjv_def":"bewail, weep","pos":"verb","usage":"weep(39x), bewail(1x)"},"G2796":{"id":"G2796","lemma":"κίνησις","translit":"kínēsis","derivation":"from G2795 (κινέω);","strongs_def":"a stirring","kjv_def":"moving","pos":"feminine noun","usage":"moving(1x)"},"G2764":{"id":"G2764","lemma":"κεραμικός","translit":"keramikós","derivation":"from G2766 (κέραμος);","strongs_def":"made of clay, i.e. earthen","kjv_def":"of a potter","pos":"adjective"},"G2765":{"id":"G2765","lemma":"κεράμιον","translit":"kerámion","derivation":"neuter of a presumed derivative of G2766 (κέραμος);","strongs_def":"an earthenware vessel, i.e. jar","kjv_def":"pitcher","pos":"neuter noun","usage":"pitcher(2x)"},"G2759":{"id":"G2759","lemma":"κέντρον","translit":"kéntron","derivation":"from (to prick);","strongs_def":"a point (\"centre\"), i.e. a sting (figuratively, poison) or goad (figuratively, divine impulse)","kjv_def":"prick, sting","pos":"neuter noun","usage":"sting(3x), prick(2x)"},"G2761":{"id":"G2761","lemma":"κενῶς","translit":"kenōs","derivation":"adverb from G2756 (κενός);","strongs_def":"vainly, i.e. to no purpose","kjv_def":"in vain","pos":"adverb"},"G2777":{"id":"G2777","lemma":"κεφαλίς","translit":"kephalís","derivation":"from G2776 (κεφαλή);","strongs_