},"G3141":{"id":"G3141","lemma":"μαρτυρία","translit":"martyría","derivation":"from G3144 (μάρτυς);","strongs_def":"evidence given (judicially or genitive case)","kjv_def":"record, report, testimony, witness","pos":"feminine noun","usage":"witness(15x), testimony(14x), record(7x), report(1x)"},"G3170":{"id":"G3170","lemma":"μεγαλύνω","translit":"megalýnō","derivation":"from G3173 (μέγας);","strongs_def":"to make (or declare) great, i.e. increase or (figuratively) extol","kjv_def":"enlarge, magnify, shew great","pos":"verb","usage":"magnify(5x), enlarge(2x)"},"G3112":{"id":"G3112","lemma":"μακράν","translit":"makrán","derivation":"feminine accusative case singular of G3117 (μακρός) (G3598 (ὁδός) being implied);","strongs_def":"at a distance (literally or figuratively)","kjv_def":"(a-)far (off), good (great) way off","pos":"adverb","usage":"far(4x)"},"G3101":{"id":"G3101","lemma":"μαθητής","translit":"mathētḗs","derivation":"from G3129 (μανθάνω);","strongs_def":"a learner, i.e. pupil","kjv_def":"disciple","pos":"masculine noun","usage":"disciple(268x)"},"G3163":{"id":"G3163","lemma":"μάχη","translit":"máchē","derivation":"from G3164 (μάχομαι);","strongs_def":"a battle, i.e. (figuratively) controversy","kjv_def":"fighting, strive, striving","pos":"feminine noun","usage":"fighting(2x), strife(1x), striving(1x)"},"G3193":{"id":"G3193","lemma":"μελίσσιος","translit":"melíssios","derivation":"from G3192 (μέλι);","strongs_def":"relating to honey, i.e. bee (comb)","kjv_def":"honeycomb","pos":"adjective"},"G3109":{"id":"G3109","lemma":"Μακεδονία","translit":"Makedonía","derivation":"from G3110 (Μακεδών);","strongs_def":"Macedonia, a region of Greece","kjv_def":"Macedonia","pos":"proper locative noun","usage":"Macedonia(24x)"},"G3144":{"id":"G3144","lemma":"μάρτυς","translit":"mártys","derivation":"of uncertain affinity;","strongs_def":"a witness (literally (judicially) or figuratively (genitive case)); by analogy, a \"martyr\"","kjv_def":"martyr, record, witness","pos":"mascu