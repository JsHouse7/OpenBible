","lemma":"בֶּצֶר","translit":"Betser","pron":"beh'-tser","derivation":"the same as H1220 (בֶּצֶר), an inaccessible spot;","strongs_def":"Betser, a place in Palestine; also an Israelite","kjv_def":"Bezer.","pos":"proper locative noun, proper masculine noun","usage":"Bezer(5x)"},"H1222":{"id":"H1222","lemma":"בְּצַר","translit":"bᵉtsar","pron":"bets-ar'","derivation":"another form for H1220 (בֶּצֶר);","strongs_def":"gold","kjv_def":"gold.","pos":"masculine noun","usage":"gold(1x)"},"H1223":{"id":"H1223","lemma":"בׇּצְרָה","translit":"botsrâh","pron":"bots-raw'","derivation":"feminine from H1219 (בָּצַר);","strongs_def":"an enclosure, i.e. sheep fold","kjv_def":"Bozrah.","pos":"feminine noun","usage":"Bozrah(1x)"},"H1224":{"id":"H1224","lemma":"בׇּצְרָה","translit":"Botsrâh","pron":"bots-raw'","derivation":"the same as H1223 (בׇּצְרָה);","strongs_def":"Botsrah, a place in Edom","kjv_def":"Bozrah.","pos":"proper locative noun","usage":"Bozrah(8x)"},"H1225":{"id":"H1225","lemma":"בִּצָּרוֹן","translit":"bitstsârôwn","pron":"bits-tsaw-rone'","derivation":"masculine intensive from H1219 (בָּצַר);","strongs_def":"a fortress","kjv_def":"stronghold.","pos":"masculine noun"},"H1226":{"id":"H1226","lemma":"בַּצֹּרֶת","translit":"batstsôreth","pron":"bats-tso'-reth","derivation":"feminine intensive from H1219 (בָּצַר);","strongs_def":"restraint (of rain), i.e. drought","kjv_def":"dearth, drought.","pos":"feminine noun","usage":"dearth(1x), drought(1x)"},"H1227":{"id":"H1227","lemma":"בַּקְבּוּק","translit":"Baqbûwq","pron":"bak-book'","derivation":"the same as H1228 (בַּקְבֻּק)xlit baqbûk corrected to baqbuq;","strongs_def":"Bakbuk, one of the Nethinim","kjv_def":"Bakbuk.","pos":"proper masculine noun","usage":"Bakbuk(2x)"},"H1228":{"id":"H1228","lemma":"בַּקְבֻּק","translit":"baqbuq","pron":"bak-book'","derivation":"from H1238 (בָּקַק);","strongs_def":"a bottle (from the gurgling in emptying)","kjv_def":"bottle, cruse.","pos":"masculine noun","usage":"bottle(2x), cruse(1x)"},"