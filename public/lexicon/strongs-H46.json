"},"H4658":{"id":"H4658","lemma":"מַפֶּלֶת","translit":"mappeleth","pron":"map-peh'-leth","derivation":"from H5307 (נָפַל);","strongs_def":"fall, i.e. decadence; concretely, a ruin; specifically a carcase","kjv_def":"carcase, fall, ruin.","pos":"feminine noun","usage":"fall(5x), ruin(2x), carcase(1x)"},"H4659":{"id":"H4659","lemma":"מִפְעָל","translit":"miphʻâl","pron":"mif-awl'","derivation":"or (feminine) מִפְעָלָה; from H6466 (פָּעַל);","strongs_def":"a performance","kjv_def":"work.","pos":"masculine noun","usage":"works(3x)"},"H4660":{"id":"H4660","lemma":"מַפָּץ","translit":"mappâts","pron":"map-pawts'","derivation":"from H5310 (נָפַץ);","strongs_def":"a smiting to pieces","kjv_def":"slaughter.","pos":"masculine noun","usage":"slaughter(1x)"},"H4661":{"id":"H4661","lemma":"מַפֵּץ","translit":"mappêts","pron":"map-pates'","derivation":"from H5310 (נָפַץ);","strongs_def":"a smiter, i.e. a war club","kjv_def":"battle ax.","pos":"masculine noun"},"H4662":{"id":"H4662","lemma":"מִפְקָד","translit":"miphqâd","pron":"mif-kawd'","derivation":"from H6485 (פָּקַד);","strongs_def":"an appointment, i.e. mandate; concretely, a designated spot; specifically, a census","kjv_def":"appointed place, commandment, number.","pos":"masculine noun","usage":"number(2x), commandment(1x)"},"H4663":{"id":"H4663","lemma":"מִפְקָד","translit":"Miphqâd","pron":"mif-kawd'","derivation":"the same as H4662 (מִפְקָד); assignment;","strongs_def":"Miphkad, the name of a gate in Jerusalem","kjv_def":"Miphkad.","pos":"masculine noun","usage":"Miphkad(1x)"},"H4664":{"id":"H4664","lemma":"מִפְרָץ","translit":"miphrâts","pron":"mif-rawts'","derivation":"from H6555 (פָּרַץ)lemma פּרַץ missing vowel, corrected to פָּרַץ;","strongs_def":"a break (in the shore), i.e. a haven","kjv_def":"breach."},"H4665":{"id":"H4665","lemma":"מִפְרֶקֶת","translit":"miphreqeth","pron":"mif-reh'-keth","derivation":"from H6561 (פָּרַק);","strongs_def":"properly, a fracture, i.e. joint (vertebrae) of the neck","kjv_def":"neck."},"H4666":{"id":"H4666","lemma":"מִפְרָשׂ","translit":"miphrâs","pron":"mif-rawce'","derivation":"from H6566 (פָּרַשׂ);","strongs_def":"an expansion","kjv_def":"that which...spreadest forth, spreading.","pos":"masculine noun","usage":"spreadings(1x)"},"H4667":{"id":"H4667","lemma":"מִפְשָׂעָה","translit":"miphsâʻâh","pron":"mif-saw-aw'","derivation":"from H6585 (פָּשַׂע);","strongs_def":"a stride, i.e. (by euphemism) the crotch","kjv_def":"buttocks."},"H4668":{"id":"H4668","lemma":"מַפְתֵּחַ","translit":"maphtêach","pron":"maf-tay'-akh","derivation":"from H6605 (פָּתַח);","strongs_def":"an opener, i.e. a key","kjv_def":"key.","pos":"masculine noun","usage":"key(2x), opening(1x)"},"H4669":{"id":"H4669","lemma":"מִפְתָּח","translit":"miphtâch","pron":"mif-tawkh'","derivation":"from H6605 (פָּתַח);","strongs_def":"an aperture, i.e. (figuratively) utterance","kjv_def":"opening.","pos":"masculine noun","usage":"opening(1x)"},"H4670":{"id":"H4670","lemma":"מִפְתָּן","translit":"miphtân","pron":"mif-tawn'","derivation":"from the same as H6620 (פֶּתֶן);","strongs_def":"a stretcher, i.e. a sill","kjv_def":"threshold.","pos":"masculine noun","usage":"threshold(8x)"},"H4671":{"id":"H4671","lemma":"מֹץ","translit":"môts","pron":"motes","derivation":"or מוֹץ; (Zephaniah 2:2), from H4160 (מוּץ);","strongs_def":"chaff (as pressed out, i.e. winnowed or (rather) threshed loose)","kjv_def":"chaff.","pos":"masculine noun","usage":"chaff(8x)"},"H4672":{"id":"H4672","lemma":"מָצָא","translit":"mâtsâʼ","pron":"maw-tsaw'","derivation":"a primitive root;","strongs_def":"properly, to come forth to, i.e. appear or exist; transitively, to attain, i.e. find or acquire; figuratively, to occur, meet or be present","kjv_def":"[phrase] be able, befall, being, catch, [idiom] certainly, (cause to) come (on, to, to hand), deliver, be enough (cause to) find(-ing, occasion, out), get (hold upon), [idiom] have (here), be here, hit, be left, light (up-) on, meet (with), [idiom] occasion serve, (be) present, ready, speed, suffice, take hold on.","pos":"verb","usage":"find(359x), present(20x), come(8x), meet(5x), befall(5x), get(4x), suffice(3x), deliver(2x), hit(2x), left(2x), hold(2x)"},"H4673":{"id":"H4673","lemma":"מַצָּב","translit":"matstsâb","pron":"mats-tsawb'","derivation":"from H5324 (נָצַב);","strongs_def":"a fixed spot; figuratively, an office, a military post","kjv_def":"garrison, station, place where...stood.","pos":"masculine noun","usage":"garrison(7x), station(1x)"},"H4674":{"id":"H4674","lemma":"מֻצָּב","translit":"mutstsâb","pron":"moots-tsawb'","derivation":"from H5324 (נָצַב);","strongs_def":"a station, i.e. military post","kjv_def":"mount.","pos":"masculine noun","usage":"mount(1x)"},"H4675":{"id":"H4675","lemma":"מַצָּבָה","translit":"matstsâbâh","pron":"mats-tsaw-baw'","derivation":"or מִצָּבָה; feminine of H4673 (מַצָּב);","strongs_def":"a military guard","kjv_def":"army, garrison.","pos":"feminine noun","usage":"garrison(1x), army(1x)"},"H4676":{"id":"H4676","lemma":"מַצֵּבָה","translit":"matstsêbâh","pron":"mats-tsay-baw'","derivation":"feminine (causatively) participle of H5324 (נָצַב);","strongs_def":"something stationed, i.e. a column or (memorial stone); by analogy, an idol","kjv_def":"garrison, (standing) image, pillar.","pos":"feminine noun","usage":"image(19x), pillar(12x), garrisons(1x)"},"H4677":{"id":"H4677","lemma":"מְצֹבָיָה","translit":"Mᵉtsôbâyâh","pron":"mets-o-baw-yaw'","derivation":"apparently from H4672 (מָצָא) and H3050 (יָהּ); found of Jah;","strongs_def":"Metsobajah, a place in Palestine","kjv_def":"Mesobaite."},"H4678":{"id":"H4678","lemma":"מַצֶּבֶת","translit":"matstsebeth","pron":"mats-tseh'-beth","derivation":"from H5324 (נָצַב);","strongs_def":"something stationary, i.e. a monumental stone; also the stock of atree","kjv_def":"pillar, substance.","pos":"feminine noun","usage":"pillar(4x), substance(2x)"},"H4679":{"id":"H4679","lemma":"מְצַד","translit":"mᵉtsad","pron":"mets-ad'","derivation":"or מְצָד; or (feminine) מְצָדָה; from H6679 (צוּד);","strongs_def":"a fastness (as a covert of ambush)","kjv_def":"castle, fort, (strong) hold, munition.","pos":"feminine noun","usage":"hold(3x), castle(1x), munition(1x)"},"H4680":{"id":"H4680","lemma":"מָצָה","translit":"mâtsâh","pron":"maw-tsaw'","derivation":"a primitive root;","strongs_def":"to suck out; by implication, to drain, to squeeze out","kjv_def":"suck, wring (out).","pos":"verb"},"H4681":{"id":"H4681","lemma":"מֹצָה","translit":"Môtsâh","pron":"mo-tsaw'","derivation":"active participle feminine of H4680 (מָצָה); drained;","strongs_def":"Motsah, a place in Palestine","kjv_def":"Mozah."},"H4682":{"id":"H4682","lemma":"מַצָּה","translit":"matstsâh","pron":"mats-tsaw'","derivation":"from H4711 (מָצַץ) in the sense of greedily devouring for sweetness;","strongs_def":"properly, sweetness; concretely, sweet (i.e. not soured or bittered with yeast); specifically, an unfermented cake or loaf, or (elliptically) the festival of Passover (because no leaven was then used)","kjv_def":"unleaved (bread, cake), without leaven.","pos":"feminine noun","usage":"unleavened(14x), cakes(5x)"},"H4683":{"id":"H4683","lemma":"מַצָּה","translit":"matstsâh","pron":"mats-tsaw'","derivation":"from H5327 (נָצָה);","strongs_def":"a quarrel","kjv_def":"contention, debate, strife.","pos":"feminine noun","usage":"contention(1x), strife(1x), debate(1x)"},"H4684":{"id":"H4684","lemma":"מַצְהָלָה","translit":"matshâlâh","pron":"mats-haw-law'","derivation":"from H6670 (צָהַל);","strongs_def":"a whinnying (through impatience for battle or lust)","kjv_def":"neighing.","pos":"feminine noun","usage":"neighing(2x)"},"H4685":{"id":"H4685","lemma":"מָצוֹד","translit":"mâtsôwd","pron":"maw-tsode'","derivation":"or (feminine) מְצוֹדָה; or מצֹדָה; from H6679 (צוּד); also (by interchange for H4679 (מְצַד))","strongs_def":"a net (for capturing animals or fishes);  afastness or (beseiging) tower","kjv_def":"bulwark, hold, munition, net, snare.","pos":"feminine noun, masculine noun","usage":"net(2x), snare(1x), bulwark(1x), munition(1x), hold(1x)"},"H4686":{"id":"H4686","lemma":"מָצוּד","translit":"mâtsûwd","pron":"maw-tsood'","derivation":"or (feminine) מְצוּדָה; or מְצֻדָה; for H4685 (מָצוֹד);","strongs_def":"a net, or (abstractly) capture; also a fastness","kjv_def":"castle, defense, fort(-ress), (strong) hold, be hunted, net, snare, strong place.","pos":"feminine noun","usage":"fortress(6x), hold(6x), snare(2x), castle(1x), net(1x), hunted(1x), fort(1x), defence(1x)"},"H4687":{"id":"H4687","lemma":"מִצְוָה","translit":"mitsvâh","pron":"mits-vaw'","derivation":"from H6680 (צָוָה);","strongs_def":"a command, whether human or divine (collectively, the Law)","kjv_def":"(which was) commanded(-ment), law, ordinance, precept.","pos":"feminine noun","usage":"commandments(177x), precept(4x), commanded(2x), law(1x), ordinances(1x)"},"H4688":{"id":"H4688","lemma":"מְצוֹלָה","translit":"mᵉtsôwlâh","pron":"mets-o-law'","derivation":"or מְצֹלָה; also מְצוּלָה; or מְצֻלָה; from the same as H6683 (צוּלָה);","strongs_def":"a deep place (of water or mud)","kjv_def":"bottom, deep, depth.","pos":"feminine noun","usage":"deep(5x), deeps(3x), depths(2x), bottom(1x)"},"H4689":{"id":"H4689","lemma":"מָצוֹק","translit":"mâtsôwq","pron":"maw-tsoke'","derivation":"from H6693 (צוּק);","strongs_def":"a narrow place, i.e. (abstractly and figuratively) confinement or disability","kjv_def":"anguish, distress, straitness.","pos":"masculine noun","usage":"straitness(4x), distress(1x), anguish(1x)"},"H4690":{"id":"H4690","lemma":"מָצוּק","translit":"mâtsûwq","pron":"maw-tsook'","derivation":"or מָצֻק; from H6693 (צוּק);","strongs_def":"something narrow, i.e. a column or hilltop","kjv_def":"pillar, situate."},"H4691":{"id":"H4691","lemma":"מְצוּקָה","translit":"mᵉtsûwqâh","pron":"mets-oo-kaw'","derivation":"or מְצֻקָה; feminine of H4690 (מָצוּק);","strongs_def":"narrowness, i.e. (figuratively) trouble","kjv_def":"anguish, distress.","pos":"feminine noun","usage":"distress(6x), anguish(1x)"},"H4692":{"id":"H4692","lemma":"מָצוֹר","translit":"mâtsôwr","pron":"maw-tsore'","derivation":"or מָצוּר; from H6696 (צוּר);","strongs_def":"something hemming in, i.e. (objectively) a mound (of besiegers), (abstractly) a siege, (figuratively) distress; or (subjectively) a fastness","kjv_def":"besieged, bulwark, defence, fenced, fortress, siege, strong (hold), tower.","pos":"masculine noun","usage":"siege(13x), besieged(2x), strong(2x), bulwarks(1x), defence(1x), fenced(1x), fortress(1x), hold(1x), tower(1x)"},"H4693":{"id":"H4693","lemma":"מָצוֹר","translit":"mâtsôwr","pron":"maw-tsore'","derivation":"the same as H4692 (מָצוֹר) in the sense of a limit;","strongs_def":"Egypt (as the border of Palestine)","kjv_def":"besieged places, defense, fortified.","pos":"proper locative noun","usage":"defence(1x), fortress(1x), fortified(1x)"},"H4694":{"id":"H4694","lemma":"מְצוּרָה","translit":"mᵉtsûwrâh","pron":"mets-oo-raw'","derivation":"or מְצֻרָה; feminine of H4692 (מָצוֹר);","strongs_def":"a hemming in, i.e. (objectively) a mound (of siege), or (subjectively) a rampart (of protection), (abstractly) fortification","kjv_def":"fenced (city, fort, munition, strong hold.","pos":"feminine noun","usage":"fenced(5x), forts(1x), munitions(1x)"},"H4695":{"id":"H4695","lemma":"מַצּוּת","translit":"matstsûwth","pron":"mats-tsooth'","derivation":"from H5327 (נָצָה);","strongs_def":"a quarrel","kjv_def":"that contended.","pos":"feminine noun","usage":"contended(1x)"},"H4696":{"id":"H4696","lemma":"מֵצַח","translit":"mêtsach","pron":"may'-tsakh","derivation":"from an unused root meaning to be clear, i.e. conspicuous;","strongs_def":"the forehead (as open and prominent)","kjv_def":"brow, forehead, [phrase] impudent.","pos":"masculine noun","usage":"forehead(11x), impudent(1x), brow(1x)"},"H4697":{"id":"H4697","lemma":"מִצְחָה","translit":"mitschâh","pron":"mits-khaw'","derivation":"from the same as H4696 (מֵצַח);","strongs_def":"a shinpiece of armor (as prominent), only plural","kjv_def":"greaves."},"H4698":{"id":"H4698","lemma":"מְצִלָּה","translit":"mᵉtsillâh","pron":"mets-il-law'","derivation":"from H6750 (צָלַל);","strongs_def":"a tinkler, i.e. a bell","kjv_def":"bell.","pos":"feminine noun","usage":"bell(1x)"},"H4699":{"id":"H4699","lemma":"מְצֻלָּה","translit":"mᵉtsullâh","pron":"mets-ool-law'","derivation":"from H6751 (צָלַל);","strongs_def":"shade","kjv_def":"bottom.","pos":"masculine noun","usage":"bottom(1x)"}}