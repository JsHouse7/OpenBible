{"H4600":{"id":"H4600","lemma":"מָעַךְ","translit":"mâʻak","pron":"maw-ak'","derivation":"a primitive root;","strongs_def":"to press, i.e. to pierce, emasculate, handle","kjv_def":"bruised, stuck, be pressed.","pos":"verb","usage":"bruised(1x), stuck(1x), pressed(1x)"},"H4601":{"id":"H4601","lemma":"מַעֲכָה","translit":"Maʻăkâh","pron":"mah-ak-aw'","derivation":"or מַעֲכָת; (Joshua 13:13), from H4600 (מָעַךְ); depression;","strongs_def":"Maakah (or Maakath), the name of a place in Syria, also of a Mesopotamian, of three Israelites, and of four Israelitesses and one Syrian woman","kjv_def":"Maachah, Maachathites. See also H1038 (בֵּית מַעֲכָה).","pos":"proper noun, proper feminine noun, proper masculine noun","usage":"Maachah(18x), Maacah(3x), Maachathites(1x)"},"H4602":{"id":"H4602","lemma":"מַעֲכָתִי","translit":"Maʻăkâthîy","pron":"mah-ak-aw-thee'","derivation":"patrial from H4601 (מַעֲכָה);","strongs_def":"a Maakathite, or inhabitant of Maakah","kjv_def":"Maachathite.","pos":"adjective","usage":"Maachathite(7x), Maachathi(1x)"},"H4603":{"id":"H4603","lemma":"מָעַל","translit":"mâʻal","pron":"maw-al'","derivation":"a primitive root;","strongs_def":"properly, to cover up; used only figuratively, to act covertly, i.e. treacherously","kjv_def":"transgress, (commit, do a) trespass(-ing).","pos":"verb","usage":"trespass(13x), commit(11x), transgress(10x), done(1x)"},"H4604":{"id":"H4604","lemma":"מַעַל","translit":"maʻal","pron":"mah'-al","derivation":"from H4603 (מָעַל);","strongs_def":"treachery, i.e. sin","kjv_def":"falsehood, grievously, sore, transgression, trespass, [idiom] very.","pos":"masculine noun","usage":"trespass(17x), transgression(6x), trespassed(2x), falsehood(1x), grievously(1x), sore(1x), very(1x)"},"H4605":{"id":"H4605","lemma":"מַעַל","translit":"maʻal","pron":"mah'al","derivation":"from H5927 (עָלָה);","strongs_def":"properly, the upper part, used only adverbially with prefix upward, above, overhead, from the top, etc.","kjv_def":"above, exceeding(-ly), forward, on ([idiom] very) high, over, up(-on, -ward), very.","pos":"adjective, adverb, substantive","usage":"upward(59x), above(53x), high(6x), exceedingly(4x), upon(4x), very(2x), forward(2x), exceeding(2x), over(2x)"},"H4606":{"id":"H4606","lemma":"מֵעָל","translit":"mêʻâl","pron":"may-awl'","derivation":"(Aramaic) from H5954 (עֲלַל);","strongs_def":"(only in plural as singular) the setting (of the sun)","kjv_def":"going down.","pos":"masculine noun"},"H4607":{"id":"H4607","lemma":"מֹעַל","translit":"môʻal","pron":"mo'-al","derivation":"from H5927 (עָלָה);","strongs_def":"a raising (of the hands)","kjv_def":"lifting up.","pos":"masculine noun"},"H4608":{"id":"H4608","lemma":"מַעֲלֶה","translit":"maʻăleh","pron":"mah-al-eh'","derivation":"from H5927 (עָלָה);","strongs_def":"an elevation, i.e. (concretely) acclivity or platform; abstractly (the relation or state) a rise or (figuratively) priority","kjv_def":"ascent, before, chiefest, cliff, that goeth up, going up, hill, mounting up, stairs.","pos":"masculine noun","usage":"up(11x), ascent(2x), before(1x), chiefest(1x), cliff(1x), hill(1x), stairs(1x)"},"H4609":{"id":"H4609","lemma":"מַעֲלָה","translit":"maʻălâh","pron":"mah-al-aw'","derivation":"feminine of H4608 (מַעֲלֶה);","strongs_def":"elevation, i.e. the act (literally, a journey to a higher place, figuratively, a thought arising), or (concretely) the condition (literally, a step or grademark, figuratively, a superiority of station); specifically a climactic progression (in certain Psalms)","kjv_def":"things that come up, (high) degree, deal, go up, stair, step, story.","pos":"feminine noun","usage":"degree(25x), steps(11x), stairs(5x), dial(2x), by(1x), come(1x), stories(1x)"},"H4610":{"id":"H4610","lemma":"מַעֲלֵה עַקְרַבִּים","translit":"Maʻălêh ʻAqrabbîym","pron":"mah-al-ay' ak-rabbeem'","derivation":"from H4608 (מַעֲלֶה) and (the plural of) H6137 (עַקְרָב);","strongs_def":"Steep of Scorpions, a place in the Desert","kjv_def":"Maaleh-accrabim, the 