18","lemma":"מַעֲנָה","translit":"maʻănâh","pron":"mah-an-aw'","derivation":"from H6031 (עָנָה), in the sense of depression or tilling;","strongs_def":"a furrow","kjv_def":"[phrase] acre, furrow.","pos":"feminine noun","usage":"acre(1x), furrow(1x), variant(1x)"},"H4619":{"id":"H4619","lemma":"מַעַץ","translit":"Maʻats","pron":"mah'-ats","derivation":"from H6095 (עָצָה); closure;","strongs_def":"Maats, an Israelite","kjv_def":"Maaz."},"H4620":{"id":"H4620","lemma":"מַעֲצֵבָה","translit":"maʻătsêbâh","pron":"mah-ats-ay-baw'","derivation":"from H6087 (עָצַב);","strongs_def":"anguish","kjv_def":"sorrow."},"H4621":{"id":"H4621","lemma":"מַעֲצָד","translit":"maʻătsâd","pron":"mah-ats-awd'","derivation":"from an unused root meaning to hew;","strongs_def":"an axe","kjv_def":"ax, tongs.","pos":"masculine noun","usage":"tongs(1x), axe(1x)"},"H4622":{"id":"H4622","lemma":"מַעְצוֹר","translit":"maʻtsôwr","pron":"mah-tsore'","derivation":"from H6113 (עָצָר);","strongs_def":"objectively, a hindrance","kjv_def":"restraint."},"H4623":{"id":"H4623","lemma":"מַעְצָר","translit":"maʻtsâr","pron":"mah-tsawr'","derivation":"from H6113 (עָצָר);","strongs_def":"subjectively, control","kjv_def":"rule.","pos":"masculine noun","usage":"rule(1x)"},"H4624":{"id":"H4624","lemma":"מַעֲקֶה","translit":"maʻăqeh","pron":"mah-ak-eh'","derivation":"from an unused root meaning to repress;","strongs_def":"a parapet","kjv_def":"battlement.","pos":"masculine noun","usage":"battlement(1x)"},"H4625":{"id":"H4625","lemma":"מַעֲקָשׁ","translit":"maʻăqâsh","pron":"mah-ak-awsh'","derivation":"from H6140 (עָקַשׁ);","strongs_def":"a crook (in a road)","kjv_def":"crooked thing.","pos":"masculine noun"},"H4626":{"id":"H4626","lemma":"מַעַר","translit":"maʻar","pron":"mah'-ar","derivation":"from H6168 (עָרָה);","strongs_def":"a nude place, i.e. (literally) the pudenda, or (figuratively) a vacant space","kjv_def":"nakedness, proportion.","pos":"masculine noun","usage":"proportion(1x), nakedness(1x)"},"H4627":{"id":