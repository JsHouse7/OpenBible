gs(1x)"},"H1489":{"id":"H1489","lemma":"גִּזְבָּר","translit":"gizbâr","pron":"ghiz-bawr'","derivation":"of foreign derivation;","strongs_def":"treasurer","kjv_def":"treasurer.","pos":"masculine noun","usage":"treasurer(1x)"},"H1490":{"id":"H1490","lemma":"גִּזְבָּר","translit":"gizbâr","pron":"ghiz-bawr'","derivation":"(Aramaic) corresponding to H1489 (גִּזְבָּר)","strongs_def":"{treasurer}","kjv_def":"treasurer.","pos":"masculine noun","usage":"treasurer(1x)"},"H1491":{"id":"H1491","lemma":"גָּזָה","translit":"gâzâh","pron":"gaw-zaw'","derivation":"a primitive root (akin to H1468 (גּוּז));","strongs_def":"to cut off, i.e. portion out","kjv_def":"take.","pos":"verb","usage":"take(1x)"},"H1492":{"id":"H1492","lemma":"גָּזַּה","translit":"gâzzah","pron":"gaz-zaw'","derivation":"feminine from H1494 (גַּזָז);","strongs_def":"a fleece","kjv_def":"fleece.","pos":"feminine noun","usage":"fleece(7x)"},"H1493":{"id":"H1493","lemma":"גִּזוֹנִי","translit":"Gizôwnîy","pron":"ghee-zo-nee'","derivation":"patrial from the unused name of a place apparently in Palestine;","strongs_def":"a Gizonite or inhabitant of Gizoh","kjv_def":"Gizonite."},"H1494":{"id":"H1494","lemma":"גַּזָז","translit":"gazâz","pron":"gaw-zaz'","derivation":"a primitive root (akin to H1468 (גּוּז));","strongs_def":"to cut off; specifically to shear aflock or shave the hair; figuratively to destroy an enemy","kjv_def":"cut off (down), poll, shave, (sheep-) shear(-er).","pos":"verb","usage":"shear(5x), sheepshearer(3x), shearers(3x), poll(1x), shave(1x)"},"H1495":{"id":"H1495","lemma":"גָּזֵז","translit":"Gâzêz","pron":"gaw-zaze'","derivation":"from H1494 (גַּזָז); shearer;","strongs_def":"Gazez, the name of two Israelites","kjv_def":"Gazez."},"H1496":{"id":"H1496","lemma":"גָּזִית","translit":"gâzîyth","pron":"gaw-zeeth'","derivation":"from H1491 (גָּזָה);","strongs_def":"something cut, i.e. dressed stone","kjv_def":"hewed, hewn stone, wrought.","pos":"feminine noun","usage":"hewn(10x), wrought(1x)"},"H1497"