{"H6300":{"id":"H6300","lemma":"פְּדַהְאֵל","translit":"Pᵉdahʼêl","pron":"ped-ah-ale'","derivation":"from H6299 (פָּדָה) and H410 (אֵל); God has ransomed;","strongs_def":"Pedahel, an Israelite","kjv_def":"Pedahel.","pos":"proper masculine noun","usage":"Pedahel(1x)"},"H6301":{"id":"H6301","lemma":"פְּדָהצוּר","translit":"Pᵉdâhtsûwr","pron":"ped-aw-tsoor'","derivation":"from H6299 (פָּדָה) and H6697 (צוּר); a rock (i.e. God) has ransomed;","strongs_def":"Pedahtsur, an Israelite","kjv_def":"Pedahzur.","pos":"proper masculine noun","usage":"Pedahzur(5x)"},"H6302":{"id":"H6302","lemma":"פָּדוּי","translit":"pâdûwy","pron":"paw-doo'ee","derivation":"passive participle of H6299 (פָּדָה). ransomed (and so occurring under H6299 (פָּדָה));","strongs_def":"as abstractly (in plural masculine) a ransom","kjv_def":"(that are) to be (that were) redeemed.","pos":"masculine noun","usage":"redeemed(4x)"},"H6303":{"id":"H6303","lemma":"פָּדוֹן","translit":"Pâdôwn","pron":"paw-done'","derivation":"from H6299 (פָּדָה); ransom;","strongs_def":"Padon, one of the Nethinim.","kjv_def":"Padon."},"H6304":{"id":"H6304","lemma":"פְּדוּת","translit":"pᵉdûwth","pron":"ped-ooth'","derivation":"or פְּדֻת; from H6929 (קֵדְמָה)lemma קדְמָה missing vowel, corrected to קֵדְמָה;","strongs_def":"distinction; also deliverance","kjv_def":"division, redeem, redemption.","pos":"feminine noun","usage":"redemption(2x), redeem(1x), division(1x)"},"H6305":{"id":"H6305","lemma":"פְּדָיָה","translit":"Pᵉdâyâh","pron":"ped-aw-yaw'","derivation":"or פְּדָיָהוּ; from H6299 (פָּדָה) and H3050 (יָהּ); Jah has ransomed;","strongs_def":"Pedajah, the name of six Israelites","kjv_def":"Pedaiah.","pos":"proper masculine noun","usage":"Pedaiah(8x)"},"H6306":{"id":"H6306","lemma":"פִּדְיוֹם","translit":"pidyôwm","pron":"pid-yome'","derivation":"or פִּדְיֹם; also פִּדְיוֹן; or פִּדְיֹן; from H6299 (פָּדָה);","strongs_def":"a ransom","kjv_def":"ransom, that were redeemed, redemption.","pos":"masculine noun","usage":"redemption(2x), ransom(1x), variant(1x)"},"H6307":{"id":"H6307","lemma":"פַּדָּן","translit":"Paddân","pron":"pad-dawn'","derivation":"from an unused root meaning to extend; a plateau; or פַּדַּן אֲרָם; from the same and H758 (אֲרָם); the table-land of Aram;","strongs_def":"Paddan or Paddan-Aram, a region of Syria","kjv_def":"Padan, Padan-aram.","pos":"proper locative noun","usage":"Padanaram(10x), Padan(1x)"},"H6308":{"id":"H6308","lemma":"פָּדַע","translit":"pâdaʻ","pron":"paw-dah'","derivation":"a primitive root;","strongs_def":"to retrieve","kjv_def":"deliver.","pos":"verb","usage":"deliver(1x)"},"H6309":{"id":"H6309","lemma":"פֶּדֶר","translit":"peder","pron":"peh'der","derivation":"from an unused root meaning to be greasy;","strongs_def":"suet","kjv_def":"fat.","pos":"masculine noun","usage":"fat(3x)"},"H6310":{"id":"H6310","lemma":"פֶּה","translit":"peh","pron":"peh","derivation":"from H6284 (פָּאָה);","strongs_def":"the mouth (as the means of blowing), whether literal or figurative (particularly speech); specifically edge, portion or side; adverbially (with preposition) according to","kjv_def":"accord(-ing as, -ing to), after, appointment, assent, collar, command(-ment), [idiom] eat, edge, end, entry, [phrase] file, hole, [idiom] in, mind, mouth, part, portion, [idiom] (should) say(-ing), sentence, skirt, sound, speech, [idiom] spoken, talk, tenor, [idiom] to, [phrase] two-edged, wish, word.","pos":"masculine noun","usage":"mouth(340x), commandment(37x), edge(35x), according(22x), word(15x), hole(6x), end(3x), appointment(2x), portion(2x), tenor(2x), sentence(2x)"},"H6311":{"id":"H6311","lemma":"פֹּה","translit":"pôh","pron":"po","derivation":"or פֹּא; (Job 38:11), or פּוֹ; probably from a primitive inseparable particle 'p' (of demonstrative force) and H1931 (הוּא);","strongs_def":"this place (French ici), i.e. here or hence","kjv_def":"here, hither, the one (other, this, that) side.","pos":"adverb"},"H6312":{"id":"H6312","lemma":"פּוּאָה","translit":"Pûwʼâh","pron":"poo-aw'","derivation":"or פֻּוָּה; from H6284 (פָּאָה); a blast;","strongs_def":"Puah or Puvvah, the name of two Israelites","kjv_def":"Phuvah, Pua, Puah.","pos":"proper masculine noun","usage":"Puah(2x), Pua(1x), Phuvah(1x)"},"H6313":{"id":"H6313","lemma":"פּוּג","translit":"pûwg","pron":"poog","derivation":"a primitive root;","strongs_def":"to be sluggish","kjv_def":"cease, be feeble, faint, be slacked.","pos":"verb","usage":"fainted(1x), ceased(1x), slacked(1x), feeble(1x)"},"H6314":{"id":"H6314","lemma":"פּוּגָה","translit":"pûwgâh","pron":"poo-gaw'","derivation":"from H6313 (פּוּג);","strongs_def":"intermission","kjv_def":"rest.","pos":"feminine noun","usage":"rest(1x)"},"H6315":{"id":"H6315","lemma":"פּוּחַ","translit":"pûwach","pron":"poo'akh","derivation":"a primitive root;","strongs_def":"to puff, i.e. blow with the breath or air; hence, to fan (as a breeze), to utter, to kindle (a fire), to scoff","kjv_def":"blow (upon), break, puff, bring into a snare, speak, utter.","pos":"verb","usage":"speak(6x), puff(2x), blow(2x), break(2x), utter(1x)"},"H6316":{"id":"H6316","lemma":"פּוּט","translit":"Pûwṭ","pron":"poot","derivation":"of foreign origin;","strongs_def":"Put, a son of Ham, also the name of his descendants or their region, and of a Persian tribe","kjv_def":"Phut, Put.","pos":"proper noun with reference to people","usage":"Put(2x), Phut(2x), Libyan(2x), Libya(1x)"},"H6317":{"id":"H6317","lemma":"פּוּטִיאֵל","translit":"Pûwṭîyʼêl","pron":"poo-tee-ale'","derivation":"from an unused root (probably meaning to disparage) and H410 (אֵל); contempt of God;","strongs_def":"Putiel, an Israelite","kjv_def":"Putiel.","pos":"proper masculine noun","usage":"Putiel(1x)"},"H6318":{"id":"H6318","lemma":"פּוֹטִיפַר","translit":"Pôwṭîyphar","pron":"po-tee-far'","derivation":"of Egyptian derivation;","strongs_def":"Potiphar, an Egyptian","kjv_def":"Potiphar.","pos":"proper masculine noun","usage":"Potiphar(2x)"},"H6319":{"id":"H6319","lemma":"פּוֹטִי פֶרַע","translit":"Pôwṭîy Pheraʻ","pron":"po-tee feh'-rah","derivation":"of Egyptian derivation;","strongs_def":"Poti-Phera, an Egyptian","kjv_def":"Poti-pherah.","pos":"proper masculine noun","usage":"Potipherah(3x)"},"H6320":{"id":"H6320","lemma":"פּוּךְ","translit":"pûwk","pron":"pook","derivation":"from an unused root meaning to paint;","strongs_def":"dye (specifically, stibium for the eyes)","kjv_def":"fair colours, glistering, paint(-ed) (-ing).","pos":"masculine noun","usage":"paint(2x), glistering(1x)"},"H6321":{"id":"H6321","lemma":"פּוֹל","translit":"pôwl","pron":"pole","derivation":"from an unused root meaning to be thick;","strongs_def":"a bean (as plump)","kjv_def":"beans.","pos":"collective masculine noun","usage":"beans(2x)"},"H6322":{"id":"H6322","lemma":"פּוּל","translit":"Pûwl","pron":"pool","derivation":"of foreign origin;","strongs_def":"Pul, the name of an Assyrian king and of an Ethiopian tribe","kjv_def":"Pul.","pos":"proper masculine noun","usage":"Pul(4x)"},"H6323":{"id":"H6323","lemma":"פּוּן","translit":"pûwn","pron":"poon","derivation":"a primitive root meaning to turn, i.e.","strongs_def":"be perplexed","kjv_def":"be distracted."},"H6324":{"id":"H6324","lemma":"פּוּנִי","translit":"Pûwnîy","pron":"poo-nee'","derivation":"patronymically from an unused name meaning a turn;","strongs_def":"a Punite (collectively) or descendants of an unknown Pun","kjv_def":"Punites."},"H6325":{"id":"H6325","lemma":"פּוּנֹן","translit":"Pûwnôn","pron":"poo-none'","derivation":"from H6323 (פּוּן); perplexity;","strongs_def":"Punon, a place in the Desert","kjv_def":"Punon.","pos":"proper locative noun","usage":"Punon(2x)"},"H6326":{"id":"H6326","lemma":"פּוּעָה","translit":"Pûwʻâh","pron":"poo-aw'","derivation":"from an unused root meaning to glitter; brilliancy;","strongs_def":"Puah, an Israelitess","kjv_def":"Puah."},"H6327":{"id":"H6327","lemma":"פּוּץ","translit":"pûwts","pron":"poots","derivation":"a primitive root;","strongs_def":"to dash in pieces, literally or figuratively 