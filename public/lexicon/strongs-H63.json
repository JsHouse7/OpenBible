,"kjv_def":"be afraid, stand in awe, (be in) fear, make to shake.","pos":"verb","usage":"fear(14x), afraid(9x), awe(1x), shake(1x)"},"H6343":{"id":"H6343","lemma":"פַּחַד","translit":"pachad","pron":"pakh'-ad","derivation":"from H6342 (פָּחַד);","strongs_def":"a (sudden) alarm (properly, the object feared, by implication, the feeling)","kjv_def":"dread(-ful), fear, (thing) great (fear, -ly feared), terror.","pos":"masculine noun","usage":"fear(40x), dread(3x), great(2x), terror(2x), dreadful(1x), greatly(1x)"},"H6344":{"id":"H6344","lemma":"פַּחַד","translit":"pachad","pron":"pakh'-ad","derivation":"the same as H6343 (פַּחַד);","strongs_def":"a testicle (as a cause of shame akin to fear)","kjv_def":"stone.","pos":"masculine noun","usage":"stones(1x)"},"H6345":{"id":"H6345","lemma":"פַּחְדָּה","translit":"pachdâh","pron":"pakh-daw'","derivation":"feminine of H6343 (פַּחַד);","strongs_def":"alarm (i.e. awe)","kjv_def":"fear.","pos":"feminine noun","usage":"fear(1x)"},"H6346":{"id":"H6346","lemma":"פֶּחָה","translit":"pechâh","pron":"peh-khaw'","derivation":"of foreign origin;","strongs_def":"a prefect (of a city or small district)","kjv_def":"captain, deputy, governor.","pos":"masculine noun","usage":"governor(17x), captain(9x), deputies(2x)"},"H6347":{"id":"H6347","lemma":"פֶּחָה","translit":"pechâh","pron":"peh-khaw'","derivation":"(Aramaic) corresponding to H6346 (פֶּחָה)","strongs_def":"{a prefect (of a city or small district)}","kjv_def":"captain, governor.","pos":"masculine noun","usage":"governor(6x), captain(4x)"},"H6348":{"id":"H6348","lemma":"פָּחַז","translit":"pâchaz","pron":"paw-khaz'","derivation":"a primitive root;","strongs_def":"to bubble up or froth (as boiling water), i.e. (figuratively) to be unimportant","kjv_def":"light.","pos":"verb","usage":"light(2x)"},"H6349":{"id":"H6349","lemma":"פַּחַז","translit":"pachaz","pron":"pakh'-az","derivation":"from H6348 (פָּחַז);","strongs_def":"ebullition, i.e. froth (figuratively, lust)","kjv_def":"unstable.","pos":"masculine noun","usage":"unstable(1x)"},"H6350":{"id":"H6350","lemma":"פַּחֲזוּת","translit":"pachăzûwth","pron":"pakh-az-ooth'","derivation":"from H6348 (פָּחַז);","strongs_def":"frivolity","kjv_def":"lightness.","pos":"feminine noun","usage":"lightness(1x)"},"H6351":{"id":"H6351","lemma":"פָּחַח","translit":"pâchach","pron":"paw-khakh'","derivation":"a primitive root; to batter out; but used only as denominative from H6341 (פַּח),","strongs_def":"to spread a net","kjv_def":"be snared.","pos":"verb","usage":"snared(1x)"},"H6352":{"id":"H6352","lemma":"פֶּחָם","translit":"pechâm","pron":"peh-khawm'","derivation":"perhaps from an unused root probably meaning to be black;","strongs_def":"a coal, whether charred or live","kjv_def":"coals.","pos":"masculine noun","usage":"coals(3x)"},"H6353":{"id":"H6353","lemma":"פֶּחָר","translit":"pechâr","pron":"peh-khawr'","derivation":"(Aramaic) from an unused root probably meaning to fashion;","strongs_def":"a potter","kjv_def":"potter.","pos":"masculine noun","usage":"potter(1x)"},"H6354":{"id":"H6354","lemma":"פַּחַת","translit":"pachath","pron":"pakh'-ath","derivation":"probably from an unused root apparently meaning to dig;","strongs_def":"a pit, especially forcatching animals","kjv_def":"hole, pit, snare.","pos":"masculine noun","usage":"pit(8x), hole(1x), snare(1x)"},"H6355":{"id":"H6355","lemma":"פַּחַת מוֹאָב","translit":"Pachath Môwʼâb","pron":"pakh'-ath mo-awb'","derivation":"from H6354 (פַּחַת) and H4124 (מוֹאָב); pit of Moab;","strongs_def":"Pachath-Moab, an Israelite","kjv_def":"Pahathmoab.","pos":"proper masculine noun","usage":"Pahathmoab(6x)"},"H6356":{"id":"H6356","lemma":"פְּחֶתֶת","translit":"pᵉchetheth","pron":"pekh-eh'-theth","derivation":"from the same as H6354 (פַּחַת);","strongs_def":"a hole (by mildew in a garment)","kjv_def":"fret inward.","pos":"feminine noun"},"H6357":{"id":"H6357","lemma":"פִּטְדָה","translit":"piṭdâh","pron":"pit-daw'","derivation":"of foreign derivation;","strongs_def":"a gem, probably the topaz","kjv_def":"topaz.","pos":"feminine noun","usage":"topaz(4x)"},"H6358":{"id":"H6358","lemma":"פָּטוּר","translit":"pâṭûwr","pron":"paw-toor'","derivation":"passive participle of H6362 (פָּטַר);","strongs_def":"opened, i.e. (as noun) a bud","kjv_def":"open.","pos":"substantive","usage":"dismissed(1x)"},"H6359":{"id":"H6359","lemma":"פָּטִיר","translit":"pâṭîyr","pron":"paw-teer'","derivation":"from H6362 (פָּטַר);","strongs_def":"open, i.e. unoccupied","kjv_def":"free."},"H6360":{"id":"H6360","lemma":"פַּטִּישׁ","translit":"paṭṭîysh","pron":"pat-teesh'","derivation":"intensively from an unused root meaning to pound;","strongs_def":"a hammer","kjv_def":"hammer.","pos":"masculine noun","usage":"hammer(3x)"},"H6361":{"id":"H6361","lemma":"פַּטִּישׁ","translit":"paṭṭîysh","pron":"pat-teesh'","derivation":"(Aramaic) from a root corresponding to that of H6360 (פַּטִּישׁ);","strongs_def":"a gown (as if hammered out wide)","kjv_def":"hose.","pos":"masculine noun","usage":"hosen(1x), variant(1x)"},"H6362":{"id":"H6362","lemma":"פָּטַר","translit":"pâṭar","pron":"paw-tar'","derivation":"a primitive root;","strongs_def":"to cleave or burst through, i.e. (causatively) to emit, whether literal or figurative (gape)","kjv_def":"dismiss, free, let (shoot) out, slip away.","pos":"verb","usage":"open(4x), free(1x)"},"H6363":{"id":"H6363","lemma":"פֶּטֶר","translit":"peṭer","pron":"peh'-ter","derivation":"or פִּטְרָה; from H6362 (פָּטַר);","strongs_def":"a fissure, i.e. (concretely) firstling (as opening the matrix)","kjv_def":"firstling, openeth, such as open.","pos":"masculine noun","usage":"open(8x), firstling(4x)"},"H6364":{"id":"H6364","lemma":"פִּי־בֶסֶת","translit":"Pîy-Beçeth","pron":"pee beh'-seth","derivation":"of Egyptian origin;","strongs_def":"Pi-Beseth, a place in Egypt","kjv_def":"Pi-beseth.","pos":"proper locative noun","usage":"Pibeseth(1x)"},"H6365":{"id":"H6365","lemma":"פִּיד","translit":"pîyd","pron":"peed","derivation":"from an unused root pr