{"H1500":{"id":"H1500","lemma":"גְּזֵלָה","translit":"gᵉzêlâh","pron":"ghez-ay-law'","derivation":"feminine of H1498 (גָּזֵל) and mean the same","strongs_def":"{robbery, or (concretely) plunder}","kjv_def":"that (he had robbed) (which he took violently away), spoil, violence.","pos":"feminine noun","usage":"violence(3x), robbed(1x)"},"H1501":{"id":"H1501","lemma":"גָּזָם","translit":"gâzâm","pron":"gaw-zawm'","derivation":"from an unused root meaning to devour;","strongs_def":"a kind of locust","kjv_def":"palmer-worm.","pos":"collective masculine noun","usage":"palmerworm(3x)"},"H1502":{"id":"H1502","lemma":"גַּזָּם","translit":"Gazzâm","pron":"gaz-zawm'","derivation":"from the same as H1501 (גָּזָם); devourer","strongs_def":"Gazzam, one of the Nethinim","kjv_def":"Gazzam.","pos":"proper masculine noun","usage":"Gazzam(2x)"},"H1503":{"id":"H1503","lemma":"גֶּזַע","translit":"gezaʻ","pron":"geh'-zah","derivation":"from an unused root meaning to cut down (trees);","strongs_def":"the trunk or stump of atree (as felled or as planted)","kjv_def":"stem, stock.","pos":"masculine noun","usage":"stock(2x), stem(1x)"},"H1504":{"id":"H1504","lemma":"גָּזַר","translit":"gâzar","pron":"gaw-zar'","derivation":"a primitive root;","strongs_def":"to cut down or off; (figuratively) to destroy, divide, exclude, or decide","kjv_def":"cut down (off), decree, divide, snatch.","pos":"verb","usage":"divide(3x), decree(2x), snatch(1x)"},"H1505":{"id":"H1505","lemma":"גְּזַר","translit":"gᵉzar","pron":"ghez-ar'","derivation":"(Aramaic) corresponding to H1504 (גָּזַר);","strongs_def":"to quarry; determine","kjv_def":"cut out, soothsayer.","pos":"verb","usage":"soothsayer(4x)"},"H1506":{"id":"H1506","lemma":"גֶּזֶר","translit":"gezer","pron":"gheh'-zer","derivation":"from H1504 (גָּזַר);","strongs_def":"something cut off; a portion","kjv_def":"part, piece.","pos":"masculine plural noun","usage":"piece(1x), part(1x)"},"H1507":{"id":"H1507","lemma":"גֶּזֶר","translit":"Gezer","pron":"gheh'-zer","derivation":"the same as H1506 (גֶּזֶר);","strongs_def":"Gezer, a place in Palestine","kjv_def":"Gazer, Gezer.","pos":"proper locative noun","usage":"Gezer(13x), Gazer(2x)"},"H1508":{"id":"H1508","lemma":"גִּזְרָה","translit":"gizrâh","pron":"ghiz-raw'","derivation":"feminine of H1506 (גֶּזֶר);","strongs_def":"the figure or person (as if cut out); also an inclosure (as separated)","kjv_def":"polishing, separate place.","pos":"feminine noun","usage":"polishing(1x)"},"H1509":{"id":"H1509","lemma":"גְּזֵרָה","translit":"gᵉzêrâh","pron":"ghez-ay-raw'","derivation":"from H1504 (גָּזַר);","strongs_def":"a desert (as separated)","kjv_def":"not inhabited.","pos":"feminine noun","usage":"inhabited(1x)"},"H1510":{"id":"H1510","lemma":"גְּזֵרָה","translit":"gᵉzêrâh","pron":"ghez-ay-raw'","derivation":"(Aramaic) from H1505 (גְּזַר) (as H1504 (גָּזַר));","strongs_def":"a decree","kjv_def":"decree.","pos":"feminine noun","usage":"decree(2x)"},"H1511":{"id":"H1511","lemma":"גִּזְרִי","translit":"Gizrîy","pron":"ghiz-ree'","derivation":"(in the m patrial from H1507 (גֶּזֶר); a Gezerite (collectively) or inhabitants of Gezer; but better (as in the text) bytransposition גִּזְרִיxlit Girzîy corrected to Gizrîy; patrial of H1630 (גְּרִזִים);","strongs_def":"a Grizite (collectively) or member of a native tribe in Palestine","kjv_def":"Gezrites."},"H1512":{"id":"H1512","lemma":"גָּחוֹן","translit":"gâchôwn","pron":"gaw-khone'","derivation":"probably from H1518 (גִּיחַ)lemma גּיחַ missing vowel, corrected to גִּיחַ; (compare H1521 (גִּיחוֹן))","strongs_def":"the external abdomen, belly (as the source of the faetus )","kjv_def":"belly.","pos":"masculine noun","usage":"belly(2x)"},"H1513":{"id":"H1513","lemma":"גֶּחֶל","translit":"gechel","pron":"geh'-khel","derivation":"or (feminine) גַּחֶלֶת; from an unused root meaning to glow or kindle;","strongs_def":"an ember","kjv_def":"(burning) coal.","pos":"feminine noun","usage":"coals(17x)"},"H1514":{"id":"H1514","lemma":"גַּחַם","translit":"Gacham","pron":"gah'-kham","derivation":"from an unused root meaning to burn; flame;","strongs_def":"Gacham, a son of Nahor","kjv_def":"Gaham.","pos":"proper masculine noun","usage":"Gaham(1x)"},"H1515":{"id":"H1515","lemma":"גַּחַר","translit":"Gachar","pron":"gah'-khar","derivation":"from an unused root meaning to hide; lurker;","strongs_def":"Gachar, one of the Nethinim","kjv_def":"Gahar.","pos":"proper masculine noun","usage":"Gahar(2x)"},"H1516":{"id":"H1516","lemma":"גַּיְא","translit":"gayʼ","pron":"gah'-ee","derivation":"or (shortened) גַּי; probably (by transmutation) from the same root as H1466 (גֵּוָה) (abbreviated);","strongs_def":"a gorge (from its lofty sides; hence, narrow, but not a gully or winter-torrent)","kjv_def":"valley.","pos":"masculine/feminine noun","usage":"valley(60x)"},"H1517":{"id":"H1517","lemma":"גִּיד","translit":"gîyd","pron":"gheed","derivation":"probably from H1464 (גּוּד);","strongs_def":"a thong (as compressing); by analogy, a tendon","kjv_def":"sinew.","pos":"masculine noun","usage":"sinew(7x)"},"H1518":{"id":"H1518","lemma":"גִּיחַ","translit":"gîyach","pron":"ghee'-akh","derivation":"or (shortened) גֹּחַ; a primitive root;","strongs_def":"to gush forth (as water), generally to issue","kjv_def":"break forth, labor to bring forth, come forth, draw up, take out.","pos":"verb","usage":"take(1x)"},"H1519":{"id":"H1519","lemma":"גִּיחַ","translit":"gîyach","pron":"ghee'-akh","derivation":"(Aramaic) or (shortened) גּוּחַ; (Aramaic), corresponding to H1518 (גִּיחַ)lemma גּיחַ missing vowel, corrected to גִּיחַ;","strongs_def":"to rush forth","kjv_def":"strive.","pos":"verb","usage":"strove(1x)"},"H1520":{"id":"H1520","lemma":"גִּיחַ","translit":"Gîyach","pron":"ghee'-akh","derivation":"from H1518 (גִּיחַ)lemma גּיחַ missing vowel, corrected to גִּיחַ; a fountain;","strongs_def":"Giach, a place in Palestine","kjv_def":"Giah."},"H1521":{"id":"H1521","lemma":"גִּיחוֹן","translit":"Gîychôwn","pron":"ghee-khone'","derivation":"or (shortened) גִּחוֹן; from H1518 (גִּיחַ)lemma גּיחַ missing vowel, corrected to גִּיחַ; stream;","strongs_def":"Gichon, a river of Paradise; also a valley (or pool) near Jerusalem","kjv_def":"Gihon.","pos":"proper masculine noun","usage":"Gihon(6x)"},"H1522":{"id":"H1522","lemma":"גֵּיחֲזִי","translit":"Gêychăzîy","pron":"gay-khah-zee'","derivation":"or גֵּחֲזִי; apparently from H1516 (גַּיְא) and H2372 (חָזָה); valley of a visionary;","strongs_def":"Gechazi, the servant of Elisha","kjv_def":"Gehazi."},"H1523":{"id":"H1523","lemma":"גִּיל","translit":"gîyl","pron":"gheel","derivation":"or (by permutation) גּוּל; a primitive root;","strongs_def":"properly, to spin round (under the influence of any violent emotion), i.e. usually rejoice, or (as cringing) fear","kjv_def":"be glad, joy, be joyful, rejoice.","pos":"verb","usage":"rejoice(27x), glad(10x), joyful(4x), joy(2x), delight(1x)"},"H1524":{"id":"H1524","lemma":"גִּיל","translit":"gîyl","pron":"gheel","derivation":"from H1523 (גִּיל);","strongs_def":"a revolution (of time, i.e. an age); also joy","kjv_def":"[idiom] exceedingly, gladness, [idiom] greatly, joy, rejoice(-ing), sort.","pos":"masculine noun","usage":"rejoice(3x), joy(3x), gladness(2x), exceedingly(1x)"},"H1525":{"id":"H1525","lemma":"גִּילָה","translit":"gîylâh","pron":"ghee-law'","derivation":"or גִּילַת; feminine of H1524 (גִּיל);","strongs_def":"joy","kjv_def":"joy, rejoicing.","pos":"feminine noun","usage":"rejoicing(1x), joy(1x)"},"H1526":{"id":"H1526","lemma":"גִּילֹנִי","translit":"Gîylônîy","pron":"ghee-lo-nee'","derivation":"patrial from H1542 (גִּלֹה);","strongs_def":"a Gilonite or inhabitant of Giloh","kjv_def":"Gilonite."},"H1527":{"id":"H1527","lemma":"גִּינַת","translit":"Gîynath","pron":"ghee-nath'","derivation":"of uncertain derivation;","strongs_def":"Ginath, an Israelite","kjv_def":"Ginath."},"H1528":{"id":"H1528","lemma":"גִּיר","translit":"gîyr","pron":"gheer","derivation":"(Aramaic) corresponding to H1615 (גִּר);","strongs_def":"lime","kjv_def":"plaster.","pos":"masculine noun","usage":"plaister(1x)"},"H1529":{"id":"H1529","lemma":"גֵּישָׁן","translit":"Gêyshân","pron":"gay-shawn'","derivation":"from the same as H1487 (גּוּשׁ); lumpish;","strongs_def":"Geshan, an Israelite","kjv_def":"Geshan."},"H1530":{"id":"H1530","lemma":"גַּל","translit":"gal","pron":"gal","derivation":"from H1556 (גָּלַל);","strongs_def":"something rolled, i.e. a heap of stone or dung (plural ruins), by analogy, a spring of water (plural waves)","kjv_def":"billow, heap, spring, wave.","pos":"masculine noun","usage":"heap(18x), wave(14x), spring(1x), billow(1x), of(1x)"},"H1531":{"id":"H1531","lemma":"גֹּל","translit":"gôl","pron":"gole","derivation":"from H1556 (גָּלַל);","strongs_def":"a cup for oil (as round)","kjv_def":"bowl.","pos":"masculine noun","usage":"bowl(1x)"},"H1532":{"id":"H1532","lemma":"גַּלָּב","translit":"gallâb","pron":"gal-lawb'","derivation":"from an unused root meaning to shave;","strongs_def":"a barber","kjv_def":"barber.","pos":"masculine noun","usage":"barber(1x)"},"H1533":{"id":"H1533","lemma":"גִּלְבֹּעַ","translit":"Gilbôaʻ","pron":"ghil-bo'-ah","derivation":"from H1530 (גַּל) and H1158 (בָּעָה); fountain of ebullition;","strongs_def":"Gilboa, a mountain of Palestine","kjv_def":"Gilboa."},"H1534":{"id":"H1534","lemma":"גַּלְגַּל","translit":"galgal","pron":"gal-gal'","derivation":"by reduplication from H1556 (גָּלַל);","strongs_def":"a wheel; by analogy, a whirlwind; also dust (as whirled)","kjv_def":"heaven, rolling thing, wheel.","pos":"masculine noun","usage":"wheel(8x), heaven(1x), whirlwind(1x)"},"H1535":{"id":"H1535","lemma":"גַּלְגַּל","translit":"galgal","pron":"gal-gal'","derivation":"(Aramaic) corresponding to H1534 (גַּלְגַּל);","strongs_def":"a wheel","kjv_def":"wheel.","pos":"masculine noun","usage":"wheel(1x)"},"H1536":{"id":"H1536","lemma":"גִּלְגָּל","translit":"gilgâl","pron":"ghil-gawl'","derivation":"a variation of H1534 (גַּלְגַּל)","strongs_def":"{a wheel; by analogy, a whirlwind; also dust (as whirled)}","kjv_def":"wheel.","pos":"masculine noun","usage":"wheel(1x)"},"H1537":{"id":"H1537","lemma":"גִּלְגָּל","translit":"Gilgâl","pron":"ghil-gawl'","derivation":"the same as H1536 (גִּלְגָּל) (with the article as a properly, noun);","strongs_def":"Gilgal, the name of three places in Palestine","kjv_def":"Gilgal. See also H1019 (בֵּית הַגִּלְגָּל).","pos":"proper locative noun","usage":"Gilgal(41x)"},"H1538":{"id":"H1538","lemma":"גֻּלְגֹּלֶת","translit":"gulgôleth","pron":"gul-go'-leth","derivation":"by reduplication from H1556 (גָּלַל);","strongs_def":"a skull (as round); by implication, a head (in enumeration of persons)","kjv_def":"head, every man, poll, skull.","pos":"feminine noun","usage":"poll(7x), scull(2x), head(1x)"},"H1539":{"id":"H1539","lemma":"גֶּלֶד","translit":"geled","pron":"ghe'-led","derivation":"from an unused root probably meaning to polish;","strongs_def":"the (human) skin (as smooth)","kjv_def":"skin.","pos":"masculine noun","usage":"skin(1x)"},"H1540":{"id":"H1540","lemma":"גָּלָה","translit":"gâlâh","pron":"gaw-law'","derivation":"a primitive root;","strongs_def":"to denude (especially in a disgraceful sense); by implication, to exile (captives being usually stripped); figuratively, to reveal","kjv_def":"[phrase] advertise, appear, bewray, bring, (carry, lead, go) captive (into captivity), depart, disclose, discover, exile, be gone, open, [idiom] plainly, publish, remove, reveal, [idiom] shamelessly, shew, [idiom] surely, tell, uncover.","pos":"verb","usage":"uncover(34x), discover(29x), captive(28x), reveal(16x), open(12x), captivity(11x), shew(9x), remove(6x), appear(3x)"},"H1541":{"id":"H1541","lemma":"גְּלָה","translit":"gᵉlâh","pron":"ghel-aw'","derivation":"(Aramaic) or גְּלָא; (Aramaic), corresponding to H1540 (גָּלָה)","strongs_def":"{to denude (especially in a disgraceful sense); by implication, to exile (captives being usually stripped); figuratively, to reveal}","kjv_def":"bring over, carry away, reveal.","pos":"verb","usage":"reveal(7x)"},"H1542":{"id":"H1542","lemma":"גִּלֹה","translit":"Gilôh","pron":"ghee-lo'","derivation":"or (fully) גִּילֹה; from H1540 (גָּלָה); open;","strongs_def":"Giloh, a place in Palestine","kjv_def":"Giloh.","pos":"proper locative noun","usage":"Giloh(2x)"},"H1543":{"id":"H1543","lemma":"גֻּלָּה","translit":"gullâh","pron":"gool-law'","derivation":"feminine from H1556 (גָּלַל);","strongs_def":"a fountain, bowl or globe (all as round)","kjv_def":"bowl, pommel, spring.","pos":"feminine noun","usage":"spring(6x), bowl(5x), pommel(3x)"},"H1544":{"id":"H1544","lemma":"גִּלּוּל","translit":"gillûwl","pron":"ghil-lool'","derivation":"or (shortened) גִּלֻּל; from H1556 (גָּלַל);","strongs_def":"properly, a log (as round); by implication, an idol","kjv_def":"idol.","pos":"masculine plural noun","usage":"idol(47x), image(1x)"},"H1545":{"id":"H1545","lemma":"גְּלוֹם","translit":"gᵉlôwm","pron":"ghel-ome'","derivation":"from H1563 (גָּלַם);","strongs_def":"clothing (as wrapped)","kjv_def":"clothes.","pos":"masculine noun","usage":"clothes(1x)"},"H1546":{"id":"H1546","lemma":"גָּלוּת","translit":"gâlûwth","pron":"gaw-looth'","derivation":"feminine from H1540 (גָּלָה);","strongs_def":"captivity; concretely, exiles (collectively)","kjv_def":"(they that are carried away) captives(-ity).","pos":"feminine noun","usage":"captivity(10x)"},"H1547":{"id":"H1547","lemma":"גָּלוּת","translit":"gâlûwth","pron":"gaw-looth'","derivation":"(Aramaic) corresponding to H1546 (גָּלוּת)","strongs_def":"{captivity; concretely, exiles (collectively)}","kjv_def":"captivity.","pos":"feminine noun","usage":"captivity(3x), captive(1x)"},"H1548":{"id":"H1548","lemma":"גָּלַח","translit":"gâlach","pron":"gaw-lakh'","derivation":"a primitive root;","strongs_def":"properly, to be bald, i.e. (causatively) to shave; figuratively to lay waste","kjv_def":"poll, shave (off).","pos":"verb","usage":"shave(17x), poll(2x)"},"H1549":{"id":"H1549","lemma":"גִּלָּיוֹן","translit":"gillâyôwn","pron":"ghil-law-yone'","derivation":"or גִּלְיוֹן; from H1540 (גָּלָה);","strongs_def":"a tablet for writing (as bare); by analogy, a mirror (as a plate)","kjv_def":"glass, roll.","pos":"masculine noun","usage":"glasses(1x), roll(1x)"},"H1550":{"id":"H1550","lemma":"גָּלִיל","translit":"gâlîyl","pron":"gaw-leel'","derivation":"from H1556 (גָּלַל);","strongs_def":"a valve of a folding door (as turning); also a ring (as round)","kjv_def":"folding, ring.","pos":"adjective, masculine noun","usage":"folding(2x), ring(2x)"},"H1551":{"id":"H1551","lemma":"גָּלִיל","translit":"Gâlîyl","pron":"gaw-leel'","derivation":"or (prolonged) גָּלִילָה; the same as H1550 (גָּלִיל); a circle (with the article);","strongs_def":"Galil (as a special circuit) in the North of Palestine","kjv_def":"Galilee.","pos":"masculine noun, proper locative noun","usage":"Galilee(6x)"},"H1552":{"id":"H1552","lemma":"גְלִילָה","translit":"gᵉlîylâh","pron":"ghel-ee-law'","derivation":"feminine of H1550 (גָּלִיל);","strongs_def":"a circuit or region","kjv_def":"border, coast, country.","pos":"feminine noun, proper locative noun","usage":"border(3x), coast(1x), country(1x)"},"H1553":{"id":"H1553","lemma":"גְּלִילוֹת","translit":"Gᵉlîylôwth","pron":"ghel-ee-lowth'","derivation":"plural of H1552 (גְלִילָה); circles;","strongs_def":"Geliloth, a place in Palestine","kjv_def":"Geliloth.","pos":"proper locative noun","usage":"Geliloth(1x)"},"H1554":{"id":"H1554","lemma":"גַּלִּים","translit":"Gallîym","pron":"gal-leem'","derivation":"plural of H1530 (גַּל); springs;","strongs_def":"Gallim, a place in Palestine","kjv_def":"Gallim.","pos":"proper locative noun","usage":"Gallim(2x)"},"H1555":{"id":"H1555","lemma":"גׇּלְיַת","translit":"Golyath","pron":"gol-yath'","derivation":"perhaps from H1540 (גָּלָה); exile;","strongs_def":"Goljath, a Philistine","kjv_def":"Goliath."},"H1556":{"id":"H1556","lemma":"גָּלַל","translit":"gâlal","pron":"gaw-lal'","derivation":"a primitive root;","strongs_def":"to roll (literally or figuratively)","kjv_def":"commit, remove, roll (away, down, together), run down, seek occasion, trust, wallow.","pos":"verb","usage":"roll(9x), wallow(1x), trust(1x), commit(1x), remove(1x)"},"H1557":{"id":"H1557","lemma":"גָּלָל","translit":"gâlâl","pron":"gaw-lawl'","derivation":"from H1556 (גָּלַל);","strongs_def":"dung (as in balls)","kjv_def":"dung."},"H1558":{"id":"H1558","lemma":"גָּלָל","translit":"gâlâl","pron":"gaw-lawl'","derivation":"from H1556 (גָּלַל);","strongs_def":"a circumstance (as rolled around); only used adverbially, on account of","kjv_def":"because of, for (sake).","pos":"masculine noun construction (with preposition)","usage":"because(4x), for(1x)"},"H1559":{"id":"H1559","lemma":"גָּלָל","translit":"Gâlâl","pron":"gaw-lawl'","derivation":"from H1556 (גָּלַל), in the sense of H1560 (גְּלָל); great;","strongs_def":"Galal, the name of two Israelites","kjv_def":"Galal.","pos":"proper masculine noun","usage":"Galal(3x)"},"H1560":{"id":"H1560","lemma":"גְּלָל","translit":"gᵉlâl","pron":"ghel-awl'","derivation":"(Aramaic) from a root corresponding to H1556 (גָּלַל);","strongs_def":"weight or size (as if rolled)","kjv_def":"great.","pos":"adjective","usage":"great(2x)"},"H1561":{"id":"H1561","lemma":"גֵּלֶל","translit":"gêlel","pron":"gay'-lel","derivation":"a variation of H1557 (גָּלָל);","strongs_def":"dung (plural balls of dung)","kjv_def":"dung.","pos":"masculine noun","usage":"dung(4x)"},"H1562":{"id":"H1562","lemma":"גִּלֲלַי","translit":"Gilălay","pron":"ghe-lal-ah'-ee","derivation":"from H1561 (גֵּלֶל); dungy;","strongs_def":"Gilalai, an Israelite","kjv_def":"Gilalai.","pos":"proper masculine noun","usage":"Gilalai(1x)"},"H1563":{"id":"H1563","lemma":"גָּלַם","translit":"gâlam","pron":"gaw-lam'","derivation":"a primitive root;","strongs_def":"to fold","kjv_def":"wrap together."},"H1564":{"id":"H1564","lemma":"גֹּלֶם","translit":"gôlem","pron":"go'-lem","derivation":"from H1563 (גָּלַם);","strongs_def":"a wrapped (and unformed mass, i.e. as the