2","lemma":"צֵלֶל","translit":"tsêlel","pron":"tsay'-lel","derivation":"from H6751 (צָלַל);","strongs_def":"shade","kjv_def":"shadow.","pos":"masculine noun","usage":"shadow(4x)"},"H6753":{"id":"H6753","lemma":"צְלֶלְפּוֹנִי","translit":"Tsᵉlelpôwnîy","pron":"tsel-el-po-nee'","derivation":"from H6752 (צֵלֶל) and the active participle of H6437 (פָּנָה); shade-facing;","strongs_def":"Tselelponi, an Israelitess","kjv_def":"Hazelelponi (including the article)."},"H6754":{"id":"H6754","lemma":"צֶלֶם","translit":"tselem","pron":"tseh'-lem","derivation":"from an unused root meaning to shade;","strongs_def":"a phantom, i.e. (figuratively) illusion, resemblance; hence, a representative figure, especially an idol","kjv_def":"image, vain shew.","pos":"masculine noun","usage":"image(16x)"},"H6755":{"id":"H6755","lemma":"צֶלֶם","translit":"tselem","pron":"tseh'-lem","derivation":"(Aramaic) or צְלֶם; (Aramaic), corresponding to H6754 (צֶלֶם);","strongs_def":"an idolatrous figure","kjv_def":"form, image.","pos":"masculine noun","usage":"image(16x), form(1x)"},"H6756":{"id":"H6756","lemma":"צַלְמוֹן","translit":"Tsalmôwn","pron":"tsal-mone'","derivation":"from H6754 (צֶלֶם); shady;","strongs_def":"Tsalmon, the name of a place in Palestine and of an Israelite","kjv_def":"Zalmon.","pos":"proper locative noun, proper masculine noun","usage":"Zalmon(2x), Salmon(1x)"},"H6757":{"id":"H6757","lemma":"צַלְמָוֶת","translit":"tsalmâveth","pron":"tsal-maw'-veth","derivation":"from H6738 (צֵל) and H4194 (מָוֶת);","strongs_def":"shade of death, i.e. the grave (figuratively, calamity)","kjv_def":"shadow of death.","pos":"masculine noun"},"H6758":{"id":"H6758","lemma":"צַלְמֹנָה","translit":"Tsalmônâh","pron":"tsal-mo-naw'","derivation":"feminine of H6757 (צַלְמָוֶת); shadiness;","strongs_def":"Tsalmonah, a place in the Desert","kjv_def":"Zalmonah.","pos":"proper locative noun","usage":"Zalmonah(2x)"},"H6759":{"id":"H6759","lemma":"צַלְמֻנָּע","translit":"Tsalmunnâʻ","pron":"tsal-moon-naw'","derivation":"from H6738 (צֵל) and H4513 (מָנַע); shade has been denied;","strongs_def":"Tsalmunna, a Midianite","kjv_def":"Zalmunna.","pos":"proper masculine noun","usage":"Zalmunna(12x)"},"H6760":{"id":"H6760","lemma":"צָלַע","translit":"tsâlaʻ","pron":"tsaw-lah'","derivation":"a primitive root; probably to curve; used only as denominative from H6763 (צֵלָע),","strongs_def":"to limp (as if one-sided)","kjv_def":"halt.","pos":"verb","usage":"halt(4x)"},"H6761":{"id":"H6761","lemma":"צֶלַע","translit":"tselaʻ","pron":"tseh'-lah","derivation":"from H6760 (צָלַע);","strongs_def":"a limping or full (figuratively)","kjv_def":"adversity, halt(-ing).","pos":"masculine noun","usage":"halt(1x), adversity(1x), variant(1x)"},"H6762":{"id":"H6762","lemma":"צֶלַע","translit":"Tselaʻ","pron":"tseh'-lah","derivation":"the same as H6761 (צֶלַע);","strongs_def":"Tsela, a place in Palestine","kjv_def":"Zelah.","pos":"proper locative noun","usage":"Zelah(2x)"},"H6763":{"id":"H6763","lemma":"צֵלָע","translit":"tsêlâʻ","pron":"tsay-law'","derivation":"or (feminine) צַלְעָה; from H6760 (צָלַע);","strongs_def":"a rib (as curved), literally (of the body) or figuratively (of a door, i.e. leaf); hence, a side, literally (of a person) or figuratively (of an object or the sky, i.e. quarter); architecturally, a (especially floor or ceiling) timber or plank (single or collective, i.e. a flooring)","kjv_def":"beam, board, chamber, corner, leaf, plank, rib, side (chamber).","pos":"feminine noun","usage":"side(19x), chamber(11x), boards(2x), corners(2x), rib(2x), another(1x), beams(1x), halting(1x), leaves(1x), planks(1x)"},"H6764":{"id":"H6764","lemma":"צָלָף","translit":"Tsâlâph","pron":"tsaw-lawf'","derivation":"from an unused root of unknown meaning;","strongs_def":"Tsalaph, an Israelite","kjv_def":"Zalaph.","pos":"proper masculine noun","usage":"Zalaph(1x)"},"H6765":{"id":"H6765","lemma":"צְלׇפְחָד","translit":"Tsᵉlophchâd","pron":"tsel-of-chawd'","derivation":"from the same as H6764 (צָלָף) and H259 (אֶחָד);","strongs_def":"Tselophchad, an Israelite","kjv_def":"Zelophehad.","pos":"proper masculine noun","usage":"Zelophehad(11x)"},"H6766":{"id":"H6766","lemma":"צֶלְצַח","translit":"Tseltsach","pron":"tsel-tsakh'","derivation":"from H6738 (צֵל) and H6703 (צַח); clear shade;","strongs_def":"Tseltsach, a place in Palestine","kjv_def":"Zelzah."},"H6767":{"id":"H6767","lemma":"צְלָצַל","translit":"tsᵉlâtsal","pron":"tsel-aw-tsal'","derivation":"from H6750 (צָלַל) reduplicated;","strongs_def":"a clatter, i.e. (abstractly) whirring (of wings); (concretely) a cricket; also a harpoon (as rattling), a cymbal (as clanging)","kjv_def":"cymbal, locust, shadowing, spear.","pos":"masculine noun","usage":"cymbal(3x), locust(1x), spear(1x), shadowing(1x)"},"H6768":{"id":"H6768","lemma":"צֶלֶק","translit":"Tseleq","pron":"tseh'-lek","derivation":"from an unused root meaning to split; fissure;","strongs_def":"Tselek, an Israelite","kjv_def":"Zelek."},"H6769":{"id":"H6769","lemma":"צִלְּתַי","translit":"Tsillᵉthay","pron":"tsil-leth-ah'-ee","derivation":"from the feminine of H6738 (צֵל); shady;","strongs_def":"Tsillethai, the name of two Israelites","kjv_def":"Zilthai."},"H6770":{"id":"H6770","lemma":"צָמֵא","translit":"tsâmêʼ","pron":"tsaw-may'","derivation":"a primitive root;","strongs_def":"to thirst (literally or figuratively)","kjv_def":"(be a-, suffer) thirst(-y).","pos":"verb","usage":"thirst(5x), athirst(2x), thirsty(1x)"},"H6771":{"id":"H6771","lemma":"צָמֵא","translit":"tsâmêʼ","pron":"tsaw-may'","derivation":"from H6770 (צָמֵא);","strongs_def":"thirsty (literally or figuratively)","kjv_def":"(that) thirst(-eth, -y).","pos":"adjective","usage":"thirsty(7x), thirst(2x)"},"H6772":{"id":"H6772","lemma":"צָמָא","translit":"tsâmâʼ","pron":"tsaw-maw'","derivation":"from H6770 (צָמֵא);","strongs_def":"thirst (literally or figuratively)","kjv_def":"thirst(-y).","pos":"masculine noun","usage":"thirst(16x), thirsty(1x)"},"H6773":{"id":"H6773","lemma":"צִמְאָה","translit":"tsimʼ