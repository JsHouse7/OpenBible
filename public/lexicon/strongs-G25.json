uter noun","usage":"jot(1x)"},"G2541":{"id":"G2541","lemma":"Καῖσαρ","translit":"Kaîsar","derivation":"of Latin origin;","strongs_def":"Cæsar, a title of the Roman emperor","kjv_def":"Cæsar","pos":"masculine noun","usage":"Caesar(30x)"},"G2553":{"id":"G2553","lemma":"κακοπαθέω","translit":"kakopathéō","derivation":"from the same as G2552 (κακοπάθεια);","strongs_def":"to undergo hardship","kjv_def":"be afflicted, endure afflictions (hardness), suffer trouble","pos":"verb"},"G2513":{"id":"G2513","lemma":"καθαρός","translit":"katharós","derivation":"of uncertain affinity;","strongs_def":"clean (literally or figuratively)","kjv_def":"clean, clear, pure","pos":"adjective","usage":"pure(17x), clean(10x), clear(1x)"},"G2575":{"id":"G2575","lemma":"κάμινος","translit":"káminos","derivation":"probably from G2545 (καίω);","strongs_def":"a furnace","kjv_def":"furnace","pos":"feminine noun","usage":"furnace(4x)"},"G2546":{"id":"G2546","lemma":"κἀκεῖ","translit":"kakeî","derivation":"from G2532 (καί) and G1563 (ἐκεῖ);","strongs_def":"likewise in that place","kjv_def":"and there, there (thither) also","pos":"adverb"},"G2590":{"id":"G2590","lemma":"καρπός","translit":"karpós","derivation":"probably from the base of G726 (ἁρπάζω);","strongs_def":"fruit (as plucked), literally or figuratively","kjv_def":"fruit","pos":"masculine noun","usage":"fruit(66x)"},"G2593":{"id":"G2593","lemma":"καρποφόρος","translit":"karpophóros","derivation":"from G2590 (καρπός) and G5342 (φέρω);","strongs_def":"fruitbearing (figuratively)","kjv_def":"fruitful","pos":"adjective","usage":"fruitful(1x)"},"G2533":{"id":"G2533","lemma":"Καϊάφας","translit":"Kaïáphas","derivation":"of Chaldee origin;","strongs_def":"the dell; Caiaphas (i.e. Cajepha), an Israelite","kjv_def":"Caiaphas","pos":"proper masculine noun","usage":"Caiaphas(9x)"},"G2525":{"id":"G2525","lemma":"καθίστημι","translit":"kathístēmi","derivation":"from G2596 (κατά) and G2476 (ἵστημι);","strongs_def":"to place down (permanently), i.e. (figuratively) to designate, constitute, convoy","kjv_def":"appoint, be, conduct, make, ordain, set","pos":"verb","usage":"make(8x), ordain(3x), be(2x), appoint(1x), conduct(1x), set(1x)"},"G2559":{"id":"G2559","lemma":"κακόω","translit":"kakóō","derivation":"from G2556 (κακός);","strongs_def":"to injure; figuratively, to exasperate","kjv_def":"make evil affected, entreat evil, harm, hurt, vex","pos":"verb","usage":"vex(1x), hurt(1x), harm(1x)"},"G2589":{"id":"G2589","lemma":"καρδιογνώστης","translit":"kardiognṓstēs","derivation":"from G2588 (καρδία) and G1097 (γινώσκω);","strongs_def":"a heart-knower","kjv_def":"which knowest the hearts","pos":"masculine noun"},"G2512":{"id":"G2512","lemma":"καθαρισμός","translit":"katharismós","derivation":"from G2511 (καθαρίζω);","strongs_def":"a washing off, i.e. (ceremonially) ablution, (morally) expiation","kjv_def":"cleansing, + purge, purification(-fying)","pos":"masculine noun","usage":"cleansing(2x), purifying(2x), purification(1x)"},"G2561":{"id":"G2561","lemma":"κάκωσις","translit":"kákōsis","derivation":"from G2559 (κακόω);","strongs_def":"maltreatment","kjv_def":"affliction","pos":"feminine noun","usage":"affliction(1x)"},"G2511":{"id":"G2511","lemma":"καθαρίζω","translit":"katharízō","derivation":"from G2513 (καθαρός);","strongs_def":"to cleanse (literally or figuratively)","kjv_def":"(make) clean(-se), purge, purify","pos":"verb","usage":"cleanse(16x), purge(3x), purify(3x)"},"G2552":{"id":"G2552","lemma":"κακοπάθεια","translit":"kakopátheia","derivation":"from a compound of G2256 (ἡμιώριον) and G3806 (πάθος);","strongs_def":"hardship","kjv_def":"suffering affliction","pos":"feminine noun"},"G2510":{"id":"G2510","lemma":"καθάπτω","translit":"katháptō","derivation":"from G2596 (κατά) and G680 (ἅπτομαι);","strongs_def":"to seize upon","kjv_def":"fasten on","pos":"verb"},"G2547":{"id":"G2547","lemma":"κἀκεῖθεν","translit":"kakeîthen","derivation":"from G2532 (καί) and G1564 (ἐκεῖθεν);","strongs_def":"likewise from that place (o