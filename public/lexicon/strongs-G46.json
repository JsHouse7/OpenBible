{"G4641":{"id":"G4641","lemma":"σκληροκαρδία","translit":"sklērokardía","derivation":"feminine of a compound of G4642 (σκληρός) and G2588 (καρδία);","strongs_def":"hard-heartedness, i.e. (specially), destitution of (spiritual) perception","kjv_def":"hardness of heart","pos":"feminine noun"},"G4603":{"id":"G4603","lemma":"σιδήρεος","translit":"sidḗreos","derivation":"from G4604 (σίδηρος);","strongs_def":"made of iron","kjv_def":"(of) iron","pos":"adjective","usage":"iron(1x)"},"G4693":{"id":"G4693","lemma":"σπήλαιον","translit":"spḗlaion","derivation":"neuter of a presumed derivative of (a grotto);","strongs_def":"a cavern; by implication, a hiding-place or resort","kjv_def":"cave, den","pos":"neuter noun","usage":"den(5x), cave(1x)"},"G4652":{"id":"G4652","lemma":"σκοτεινός","translit":"skoteinós","derivation":"from G4655 (σκότος);","strongs_def":"opaque, i.e. (figuratively) benighted","kjv_def":"dark, full of darkness","pos":"adjective","usage":"dark(1x)"},"G4648":{"id":"G4648","lemma":"σκοπέω","translit":"skopéō","derivation":"from G4649 (σκοπός);","strongs_def":"to take aim at (spy), i.e. (figuratively) regard","kjv_def":"consider, take heed, look at (on), mark","pos":"verb","usage":"mark(2x), consider(1x)"},"G4685":{"id":"G4685","lemma":"σπάω","translit":"spáō","derivation":"a primary verb;","strongs_def":"to draw","kjv_def":"draw (out)","pos":"verb","usage":"draw(1x)"},"G4649":{"id":"G4649","lemma":"σκοπός","translit":"skopós","derivation":"from (to peer about (\"skeptic\");","strongs_def":"perhaps akin to G4626 (σκάπτω) through the idea of concealment; compare G4629 (σκέπασμα)); a watch (sentry or scout), i.e. (by implication) a goal","kjv_def":"mark","pos":"masculine noun","usage":"mark(1x)"},"G4600":{"id":"G4600","lemma":"σιαγών","translit":"siagṓn","derivation":"of uncertain derivation;","strongs_def":"the jaw-bone, i.e. (by implication) the cheek or side of the face","kjv_def":"cheek","pos":"feminine noun","usage":"cheek(2x)"},"G4612":{"id":"G4612","lemma"