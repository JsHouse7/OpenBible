rently a primary word;","strongs_def":"a trough, i.e. wine-vat","kjv_def":"winepress","pos":"feminine noun","usage":"winepress(4x)"},"G3067":{"id":"G3067","lemma":"λουτρόν","translit":"loutrón","derivation":"from G3068 (λούω);","strongs_def":"a bath, i.e. (figuratively), baptism","kjv_def":"washing","pos":"neuter noun","usage":"washing(2x)"},"G3088":{"id":"G3088","lemma":"λύχνος","translit":"lýchnos","derivation":"from the base of G3022 (λευκός);","strongs_def":"a portable lamp or other illuminator (literally or figuratively)","kjv_def":"candle, light","pos":"masculine noun","usage":"candle(8x), light(6x)"},"G3087":{"id":"G3087","lemma":"λυχνία","translit":"lychnía","derivation":"from G3088 (λύχνος);","strongs_def":"a lamp-stand (literally or figuratively)","kjv_def":"candlestick","pos":"feminine noun","usage":"candlestick(12x)"},"G3035":{"id":"G3035","lemma":"λίθινος","translit":"líthinos","derivation":"from G3037 (λίθος);","strongs_def":"stony, i.e. made of stone","kjv_def":"of stone","pos":"adjective"},"G3031":{"id":"G3031","lemma":"λιβανωτός","translit":"libanōtós","derivation":"from G3030 (λίβανος);","strongs_def":"frankincense, i.e. (by extension) a censer for burning it","kjv_def":"censer","pos":"masculine noun","usage":"censer(2x)"},"G3005":{"id":"G3005","lemma":"λεῖμμα","translit":"leîmma","derivation":"from G3007 (λείπω);","strongs_def":"a remainder","kjv_def":"remnant","pos":"neuter noun","usage":"remnant(1x)"},"G3098":{"id":"G3098","lemma":"Μαγώγ","translit":"Magṓg","derivation":"of Hebrew origin (H04031);","strongs_def":"Magog, a foreign nation, i.e. (figuratively) an Antichristian party","kjv_def":"Magog","pos":"proper locative noun","usage":"Magog(1x)"},"G3064":{"id":"G3064","lemma":"λοιποῦ","translit":"loipoû","derivation":"genitive case singular of the same as G3062 (λοιποί);","strongs_def":"remaining time","kjv_def":"from henceforth","pos":"adjective"},"G3006":{"id":"G3006","lemma":"λεῖος","translit":"leîos","derivation":"apparently a primary word;