{"G4533":{"id":"G4533","lemma":"Σαλμών","translit":"Salmṓn","derivation":"of Hebrew origin (H08012);","strongs_def":"Salmon, an Israelite","kjv_def":"Salmon","pos":"proper masculine noun","usage":"Salmon(3x)"},"G4568":{"id":"G4568","lemma":"σάτον","translit":"sáton","derivation":"of Hebrew origin (H05429);","strongs_def":"a certain measure for things dry","kjv_def":"measure","pos":"neuter noun","usage":"measure(2x)"},"G4549":{"id":"G4549","lemma":"Σαούλ","translit":"Saoúl","derivation":"of Hebrew origin (H07586);","strongs_def":"Saul (i.e. Shaul), the Jewish name of Paul","kjv_def":"Saul","pos":"proper masculine noun"},"G4592":{"id":"G4592","lemma":"σημεῖον","translit":"sēmeîon","derivation":"neuter of a presumed derivative of the base of G4591 (σημαίνω);","strongs_def":"an indication, especially ceremonially or supernaturally","kjv_def":"miracle, sign, token, wonder","pos":"neuter noun","usage":"sign(50x), miracle(23x), wonder(3x), token(1x)"},"G4579":{"id":"G4579","lemma":"σείω","translit":"seíō","derivation":"apparently a primary verb;","strongs_def":"to rock (vibrate, properly, sideways or to and fro), i.e. (generally) to agitate (in any direction; cause to tremble); figuratively, to throw into a tremor (of fear or concern)","kjv_def":"move, quake, shake","pos":"verb","usage":"shake(3x), move(1x), quake(1x)"},"G4575":{"id":"G4575","lemma":"σεβαστός","translit":"sebastós","derivation":"from G4573 (σεβάζομαι);","strongs_def":"venerable (august), i.e. (as noun) a title of the Roman Emperor, or (as adjective) imperial","kjv_def":"Augustus(-')","pos":"adjective","usage":"Augustus(3x)"},"G4565":{"id":"G4565","lemma":"Σάρων","translit":"Sárōn","derivation":"of Hebrew origin (H08289);","strongs_def":"Saron (i.e. Sharon), a district of Palestine","kjv_def":"Saron","pos":"proper locative noun","usage":"Saron(1x)"},"G4540":{"id":"G4540","lemma":"Σαμάρεια","translit":"Samáreia","derivation":"of Hebrew origin (H08111);","strongs_def":"Samaria (i.e. Shomeron), a city and region of Palestine","kjv_def":"Samaria","pos":"proper locative noun","usage":"Samaria(11x)"},"G4544":{"id":"G4544","lemma":"Σάμος","translit":"Sámos","derivation":"of uncertain affinity;","strongs_def":"Samus, an island of the Mediterranean","kjv_def":"Samos","pos":"proper locative noun","usage":"Samos(1x)"},"G4547":{"id":"G4547","lemma":"σανδάλιον","translit":"sandálion","derivation":"neuter of a derivative of (a \"sandal\";","strongs_def":"of uncertain origin); a slipper or sole-pad","kjv_def":"sandal","pos":"neuter noun","usage":"sandal(2x)"},"G4558":{"id":"G4558","lemma":"Σάρεπτα","translit":"Sárepta","derivation":"of Hebrew origin (H06886);","strongs_def":"Sarepta (i.e. Tsarephath), a place in Palestine","kjv_def":"Sarepta","pos":"proper locative noun","usage":"Sarepta(1x)"},"G4520":{"id":"G4520","lemma":"σαββατισμός","translit":"sabbatismós","derivation":"from a derivative of G4521 (σάββατον);","strongs_def":"a \"sabbatism\", i.e. (figuratively) the repose of Christianity (as a type of heaven)","kjv_def":"rest","pos":"masculine noun","usage":"rest(1x)"},"G4524":{"id":"G4524","lemma":"Σαδώκ","translit":"Sadṓk","derivation":"of Hebrew origin (H06659);","strongs_def":"Sadoc (i.e. Tsadok), an Israelite","kjv_def":"Sadoc","pos":"proper masculine noun","usage":"Sadoc(2x)"},"G4502":{"id":"G4502","lemma":"Ῥουβήν","translit":"Rhoubḗn","derivation":"of Hebrew origin (H07205);","strongs_def":"Ruben (i.e. Reuben), an Israelite","kjv_def":"Reuben","pos":"proper masculine noun","usage":"Reuben(1x)"},"G4586":{"id":"G4586","lemma":"σεμνός","translit":"semnós","derivation":"from G4576 (σέβομαι);","strongs_def":"venerable, i.e. honorable","kjv_def":"grave, honest","pos":"adjective","usage":"grave(3x), honest(1x)"},"G4590":{"id":"G4590","lemma":"Σήμ","translit":"Sḗm","derivation":"of Hebrew origin (H08035);","strongs_def":"Sem (i.e. Shem), a patriarch","kjv_def":"Sem","pos":"proper masculine noun","usage":"Sem(1x)"},"G4555":{"id":"G4555","lemma":"σάρδινος","translit":"sárdinos","derivation":"from the same as G4556 (σάρδιος);","strongs_def":"sardine (G3037 (λίθος) being implied), i.e. a gem, so called","kjv_def":"sardine","pos":"adjective","usage":"sardine(1x)"},"G4578":{"id":"G4578","lemma":"σεισμός","translit":"seismós","derivation":"from G4579 (σείω);","strongs_def":"a commotion, i.e. (of the air) a gale, (of the ground) an earthquake","kjv_def":"earthquake, tempest","pos":"masculine noun","usage":"earthquake(13x), tempest(1x)"},"G4537":{"id":"G4537","lemma":"σαλπίζω","translit":"salpízō","derivation":"from G4536 (σάλπιγξ);","strongs_def":"to trumpet, i.e. sound a blast (literally or figuratively)","kjv_def":"(which are yet to) sound (a trumpet)","pos":"verb","usage":"sound(10x)"},"G4521":{"id":"G4521","lemma":"σάββατον","translit":"sábbaton","derivation":"of Hebrew origin (H07676);","strongs_def":"the Sabbath (i.e. Shabbath), or day of weekly repose from secular avocations (also the observance or institution itself); by extension, a se'nnight, i.e. the interval between two Sabbaths; likewise the plural in all the above applications","kjv_def":"sabbath (day), week","pos":"neuter noun","usage":"sabbath(22x), week(9x)"},"G4530":{"id":"G4530","lemma":"Σαλείμ","translit":"Saleím","derivation":"probably from the same as G4531 (σαλεύω);","strongs_def":"Salim, a place in Palestine","kjv_def":"Salim","pos":"proper locative noun","usage":"Salim(1x)"},"G4539":{"id":"G4539","lemma":"Σαλώμη","translit":"Salṓmē","derivation":"probably of Hebrew origin (feminine from H07965);","strongs_def":"Salome (i.e. Shelomah), an Israelitess","kjv_def":"Salome","pos":"proper feminine noun","usage":"Salome(2x)"},"G4584":{"id":"G4584","lemma":"Σεμεΐ","translit":"Semeḯ","derivation":"of Hebrew origin (H08096);","strongs_def":"Semei (i.e. Shimi), an Israelite","kjv_def":"Semei","pos":"proper masculine noun","usage":"Semei(1x)"},"G4581":{"id":"G4581","lemma":"Σελεύκεια","translit":"Seleúkeia","derivation":"from (Seleucus, a Syrian king);","strongs_def":"Seleuceia, a place in Syria","kjv_def":"Seleucia","pos":"proper locative noun","usage":"Seleucia(1x)"},"G4566":{"id":"G4566","lemma":"Σατᾶν","translit":"Satân","derivation":"of Hebrew origin (H07854);","strongs_def":"Satan, i.e. the devil","kjv_def":"Satan"},"G4593":{"id":"G4593","lemma":"σημειόω","translit":"sēmeióō","derivation":"from G4592 (σημεῖον);","strongs_def":"to distinguish, i.e. mark (for avoidance)","kjv_def":"note"},"G4550":{"id":"G4550","lemma":"σαπρός","translit":"saprós","derivation":"from G4595 (σήπω);","strongs_def":"rotten, i.e. worthless (literally or morally)","kjv_def":"bad, corrupt","pos":"adjective","usage":"corrupt(7x), bad(1x)"},"G4572":{"id":"G4572","lemma":"σεαυτοῦ","translit":"seautoû","derivation":"genitive case from G4571 (σέ) and G846 (αὐτός), also dative case of the same, , and accusative case , likewise contracted , , and , respectively;","strongs_def":"of (with, to) thyself","kjv_def":"thee, thine own self, (thou) thy(-self)","pos":"pronoun","usage":"thyself(35x), thee(1x), thy(1x)"},"G4519":{"id":"G4519","lemma":"σαβαώθ","translit":"sabaṓth","derivation":"of Hebrew origin (H06635 in feminine plural);","strongs_def":"armies; sabaoth (i.e. tsebaoth), a military epithet of God","kjv_def":"sabaoth","pos":"indeclinable noun","usage":"sabaoth(2x)"},"G4560":{"id":"G4560","lemma":"σάρκινος","translit":"sárkinos","derivation":"from G4561 (σάρξ);","strongs_def":"similar to flesh, i.e. (by analogy) soft","kjv_def":"fleshly"},"G4552":{"id":"G4552","lemma":"σάπφειρος","translit":"sáppheiros","derivation":"of Hebrew origin (H05601);","strongs_def":"a \"sapphire\" or lapis-lazuli gem","kjv_def":"sapphire","pos":"feminine noun","usage":"sapphire(1x)"},"G4580":{"id":"G4580","lemma":"Σεκοῦνδος","translit":"Sekoûndos","derivation":"of Latin origin;","strongs_def":"\"second\"; Secundus, a Christian","kjv_def":"Secundus","pos":"proper masculine noun","usage":"Secundus(1x)"},"G4529":{"id":"G4529","lemma":"Σαλαμίς","translit":"Salamís","derivation":"probably from G4535 (σάλος) (from the surge on the shore);","strongs_def":"Salamis, a place in Cyprus","kjv_def":"Salamis","pos":"proper locative noun","usage":"Salamis(1x)"},"G4597":{"id":"G4597","lemma":"σής","translit":"sḗs","derivation":"apparently of Hebrew origin (H05580);","strongs_def":"a moth","kjv_def":"moth","pos":"neuter noun","usage":"moth(3x)"},"G4562":{"id":"G4562","lemma":"Σαρούχ","translit":"Saroúch","derivation":"of Hebrew origin (H08286);","strongs_def":"Saruch (i.e. Serug), a patriarch","kjv_def":"Saruch","pos":"proper masculine noun","usage":"Saruch(1x)"},"G4599":{"id":"G4599","lemma":"σθενόω","translit":"sthenóō","derivation":"from (bodily vigor;","strongs_def":"probably akin to the base of G2476 (ἵστημι)); to strengthen, i.e. (figuratively) confirm (in spiritual knowledge and power)","kjv_def":"strengthen"},"G4536":{"id":"G4536","lemma":"σάλπιγξ","translit":"sálpinx","derivation":"perhaps from G4535 (σάλος) (through the idea of quavering or reverberation);","strongs_def":"a trumpet","kjv_def":"trump(-et)","pos":"feminine noun","usage":"trumpet(9x), trump(2x)"},"G4576":{"id":"G4576","lemma":"σέβομαι","translit":"sébomai","derivation":"middle voice of an apparently primary verb;","strongs_def":"to revere, i.e. adore","kjv_def":"devout, religious, worship","pos":"verb","usage":"worship(6x), devout(3x), religious(1x)"},"G4589":{"id":"G4589","lemma":"Σήθ","translit":"Sḗth","derivation":"of Hebrew origin (H08352);","strongs_def":"Seth (i.e. Sheth), a patriarch","kjv_def":"Seth","pos":"proper masculine noun","usage":"Seth(1x)"},"G4512":{"id":"G4512","lemma":"ῥυτίς","translit":"rhytís","derivation":"from G4506 (ῥύομαι);","strongs_def":"a fold (as drawing together), i.e. a wrinkle (especially on the face)","kjv_def":"wrinkle","pos":"feminine noun","usage":"wrinkle(1x)"},"G4508":{"id":"G4508","lemma":"ῥυπαρός","translit":"rhyparós","derivation":"from G4509 (ῥύπος);","strongs_def":"dirty, i.e. (relatively) cheap or shabby; morally, wicked","kjv_def":"vile","pos":"adjective","usage":"vile(1x)"},"G4532":{"id":"G4532","lemma":"Σαλήμ","translit":"Salḗm","derivation":"of Hebrew origin (H08004);","strongs_def":"Salem (i.e. Shalem), a place in Palestine","kjv_def":"Salem","pos":"proper locative noun","usage":"Salem(2x)"},"G4503":{"id":"G4503","lemma":"Ῥούθ","translit":"Rhoúth","derivation":"of Hebrew origin (H07327);","strongs_def":"Ruth, a Moabitess","kjv_def":"Ruth","pos":"proper feminine noun","usage":"Ruth(1x)"},"G4571":{"id":"G4571","lemma":"σέ","translit":"sé","derivation":"accusative case singular of G4771 (σύ);","strongs_def":"thee","kjv_def":"thee, thou, X thy house","pos":"pronoun","usage":"thee(178x), thou(16x)"},"G4534":{"id":"G4534","lemma":"Σαλμώνη","translit":"Salmṓnē","derivation":"perhaps of similar origin to G4529 (Σαλαμίς);","strongs_def":"Salmone, a place in Crete","kjv_def":"Salmone"},"G4505":{"id":"G4505","lemma":"ῥύμη","translit":"rhýmē","derivation":"prolongation from G4506 (ῥύομαι) in its original sense;","strongs_def":"an alley or avenue (as crowded)","kjv_def":"lane, street","pos":"feminine noun","usage":"street(3x), lane(1x)"},"G4527":{"id":"G4527","lemma":"Σαλά","translit":"Salá","derivation":"of Hebrew origin (H07974);","strongs_def":"Sala (i.e. Shelach), a patriarch","kjv_def":"Sala"},"G4577":{"id":"G4577","lemma":"σειρά","translit":"seirá","derivation":"probably from G4951 (σύρω) through its congener (to fasten;","strongs_def":"akin to G138 (αἱρέομαι)); a chain (as binding or drawing)","kjv_def":"chain"},"G4553":{"id":"G4553","lemma":"σαργάνη","translit":"sargánē","derivation":"apparently of Hebrew origin (H08276);","strongs_def":"a basket (as interwoven or wicker-work","kjv_def":"basket"},"G4514":{"id":"G4514","lemma":"Ῥωμαῖος","translit":"Rhōmaîos","derivation":"from G4516 (Ῥώμη);","strongs_def":"Romæan, i.e. Roman (as noun)","kjv_def":"Roman, of Rome","pos":"adjective","usage":"Roman(12x)"},"G4585":{"id":"G4585","lemma":"σεμίδαλις","translit":"semídalis","derivation":"probably of foreign origin;","strongs_def":"fine wheaten flour","kjv_def":"fine flour","pos":"feminine noun"},"G4573":{"id":"G4573","lemma":"σεβάζομαι","translit":"sebázomai","derivation":"middle voice from a derivative of G4576 (σέβομαι);","strongs_def":"to venerate, i.e. adore","kjv_def":"worship","pos":"verb","usage":"worship(1x)"},"G4515":{"id":"G4515","lemma":"Ῥωμαϊστί","translit":"Rhōmaïstí","derivation":"adverb from a presumed derivative of G4516 (Ῥώμη);","strongs_def":"Romaistically, i.e. in the Latin language","kjv_def":"Latin"},"G4561":{"id":"G4561","lemma":"σάρξ","translit":"sárx","derivation":"probably from the base of G4563 (σαρόω);","strongs_def":"flesh (as stripped of the skin), i.e. (strictly) the meat of an animal (as food), or (by extension) the body (as opposed to the soul (or spirit), or as the symbol of what is external, or as the means of kindred), or (by implication) human nature (with its frailties (physically or morally) and passions), or (specially), a human being (as such)","kjv_def":"carnal(-ly, + -ly minded), flesh(-ly)","pos":"feminine noun","usage":"flesh(147x), carnal(2x), fleshly(1x)"},"G4531":{"id":"G4531","lemma":"σαλεύω","translit":"saleúō","derivation":"from G4535 (σάλος);","strongs_def":"to waver, i.e. agitate, rock, topple or (by implication) destroy; figuratively, to disturb, incite","kjv_def":"move, shake (together), which can(-not) be shaken, stir up","pos":"verb","usage":"shake(10x), move(1x)"},"G4563":{"id":"G4563","lemma":"σαρόω","translit":"saróō","derivation":"from a derivative of (to brush off;","strongs_def":"akin to G4951 (σύρω)); meaning a broom; to sweep","kjv_def":"sweep","pos":"verb","usage":"sweep(3x)"},"G4557":{"id":"G4557","lemma":"σαρδόνυξ","translit":"sardónyx","derivation":"from the base of G4556 (σάρδιος) and (the nail of a finger;","strongs_def":"hence the \"onyx\" stone); a \"sardonyx\", i.e. the gem so called","kjv_def":"sardonyx","pos":"masculine noun","usage":"sardonyx(1x)"},"G4569":{"id":"G4569","lemma":"Σαῦλος","translit":"Saûlos","derivation":"of Hebrew origin, the same as G4549 (Σαούλ);","strongs_def":"Saulus (i.e. Shaul), the Jewish name of Paul","kjv_def":"Saul","pos":"proper masculine noun","usage":"Saul(17x)"},"G4504":{"id":"G4504","lemma":"Ῥοῦφος","translit":"Rhoûphos","derivation":"of Latin origin;","strongs_def":"red; Rufus, a Christian","kjv_def":"Rufus","pos":"proper masculine noun","usage":"Rufus(2x)"},"G4516":{"id":"G4516","lemma":"Ῥώμη","translit":"Rhṓmē","derivation":"from the base of G4517 (ῥώννυμι);","strongs_def":"strength; Roma, the capital of Italy","kjv_def":"Rome","pos":"proper locative noun","usage":"Rome(14x)"},"G4522":{"id":"G4522","lemma":"σαγήνη","translit":"sagḗnē","derivation":"from a derivative of (to equip) meaning furniture, especially a pack-saddle (which in the East is merely a bag of netted rope);","strongs_def":"a \"seine\" for fishing","kjv_def":"net","pos":"feminine noun","usage":"net(1x)"},"G4546":{"id":"G4546","lemma":"Σαμψών","translit":"Sampsṓn","derivation":"of Hebrew origin (H08123);","strongs_def":"Sampson (i.e. Shimshon), an Israelite","kjv_def":"Samson","pos":"proper masculine noun","usage":"Samson(1x)"},"G4523":{"id":"G4523","lemma":"Σαδδουκαῖος","translit":"Saddoukaîos","derivation":"probably from G4524 (Σαδώκ);","strongs_def":"a Sadducæan (i.e. Tsadokian), or follower of a certain heretical Israelite","kjv_def":"Sadducee","pos":"masculine noun","usage":"Sadducees(14x)"},"G4591":{"id":"G4591","lemma":"σημαίνω","translit":"sēmaínō","derivation":"from (a mark;","strongs_def":"of uncertain derivation); to indicate","kjv_def":"signify","pos":"verb","usage":"signify(6x)"},"G4543":{"id":"G4543","lemma":"Σαμοθρᾴκη","translit":"Samothráikē","derivation":"from G4544 (Σάμος) and (Thrace);","strongs_def":"Samo-thrace (Samos of Thrace), an island in the Mediterranean","kjv_def":"Samothracia","pos":"proper locative noun","usage":"Samothracia(1x)"},"G4598":{"id":"G4598","lemma":"σητόβρωτος","translit":"sētóbrōtos","derivation":"from G4597 (σής) and a derivative of G977 (βιβρώσκω);","strongs_def":"moth-eaten","kjv_def":"motheaten"},"G4588":{"id":"G4588","lemma":"Σέργιος","translit":"Sérgios","derivation":"of Latin origin;","strongs_def":"Sergius, a Roman","kjv_def":"Sergius","pos":"proper masculine noun"},"G4500":{"id":"G4500","lemma":"ῥοιζηδόν","translit":"rhoizēdón","derivation":"adverb from a derivative of (a whir);","strongs_def":"whizzingly, i.e. with a crash","kjv_def":"with a great noise"},"G4526":{"id":"G4526","lemma":"σάκκος","translit":"sákkos","derivation":"of Hebrew origin (H08242);","strongs_def":"\"sack\"-cloth, i.e. mohair (the material or garments made of it, worn as a sign of grief)","kjv_def":"sackcloth","pos":"masculine noun","usage":"sackcloth(4x)"},"G4538":{"id":"G4538","lemma":"σαλπιστής","translit":"salpistḗs","derivation":"from G4537 (σαλπίζω);","strongs_def":"a trumpeter","kjv_def":"trumpeter","pos":"masculine noun","usage":"trumpeter(1x)"},"G4501":{"id":"G4501","lemma":"ῥομφαία","translit":"rhomphaía","derivation":"probably of foreign origin;","strongs_def":"a sabre, i.e. a long and broad cutlass (any weapon of the kind, literally or figuratively)","kjv_def":"sword","pos":"feminine noun","usage":"sword(7x)"},"G4587":{"id":"G4587","lemma":"σεμνότης","translit":"semnótēs","derivation":"from G4586 (σεμνός);","strongs_def":"venerableness, i.e. probity","kjv_def":"gravity, honesty","pos":"feminine noun","usage":"gravity(2x), honesty(1x)"},"G4582":{"id":"G4582","lemma":"σελήνη","translit":"selḗnē","derivation":"from (brilliancy;","strongs_def":"probably akin to the alternate of G138 (αἱρέομαι), through the idea of attractiveness); the moon","kjv_def":"moon","pos":"feminine noun","usage":"moon(9x)"},"G4548":{"id":"G4548","lemma":"σανίς","translit":"sanís","derivation":"of uncertain affinity;","strongs_def":"a plank","kjv_def":"board","pos":"feminine noun","usage":"board(1x)"},"G4528":{"id":"G4528","lemma":"Σαλαθιήλ","translit":"Salathiḗl","derivation":"of Hebrew origin (H07597);","strongs_def":"Salathiel (i.e. Shealtiel), an Israelite","kjv_def":"Salathiel","pos":"proper masculine noun","usage":"Salathiel(3x)"},"G4583":{"id":"G4583","lemma":"σεληνιάζομαι","translit":"selēniázomai","derivation":"middle voice or passive from a presumed derivative of G4582 (σελήνη);","strongs_def":"to be moon-struck, i.e. crazy","kjv_def":"be a lunatic","pos":"verb"},"G4545":{"id":"G4545","lemma":"Σαμουήλ","translit":"Samouḗl","derivation":"of Hebrew origin (H08050);","strongs_def":"Samuel (i.e. Shemuel), an Israelite","kjv_def":"Samuel","pos":"proper masculine noun","usage":"Samuel(3x)"},"G4518":{"id":"G4518","lemma":"σαβαχθάνι","translit":"sabachtháni","derivation":"of Chaldee or (H07662 with pronominal suffix);","strongs_def":"thou hast left me; sabachthani (i.e. shebakthani), a cry of distress","kjv_def":"sabachthani","pos":"Aramaism","usage":"sabachthani(2x)"},"G4564":{"id":"G4564","lemma":"Σάῤῥα","translit":"Sárrha","derivation":"of Hebrew origin (H08283);","strongs_def":"Sarra (i.e. Sarah), the wife of Abraham","kjv_def":"Sara, Sarah","pos":"proper feminine noun","usage":"Sarah(2x), Sara(2x)"},"G4596":{"id":"G4596","lemma":"σηρικός","translit":"sērikós","derivation":"from (an Indian tribe from whom silk was procured;","strongs_def":"hence the name of the silk-worm); Seric, i.e. silken (neuter as noun, a silky fabric)","kjv_def":"silk","pos":"adjective","usage":"silk(1x)"},"G4542":{"id":"G4542","lemma":"Σαμαρεῖτις","translit":"Samareîtis","derivation":"feminine of G4541 (Σαμαρείτης);","strongs_def":"a Samaritess, i.e. woman of Samaria","kjv_def":"of Samaria","pos":"proper feminine noun","usage":"Samaria(2x)"},"G4574":{"id":"G4574","lemma":"σέβασμα","translit":"sébasma","derivation":"from G4573 (σεβάζομαι);","strongs_def":"something adored, i.e. an object of worship (god, altar, etc)","kjv_def":"devotion, that is worshipped","pos":"neuter noun","usage":"devotion(1x)"},"G4570":{"id":"G4570","lemma":"σβέννυμι","translit":"sbénnymi","derivation":"a prolonged form of an apparently primary verb;","strongs_def":"to extinguish (literally or figuratively)","kjv_def":"go out, quench","pos":"verb","usage":"quench(7x)"},"G4510":{"id":"G4510","lemma":"ῥυπόω","translit":"rhypóō","derivation":"from G4509 (ῥύπος);","strongs_def":"to soil, i.e. (intransitively) to become dirty (morally)","kjv_def":"be filthy","pos":"verb","usage":"filthy(2x)"},"G4567":{"id":"G4567","lemma":"Σατανᾶς","translit":"Satanâs","derivation":"of Chaldee origin corresponding to H04566 (with the definite affix);","strongs_def":"the accuser, i.e. the devil","kjv_def":"Satan","pos":"proper masculine noun","usage":"Satan(36x)"},"G4594":{"id":"G4594","lemma":"σήμερον","translit":"sḗmeron","derivation":"neuter (as adverb) of a presumed compound of the article G3588 (ὁ) (t changed to s) and G2250 (ἡμέρα);","strongs_def":"on the (i.e. this) day (or night current or just passed); generally, now (i.e. at present, hitherto)","kjv_def":"this (to-)day","pos":"adverb"},"G4509":{"id":"G4509","lemma":"ῥύπος","translit":"rhýpos","derivation":"of uncertain affinity;","strongs_def":"dirt, i.e. (morally) depravity","kjv_def":"filth"},"G4551":{"id":"G4551","lemma":"Σαπφείρη","translit":"Sappheírē","derivation":"feminine of G4552 (σάπφειρος);","strongs_def":"Sapphire, an Israelitess","kjv_def":"Sapphira","pos":"proper feminine noun","usage":"Sapphira(1x)"},"G4535":{"id":"G4535","lemma":"σάλος","translit":"sálos","derivation":"probably from the base of G4525 (σαίνω);","strongs_def":"a vibration, i.e. (specially), billow","kjv_def":"wave","pos":"masculine noun","usage":"wave(1x)"},"G4506":{"id":"G4506","lemma":"ῥύομαι","translit":"rhýomai","derivation":"middle voice of an obsolete verb, akin to G4482 (ῥέω) (through the idea of a current;","strongs_def":"compare G4511 (ῥύσις)); to rush or draw (for oneself), i.e. rescue","kjv_def":"deliver(-er)","pos":"verb","usage":"deliver(17x), Deliverer(1x)"},"G4554":{"id":"G4554","lemma":"Σάρδεις","translit":"Sárdeis","derivation":"plural of uncertain derivation;","strongs_def":"Sardis, a place in Asia Minor","kjv_def":"Sardis","pos":"proper locative noun","usage":"Sardis(3x)"},"G4507":{"id":"G4507","lemma":"ῥυπαρία","translit":"rhyparía","derivation":"from G4508 (ῥυπαρός);","strongs_def":"dirtiness (morally)","kjv_def":"turpitude","pos":"feminine noun","usage":"filthiness(1x)"},"G4541":{"id":"G4541","lemma":"Σαμαρείτης","translit":"Samareítēs","derivation":"from G4540 (Σαμάρεια);","strongs_def":"a Samarite, i.e. inhabitant of Samaria","kjv_def":"Samaritan","pos":"proper masculine noun","usage":"Samaritans(9x)"},"G4511":{"id":"G4511","lemma":"ῥύσις","translit":"rhýsis","derivation":"from G4506 (ῥύομαι) in the sense of its congener G4482 (ῥέω);","strongs_def":"a flux (of blood)","kjv_def":"issue","pos":"feminine noun","usage":"issue(3x)"},"G4513":{"id":"G4513","lemma":"Ῥωμαϊκός","translit":"Rhōmaïkós","derivation":"from G4514 (Ῥωμαῖος);","strongs_def":"Romaic, i.e. Latin","kjv_def":"Latin","pos":"adjective","usage":"Latin(1x)"},"G4525":{"id":"G4525","lemma":"σαίνω","translit":"saínō","derivation":"akin to G4579 (σείω);","strongs_def":"to wag (as a dog its tail fawningly), i.e. (generally) to shake (figuratively, disturb)","kjv_def":"move"},"G4556":{"id":"G4556","lemma":"σάρδιος","translit":"sárdios","derivation":"properly, an adjective from an uncertain base;","strongs_def":"sardian (3037 being implied), i.e. (as noun) the gem so called","kjv_def":"sardius","pos":"adjective","usage":"sardius(1x)"},"G4517":{"id":"G4517","lemma":"ῥώννυμι","translit":"rhṓnnymi","derivation":"prolongation from (to dart;","strongs_def":"probably akin to G4506 (ῥύομαι)); to strengthen, i.e. (impersonal passive) have health (as a parting exclamation, good-bye)","kjv_def":"farewell"},"G4559":{"id":"G4559","lemma":"σαρκικός","translit":"sarkikós","derivation":"from G4561 (σάρξ);","strongs_def":"pertaining to flesh, i.e. (by extension) bodily, temporal, or (by implication) animal, unregenerate","kjv_def":"carnal, fleshly","pos":"adjective","usage":"carnal(9x), fleshly(2x)"},"G4595":{"id":"G4595","lemma":"σήπω","translit":"sḗpō","derivation":"apparently a primary verb;","strongs_def":"to putrefy, i.e. (figuratively) perish","kjv_def":"be corrupted","pos":"verb"}}