":"removed(1x)"},"H5207":{"id":"H5207","lemma":"נִיחוֹחַ","translit":"nîychôwach","pron":"nee-kho'-akh","derivation":"or נִיחֹחַ; from H5117 (נוּחַ);","strongs_def":"properly, restful, i.e. pleasant; abstractly, delight","kjv_def":"sweet (odour).","pos":"masculine noun","usage":"sweet(42x)"},"H5208":{"id":"H5208","lemma":"נִיחוֹחַ","translit":"nîychôwach","pron":"nee-kho'-akh","derivation":"(Aramaic) or נִיחֹחַ; (shorter) (Aramaic), corresponding to H5207 (נִיחוֹחַ);","strongs_def":"pleasure","kjv_def":"sweet odour (savour).","pos":"masculine noun","usage":"fruit(2x)"},"H5209":{"id":"H5209","lemma":"נִין","translit":"nîyn","pron":"neen","derivation":"from H5125 (נוּן);","strongs_def":"progeny","kjv_def":"son.","pos":"masculine noun","usage":"son(3x)"},"H5210":{"id":"H5210","lemma":"נִינְוֵה","translit":"Nîynᵉvêh","pron":"nee-nev-ay'","derivation":"of foreign origin;","strongs_def":"Nineveh, the capital of Assyria","kjv_def":"Nineveh.","pos":"proper locative noun","usage":"Nineveh(17x)"},"H5211":{"id":"H5211","lemma":"נִיס","translit":"nîyç","pron":"neece","derivation":"from H5127 (נוּס);","strongs_def":"fugitive","kjv_def":"that fleeth.","pos":"participle","usage":"variant(1x)"},"H5212":{"id":"H5212","lemma":"נִיסָן","translit":"Nîyçân","pron":"nee-sawn'","derivation":"probably of foreign origin;","strongs_def":"Nisan, the first month of the Jewish sacred year","kjv_def":"Nisan.","pos":"proper noun","usage":"Nisan(2x)"},"H5213":{"id":"H5213","lemma":"נִיצוֹץ","translit":"nîytsôwts","pron":"nee-tsotes'","derivation":"from H5340 (נָצַץ);","strongs_def":"a spark","kjv_def":"spark.","pos":"masculine noun","usage":"spark(1x)"},"H5214":{"id":"H5214","lemma":"נִיר","translit":"nîyr","pron":"neer","derivation":"a root probably identical with that of H5216 (נִיר), through the idea of the gleam of a fresh furrow;","strongs_def":"to till the soil","kjv_def":"break up.","pos":"verb"},"H5215":{"id":"H5215","lemma":"נִיר","translit":"nîyr","pron":"neer","derivation":"or נִר; from H5214 (נִיר);","strongs_def":"properly, plowing, i.e. (concretely) freshly plowed land","kjv_def":"fallow ground, plowing, tillage.","pos":"masculine noun","usage":"tillage(1x), plowing(1x)"},"H5216":{"id":"H5216","lemma":"נִיר","translit":"nîyr","pron":"neer","derivation":"or נִר; also נֵיר; or נֵר; or (feminine) נֵרָה; from a primitive root (see H5214 (נִיר); H5135 (נוּר)) properly, meaning to glisten;","strongs_def":"a lamp (i.e. the burner) or light (literally or figuratively)","kjv_def":"candle, lamp, light.","pos":"masculine noun","usage":"lamp(35x), candle(9x), light(4x)"},"H5217":{"id":"H5217","lemma":"נָכָא","translit":"nâkâʼ","pron":"naw-kaw'","derivation":"a primitive root;","strongs_def":"to smite, i.e. drive away","kjv_def":"be viler.","pos":"verb","usage":"viler(1x)"},"H5218":{"id":"H5218","lemma":"נָכֵא","translit":"nâkêʼ","pron":"naw-kay'","derivation":"or נָכָא; from H5217 (נָכָא);","strongs_def":"smitten, i.e. (figuratively) afflicted","kjv_def":"broken, stricken, wounded.","pos":"adjective","usage":"broken(2x), stricken(1x), wounded(1x)"},"H5219":{"id":"H5219","lemma":"נְכֹאת","translit":"nᵉkôʼth","pron":"nek-ohth'","derivation":"from H5218 (נָכֵא);","strongs_def":"properly, a smiting, i.e. (concretely) an aromatic gum (perhaps styrax) (as powdered)","kjv_def":"spicery(-ces).","pos":"feminine noun","usage":"spicery(1x), spices(1x)"},"H5220":{"id":"H5220","lemma":"נֶכֶד","translit":"neked","pron":"neh'-ked","derivation":"from an unused root meaning to propagate;","strongs_def":"offspring","kjv_def":"nephew, son's son.","pos":"masculine noun","usage":"nephew(2x)"},"H5221":{"id":"H5221","lemma":"נָכָה","translit":"nâkâh","pron":"naw-kaw'","derivation":"a primitive root;","strongs_def":"to strike (lightly or severely, literally or figuratively)","kjv_def":"beat, cast forth, clap, give (wounds), [idiom] go forward, [idiom] indeed, kill, make (slaughter), murderer, punish, slaughter, slay(-er, -ing), smite(-r, -ing), strike, be stricken, (give) stripes, [idiom] surely, wound.","pos":"verb","usage":"smite(348x), slay(92x), kill(20x), beat(9x), slaughter(5x), stricken(3x), given(3x), wounded(3x), strike(2x), stripes(2x)"},"H5222":{"id":"H5222","lemma":"נֵכֶה","translit":"nêkeh","pron":"nay-keh'","derivation":"from H5221 (נָכָה);","strongs_def":"a smiter, i.e. (figuratively) traducer","kjv_def":"abject.","pos":"adjective","usage":"abjects(1x)"},"H5223":{"id":"H5223","lemma":"נָכֶה","translit":"nâkeh","pron":"naw-keh'","strongs_def":"smitten, i.e. (literally) maimed, or (figuratively) dejected","kjv_def":"contrite, lame.","pos":"adjective","usage":"lame(2x), contrite(1x)"},"H5224":{"id":"H5224","lemma":"נְכוֹ","translit":"Nᵉkôw","pron":"nek-o'","derivation":"probably of Egyptian origin;","strongs_def":"Neko, an Egyptian king","kjv_def":"Necho. Compare H6549 (פַּרְעֹה נְכֹה)."},"H5225":{"id":"H5225","lemma":"נָכוֹן","translit":"Nâkôwn","pron":"naw-kone'","derivation":"from H3559 (כּוּן); prepared;","strongs_def":"Nakon, probably an Israelite","kjv_def":"Nachon."},"H5226":{"id":"H5226","lemma":"נֵכַח","translit":"nêkach","pron":"nay'-kakh","derivation":"from an unused root meaning to be straightforward;","strongs_def":"properly, the fore part; used adverbially, opposite","kjv_def":"before, over against.","pos":"adjective, adverb, substantive","usage":"before(1x), against(1x)"},"H5227":{"id":"H5227","lemma":"נֹכַח","translit":"nôkach","pron":"no'-kakh","derivation":"from the same as H5226 (נֵכַח);","strongs_def":"properly, the front part; used adverbially (especially with preposition), opposite, in front of, forward, in behalf of","kjv_def":"(over) against, before, direct(-ly), for, right (on).","pos":"adjective, adverb, substantive","usage":"against(10x), before(9x), directly(1x), for(1x), on(1x), over(1x)"},"H5228":{"id":"H5228","lemma":"נָכֹחַ","translit":"nâkôach","pron":"naw-ko'-akh","derivation":"from the same as H5226 (נֵכַח);","strongs_def":"straightforward, i.e. (figuratively), equitable, correct, or (abstractly), integrity","kjv_def":"plain, right, uprightness.","pos":"adjective, substantive","usage":"right(2x), uprightness(1x), plain(1x)"},"H5229":{"id":"H5229","lemma":"נְכֹחָה","translit":"nᵉkôchâh","pron":"nek-o-khaw'","derivation":"feminine of H5228 (נָכֹחַ);","strongs_def":"properly, straightforwardness, i.e. (figuratively) integrity, or (concretely) a truth","kjv_def":"equity, right (thing), uprightness.","pos":"feminine adjective","usage":"uprightness(1x), equity(1x), right(1x)"},"H5230":{"id":"H5230","lemma":"נָכַל","translit":"nâkal","pron":"naw-kal'","derivation":"a primitive root;","strongs_def":"to defraud, i.e. act treacherously","kjv_def":"beguile, conspire, deceiver, deal subtilly.","pos":"verb","usage":"deceiver(1x), beguile(1x), conspired(1x)"},"H5231":{"id":"H5231","lemma":"נֵכֶל","translit":"nêkel","pron":"nay'-kel","derivation":"from H5230 (נָכַל);","strongs_def":"deceit","kjv_def":"wile.","pos":"masculine noun","usage":"wiles(1x)"},"H5232":{"id":"H5232","lemma":"נְכַס","translit":"nᵉkaç","pron":"nek-as'","derivation":"(Aramaic) corresponding to H5233 (נֶכֶס)","strongs_def":"{treasure}","kjv_def":"goods.","pos":"masculine noun","usage":"goods(2x)"},"H5233":{"id":"H5233","lemma":"נֶכֶס","translit":"nekeç","pron":"neh'-kes","derivation":"from an unused root meaning to accumulate;","strongs_def":"treasure","kjv_def":"riches, wealth.","pos":"masculine noun","usage":"wealth(4x), riches(1x)"},"H5234":{"id":"H5234","lemma":"נָכַר","translit":"nâkar","pron":"naw-kar'","derivation":"a primitive root;","strongs_def":"properly, to scrutinize, i.e. look intently at; hence (with recognition implied), to acknowledge, be acquainted with, care for, respect, revere, or (with suspicion implied), to disregard, ignore, be strange toward, reject, resign, dissimulate (as if ignorant or disowning)","kjv_def":"acknowledge, [idiom] could, deliver, discern, dissemble, estrange, feign self to be another, know, take knowledge (notice), perceive, regard, (have) respect, behave (make) self strange(-ly).","pos":"verb","usage":"know(16x), acknowledge(7x), discern(6x), respect(4x), knowledge(2x), known(2x)"},"H5235":{"id":"H5235","lemma":"נֶכֶר","translit":"neker","pron":"neh'-ker","derivation":"or נֹכֶר; from H5234 (נָכַר);","strongs_def":"something strange, i.e. unexpected calamity","kjv_def":"strange.","pos":"masculine noun","usage":"strange(1x), stranger(1x)"},"H5236":{"id":"H5236","lemma":"נֵכָר","translit":"nêkâr","pron":"nay-kawr'","derivation":"' from H5234 (נָכַר);","strongs_def":"foreign, or (concretely) a foreigner, or (abstractly) heathendom","kjv_def":"alien, strange ([phrase] -er).","pos":"masculine noun","usage":"strange(17x), stranger(7x), alien(1x)"},"H5237":{"id":"H5237","lemma":"נׇכְרִי","translit":"nokrîy","pron":"nok-ree'","derivation":"from H5235 (נֶכֶר) (second form);","strongs_def":"strange, in a variety of degrees and applications (foreign, non-relative, adulterous, different, wonderful)","kjv_def":"alien, foreigner, outlandish, strange(-r, woman).","pos":"adjective","usage":"stranger(18x), strange(17x), alien(4x), foreigner(2x), outlandish(1x)"},"H5238":{"id":"H5238","lemma":"נְכֹת","translit":"nᵉkôth","pron":"nek-oth'","derivation":"probably for H5219 (נְכֹאת);","strongs_def":"spicery, i.e. (generally) valuables","kjv_def":"precious things.","pos":"feminine noun"},"H5239":{"id":"H5239","lemma":"נָלָה","translit":"nâlâh","pron":"naw-law'","derivation":"apparently a primitive root;","strongs_def":"to complete","kjv_def":"make an end.","pos":"verb"},"H5240":{"id":"H5240","lemma":"נְמִבְזֶה","translit":"nᵉmibzeh","pron":"nem-ib-zeh'","derivation":"from H959 (בָּזָה),","strongs_def":"despised","kjv_def":"vile."},"H5241":{"id":"H5241","lemma":"נְמוּאֵל","translit":"Nᵉmûwʼêl","pron":"nem-oo-ale'","derivation":"apparently for H3223 (יְמוּאֵל);","strongs_def":"Nemuel, the name of two Israelites","kjv_def":"Nemuel.","pos":"proper masculine noun","usage":"Nemuel(3x)"},"H5242":{"id":"H5242","lemma":"נְמוּאֵלִי","translit":"Nᵉmûwʼêlîy","pron":"nem-oo-ay-lee'","derivation":"from H5241 (נְמוּאֵל);","strongs_def":"a Nemuelite, or descendant of Nemuel","kjv_def":"Nemuelite.","pos":"adjective","usage":"Nemuelites(1x)"},"H5243":{"id":"H5243","lemma":"נָמַל","translit":"nâmal","pron":"naw-mal'","derivation":"a primitive root;","strongs_def":"to become clipped or (specifically) circumcised","kjv_def":"(branch to) be cut down (off), circumcise.","pos":"verb","usage":"circumcised(1x)"},"H5244":{"id":"H5244","lemma":"נְמָלָה","translit":"nᵉmâlâh","pron":"nem-aw-law'","derivation":"feminine from H5243 (נָמַל);","strongs_def":"an ant (probably from its almost bisected form)","kjv_def":"ant.","pos":"feminine noun","usage":"ant(2x)"},"H5245":{"id":"H5245","lemma":"נְמַר","translit":"nᵉmar","pron":"nem-ar'","derivation":"(Aramaic) corresponding to H5246 (נָמֵר)","strongs_def":"{a leopard (from its stripes)}","kjv_def":"leopard.","pos":"masculine noun","usage":"leopard(1x)"},"H5246":{"id":"H5246","lemma":"נָמֵר","translit":"nâmêr","pron":"naw-mare'","derivation":"from an unused root meaning properly, to filtrate, i.e. be limpid (comp H5247 (נִמְרָה) and H5249 (נִמְרִים)); and thus to spot or stain as if by dripping;","strongs_def":"a leopard (from its stripes)","kjv_def":"leopard.","pos":"masculine noun","usage":"leopard(6x)"},"H5247":{"id":"H5247","lemma":"נִמְרָה","translit":"Nimrâh","pron":"nim-raw'","derivation":"from the same as H5246 (נָמֵר); clear water;","strongs_def":"Nimrah, a place East of the Jordan","kjv_def":"Nimrah. See also H1039 (בֵּית נִמְרָה), H5249 (נִמְרִים).","pos":"proper locative noun","usage":"Nimrah(1x)"},"H5248":{"id":"H5248","lemma":"נִמְרוֹד","translit":"Nimrôwd","pron":"nim-rode'","derivation":"or נִמְרֹד; probably of foreign origin;","strongs_def":"Nimrod, a son of Cush","kjv_def":"Nimrod.","pos":"proper masculine noun","usage":"Nimrod(4x)"},"H5249":{"id":"H5249","lemma":"נִמְרִים","translit":"Nimrîym","pron":"nim-reem'","derivation":"plural of a masculine corresponding to H5247 (נִמְרָה); clear waters;","strongs_def":"Nimrim, a place East of the Jordan","kjv_def":"Nimrim. Compare H1039 (בֵּית נִמְרָה).","pos":"proper masculine locative plural noun","usage":"Nimrim(2x)"},"H5250":{"id":"H5250","lemma":"נִמְשִׁי","translit":"Nimshîy","pron":"nim-shee'","derivation":"probably from H4871 (מָשָׁה); extricated;","strongs_def":"Nimshi, the (grand-) father of Jehu","kjv_def":"Nimshi."},"H5251":{"id":"H5251","lemma":"נֵס","translit":"nêç","pron":"nace","derivation":"from H5264 (נָסַס);","strongs_def":"a flag; also a sail; by implication, a flagstaff; generally a signal; figuratively, a token","kjv_def":"banner, pole, sail, (en-) sign, standard.","pos":"masculine noun","usage":"standard(7x), ensign(6x), pole(2x), banner(2x), sail(2x), sign(1x)"},"H5252":{"id":"H5252","lemma":"נְסִבָּה","translit":"nᵉçibbâh","pron":"nes-ib-baw'","derivation":"feminine participle passive of H5437 (סָבַב);","strongs_def":"properly, an environment, i.e. circumstance or turn of affairs","kjv_def":"cause."},"H5253":{"id":"H5253","lemma":"נָסַג","translit":"nâçag","pron":"naw-sag'","derivation":"a primitive root;","strongs_def":"to retreat","kjv_def":"departing away, remove, take (hold), turn away.","pos":"verb","usage":"remove(5x), take(1x)"},"H5254":{"id":"H5254","lemma":"נָסָה","translit":"nâçâh","pron":"naw-saw'","derivation":"a primitive root;","strongs_def":"to test; by implication, to attempt","kjv_def":"adventure, assay, prove, tempt, try.","pos":"verb","usage":"prove(20x), tempt(12x), assay(2x), adventure(1x), try(1x)"},"H5255":{"id":"H5255","lemma":"נָסַח","translit":"nâçach","pron":"naw-sakh'","derivation":"a primitive root;","strongs_def":"to tear away","kjv_def":"destroy, pluck, root.","pos":"verb","usage":"pluck(2x), rooted(1x), destroy(1x)"},"H5256":{"id":"H5256","lemma":"נְסַח","translit":"nᵉçach","pron":"nes-akh'","derivation":"(Aramaic) corresponding to H5255 (נָסַח)","strongs_def":"{to tear away}","kjv_def":"pull down.","pos":"verb"},"H5257":{"id":"H5257","lemma":"נְסִיךְ","translit":"nᵉçîyk","pron":"nes-eek'","derivation":"from H5258 (נָסַךְ);","strongs_def":"properly, something poured out, i.e. a libation; also a molten image; by implication, a prince (as anointed)","kjv_def":"drink offering, duke, prince(-ipal).","pos":"masculine noun","usage":"prince(3x), duke(1x), principal(1x)"},"H5258":{"id":"H5258","lemma":"נָסַךְ","translit":"nâçak","pron":"naw-sak'","derivation":"a primitive root;","strongs_def":"to pour out, especially a libation, or to cast (metal); by analogy, to anoint aking","kjv_def":"cover, melt, offer, (cause to) pour (out), set (up).","pos":"verb","usage":"pour(4x), cover(3x), offer(2x), melteth(1x), molten(1x), set(1x)"},"H5259":{"id":"H5259","lemma":"נָסַךְ","translit":"nâçak","pron":"naw-sak'","derivation":"a primitive root (probably identical with H5258 (נָסַךְ) through the idea of fusion);","strongs_def":"to interweave, i.e. (figuratively) to overspread","kjv_def":"that is spread.","pos":"verb","usage":"spread(1x)"},"H5260":{"id":"H5260","lemma":"נְסַךְ","translit":"nᵉçak","pron":"nes-ak'","derivation":"(Aramaic) corresponding to H5258 (נָסַךְ);","strongs_def":"to pour out a libation","kjv_def":"offer.","pos":"verb","usage":"offer(1x)"},"H5261":{"id":"H5261","lemma":"נְסַךְ","translit":"nᵉçak","pron":"nes-ak'","derivation":"(Aramaic) corresponding to H5262 (נֶסֶךְ);","strongs_def":"a libation","kjv_def":"drink offering.","pos":"masculine noun"},"H5262":{"id":"H5262","lemma":"נֶסֶךְ","translit":"neçek","pron":"neh'-sek","derivation":"or נֵסֶךְ; from H5258 (נָסַךְ);","strongs_def":"a libation; also a cast idol","kjv_def":"cover, drink offering, molten image.","pos":"masculine noun","usage":"offering(59x), image(4x)"},"H5263":{"id":"H5263","lemma":"נָסַס","translit":"nâçaç","pron":"naw-sas'","derivation":"a primitive root;","strongs_def":"to wane, i.e. be sick","kjv_def":"faint.","pos":"verb","usage":"standardbearer(1x)"},"H5264":{"id":"H5264","lemma":"נָסַס","translit":"nâçaç","pron":"naw-sas'","derivation":"a primitive root; to gleam from afar, i.e. to be conspicuous as a signal; or rather perhaps a denominative from H5251 (נֵס) (and identical with H5263 (נָסַס), through the idea of a flag as fluttering in the wind);","strongs_def":"to raise a beacon","kjv_def":"lift up as an ensign.","pos":"verb"},"H5265":{"id":"H5265","lemma":"נָסַע","translit":"nâçaʻ","pron":"naw-sah'","derivation":"a primitive root;","strongs_def":"properly, to pull up, especially the tent-pins, i.e. start on ajourney","kjv_def":"cause to blow, bring, get, (make to) go (away, forth, forward, onward, out), (take) journey, march, remove, set aside (forward), [idiom] still, be on his (go their) way.","pos":"verb","usage":"journey(41x), departed(30x), remove(28x), forward(18x), went(8x), brought(3x), get(1x)"},"H5266":{"id":"H5266","lemma":"נָסַק","translit":"nâçaq","pron":"naw-sak'","derivation":"a primitive root;","strongs_def":"to go up","kjv_def":"ascend.","pos":"verb"},"H5267":{"id":"H5267","lemma":"נְסַק","translit":"nᵉçaq","pron":"nes-ak'","derivation":"(Aramaic) corresponding to H5266 (נָסַק)","strongs_def":"{to go up}","kjv_def":"take up.","pos":"verb"},"H5268":{"id":"H5268","lemma":"נִסְרֹךְ","translit":"Niçrôk","pron":"nis-roke'","derivation":"of foreign origin;","strongs_def":"Nisrok, a Babylonian idol","kjv_def":"Nisroch.","pos":"proper masculine noun","usage":"Nisroch(2x)"},"H5269":{"id":"H5269","lemma":"נֵעָה","translit":"Nêʻâh","pron":"nay-aw'","derivation":"from H5128 (נוּעַ); motion;","strongs_def":"Neah, a place in Palestine","kjv_def":"Neah."},"H5270":{"id":"H5270","lemma":"נֹעָה","translit":"Nôʻâh","pron":"no-aw'","derivation":"from H5128 (נוּעַ); movement;","strongs_def":"Noah, an Israelitess","kjv_def":"Noah.","pos":"proper feminine noun","usage":"Noah(4x)"},"H5271":{"id":"H5271","lemma":"נָעוּר","translit":"nâʻûwr","pron":"naw-oor'","derivation":"or נָעֻר; and (feminine) נְעֻרָה; properly, passive participle from H5288 (נַעַר) as denominative;","strongs_def":"(only in plural collectively or emphatic form) youth, the state (juvenility) or the persons (young people)","kjv_def":"childhood, youth.","pos":"feminine noun","usage":"youth(46x), childhood(1x)"},"H5272":{"id":"H5272","lemma":"נְעִיאֵל","translit":"Nᵉʻîyʼêl","pron":"neh-ee-ale'","derivation":"from H5128 (נוּעַ) and H410 (אֵל); moved of God;","strongs_def":"Neiel, a place in Palestine","kjv_def":"Neiel.","pos":"proper locative noun","usage":"Neiel(1x)"},"H5273":{"id":"H5273","lemma":"נָעִים","translit":"nâʻîym","pron":"naw-eem'","derivation":"from H5276 (נָעֵם);","strongs_def":"delightful (objective or subjective, literal or figurative)","kjv_def":"pleasant(-ure), sweet.","pos":"adjective","usage":"pleasant(8x), pleasures(2x), sweet(2x)"},"H5274":{"id":"H5274","lemma":"נָעַל","translit":"nâʻal","pron":"naw-al'","derivation":"a primitive root; also denominative from H5275 (נַעַל)","strongs_def":"properly, to fasten up, i.e. with abar or cord; hence, to sandal, i.e. furnish with slippers","kjv_def":"bolt, inclose, lock, shoe, shut up.","pos":"verb","usage":"lock(2x), bolt(2x), shod(2x), inclosed(1x)"},"H5275":{"id":"H5275","lemma":"נַעַל","translit":"naʻal","pron":"nah'-al","derivation":"or (feminine) נַעֲלָה; from H5274 (נָעַל);","strongs_def":"properly, a sandal tongue; by extension a sandal or slipper (sometimes as a symbol of occupancy, a refusal to marry, or of something valueless)","kjv_def":"dryshod, (pair of) shoe((-latchet), -s).","pos":"feminine noun","usage":"shoe(20x), dryshod(1x)"},"H5276":{"id":"H5276","lemma":"נָעֵם","translit":"nâʻêm","pron":"naw-ame'","derivation":"a primitive root;","strongs_def":"to be agreeable (literally or figuratively)","kjv_def":"pass in beauty, be delight, be pleasant, be sweet.","pos":"verb","usage":"pleasant(5x), sweet(1x), beauty(1x), delight(1x)"},"H5277":{"id":"H5277","lemma":"נַעַם","translit":"Naʻam","pron":"nah'-am","derivation":"from H5276 (נָעֵם); pleasure;","strongs_def":"Naam, an Israelite","kjv_def":"Naam."},"H5278":{"id":"H5278","lemma":"נֹעַם","translit":"nôʻam","pron":"no'-am","derivation":"from H5276 (נָעֵם);","strongs_def":"agreeableness, i.e. delight, suitableness, splendor or grace","kjv_def":"beauty, pleasant(-ness).","pos":"masculine noun","usage":"beauty(4x), pleasant(2x), pleasantness(1x)"},"H5279":{"id":"H5279","lemma":"נַעֲמָה","translit":"Naʻămâh","pron":"nah-am-aw'","derivation":"feminine of H5277 (נַעַם); pleasantness;","strongs_def":"Naamah, the name of an antediluvian woman, of an Ammonitess, and of a place in Palestine","kjv_def":"Naamah.","pos":"proper feminine noun, proper feminine locative noun","usage":"Naamah(5x)"},"H5280":{"id":"H5280","lemma":"נַעֲמִי","translit":"Naʻămîy","pron":"nah-am-ee'","derivation":"patronymic from H5283 (נַעֲמָן);","strongs_def":"a Naamanite, or descendant of Naaman (collectively)","kjv_def":"Naamites."},"H5281":{"id":"H5281","lemma":"נׇעֳמִי","translit":"Noʻŏmîy","pron":"no-om-ee'","derivation":"from H5278 (נֹעַם); pleasant;","strongs_def":"Noomi, an Israelitess","kjv_def":"Naomi.","pos":"proper feminine noun","usage":"Naomi(21x)"},"H5282":{"id":"H5282","lemma":"נַעֲמָן","translit":"naʻămân","pron":"nah-am-awn'","derivation":"from H5276 (נָעֵם);","strongs_def":"pleasantness (plural as concrete)","kjv_def":"pleasant.","pos":"masculine noun","usage":"pleasant(1x)"},"H5283":{"id":"H5283","lemma":"נַעֲמָן","translit":"Naʻămân","pron":"nah-am-awn'","derivation":"the same as H5282 (נַעֲמָן);","strongs_def":"Naaman, the name of an Israelite and of a Damascene","kjv_def":"Naaman.","pos":"proper masculine noun","usage":"Naaman(16x)"},"H5284":{"id":"H5284","lemma":"נַעֲמָתִי","translit":"Naʻămâthîy","pron":"nah-am-aw-thee'","derivation":"patrial from a place corresponding in name (but not identical) with H5279 (נַעֲמָה);","strongs_def":"a Naamathite, or inhabitant of Naamah","kjv_def":"Naamathite.","pos":"adjective","usage":"Naamathite(4x)"},"H5285":{"id":"H5285","lemma":"נַעֲצוּץ","translit":"naʻătsûwts","pron":"nah-ats-oots'","derivation":"from an unused root meaning to prick;","strongs_def":"probably a brier; by implication, a thicket of thorny bushes","kjv_def":"thorn.","pos":"masculine noun","usage":"thorn(2x)"},"H5286":{"id":"H5286","lemma":"נָעַר","translit":"nâʻar","pron":"naw-ar'","derivation":"a primitive root;","strongs_def":"to growl","kjv_def":"yell.","pos":"verb","usage":"yell(1x)"},"H5287":{"id":"H5287","lemma":"נָעַר","translit":"nâʻar","pron":"naw-ar'","derivation":"a primitive root (probably identical with H5286 (נָעַר), through the idea of the rustling of mane, which usually accompanies the lion's roar);","strongs_def":"to tumble about","kjv_def":"shake (off, out, self), overthrow, toss up and down.","pos":"verb","usage":"shake(4x), overthrow(2x)"},"H5288":{"id":"H5288","lemma":"נַעַר","translit":"naʻar","pron":"nah'-ar","derivation":"from H5287 (נָעַר);","strongs_def":"(concretely) a boy (as active), from the age of infancy to adolescence; by implication, a servant; also (by interch. of sex), a girl (of similar latitude in age)","kjv_def":"babe, boy, child, damsel (from the margin), lad, servant, young (man).","pos":"masculine noun","usage":"servant(54x), child(44x), lad(33x), young(15x), children(7x), youth(6x), babe(1x), boys(1x), young(1x)"},"H5289":{"id":"H5289","lemma":"נַעַר","translit":"naʻar","pron":"nah'-ar","derivation":"from H5287 (נָעַר) in its derivative sense of tossing about;","strongs_def":"a wanderer","kjv_def":"young one.","pos":"masculine noun"},"H5290":{"id":"H5290","lemma":"נֹעַר","translit":"nôʻar","pron":"no'-ar","derivation":"from H5287 (נָעַר); (compare H5288 (נַעַר))","strongs_def":"(abstractly) boyhood","kjv_def":"child, youth.","pos":"masculine noun","usage":"child(2x), youth(2x)"},"H5291":{"id":"H5291","lemma":"נַעֲרָה","translit":"naʻărâh","pron":"nah-ar-aw'","derivation":"feminine of H5288 (נַעַר);","strongs_def":"a girl (from infancy to adolescence)","kjv_def":"damsel, maid(-en), young (woman).","pos":"feminine noun","usage":"damsel(34x), maiden(16x), maid(7x), young(4x)"},"H5292":{"id":"H5292","lemma":"נַעֲרָה","translit":"Naʻărâh","pron":"nah-ar-aw'","derivation":"the same as H5291 (נַעֲרָה);","strongs_def":"Naarah, the name of an Israelitess, and of a place in Palestine","kjv_def":"Naarah, Naarath.","pos":"proper feminine noun, proper locative noun","usage":"Naarah(3x), Naarath(1x)"},"H5293":{"id":"H5293","lemma":"נַעֲרַי","translit":"Naʻăray","pron":"nah-ar-ah'-ee","derivation":"from H5288 (נַעַר); youthful;","strongs_def":"Naarai, an Israelite","kjv_def":"Naarai."},"H5294":{"id":"H5294","lemma":"נְעַרְיָה","translit":"Nᵉʻaryâh","pron":"neh-ar-yaw'","derivation":"from H5288 (נַעַר) and H3050 (יָהּ); servant of Jah;","strongs_def":"Nearjah, the name of two Israelites","kjv_def":"Neariah."},"H5295":{"id":"H5295","lemma":"נַעֲרָן","translit":"Naʻărân","pron":"nah-ar-awn'","derivation":"from H5288 (נַעַר); juvenile;","strongs_def":"Naaran, a place in Palestine","kjv_def":"Naaran."},"H5296":{"id":"H5296","lemma":"נְעֹרֶת","translit":"nᵉʻôreth","pron":"neh-o'-reth","derivation":"from H5287 (נָעַר);","strongs_def":"something shaken out, i.e. tow (as the refuse of flax)","kjv_def":"tow.","pos":"feminine noun","usage":"tow(2x)"},"H5297":{"id":"H5297","lemma":"נֹף","translit":"Nôph","pron":"nofe","derivation":"a variation of H4644 (מֹף);","strongs_def":"Noph, the capital of Upper Egypt","kjv_def":"Noph.","pos":"proper locative noun","usage":"Noph(7x)"},"H5298":{"id":"H5298","lemma":"נֶפֶג","translit":"Nepheg","pron":"neh'-feg","derivation":"from an unused root probably meaning to spring forth; a sprout;","strongs_def":"Nepheg, the name of two Israelites","kjv_def":"Nepheg.","pos":"proper masculine noun","usage":"Nepheg(4x)"},"H5299":{"id":"H5299","lemma":"נָפָה","translit":"nâphâh","pron":"naw-faw'","derivation":"from H5130 (נוּף) in the sense of lifting;","strongs_def":"a height; also a sieve","kjv_def":"border, coast, region, sieve.","pos":"feminine noun","usage":"border(1x), coast(1x), region(1x), sieve(1x)"}