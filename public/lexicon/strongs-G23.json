{"G2345":{"id":"G2345","lemma":"θιγγάνω","translit":"thingánō","derivation":"a prolonged form of an obsolete primary (to finger);","strongs_def":"to manipulate, i.e. have to do with; by implication, to injure","kjv_def":"handle, touch","pos":"verb","usage":"touch(2x), handle(1x)"},"G2335":{"id":"G2335","lemma":"θεωρία","translit":"theōría","derivation":"from the same as G2334 (θεωρέω);","strongs_def":"spectatorship, i.e. (concretely) a spectacle","kjv_def":"sight","pos":"feminine noun","usage":"sight(1x)"},"G2316":{"id":"G2316","lemma":"θεός","translit":"theós","derivation":"of uncertain affinity; a deity, especially (with G3588 (ὁ)) the supreme Divinity;","strongs_def":"figuratively, a magistrate; by Hebraism, very","kjv_def":"X exceeding, God, god(-ly, -ward)","pos":"masculine noun","usage":"god(13x), godly(3x)"},"G2390":{"id":"G2390","lemma":"ἰάομαι","translit":"iáomai","derivation":"middle voice of apparently a primary verb;","strongs_def":"to cure (literally or figuratively)","kjv_def":"heal, make whole","pos":"verb","usage":"heal(26x)"},"G2311":{"id":"G2311","lemma":"θεμελιόω","translit":"themelióō","derivation":"from G2310 (θεμέλιος);","strongs_def":"to lay a basis for, i.e. (literally) erect, or (figuratively) consolidate","kjv_def":"(lay the) found(- ation), ground, settle","pos":"verb","usage":"found(2x), ground(2x), settle(1x)"},"G2314":{"id":"G2314","lemma":"θεομάχος","translit":"theomáchos","derivation":"from G2316 (θεός) and G3164 (μάχομαι);","strongs_def":"an opponent of deity","kjv_def":"to fight against God"},"G2329":{"id":"G2329","lemma":"θέρμη","translit":"thérmē","derivation":"from the base of G2330 (θέρος);","strongs_def":"warmth","kjv_def":"heat","pos":"feminine noun","usage":"heat(1x)"},"G2364":{"id":"G2364","lemma":"θυγάτηρ","translit":"thygátēr","derivation":"apparently a primary word (compare \"daughter\");","strongs_def":"a female child, or (by Hebraism) descendant (or inhabitant)","kjv_def":"daughter","pos":"feminine noun","usage":"daughter(29x)"},"G2383":{"id":"G2383","lemma":"Ἰάειρος","translit":"Iáeiros","derivation":"of Hebrew origin (H02971);","strongs_def":"Jairus (i.e. Jair), an Israelite","kjv_def":"Jairus","pos":"proper masculine noun","usage":"Jairus(2x)"},"G2394":{"id":"G2394","lemma":"Ἰάσων","translit":"Iásōn","derivation":"future active participle masculine of G2390 (ἰάομαι);","strongs_def":"about to cure; Jason, a Christian","kjv_def":"Jason","pos":"proper masculine noun","usage":"Jason(5x)"},"G2356":{"id":"G2356","lemma":"θρησκεία","translit":"thrēskeía","derivation":"from a derivative of G2357 (θρησκός);","strongs_def":"ceremonial observance","kjv_def":"religion, worshipping","pos":"feminine noun","usage":"religion(3x), worshipping(1x)"},"G2358":{"id":"G2358","lemma":"θριαμβεύω","translit":"thriambeúō","derivation":"from a prolonged compound of the base of G2360 (θροέω);","strongs_def":"and a derivative of G680 (ἅπτομαι) (meaning a noisy iambus, sung in honor of Bacchus); to make an acclamatory procession, i.e. (figuratively) to conquer or (by Hebraism) to give victory","kjv_def":"(cause) to triumph (over)","pos":"verb"},"G2389":{"id":"G2389","lemma":"Ἰαννῆς","translit":"Iannēs","derivation":"of Egyptian origin;","strongs_def":"Jannes, an Egyptian","kjv_def":"Jannes"},"G2315":{"id":"G2315","lemma":"θεόπνευστος","translit":"theópneustos","derivation":"from G2316 (θεός) and a presumed derivative of G4154 (πνέω);","strongs_def":"divinely breathed in","kjv_def":"given by inspiration of God"},"G2357":{"id":"G2357","lemma":"θρησκός","translit":"thrēskós","derivation":"probably from the base of G2360 (θροέω);","strongs_def":"ceremonious in worship (as demonstrative), i.e. pious","kjv_def":"religious","pos":"adjective","usage":"religious(1x)"},"G2355":{"id":"G2355","lemma":"θρῆνος","translit":"thrēnos","derivation":"from the base of G2360 (θροέω);","strongs_def":"wailing","kjv_def":"lamentation","pos":"masculine noun","usage":"lamentation(1x)"},"G2374":{"id":"G2374","lemma":"θύρα","translit":"thýra","derivation":"apparently a primary word (compare \"door\");","strongs_def":"a portal or entrance (the opening or the closure, literally or figuratively)","kjv_def":"door, gate","pos":"feminine noun","usage":"door(38x), gate(1x)"},"G2365":{"id":"G2365","lemma":"θυγάτριον","translit":"thygátrion","derivation":"from G2364 (θυγάτηρ);","strongs_def":"a daughterling","kjv_def":"little (young) daughter","pos":"neuter noun"},"G2300":{"id":"G2300","lemma":"θεάομαι","translit":"theáomai","derivation":"a prolonged form of a primary verb;","strongs_def":"to look closely at, i.e. (by implication) perceive (literally or figuratively); by extension to visit","kjv_def":"behold, look (upon), see","pos":"verb","usage":"see(20x), behold(2x), look(1x)"},"G2312":{"id":"G2312","lemma":"θεοδίδακτος","translit":"theodídaktos","derivation":"from G2316 (θεός) and G1321 (διδάσκω);","strongs_def":"divinely instructed","kjv_def":"taught of God"},"G2366":{"id":"G2366","lemma":"θύελλα","translit":"thýella","derivation":"from G2380 (θύω) (in the sense of blowing) a storm","kjv_def":"tempest"},"G2393":{"id":"G2393","lemma":"ἴασπις","translit":"íaspis","derivation":"probably of foreign origin (see H03471);","strongs_def":"\"jasper\", a gem","kjv_def":"jasper","pos":"feminine noun","usage":"jasper(4x)"},"G2372":{"id":"G2372","lemma":"θυμός","translit":"thymós","derivation":"from G2380 (θύω);","strongs_def":"passion (as if breathing hard)","kjv_def":"fierceness, indignation, wrath","pos":"masculine noun","usage":"wrath(15x), fierceness(2x), indignation(1x)"},"G2310":{"id":"G2310","lemma":"θεμέλιος","translit":"themélios","derivation":"from a derivative of G5087 (τίθημι);","strongs_def":"something put down, i.e. a substruction (of a building, etc.), (literally or figuratively)","kjv_def":"foundation","pos":"noun","usage":"foundation(16x)"},"G2325":{"id":"G2325","lemma":"θερίζω","translit":"therízō","derivation":"from G2330 (θέρος) (in the sense of the crop);","strongs_def":"to harvest","kjv_def":"reap","pos":"verb","usage":"reap(21x)"},"G2385":{"id":"G2385","lemma":"Ἰάκωβος","translit":"Iákōbos","derivation":"the same as G2384 (Ἰακώβ) Græcized;","strongs_def":"Jacobus, the name of three Israelites","kjv_def":"James","pos":"proper masculine noun"},"G2391":{"id":"G2391","lemma":"Ἰάρεδ","translit":"Iáred","derivation":"of Hebrew origin (H03382);","strongs_def":"Jared (i.e. Jered), an antediluvian","kjv_def":"Jared","pos":"proper masculine noun","usage":"Jared(1x)"},"G2304":{"id":"G2304","lemma":"θεῖος","translit":"theîos","derivation":"from G2316 (θεός);","strongs_def":"godlike (neuter as noun, divinity)","kjv_def":"divine, godhead","pos":"adjective","usage":"divine(2x), Godhead(1x)"},"G2349":{"id":"G2349","lemma":"θνητός","translit":"thnētós","derivation":"from G2348 (θνήσκω);","strongs_def":"liable to die","kjv_def":"mortal(-ity)","pos":"adjective","usage":"mortal(5x)"},"G2386":{"id":"G2386","lemma":"ἴαμα","translit":"íama","derivation":"from G2390 (ἰάομαι);","strongs_def":"a cure (the effect)","kjv_def":"healing"},"G2323":{"id":"G2323","lemma":"θεραπεύω","translit":"therapeúō","derivation":"from the same as G2324 (θεράπων);","strongs_def":"to wait upon menially, i.e. (figuratively) to adore (God), or (specially) to relieve (of disease)","kjv_def":"cure, heal, worship","pos":"verb","usage":"heal(38x), cure(5x), worship(1x)"},"G2360":{"id":"G2360","lemma":"θροέω","translit":"throéō","derivation":"from to wail;","strongs_def":"to clamor, i.e. (by implication) to frighten","kjv_def":"trouble","pos":"verb","usage":"trouble(3x)"},"G2318":{"id":"G2318","lemma":"θεοσεβής","translit":"theosebḗs","derivation":"from G2316 (θεός) and G4576 (σέβομαι);","strongs_def":"reverent of God, i.e. pious","kjv_def":"worshipper of God","pos":"adjective"},"G2379":{"id":"G2379","lemma":"θυσιαστήριον","translit":"thysiastḗrion","derivation":"from a derivative of G2378 (θυσία);","strongs_def":"a place of sacrifice, i.e. an altar (special or genitive case, literal or figurative)","kjv_def":"altar","pos":"neuter noun","usage":"altar(23x)"},"G2353":{"id":"G2353","lemma":"θρέμμα","translit":"thrémma","derivation":"from G5142 (τρέφω);","strongs_def":"stock (as raised on a farm)","kjv_def":"cattle"},"G2346":{"id":"G2346","lemma":"θλίβω","translit":"thlíbō","derivation":"akin to the base of G5147 (τρίβος);","strongs_def":"to crowd (literally or figuratively)","kjv_def":"afflict, narrow, throng, suffer tribulation, trouble","pos":"verb","usage":"trouble(4x), afflict(3x), narrow(1x), throng(1x)"},"G2334":{"id":"G2334","lemma":"θεωρέω","translit":"theōréō","derivation":"from a derivative of G2300 (θεάομαι) (perhaps by addition of G3708 (ὁράω));","strongs_def":"to be a spectator of, i.e. discern, (literally, figuratively (experience) or intensively (acknowledge))","kjv_def":"behold, consider, look on, perceive, see","pos":"verb","usage":"see(40x), behold(11x), perceive(4x), consider(1x)"},"G2367":{"id":"G2367","lemma":"θύϊνος","translit":"thýïnos","derivation":"from a derivative of G2380 (θύω) (in the sense of blowing;","strongs_def":"denoting a certain fragrant tree); made of citron-wood","kjv_def":"thyine","pos":"adjective","usage":"thyine(1x)"},"G2303":{"id":"G2303","lemma":"θεῖον","translit":"theîon","derivation":"probably neuter of G2304 (θεῖος) (in its original sense of flashing);","strongs_def":"sulphur","kjv_def":"brimstone","pos":"neuter noun","usage":"brimstone(7x)"},"G2363":{"id":"G2363","lemma":"Θυάτειρα","translit":"Thyáteira","derivation":"of uncertain derivation;","strongs_def":"Thyatira, a place in Asia Minor","kjv_def":"Thyatira","pos":"proper locative noun","usage":"Thyatira(4x)"},"G2396":{"id":"G2396","lemma":"ἴδε","translit":"íde","derivation":"second person singular imperative active of G1492 (εἴδω);","strongs_def":"used as an interjection to denote surprise; lo!","kjv_def":"behold, lo, see","pos":"particle","usage":"behold(22x), lo(3x), look(1x), see(1x)"},"G2381":{"id":"G2381","lemma":"Θωμᾶς","translit":"Thōmâs","derivation":"of Chaldee origin (compare H08380);","strongs_def":"the twin; Thomas, a Christian","kjv_def":"Thomas","pos":"proper masculine noun","usage":"Thomas(12x)"},"G2327":{"id":"G2327","lemma":"θεριστής","translit":"theristḗs","derivation":"from G2325 (θερίζω);","strongs_def":"a harvester","kjv_def":"reaper","pos":"masculine noun","usage":"reaper(2x)"},"G2378":{"id":"G2378","lemma":"θυσία","translit":"thysía","derivation":"from G2380 (θύω);","strongs_def":"sacrifice (the act or the victim, literally or figuratively)","kjv_def":"sacrifice","pos":"feminine noun","usage":"sacrifice(29x)"},"G2301":{"id":"G2301","lemma":"θεατρίζω","translit":"theatrízō","derivation":"from G2302 (θέατρον);","strongs_def":"to expose as a spectacle","kjv_def":"make a gazing stock","pos":"verb"},"G2338":{"id":"G2338","lemma":"θῆλυς","translit":"thēlys","derivation":"from the same as G2337 (θηλάζω);","strongs_def":"female","kjv_def":"female, woman","pos":"adjective","usage":"woman(2x), female(3x)"},"G2337":{"id":"G2337","lemma":"θηλάζω","translit":"thēlázō","derivation":"from (the nipple);","strongs_def":"to suckle, (by implication) to suck","kjv_def":"(give) suck(-ling)","pos":"verb","usage":"suck(1x), suckling(1x)"},"G2343":{"id":"G2343","lemma":"θησαυρίζω","translit":"thēsaurízō","derivation":"from G2344 (θησαυρός);","strongs_def":"to amass or reserve (literally or figuratively)","kjv_def":"lay up (treasure), (keep) in store, (heap) treasure (together, up)","pos":"verb"},"G2399":{"id":"G2399","lemma":"ἰδιώτης","translit":"idiṓtēs","derivation":"from G2398 (ἴδιος);","strongs_def":"a private person, i.e. (by implication) an ignoramus (compare \"idiot\")","kjv_def":"ignorant, rude, unlearned","pos":"masculine noun","usage":"unlearned(3x), ignorant(1x), rude(1x)"},"G2387":{"id":"G2387","lemma":"Ἰαμβρῆς","translit":"Iambrēs","derivation":"of Egyptian origin;","strongs_def":"Jambres, an Egyptian","kjv_def":"Jambres"},"G2322":{"id":"G2322","lemma":"θεραπεία","translit":"therapeía","derivation":"from G2323 (θεραπεύω);","strongs_def":"attendance (specially, medical, i.e. cure); figuratively and collectively, domestics","kjv_def":"healing, household","pos":"feminine noun","usage":"household(2x), healing(2x)"},"G2309":{"id":"G2309","lemma":"θέλω","translit":"thélō","derivation":"apparently strengthened from the alternate form of G138 (αἱρέομαι);","strongs_def":"to determine (as an active option from subjective impulse; whereas G1014 (βούλομαι) properly denotes rather a passive acquiescence in objective considerations), i.e. choose or prefer (literally or figuratively); by implication, to wish, i.e. be inclined to (sometimes adverbially, gladly); impersonally for the future tense, to be about to; by Hebraism, to delight in","kjv_def":"desire, be disposed (forward), intend, list, love, mean, please, have rather, (be) will (have, -ling, - ling(-ly))","pos":"verb","usage":"will/would(159x), desire(13x), desirous(3x), list(3x)"},"G2377":{"id":"G2377","lemma":"θυρωρός","translit":"thyrōrós","derivation":"from G2374 (θύρα) and (a watcher);","strongs_def":"a gate- warden","kjv_def":"that kept the door, porter","pos":"masculine noun","usage":"porter(2x)"},"G2348":{"id":"G2348","lemma":"θνήσκω","translit":"thnḗskō","derivation":"a strengthened form of a simpler primary (which is used for it only in certain tenses);","strongs_def":"to die (literally or figuratively)","kjv_def":"be dead, die","pos":"verb","usage":"die(1x), dead(1x)"},"G2317":{"id":"G2317","lemma":"θεοσέβεια","translit":"theosébeia","derivation":"from G2318 (θεοσεβής);","strongs_def":"devoutness, i.e. piety","kjv_def":"godliness"},"G2307":{"id":"G2307","lemma":"θέλημα","translit":"thélēma","derivation":"from the prolonged form of G2309 (θέλω);","strongs_def":"a determination (properly, the thing), i.e. (actively) choice (specially, purpose, decree; abstractly, volition) or (passively) inclination","kjv_def":"desire, pleasure, will","pos":"neuter noun","usage":"will(62x), desire(1x), pleasure(1x)"},"G2302":{"id":"G2302","lemma":"θέατρον","translit":"théatron","derivation":"from G2300 (θεάομαι);","strongs_def":"a place for public show (\"theatre\"), i.e. general audience-room; by implication, a show itself (figuratively)","kjv_def":"spectacle, theatre"},"G2341":{"id":"G2341","lemma":"θηριομαχέω","translit":"thēriomachéō","derivation":"from a compound of G2342 (θηρίον) and G3164 (μάχομαι);","strongs_def":"to be a beast-fighter (in the gladiatorial show), i.e. (figuratively) to encounter (furious men)","kjv_def":"fight with wild beasts"},"G2351":{"id":"G2351","lemma":"θόρυβος","translit":"thórybos","derivation":"from the base of G2360 (θροέω);","strongs_def":"a disturbance","kjv_def":"tumult, uproar","pos":"masculine noun","usage":"tumult(4x), uproar(3x)"},"G2324":{"id":"G2324","lemma":"θεράπων","translit":"therápōn","derivation":"apparently a participle from an otherwise obsolete derivative of the base of G2330 (θέρος);","strongs_def":"a menial attendant (as if cherishing)","kjv_def":"servant","pos":"masculine noun","usage":"servant(1x)"},"G2321":{"id":"G2321","lemma":"Θεόφιλος","translit":"Theóphilos","derivation":"from G2316 (θεός) and G5384 (φίλος);","strongs_def":"friend of God; Theophilus, a Christian","kjv_def":"Theophilus","pos":"proper masculine noun","usage":"Theophilus(2x)"},"G2339":{"id":"G2339","lemma":"θήρα","translit":"thḗra","derivation":"from (a wild animal, as game);","strongs_def":"hunting, i.e. (figuratively) destruction","kjv_def":"trap","pos":"feminine noun","usage":"trap(1x)"},"G2371":{"id":"G2371","lemma":"θυμομαχέω","translit":"thymomachéō","derivation":"from a presumed compound of G2372 (θυμός) and G3164 (μάχομαι);","strongs_def":"to be in a furious fight, i.e. (figuratively) to be exasperated","kjv_def":"be highly displeased","pos":"verb"},"G2380":{"id":"G2380","lemma":"θύω","translit":"thýō","derivation":"a primary verb;","strongs_def":"properly, to rush (breathe hard, blow, smoke), i.e. (by implication) to sacrifice (properly, by fire, but genitive case); by extension to immolate (slaughter for any purpose)","kjv_def":"kill, (do) sacrifice, slay","pos":"verb","usage":"kill(8x), sacrifice(3x), slay(1x)"},"G2362":{"id":"G2362","lemma":"θρόνος","translit":"thrónos","derivation":"from (to sit);","strongs_def":"a stately seat (\"throne\"); by implication, power or (concretely) a potentate","kjv_def":"seat, throne","pos":"masculine noun","usage":"throne(54x), seat(7x)"},"G2382":{"id":"G2382","lemma":"θώραξ","translit":"thṓrax","derivation":"of uncertain affinity;","strongs_def":"the chest (\"thorax\"), i.e. (by implication) a corslet","kjv_def":"breast-plate","pos":"masculine noun","usage":"breastplate(5x)"},"G2308":{"id":"G2308","lemma":"θέλησις","translit":"thélēsis","derivation":"from G2309 (θέλω);","strongs_def":"determination (properly, the act), i.e. option","kjv_def":"will"},"G2395":{"id":"G2395","lemma":"ἰατρός","translit":"iatrós","derivation":"from G2390 (ἰάομαι);","strongs_def":"a physician","kjv_def":"physician","pos":"masculine noun","usage":"physician(7x)"},"G2328":{"id":"G2328","lemma":"θερμαίνω","translit":"thermaínō","derivation":"from G2329 (θέρμη);","strongs_def":"to heat (oneself)","kjv_def":"(be) warm(-ed, self)","pos":"verb"},"G2368":{"id":"G2368","lemma":"θυμίαμα","translit":"thymíama","derivation":"from G2370 (θυμιάω);","strongs_def":"an aroma, i.e. fragrant powder burnt in religious service; by implication, the burning itself","kjv_def":"incense, odour","pos":"neuter noun","usage":"incense(4x), odour(2x)"},"G2347":{"id":"G2347","lemma":"θλῖψις","translit":"thlîpsis","derivation":"from G2346 (θλίβω);","strongs_def":"pressure (literally or figuratively)","kjv_def":"afflicted(-tion), anguish, burdened, persecution, tribulation, trouble","pos":"feminine noun","usage":"tribulation(21x), affliction(17x), trouble(3x), anguish(1x), persecution(1x), burdened(1x)"},"G2340":{"id":"G2340","lemma":"θηρεύω","translit":"thēreúō","derivation":"from G2339 (θήρα);","strongs_def":"to hunt (an animal), i.e. (figuratively) to carp at","kjv_def":"catch","pos":"verb","usage":"catch(1x)"},"G2361":{"id":"G2361","lemma":"θρόμβος","translit":"thrómbos","derivation":"perhaps from G5142 (τρέφω) (in the sense of thickening);","strongs_def":"a clot","kjv_def":"great drop","pos":"masculine noun"},"G2352":{"id":"G2352","lemma":"θραύω","translit":"thraúō","derivation":"a primary verb;","strongs_def":"to crush","kjv_def":"bruise"},"G2375":{"id":"G2375","lemma":"θυρεός","translit":"thyreós","derivation":"from G2374 (θύρα);","strongs_def":"a large shield (as door-shaped)","kjv_def":"shield","pos":"masculine noun","usage":"shield(1x)"},"G2350":{"id":"G2350","lemma":"θορυβέω","translit":"thorybéō","derivation":"from G2351 (θόρυβος);","strongs_def":"to be in tumult, i.e. disturb, clamor","kjv_def":"make ado (a noise), trouble self, set on an uproar","pos":"verb"},"G2384":{"id":"G2384","lemma":"Ἰακώβ","translit":"Iakṓb","derivation":"of Hebrew origin (H03290);","strongs_def":"Jacob (i.e. Ja`akob), the progenitor of the Israelites","kjv_def":"also an Israelite:--Jacob","pos":"proper masculine noun","usage":"Jacob(27x)"},"G2332":{"id":"G2332","lemma":"Θεσσαλονίκη","translit":"Thessaloníkē","derivation":"from (a Thessalian) and G3529 (νίκη);","strongs_def":"Thessalonice, a place in Asia Minor","kjv_def":"Thessalonica","pos":"proper locative noun","usage":"Thessalonica(5x)"},"G2305":{"id":"G2305","lemma":"θειότης","translit":"theiótēs","derivation":"from G2304 (θεῖος);","strongs_def":"divinity (abstractly)","kjv_def":"godhead","pos":"feminine noun","usage":"Godhead(1x)"},"G2344":{"id":"G2344","lemma":"θησαυρός","translit":"thēsaurós","derivation":"from G5087 (τίθημι);","strongs_def":"a deposit, i.e. wealth (literally or figuratively)","kjv_def":"treasure","pos":"masculine noun","usage":"treasure(18x)"},"G2336":{"id":"G2336","lemma":"θήκη","translit":"thḗkē","derivation":"from G5087 (τίθημι);","strongs_def":"a receptacle, i.e. scabbard","kjv_def":"sheath","pos":"feminine noun","usage":"sheath(1x)"},"G23