{"G2660":{"id":"G2660","lemma":"κατανύσσω","translit":"katanýssō","derivation":"from G2596 (κατά) and G3572 (νύσσω);","strongs_def":"to pierce thoroughly, i.e. (figuratively) to agitate violently (\"sting to the quick\")","kjv_def":"prick","pos":"verb","usage":"prick(1x)"},"G2665":{"id":"G2665","lemma":"καταπέτασμα","translit":"katapétasma","derivation":"from a compound of G2596 (κατά) and a congener of G4072 (πέτομαι);","strongs_def":"something spread thoroughly, i.e. (specially) the door screen (to the Most Holy Place) in the Jewish Temple","kjv_def":"vail","pos":"neuter noun","usage":"veil(6x)"},"G2680":{"id":"G2680","lemma":"κατασκευάζω","translit":"kataskeuázō","derivation":"from G2596 (κατά) and a derivative of G4632 (σκεῦος);","strongs_def":"to prepare thoroughly (properly, by external equipment; whereas G2090 (ἑτοιμάζω) refers rather to internal fitness); by implication, to construct, create","kjv_def":"build, make, ordain, prepare","pos":"verb","usage":"prepare(6x), build(3x), make(1x), ordain(1x)"},"G2618":{"id":"G2618","lemma":"κατακαίω","translit":"katakaíō","derivation":"from G2596 (κατά) and G2545 (καίω);","strongs_def":"to burn down (to the ground), i.e. consume wholly","kjv_def":"burn (up, utterly)","pos":"verb","usage":"burn(7x)"},"G2646":{"id":"G2646","lemma":"κατάλυμα","translit":"katályma","derivation":"from G2647 (καταλύω);","strongs_def":"properly, a dissolution (breaking up of a journey), i.e. (by implication) a lodging-place","kjv_def":"guestchamber, inn","pos":"neuter noun","usage":"inn(1x)"},"G2681":{"id":"G2681","lemma":"κατασκηνόω","translit":"kataskēnóō","derivation":"from G2596 (κατά) and G4637 (σκηνόω);","strongs_def":"to camp down, i.e. haunt; figuratively, to remain","kjv_def":"lodge, rest","pos":"verb","usage":"lodge(3x), rest(1x)"},"G2697":{"id":"G2697","lemma":"κατάσχεσις","translit":"katáschesis","derivation":"from G2722 (κατέχω);","strongs_def":"a holding down, i.e. occupancy","kjv_def":"possession","pos":"feminine noun","usage":"possession(2x)"},"G2615":{"id":"G2615","lemma":"καταδουλόω","translit":"katadoulóō","derivation":"from G2596 (κατά) and G1402 (δουλόω);","strongs_def":"to enslave utterly","kjv_def":"bring into bondage","pos":"verb"},"G2693":{"id":"G2693","lemma":"καταστρώννυμι","translit":"katastrṓnnymi","derivation":"from G2596 (κατά) and G4766 (στρώννυμι);","strongs_def":"to strew down, i.e. (by implication) to prostrate (slay)","kjv_def":"overthrow"},"G2656":{"id":"G2656","lemma":"κατανεύω","translit":"kataneúō","derivation":"from G2596 (κατά) and G3506 (νεύω);","strongs_def":"to nod down (towards), i.e. (by analogy) to make signs to","kjv_def":"beckon","pos":"verb","usage":"beckon(1x)"},"G2627":{"id":"G2627","lemma":"κατακλυσμός","translit":"kataklysmós","derivation":"from G2626 (κατακλύζω);","strongs_def":"an inundation","kjv_def":"flood","pos":"masculine noun","usage":"flood(4x)"},"G2676":{"id":"G2676","lemma":"κατάρτισις","translit":"katártisis","derivation":"from G2675 (καταρτίζω);","strongs_def":"thorough equipment (subjectively)","kjv_def":"perfection"},"G2601":{"id":"G2601","lemma":"καταβιβάζω","translit":"katabibázō","derivation":"from G2596 (κατά) and a derivative of the base of G939 (βάσις);","strongs_def":"to cause to go down, i.e. precipitate","kjv_def":"bring (thrust) down","pos":"verb"},"G2638":{"id":"G2638","lemma":"καταλαμβάνω","translit":"katalambánō","derivation":"from G2596 (κατά) and G2983 (λαμβάνω);","strongs_def":"to take eagerly, i.e. seize, possess, etc. (literally or figuratively)","kjv_def":"apprehend, attain, come upon, comprehend, find, obtain, perceive, (over-)take","pos":"verb","usage":"take(3x), apprehend(3x), comprehend(2x), perceive(2x), attain(1x), find(1x), overtake(1x), obtain(1x)"},"G2679":{"id":"G2679","lemma":"κατασκάπτω","translit":"kataskáptō","derivation":"from G2596 (κατά) and G4626 (σκάπτω);","strongs_def":"to undermine, i.e. (by implication) destroy","kjv_def":"dig down, ruin","pos":"verb","usage":"ruin(1x)"},"G2639":{"id":"G2639",