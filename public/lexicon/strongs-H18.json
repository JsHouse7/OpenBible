{"H1800":{"id":"H1800","lemma":"דַּל","translit":"dal","pron":"dal","derivation":"from H1809 (דָּלַל);","strongs_def":"properly, dangling, i.e. (by implication) weak or thin","kjv_def":"lean, needy, poor (man), weaker.","pos":"adjective","usage":"poor(43x), needy(2x), weaker(2x), lean(1x)"},"H1801":{"id":"H1801","lemma":"דָּלַג","translit":"dâlag","pron":"daw-lag'","derivation":"a primitive root;","strongs_def":"to spring","kjv_def":"leap.","pos":"verb","usage":"leap(5x)"},"H1802":{"id":"H1802","lemma":"דָּלָה","translit":"dâlâh","pron":"daw-law'","derivation":"a primitive root (compare H1809 (דָּלַל));","strongs_def":"properly, to dangle, i.e. to let down abucket (for drawing out water); figuratively, to deliver","kjv_def":"draw (out), [idiom] enough, lift up.","pos":"verb","usage":"draw(3x), enough(1x)"},"H1803":{"id":"H1803","lemma":"דַּלָּה","translit":"dallâh","pron":"dal-law'","derivation":"from H1802 (דָּלָה);","strongs_def":"properly, something dangling, i.e. a loose thread or hair; figuratively, indigent","kjv_def":"hair, pining sickness, poor(-est sort).","pos":"collective feminine noun","usage":"poor(5x), hair(1x)"},"H1804":{"id":"H1804","lemma":"דָּלַח","translit":"dâlach","pron":"daw-lakh'","derivation":"a primitive root;","strongs_def":"to roil water","kjv_def":"trouble.","pos":"verb","usage":"trouble(3x)"},"H1805":{"id":"H1805","lemma":"דְּלִי","translit":"dᵉlîy","pron":"del-ee'","derivation":"or דֳּלִי; from H1802 (דָּלָה);","strongs_def":"a pail or jar (for drawing water)","kjv_def":"bucket.","pos":"masculine noun","usage":"bucket(2x)"},"H1806":{"id":"H1806","lemma":"דְּלָיָה","translit":"Dᵉlâyâh","pron":"del-aw-yaw'","derivation":"or (prolonged) דְּלָיָהוּxlit Dᵉlâyâhhûw corrected to Dᵉlâyâhûw; from H1802 (דָּלָה) and H3050 (יָהּ); Jah has delivered;","strongs_def":"Delajah, the name of five Israelites","kjv_def":"Dalaiah, Delaiah.","pos":"proper masculine noun","usage":"Delaiah(6x), Dalaiah(1x)"},"H1807":{"id":"H1807","lemma":"דְּלִילָה","translit":"Dᵉlîylâh","pron":"del-ee-law'","derivation":"from H1809 (דָּלַל); languishing","strongs_def":"Delilah, a Philistine woman","kjv_def":"Delilah.","pos":"proper feminine noun","usage":"Delilah(6x)"},"H1808":{"id":"H1808","lemma":"דָּלִיָּה","translit":"dâlîyâh","pron":"daw-lee-yaw'","derivation":"from H1802 (דָּלָה);","strongs_def":"something dangling, i.e. a bough","kjv_def":"branch.","pos":"feminine noun","usage":"branch(8x)"},"H1809":{"id":"H1809","lemma":"דָּלַל","translit":"dâlal","pron":"daw-lal'","derivation":"a primitive root (compare H1802 (דָּלָה));","strongs_def":"to slacken or be feeble; figuratively, to be oppressed","kjv_def":"bring low, dry up, be emptied, be not equal, fail, be impoverished, be made thin.","pos":"verb","usage":"emptied(1x), fail(1x), impoverished(1x)"},"H1810":{"id":"H1810","lemma":"דִּלְעָן","translit":"Dilʻân","pron":"dil-awn'","derivation":"of uncertain derivation;","strongs_def":"Dilan, a place in Palestine","kjv_def":"Dilean.","pos":"proper locative noun","usage":"Dilean(1x)"},"H1811":{"id":"H1811","lemma":"דָּלַף","translit":"dâlaph","pron":"daw-laf'","derivation":"a primitive root;","strongs_def":"to drip; by implication, to weep","kjv_def":"drop through, melt, pour out.","pos":"verb","usage":"melt(1x)"},"H1812":{"id":"H1812","lemma":"דֶּלֶף","translit":"deleph","pron":"deh'-lef","derivation":"from H1811 (דָּלַף);","strongs_def":"a dripping","kjv_def":"dropping.","pos":"masculine noun","usage":"dropping(2x)"},"H1813":{"id":"H1813","lemma":"דַּלְפוֹן","translit":"Dalphôwn","pron":"dal-fone'","derivation":"from H1811 (דָּלַף); dripping;","strongs_def":"Dalphon, a son of Haman","kjv_def":"Dalphon.","pos":"proper masculine noun","usage":"Dalphon(1x)"},"H1814":{"id":"H1814","lemma":"דָּלַק","translit":"dâlaq","pron":"daw-lak'","derivation":"a primitive root;","strongs_def":"to flame (literally or figuratively)","kjv_def":"burning, chase, inflame, kindle, persecute(-or), pursue hotly.","pos":"verb","usage":"pursue(2x), kindle(2x), c