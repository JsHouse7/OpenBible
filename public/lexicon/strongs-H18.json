,"strongs_def":"Dothan, a place in Palestine","kjv_def":"Dothan. h","pos":"proper locative noun","usage":"Dothan(3x)"},"H1887":{"id":"H1887","lemma":"הֵא","translit":"hêʼ","pron":"hay","derivation":"a primitive particle;","strongs_def":"lo!","kjv_def":"behold, lo.","pos":"interjection","usage":"lo(1x), behold(1x)"},"H1888":{"id":"H1888","lemma":"הֵא","translit":"hêʼ","pron":"hay","derivation":"(Aramaic) or הָא; (Aramaic), corresponding to H1887 (הֵא)","strongs_def":"{lo!}","kjv_def":"even, lo.","pos":"demonstrative particle","usage":"even(1x), lo(1x)"},"H1889":{"id":"H1889","lemma":"הֶאָח","translit":"heʼâch","pron":"heh-awkh'","derivation":"from H1887 (הֵא) and H253 (אָח);","strongs_def":"aha!","kjv_def":"ah, aha, ha.","pos":"interjection","usage":"aha(13x)"},"H1890":{"id":"H1890","lemma":"הַבְהָב","translit":"habhâb","pron":"hab-hawb'","derivation":"by reduplication from H3051 (יָהַב);","strongs_def":"gift (in sacrifice), i.e. holocaust","kjv_def":"offering.","pos":"masculine noun","usage":"offering(1x)"},"H1891":{"id":"H1891","lemma":"הָבַל","translit":"hâbal","pron":"haw-bal'","derivation":"a primitive root;","strongs_def":"to be vain in act, word, or expectation; specifically to lead astray","kjv_def":"be (become, make) vain.","pos":"verb"},"H1892":{"id":"H1892","lemma":"הֶבֶל","translit":"hebel","pron":"heh'bel","derivation":"or (rarely in the abs.) הֲבֵל; from H1891 (הָבַל);","strongs_def":"emptiness or vanity; figuratively, something transitory and unsatisfactory; often used as an adverb","kjv_def":"[idiom] altogether, vain, vanity.","pos":"adverb, masculine noun","usage":"vanity(61x), vain(11x), altogether(1x)"},"H1893":{"id":"H1893","lemma":"הֶבֶל","translit":"Hebel","pron":"heh'-bel","derivation":"the same as H1892 (הֶבֶל);","strongs_def":"Hebel, the son of Adam","kjv_def":"Abel.","pos":"proper masculine noun","usage":"Abel(8x)"},"H1894":{"id":"H1894","lemma":"הֹבֶן","translit":"hôben","pron":"ho'-ben","derivation":"only in plural, from an unused root meaning to be hard;","strongs_def":"ebony","kjv_def":"ebony."},"H1895":{"id":"H1895","lemma":"הָבַר","translit":"hâbar","pron":"haw-bar'","derivation":"a primitive root of uncertain (perhaps foreign) derivation;","strongs_def":"to be a horoscopist","kjv_def":"[phrase] (astro-) loger.","pos":"verb","usage":"astrologer(1x)"},"H1896":{"id":"H1896","lemma":"הֵגֵא","translit":"Hêgêʼ","pron":"hay-gay'","derivation":"or (by permutation) הֵגַי; probably of Persian origin;","strongs_def":"Hege or Hegai, a eunuch of Xerxes","kjv_def":"Hegai, Hege.","pos":"proper masculine noun","usage":"Hegai(3x), Hege(1x)"},"H1897":{"id":"H1897","lemma":"הָגָה","translit":"hâgâh","pron":"daw-gaw'","derivation":"a primitive root (compare H1901 (הָגִיג));","strongs_def":"to murmur (in pleasure or anger); by implication, to ponder","kjv_def":"imagine, meditate, mourn, mutter, roar, [idiom] sore, speak, study, talk, utter.","pos":"verb","usage":"meditate(6x), mourn(4x), speak(4x), imagine(2x), study(2x), mutter(2x), utter(2x), roaring(1x), sore(1x), talk(1x)"},"H1898":{"id":"H1898","lemma":"הָגָה","translit":"hâgâh","pron":"haw-gaw'","derivation":"a primitive root;","strongs_def":"to remove","kjv_def":"stay, stay away.","pos":"verb","usage":"stayed(1x)"},"H1899":{"id":"H1899","lemma":"הֶגֶה","translit":"hegeh","pron":"heh'-geh","derivation":"from H1897 (הָגָה);","strongs_def":"a muttering (in sighing, thought, or as thunder)","kjv_def":"mourning, sound, tale.","pos":"masculine noun","usage":"sound(1x), tale(1x), mourning(1x)"}}