":"cease(2x), perish(2x), liken(2x), destroy(2x), undone(1x), utterly(1x)"},"H1821":{"id":"H1821","lemma":"דְּמָה","translit":"dᵉmâh","pron":"dem-aw'","derivation":"(Aramaic) corresponding to H1819 (דָּמָה);","strongs_def":"to resemble","kjv_def":"be like.","pos":"verb","usage":"like(2x)"},"H1822":{"id":"H1822","lemma":"דֻּמָּה","translit":"dummâh","pron":"doom-maw'","derivation":"from H1820 (דָּמָה);","strongs_def":"desolation; concretely, desolate","kjv_def":"destroy.","pos":"feminine noun"},"H1823":{"id":"H1823","lemma":"דְּמוּת","translit":"dᵉmûwth","pron":"dem-ooth'","derivation":"from H1819 (דָּמָה);","strongs_def":"resemblance; concretely, model, shape; adverbially, like","kjv_def":"fashion, like (-ness, as), manner, similitude.","pos":"adverb, feminine noun","usage":"likeness(19x), similitude(2x), like(2x), manner(1x), fashion(1x)"},"H1824":{"id":"H1824","lemma":"דְּמִי","translit":"dᵉmîy","pron":"dem-ee'","derivation":"or דֳּמִי; from H1820 (דָּמָה);","strongs_def":"quiet","kjv_def":"cutting off, rest, silence.","pos":"masculine noun","usage":"silence(2x), rest(1x)"},"H1825":{"id":"H1825","lemma":"דִּמְיוֹן","translit":"dimyôwn","pron":"dim-yone'","derivation":"from H1819 (דָּמָה);","strongs_def":"resemblance","kjv_def":"[idiom] like.","pos":"masculine noun","usage":"like(1x)"},"H1826":{"id":"H1826","lemma":"דָּמַם","translit":"dâmam","pron":"daw-man'","derivation":"a primitive root (compare H1724 (דָּהַם), H1820 (דָּמָה));","strongs_def":"to be dumb; by implication, to be astonished, to stop; also to perish","kjv_def":"cease, be cut down (off), forbear, hold peace, quiet self, rest, be silent, keep (put to) silence, be (stand) still, tarry, wait.","pos":"verb","usage":"silence(6x), still(6x), silent(4x), rest(2x), cease(2x), forbear(1x), peace(1x), quieted(1x), tarry(1x), wait(1x)"},"H1827":{"id":"H1827","lemma":"דְּמָמָה","translit":"dᵉmâmâh","pron":"dem-aw-maw'","derivation":"feminine from H1826 (דָּמַם);","strongs_def":"quiet","kjv_def":"calm, silence, 