},"H1677":{"id":"H1677","lemma":"דֹּב","translit":"dôb","pron":"dobe","derivation":"or (fully) דּוֹב; from H1680 (דָּבַב);","strongs_def":"the bear (as slow)","kjv_def":"bear.","pos":"masculine/feminine noun","usage":"bear(12x)"},"H1678":{"id":"H1678","lemma":"דֹּב","translit":"dôb","pron":"dobe","derivation":"(Aramaic) corresponding to H1677 (דֹּב)","strongs_def":"{the bear (as slow)}","kjv_def":"bear.","pos":"masculine noun","usage":"bear(1x)"},"H1679":{"id":"H1679","lemma":"דֹּבֶא","translit":"dôbeʼ","pron":"do'-beh","derivation":"from an unused root (compare H1680 (דָּבַב)) (probably meaning to be sluggish, i.e. restful);","strongs_def":"quiet","kjv_def":"strength."},"H1680":{"id":"H1680","lemma":"דָּבַב","translit":"dâbab","pron":"daw-bab'","derivation":"a primitive root (compare H1679 (דֹּבֶא));","strongs_def":"to move slowly, i.e. glide","kjv_def":"cause to speak."},"H1681":{"id":"H1681","lemma":"דִּבָּה","translit":"dibbâh","pron":"dib-baw'","derivation":"from H1680 (דָּבַב) (in the sense of furtive motion);","strongs_def":"slander","kjv_def":"defaming, evil report, infamy, slander.","pos":"feminine noun","usage":"slander(3x), infamy(2x), slander(1x)"},"H1682":{"id":"H1682","lemma":"דְּבוֹרָה","translit":"dᵉbôwrâh","pron":"deb-o-raw'","derivation":"or (shortened) דְּבֹרָה; from H1696 (דָבַר) (in the sense of orderly motion);","strongs_def":"the bee (from its systematic instincts)","kjv_def":"bee.","pos":"feminine noun","usage":"bee(4x)"},"H1683":{"id":"H1683","lemma":"דְּבּוֹרָה","translit":"Dᵉbôwrâh","pron":"deb-o-raw'","derivation":"or (shortened) דְּבֹרָה; the same as H1682 (דְּבוֹרָה);","strongs_def":"Deborah, the name of two Hebrewesses","kjv_def":"Deborah.","pos":"proper feminine noun","usage":"deborah(10x)"},"H1684":{"id":"H1684","lemma":"דְּבַח","translit":"dᵉbach","pron":"deb-akh'","derivation":"(Aramaic) corresponding to H2076 (זָבַח);","strongs_def":"to sacrifice (an animal)","kjv_def":"offer (sacrifice).","pos":"verb","usage":"offer(1x)"},"H1685":{"id":"H1685","lemma":"דְּבַח","translit":"dᵉbach","pron":"deb-akh'","derivation":"(Aramaic) from H1684 (דְּבַח);","strongs_def":"a sacrifice","kjv_def":"sacrifice.","pos":"masculine noun","usage":"sacrifice(1x)"},"H1686":{"id":"H1686","lemma":"דִּבְיוֹן","translit":"dibyôwn","pron":"dib-yone'","derivation":"in the margin for the textual reading, חֶרְיוֹן; both, (in the plural only and) of uncertain derivation,","strongs_def":"probably some cheap vegetable, perhaps a bulbous root","kjv_def":"dove's dung."},"H1687":{"id":"H1687","lemma":"דְּבִיר","translit":"dᵉbîyr","pron":"deb-eer'","derivation":"or (shortened) דְּבִר; from H1696 (דָבַר) (apparently in the sense of oracle);","strongs_def":"the shrine or innermost part of the sanctuary","kjv_def":"oracle."},"H1688":{"id":"H1688","lemma":"דְּבִיר","translit":"Dᵉbîyr","pron":"deb-eer'","derivation":"or (shortened) דְּבִר; (Joshua 13:26 (but see H3810 (לֹא דְבַר))), the same as H1687 (דְּבִיר);","strongs_def":"Debir, the name of an Amoritish king and of two places in Palestine","kjv_def":"Debir.","pos":"proper locative noun, proper masculine noun","usage":"Debir(14x)"},"H1689":{"id":"H1689","lemma":"דִּבְלָה","translit":"Diblâh","pron":"dib-law'","derivation":"probably an orthographical error for H7247 (רִבְלָה);","strongs_def":"Diblah, a place in Syria","kjv_def":"Diblath.","pos":"proper locative noun","usage":"Diblath(1x)"},"H1690":{"id":"H1690","lemma":"דְּבֵלָה","translit":"dᵉbêlâh","pron":"deb-ay-law'","derivation":"from an unused root (akin to H2082 (זָבַל)) probably meaning to press together;","strongs_def":"a cake of pressed figs","kjv_def":"cake (lump) of figs.","pos":"feminine noun","usage":"lump(2x)"},"H1691":{"id":"H1691","lemma":"דִּבְלַיִם","translit":"Diblayim","pron":"dib-lah'-yim","derivation":"dual from the masculine of H1690 (דְּבֵלָה); two cakes;","strongs_def":"Diblajim, a symbolic name","kjv_def":"Diblaim.","pos":"proper masculine noun","usage":"Diblaim(1x)"},"H1692":{"id":"H1692","lemma":"דָּבַק"