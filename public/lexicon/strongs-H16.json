{"H1600":{"id":"H1600","lemma":"גָּעָה","translit":"gâʻâh","pron":"gaw-aw'","derivation":"a primitive root;","strongs_def":"to bellow (as cattle)","kjv_def":"low.","pos":"verb","usage":"low(2x)"},"H1601":{"id":"H1601","lemma":"גֹּעָה","translit":"Gôʻâh","pron":"go-aw'","derivation":"feminine active participle of H1600 (גָּעָה); lowing;","strongs_def":"Goah, a place near Jerusalem","kjv_def":"Goath."},"H1602":{"id":"H1602","lemma":"גָּעַל","translit":"gâʻal","pron":"gaw-al'","derivation":"a primitive root;","strongs_def":"to detest; by implication, to reject","kjv_def":"abhor, fail, lothe, vilely cast away.","pos":"verb","usage":"abhor(5x), lothe(3x), fail(1x)"},"H1603":{"id":"H1603","lemma":"גַּעַל","translit":"Gaʻal","pron":"gah'-al","derivation":"from H1602 (גָּעַל); loathing;","strongs_def":"Gaal, an Israelite","kjv_def":"Gaal.","pos":"proper masculine noun","usage":"Gaal(9x)"},"H1604":{"id":"H1604","lemma":"גֹּעַל","translit":"gôʻal","pron":"go'-al","derivation":"from H1602 (גָּעַל);","strongs_def":"abhorrence","kjv_def":"loathing.","pos":"masculine noun","usage":"lothing(1x)"},"H1605":{"id":"H1605","lemma":"גָּעַר","translit":"gâʻar","pron":"gaw-ar'","derivation":"a primitive root;","strongs_def":"to chide","kjv_def":"corrupt, rebuke, reprove.","pos":"verb","usage":"rebuke(12x), corrupt(1x), reprove(1x)"},"H1606":{"id":"H1606","lemma":"גְּעָרָה","translit":"gᵉʻârâh","pron":"gheh-aw-raw'","derivation":"from H1605 (גָּעַר);","strongs_def":"a chiding","kjv_def":"rebuke(-ing), reproof.","pos":"feminine noun","usage":"rebuke(13x), reproof(2x)"},"H1607":{"id":"H1607","lemma":"גָּעַשׁ","translit":"gâʻash","pron":"gaw-ash'","derivation":"a primitive root","strongs_def":"to agitate violently","kjv_def":"move, shake, toss, trouble.","pos":"verb","usage":"shake(5x), move(3x), trouble(1x)"},"H1608":{"id":"H1608","lemma":"גַּעַשׁ","translit":"Gaʻash","pron":"ga'-ash","derivation":"from H1607 (גָּעַשׁ); a quaking;","strongs_def":"Gaash, a hill in Palestine","kjv_def":"Gaash.