ly abridged from H3474 (יָשַׁר);","strongs_def":"plain, Sharon, the name of a place in Palestine","kjv_def":"Lasharon, Sharon.","pos":"masculine noun, proper locative noun","usage":"Sharon(6x), Lasharon(1x)"},"H8290":{"id":"H8290","lemma":"שָׁרוֹנִי","translit":"Shârôwnîy","pron":"shaw-ro-nee'","derivation":"patrial from H8289 (שָׁרוֹן);","strongs_def":"a Sharonite or inhabitant of Sharon","kjv_def":"Sharonite."},"H8291":{"id":"H8291","lemma":"שָׂרוּק","translit":"sârûwq","pron":"sar-ook'","derivation":"passive participle from the same as H8321 (שֹׂרֵק);","strongs_def":"a grapevine","kjv_def":"principal plant. See H8320 (שָׂרֻק), H8321 (שֹׂרֵק).","pos":"masculine noun"},"H8292":{"id":"H8292","lemma":"שְׁרוּקָה","translit":"shᵉrûwqâh","pron":"sher-oo-kaw'","derivation":"or (by permutation) שְׁרִיקָה; feminine passive participle of H8319 (שָׁרַק);","strongs_def":"a whistling (in scorn); by analogy, a piping","kjv_def":"bleating, hissing.","pos":"feminine noun","usage":"hissing(2x), bleating(1x)"},"H8293":{"id":"H8293","lemma":"שֵׁרוּת","translit":"shêrûwth","pron":"shay-rooth'","derivation":"from H8281 (שָׁרָה) abbreviated;","strongs_def":"freedom","kjv_def":"remnant.","pos":"feminine noun","usage":"variant(1x)"},"H8294":{"id":"H8294","lemma":"שֶׂרַח","translit":"Serach","pron":"seh'-rakh","derivation":"by permutation for H5629 (סֶרַח); superfluity;","strongs_def":"Serach, an Israelitess","kjv_def":"Sarah, Serah.","pos":"proper feminine noun","usage":"Serah(2x), Sarah(1x)"},"H8295":{"id":"H8295","lemma":"שָׂרַט","translit":"sâraṭ","pron":"saw-rat'","derivation":"a primitive root;","strongs_def":"to gash","kjv_def":"cut in pieces, make (cuttings) pieces.","pos":"verb","usage":"make(1x)"},"H8296":{"id":"H8296","lemma":"שֶׂרֶט","translit":"sereṭ","pron":"seh'-ret","derivation":"and שָׂרֶטֶת; from H8295 (שָׂרַט);","strongs_def":"an incision","kjv_def":"cutting.","pos":"masculine/feminine noun","usage":"cuttings(2x)"},"H8297":{"id":"H8297","lemma":"שָׂרַי","translit":"Sâra