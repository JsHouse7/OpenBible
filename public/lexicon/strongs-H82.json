n","usage":"adder(1x)"},"H8208":{"id":"H8208","lemma":"שָׁפִיר","translit":"Shâphîyr","pron":"shaf-eer'","derivation":"from H8231 (שָׁפַר); beautiful;","strongs_def":"Shaphir, a place in Palestine","kjv_def":"Saphir.","pos":"proper locative noun","usage":"Saphir(1x)"},"H8209":{"id":"H8209","lemma":"שַׁפִּיר","translit":"shappîyr","pron":"shap-peer'","derivation":"(Aramaic) intensive of a form corresponding to H8208 (שָׁפִיר);","strongs_def":"beautiful","kjv_def":"fair.","pos":"adjective","usage":"fair(2x)"},"H8210":{"id":"H8210","lemma":"שָׁפַךְ","translit":"shâphak","pron":"shaw-fak'","derivation":"a primitive root;","strongs_def":"to spill forth (blood, a libation, liquid metal; or even a solid, i.e. to mound up); also (figuratively) to expend (life, soul, complaint, money, etc.); intensively, to sprawl out","kjv_def":"cast (up), gush out, pour (out), shed(-der, out), slip.","pos":"verb","usage":"shed(36x), pour(20x), cast(6x)"},"H8211":{"id":"H8211","lemma":"שֶׁפֶךְ","translit":"shephek","pron":"sheh'-fek","derivation":"from H8210 (שָׁפַךְ);","strongs_def":"an emptying place, e.g. an ash-heap","kjv_def":"are poured out.","pos":"masculine noun"},"H8212":{"id":"H8212","lemma":"שׇׁפְכָה","translit":"shophkâh","pron":"shof-kaw'","derivation":"feminine of a derivative from H8210 (שָׁפַךְ);","strongs_def":"a pipe (for pouring forth, e.g. wine), i.e. the penis","kjv_def":"privy member.","pos":"feminine noun"},"H8213":{"id":"H8213","lemma":"שָׁפֵל","translit":"shâphêl","pron":"shaw-fale'","derivation":"a primitive root;","strongs_def":"to depress or sink (expectation figuratively, to humiliate, intransitive or transitive)","kjv_def":"abase, bring (cast, put) down, debase, humble (self), be (bring, lay, make, put) low(-er).","pos":"verb","usage":"humble(7x), abase(2x), debase(1x)"},"H8214":{"id":"H8214","lemma":"שְׁפַל","translit":"shᵉphal","pron":"shef-al'","derivation":"(Aramaic) corresponding to H8213 (שָׁפֵל)","strongs_def":"{to depress or sink (expectation figuratively, to humiliate, intransitive or transitive)}","kjv_def":"abase, humble, put down, subdue.","pos":"verb","usage":"humble(1x), abase(1x), subdue(1x)"},"H8215":{"id":"H8215","lemma":"שְׁפַל","translit":"shᵉphal","pron":"shef-al'","derivation":"(Aramaic) from H8214 (שְׁפַל);","strongs_def":"low","kjv_def":"basest.","pos":"adjective","usage":"basest(1x)"},"H8216":{"id":"H8216","lemma":"שֶׁפֶל","translit":"shephel","pron":"shay'-fel","derivation":"from H8213 (שָׁפֵל);","strongs_def":"an humble rank","kjv_def":"low estate (place).","pos":"masculine noun"},"H8217":{"id":"H8217","lemma":"שָׁפָל","translit":"shâphâl","pron":"shaw-fawl'","derivation":"from H8213 (שָׁפֵל);","strongs_def":"depressed, literally or figuratively","kjv_def":"base(-st), humble, low(-er, -ly).","pos":"adjective","usage":"low(5x), lower(4x), base(4x), humble(4x), basest(1x), lowly(1x)"},"H8218":{"id":"H8218","lemma":"שִׁפְלָה","translit":"shiphlâh","pron":"shif-law'","derivation":"feminine of H8216 (שֶׁפֶל);","strongs_def":"depression","kjv_def":"low place."},"H8219":{"id":"H8219","lemma":"שְׁפֵלָה","translit":"shᵉphêlâh","pron":"shef-ay-law'","derivation":"from H8213 (שָׁפֵל);","strongs_def":"Lowland, i.e. (with the article) the maritime slope of Palestine","kjv_def":"low country, (low) plain, vale(-ley).","pos":"feminine noun","usage":"valley(8x), vale(5x), plain(3x)"},"H8220":{"id":"H8220","lemma":"שִׁפְלוּת","translit":"shiphlûwth","pron":"shif-looth'","derivation":"from H8213 (שָׁפֵל);","strongs_def":"remissness","kjv_def":"idleness.","pos":"feminine noun","usage":"idleness(1x)"},"H8221":{"id":"H8221","lemma":"שְׁפָם","translit":"Shᵉphâm","pron":"shef-awm'","derivation":"probably from H8192 (שָׁפָה); bare spot;","strongs_def":"Shepham, a place in or near Palestine","kjv_def":"Shepham.","pos":"proper locative noun","usage":"Shepham(2x)"},"H8222":{"id":"H8222","lemma":"שָׂפָם","translit":"sâphâm","pron":"saw-fawm'","derivation":"from H8193 (שָׂפָה);","strongs_def":"the beard (as a lippiece)","kjv_def":"beard, (upper) lip.","pos":"masculine noun","usage":"lip(3x), beard(1x)"},"H8223":{"id":"H8223","lemma":"שָׁפָם","translit":"Shâphâm","pron":"shaw-fawm'","derivation":"formed like H8221 (שְׁפָם); baldly;","strongs_def":"Shapham, an Israelite","kjv_def":"Shapham."},"H8224":{"id":"H8224","lemma":"שִׂפְמוֹת","translit":"Siphmôwth","pron":"sif-moth'","derivation":"feminine plural of H8221 (שְׁפָם);","strongs_def":"Siphmoth, a place in Palestine","kjv_def":"Siphmoth."},"H8225":{"id":"H8225","lemma":"שִׁפְמִי","translit":"Shiphmîy","pron":"shif-mee'","derivation":"patrial from H8221 (שְׁפָם);","strongs_def":"a Shiphmite or inhabitant of Shepham","kjv_def":"Shiphmite."},"H8226":{"id":"H8226","lemma":"שָׂפַן","translit":"sâphan","pron":"saw-fan'","derivation":"a primitive root;","strongs_def":"to conceal (as a valuable)","kjv_def":"treasure.","pos":"verb","usage":"treasure(1x)"},"H8227":{"id":"H8227","lemma":"שָׁפָן","translit":"shâphân","pron":"shaw-fawn'","derivation":"from H8226 (שָׂפַן);","strongs_def":"a species of rockrabbit (from its hiding), i.e. probably the hyrax","kjv_def":"coney.","pos":"masculine noun, proper masculine noun","usage":"Shaphan(30x), coney(4x)"},"H8228":{"id":"H8228","lemma":"שֶׁפַע","translit":"shephaʻ","pron":"sheh'-fah","derivation":"from an unused root meaning to abound;","strongs_def":"resources","kjv_def":"abundance.","pos":"masculine noun","usage":"abundance(1x)"},"H8229":{"id":"H8229","lemma":"שִׁפְעָה","translit":"shiphʻâh","pron":"shif-aw'","derivation":"feminine of H8228 (שֶׁפַע);","strongs_def":"copiousness","kjv_def":"abundance, company, multitude.","pos":"feminine noun","usage":"abundance(3x), company(2x), multitude(1x)"},"H8230":{"id":"H8230","lemma":"שִׁפְעִי","translit":"Shiphʻîy","pron":"shif-ee'","derivation":"from H8228 (שֶׁפַע); copious;","strongs_def":"Shiphi, an Israelite","kjv_def":"Shiphi."},"H8231":{"id":"H8231","lemma":"שָׁפַר","translit":"shâphar","pron":"shaw-far'","derivation":"a primitive root;","strongs_def":"to glisten, i.e. (figuratively) be (causatively, make) fair","kjv_def":"[idiom] goodly.","pos":"verb","usage":"goodly(1x)"},"H8232":{"id":"H8232","lemma":"שְׁפַר","translit":"shᵉphar","pron":"shef-ar'","derivation":"(Aramaic) corresponding to H8231 (שָׁפַר);","strongs_def":"to be beautiful","kjv_def":"be acceptable, please, [phrase] think good.","pos":"verb","usage":"please(1x), acceptable(1x)"},"H8233":{"id":"H8233","lemma":"שֶׁפֶר","translit":"shepher","pron":"sheh'-fer","derivation":"from H8231 (שָׁפַר);","strongs_def":"beauty","kjv_def":"[idiom] goodly.","pos":"masculine noun","usage":"goodly(1x)"},"H8234":{"id":"H8234","lemma":"שֶׁפֶר","translit":"Shepher","pron":"sheh'-fer","derivation":"the same as H8233 (שֶׁפֶר);","strongs_def":"Shepher, a place in the Desert","kjv_def":"Shapper.","pos":"proper noun with reference to a mountain","usage":"Shapher(2x)"},"H8235":{"id":"H8235","lemma":"שִׁפְרָה","translit":"shiphrâh","pron":"shif-raw'","derivation":"from H8231 (שָׁפַר);","strongs_def":"brightness","kjv_def":"garnish.","pos":"feminine noun","usage":"garnished(1x)"},"H8236":{"id":"H8236","lemma":"שִׁפְרָה","translit":"Shiphrâh","pron":"shif-raw'","derivation":"the same as H8235 (שִׁפְרָה);","strongs_def":"Shiphrah, an Israelitess","kjv_def":"Shiphrah.","pos":"proper feminine noun","usage":"Shiphrah(1x)"},"H8237":{"id":"H8237","lemma":"שַׁפְרוּר","translit":"shaphrûwr","pron":"shaf-roor'","derivation":"from H8231 (שָׁפַר);","strongs_def":"splendid, i.e. a tapestry or canopy","kjv_def":"royal pavilion."},"H8238":{"id":"H8238","lemma":"שְׁפַרְפַר","translit":"shᵉpharphar","pron":"shef-ar-far'","derivation":"(Aramaic) from H8231 (שָׁפַר);","strongs_def":"the dawn (as brilliant with aurora)","kjv_def":"[idiom] very early in the morning.","pos":"masculine noun"},"H8239":{"id":"H8239","lemma":"שָׁפַת","translit":"shâphath","pron":"shaw-fath'","derivation":"a primitive root;","strongs_def":"to locate, i.e. (generally) hang on or (figuratively) establish, reduce","kjv_def":"bring, ordain, set on.","pos":"verb","usage":"brought(1x), ordain(1x)"},"H8240":{"id":"H8240","lemma":"שָׁפָת","translit":"shâphâth","pron":"shaw-fawth'","derivation":"from H8239 (שָׁפַת);","strongs_def":"a (double) stall (for cattle); also a (two-pronged) hook (for flaying animals on)","kjv_def":"hook, pot.","pos":"masculine noun","usage":"pot(1x), hook(1x)"},"H8241":{"id":"H8241","lemma":"שֶׁצֶף","translit":"shetseph","pron":"sheh'-tsef","derivation":"from H7857 (שָׁטַף) (for alliteration with H7110 (קֶצֶף));","strongs_def":"an outburst (of anger)","kjv_def":"little.","pos":"masculine noun","usage":"little(1x)"},"H8242":{"id":"H8242","lemma":"שַׂק","translit":"saq","pron":"sak","derivation":"from H8264 (שָׁקַק);","strongs_def":"properly, a mesh (as allowing a liquid to run through), i.e. coarse loose cloth or sacking (used in mourning and for bagging); hence, a bag (for grain, etc.)","kjv_def":"sack(-cloth, -clothes).","pos":"masculine noun","usage":"sackcloth(41x), sack(6x), sackclothes(1x)"},"H8243":{"id":"H8243","lemma":"שָׁק","translit":"shâq","pron":"shawk","derivation":"(Aramaic) corresponding to H7785 (שׁוֹק);","strongs_def":"the leg","kjv_def":"leg.","pos":"masculine noun","usage":"legs(1x)"},"H8244":{"id":"H8244","lemma":"שָׂקַד","translit":"sâqad","pron":"saw-kad'","derivation":"a primitive root;","strongs_def":"to fasten","kjv_def":"bind.","pos":"verb","usage":"bound(1x)"},"H8245":{"id":"H8245","lemma":"שָׁקַד","translit":"shâqad","pron":"shaw-kad'","derivation":"a primitive root;","strongs_def":"to be alert, i.e. sleepless; hence to be on the lookout (whether for good or ill)","kjv_def":"hasten, remain, wake, watch (for).","pos":"verb","usage":"watch(9x), wake(1x), remain(1x), hasten(1x)"},"H8246":{"id":"H8246","lemma":"שָׁקַד","translit":"shâqad","pron":"shaw-kad'","derivation":"a denominative from H8247 (שָׁקֵד);","strongs_def":"to be (intensively, make) almond-shaped","kjv_def":"make like (unto, after the fashion of) almonds.","pos":"verb","usage":"almond(6x)"},"H8247":{"id":"H8247","lemma":"שָׁקֵד","translit":"shâqêd","pron":"shaw-kade'","derivation":"from H8245 (שָׁקַד);","strongs_def":"the almond (tree or nut; as being the earliest in bloom)","kjv_def":"almond (tree).","pos":"masculine noun","usage":"almond(2x)"},"H8248":{"id":"H8248","lemma":"שָׁקָה","translit":"shâqâh","pron":"shaw-kaw'","derivation":"a primitive root;","strongs_def":"to quaff, i.e. (causatively) to irrigate or furnish apotion to","kjv_def":"cause to (give, give to, let, make to) drink, drown, moisten, water. See H7937 (שָׁכַר), H8354 (שָׁתָה).","pos":"verb","usage":"drink(43x), water(17x), butler(9x), cupbearer(3x)"},"H8249":{"id":"H8249","lemma":"שִׁקֻּו","translit":"shiqquv","pron":"shif-koov'","derivation":"from H8248 (שָׁקָה);","strongs_def":"(plural collective) a draught","kjv_def":"drink.","pos":"masculine noun","usage":"drink(1x)"},"H8250":{"id":"H8250","lemma":"שִׁקּוּי","translit":"shiqqûwy","pron":"shik-koo'-ee","derivation":"from H8248 (שָׁקָה);","strongs_def":"a beverage; moisture, i.e. (figuratively) refreshment","kjv_def":"drink, marrow.","pos":"masculine noun","usage":"marrow(1x), drink(1x)"},"H8251":{"id":"H8251","lemma":"שִׁקּוּץ","translit":"shiqqûwts","pron":"shik-koots'","derivation":"or שִׁקֻּץ; from H8262 (שָׁקַץ);","strongs_def":"disgusting, i.e. filthy; especially idolatrous or (concretely) an idol","kjv_def":"abominable filth (idol, -ation), detestable (thing).","pos":"masculine noun","usage":"abomination(20x), detestable(1x)"},"H8252":{"id":"H8252","lemma":"שָׁקַט","translit":"shâqaṭ","pron":"shaw-kat'","derivation":"a primitive root;","strongs_def":"to repose (usually figurative)","kjv_def":"appease, idleness, (at, be at, be in, give) quiet(-ness), (be at, be in, give, have, take) rest, settle, be still.","pos":"verb","usage":"rest(16x), quiet(16x), quietness(4x), still(2x), appeaseth(1x), idleness(1x), settled(1x)"},"H8253":{"id":"H8253","lemma":"שֶׁקֶט","translit":"sheqeṭ","pron":"sheh'-ket","derivation":"from H8252 (שָׁקַט);","strongs_def":"tranquillity","kjv_def":"quietness."},"H8254":{"id":"H8254","lemma":"שָׁקַל","translit":"shâqal","pron":"shaw-kal'","derivation":"a primitive root;","strongs_def":"to suspend or poise (especially in trade)","kjv_def":"pay, receive(-r), spend, [idiom] throughly, weigh.","pos":"verb","usage":"weigh(14x), pay(4x), throughly(1x), receive(1x), receiver(1x), spend(1x)"},"H8255":{"id":"H8255","lemma":"שֶׁקֶל","translit":"sheqel","pron":"sheh'-kel","derivation":"from H8254 (שָׁקַל);","strongs_def":"probably a weight; used as a commercial standard","kjv_def":"shekel.","pos":"masculine noun","usage":"shekel(88x)"},"H8256":{"id":"H8256","lemma":"שִׁקְמָה","translit":"shiqmâh","pron":"shik-maw'","derivation":"or (feminine) שִׁקְמָה; of uncertain derivation;","strongs_def":"a sycamore (usually the tree)","kjv_def":"sycamore (fruit, tree).","pos":"feminine noun","usage":"sycamore(1x)"},"H8257":{"id":"H8257","lemma":"שָׁקַע","translit":"shâqaʻ","pron":"shaw-kah'","derivation":"(abbreviated Amos 8:8); a primitive root;","strongs_def":"to subside; by implication, to be overflowed, cease; causatively, to abate, subdue","kjv_def":"make deep, let down, drown, quench, sink.","pos":"verb","usage":"drown(2x), quench(1x), sink(1x)"},"H8258":{"id":"H8258","lemma":"שְׁקַעְרוּרָה","translit":"shᵉqaʻrûwrâh","pron":"shek-ah-roo-raw'","derivation":"from H8257 (שָׁקַע);","strongs_def":"a depression","kjv_def":"hollow strake.","pos":"feminine noun"},"H8259":{"id":"H8259","lemma":"שָׁקַף","translit":"shâqaph","pron":"shaw-kaf'","derivation":"a primitive root;","strongs_def":"properly, to lean out (of a window), i.e. (by implication) peep or gaze (passively, be a spectacle)","kjv_def":"appear, look (down, forth, out).","pos":"verb","usage":"look(11x), appear(1x)"},"H8260":{"id":"H8260","lemma":"שֶׁקֶף","translit":"sheqeph","pron":"sheh'-kef","derivation":"from H8259 (שָׁקַף);","strongs_def":"a loophole (for looking out), to admit light and air","kjv_def":"window."