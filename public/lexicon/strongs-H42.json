f":"an instrument for marking a circle, i.e. compasses","kjv_def":"compass.","pos":"feminine noun","usage":"compass(1x)"},"H4231":{"id":"H4231","lemma":"מָחוֹז","translit":"mâchôwz","pron":"maw-khoze'","derivation":"from an unused root meaning to enclose;","strongs_def":"a harbor (as shut in by the shore)","kjv_def":"haven."},"H4232":{"id":"H4232","lemma":"מְחוּיָאֵל","translit":"Mᵉchûwyâʼêl","pron":"mekh-oo-yaw-ale'","derivation":"or מְחִיּיָאֵל; from H4229 (מָחָה) and H410 (אֵל); smitten of God;","strongs_def":"Mechujael or Mechijael, an antediluvian patriarch","kjv_def":"Mehujael.","pos":"proper masculine noun","usage":"Mehujael(2x)"},"H4233":{"id":"H4233","lemma":"מַחֲוִים","translit":"Machăvîym","pron":"makh-av-eem'","derivation":"apparently a patrial, but from an unknown place (in the plural only for a singular);","strongs_def":"a Machavite or inhabitant of some place named Machaveh","kjv_def":"Mahavite."},"H4234":{"id":"H4234","lemma":"מָחוֹל","translit":"mâchôwl","pron":"maw-khole'","derivation":"from H2342 (חוּל);","strongs_def":"a (round) dance","kjv_def":"dance(-cing).","pos":"masculine noun","usage":"dance(5x), dancing(1x)"},"H4235":{"id":"H4235","lemma":"מָחוֹל","translit":"Mâchôwl","pron":"maw-khole'","derivation":"the same as H4234 (מָחוֹל); dancing;","strongs_def":"Machol, an Israelite","kjv_def":"Mahol."},"H4236":{"id":"H4236","lemma":"מַחֲזֶה","translit":"machăzeh","pron":"makh-az-eh'","derivation":"from H2372 (חָזָה);","strongs_def":"a vision","kjv_def":"vision.","pos":"masculine noun","usage":"vision(4x)"},"H4237":{"id":"H4237","lemma":"מֶחֱזָה","translit":"mechĕzâh","pron":"mekh-ez-aw'","derivation":"from H2372 (חָזָה);","strongs_def":"a window","kjv_def":"light."},"H4238":{"id":"H4238","lemma":"מַחֲזִיאוֹת","translit":"Machăzîyʼôwth","pron":"makh-az-ee-oth'","derivation":"feminine plural from H2372 (חָזָה); visions;","strongs_def":"Machazioth, an Israelite","kjv_def":"Mahazioth."},"H4239":{"id":"H4239","lemma":"מְחִי","translit":"mᵉchîy","pron"