,"lemma":"מַחְלְקָה","translit":"machlᵉqâh","pron":"makh-lek-aw'","derivation":"(Aramaic) corresponding to H4256 (מַחֲלֹקֶת);","strongs_def":"a section (of the Levites)","kjv_def":"course.","pos":"feminine noun","usage":"courses(1x)"},"H4256":{"id":"H4256","lemma":"מַחֲלֹקֶת","translit":"machălôqeth","pron":"makh-al-o'-keth","derivation":"from H2505 (חָלַק);","strongs_def":"a section (of Levites, people or soldiers)","kjv_def":"company, course, division, portion. See also H5555 (סֶלַע הַמַּחְלְקוֹת).","pos":"feminine noun","usage":"course(33x), divisions(8x), portions(1x), companies(1x)"},"H4257":{"id":"H4257","lemma":"מַחֲלַת","translit":"machălath","pron":"makh-al-ath'","derivation":"from H2470 (חָלָה); sickness;","strongs_def":"'Machalath', probably the title (initial word) of a popular song","kjv_def":"Mahalath.","pos":"feminine noun","usage":"Mahalath(2x)"},"H4258":{"id":"H4258","lemma":"מַחֲלַת","translit":"Machălath","pron":"makh-al-ath'","derivation":"the same as H4257 (מַחֲלַת); sickness;","strongs_def":"Machalath, the name of an Ishmaelitess and of an Israelitess","kjv_def":"Mahalath.","pos":"proper feminine noun","usage":"Mahalath(2x)"},"H4259":{"id":"H4259","lemma":"מְחֹלָתִי","translit":"Mᵉchôlâthîy","pron":"mekh-o-law-thee'","derivation":"patrial from H65 (אָבֵל מְחוֹלָה);","strongs_def":"a Mecholathite or inhabitant of Abel-Mecholah","kjv_def":"Mecholathite."},"H4260":{"id":"H4260","lemma":"מַחֲמָאָה","translit":"machămâʼâh","pron":"makh-am-aw-aw'","derivation":"a denominative from H2529 (חֶמְאָה);","strongs_def":"something buttery (i.e. unctuous and pleasant), as (figuratively) flattery","kjv_def":"[idiom] than butter.","pos":"feminine noun","usage":"butter(1x)"},"H4261":{"id":"H4261","lemma":"מַחְמָד","translit":"machmâd","pron":"makh-mawd'","derivation":"from H2530 (חָמַד);","strongs_def":"delightful; hence, a delight, i.e. object of affection or desire","kjv_def":"beloved, desire, goodly, lovely, pleasant (thing).","pos":"masculine noun","usage":"