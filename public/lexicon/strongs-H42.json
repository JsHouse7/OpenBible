":{"id":"H4215","lemma":"מְזָרֶה","translit":"mᵉzâreh","pron":"mez-aw-reh'","derivation":"apparently from H2219 (זָרָה);","strongs_def":"properly, a scatterer, i.e. the north wind (as dispersing clouds; only in plural)","kjv_def":"north."},"H4216":{"id":"H4216","lemma":"מַזָּרָה","translit":"mazzârâh","pron":"maz-zaw-raw'","derivation":"apparently from H5144 (נָזַר) in the sense of distinction;","strongs_def":"some noted constellation (only in the plural), perhaps collectively, the zodiac","kjv_def":"Mazzoroth. Compare H4208 (מַזָּלָה).","pos":"feminine noun","usage":"Mazzaroth(1x)"},"H4217":{"id":"H4217","lemma":"מִזְרָח","translit":"mizrâch","pron":"miz-rawkh'","derivation":"from H2224 (זָרַח);","strongs_def":"sunrise, i.e. the east","kjv_def":"east (side, -ward), (sun-) rising (of the sun).","pos":"masculine noun","usage":"east(30x), eastward(20x), rising(8x), sunrising(1x)"},"H4218":{"id":"H4218","lemma":"מִזְרָע","translit":"mizrâʻ","pron":"miz-raw'","derivation":"from H2232 (זָרַע);","strongs_def":"a planted field","kjv_def":"thing sown.","pos":"masculine noun"},"H4219":{"id":"H4219","lemma":"מִזְרָק","translit":"mizrâq","pron":"miz-rawk'","derivation":"from H2236 (זָרַק);","strongs_def":"a bowl (as if for sprinkling)","kjv_def":"bason, bowl.","pos":"masculine noun","usage":"basons(11x), bowl(21x)"},"H4220":{"id":"H4220","lemma":"מֵחַ","translit":"mêach","pron":"may'-akh","derivation":"from H4229 (מָחָה) in the sense of greasing;","strongs_def":"fat; figuratively, rich","kjv_def":"fatling (one).","pos":"masculine noun","usage":"fatling(1x)"},"H4221":{"id":"H4221","lemma":"מֹחַ","translit":"môach","pron":"mo'-akh","derivation":"from the same as H4220 (מֵחַ);","strongs_def":"fat, i.e. marrow","kjv_def":"marrow."},"H4222":{"id":"H4222","lemma":"מָחָא","translit":"mâchâʼ","pron":"maw-khaw'","derivation":"a primitive root;","strongs_def":"to rub or strike the hands together (in exultation)","kjv_def":"clap.","pos":"verb","usage":"clap(3x)"},"H4223":{"id":"H4223","l