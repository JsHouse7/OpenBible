{"H4200":{"id":"H4200","lemma":"מֶזֶו","translit":"mezev","pron":"meh'-zev","derivation":"probably from an unused root meaning to gather in;","strongs_def":"a granary","kjv_def":"garner.","pos":"masculine noun","usage":"garner(1x)"},"H4201":{"id":"H4201","lemma":"מְזוּזָה","translit":"mᵉzûwzâh","pron":"mez-oo-zaw'","derivation":"or מְזֻזָה; from the same as H2123 (זִיז);","strongs_def":"a door-post (as prominent)","kjv_def":"(door, side) post.","pos":"feminine noun","usage":"post(19x)"},"H4202":{"id":"H4202","lemma":"מָזוֹן","translit":"mâzôwn","pron":"maw-zone'","derivation":"from H2109 (זוּן);","strongs_def":"food","kjv_def":"meat, victual.","pos":"masculine noun","usage":"meat(1x), victuals(1x)"},"H4203":{"id":"H4203","lemma":"מָזוֹן","translit":"mâzôwn","pron":"maw-zone'","derivation":"(Aramaic) corresponding to H4202 (מָזוֹן)","strongs_def":"{food}","kjv_def":"meat.","pos":"masculine noun","usage":"meat(2x)"},"H4204":{"id":"H4204","lemma":"מָזוֹר","translit":"mâzôwr","pron":"maw-zore'","derivation":"from H2114 (זוּר) in the sense of turning aside from truth;","strongs_def":"treachery, i.e. a plot","kjv_def":"wound.","pos":"masculine noun","usage":"wound(1x)"},"H4205":{"id":"H4205","lemma":"מָזוֹר","translit":"mâzôwr","pron":"maw-zore'","derivation":"or מָזֹר; from H2115 (זוּר) in the sense of binding up;","strongs_def":"a bandage, i.e. remedy; hence, a sore (as needing a compress)","kjv_def":"bound up, wound.","pos":"masculine noun","usage":"wound(2x)"},"H4206":{"id":"H4206","lemma":"מָזִיחַ","translit":"mâzîyach","pron":"maw-zee'-akh","derivation":"or מֵזַח; from H2118 (זָחַח);","strongs_def":"a belt (as movable)","kjv_def":"girdle, strength.","pos":"masculine noun","usage":"strength(2x), girdle(1x)"},"H4207":{"id":"H4207","lemma":"מַזְלֵג","translit":"mazlêg","pron":"maz-layg'","derivation":"or (feminine) מִזְלָגָה; from an unused root meaning to draw up;","strongs_def":"a fork","kjv_def":"fleshhook.","pos":"masculine noun","usage":"fleshhook(7x)"},"H4208":{"