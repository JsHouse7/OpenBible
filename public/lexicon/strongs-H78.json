":"Shiloh.","pos":"proper locative noun","usage":"Shiloh(32x)"},"H7888":{"id":"H7888","lemma":"שִׁילוֹנִי","translit":"Shîylôwnîy","pron":"shee-lo-nee'","derivation":"or שִׁילֹנִי; or שִׁלֹנִי; from H7887 (שִׁילֹה);","strongs_def":"a Shilonite or inhabitant of Shiloh","kjv_def":"Shilonite."},"H7889":{"id":"H7889","lemma":"שִׁימוֹן","translit":"Shîymôwn","pron":"shee-mone'","derivation":"apparently for H3452 (יְשִׁימוֹן); desert;","strongs_def":"Shimon, an Israelite","kjv_def":"Shimon."},"H7890":{"id":"H7890","lemma":"שַׁיִן","translit":"shayin","pron":"shah'-yin","derivation":"from an unused root meaning to urinate;","strongs_def":"urine","kjv_def":"piss."},"H7891":{"id":"H7891","lemma":"שִׁיר","translit":"shîyr","pron":"sheer","derivation":"or (the original form) שׁוּר; (1 Samuel 18:6), a primitive root (rather identical with H7788 (שׁוּר) through the idea of strolling minstrelsy);","strongs_def":"to sing","kjv_def":"behold (by mistake for H7789 (שׁוּר)), sing(-er, -ing man, -ing woman).","pos":"verb","usage":"sing(41x), singer(37x), behold(1x)"},"H7892":{"id":"H7892","lemma":"שִׁיר","translit":"shîyr","pron":"sheer","derivation":"or feminine שִׁירָה; from H7891 (שִׁיר);","strongs_def":"a song; abstractly, singing","kjv_def":"musical(-ick), [idiom] sing(-er, -ing), song.","pos":"feminine noun, masculine noun","usage":"song(74x), musick(7x), singing(4x), musical(2x), sing(1x), singers(1x)"},"H7893":{"id":"H7893","lemma":"שַׁיִשׁ","translit":"shayish","pron":"shah'-yish","derivation":"from an unused root meaning to bleach, i.e. whiten;  See H8336 (שֵׁשׁ).","strongs_def":"white, i.e. marble."},"H7894":{"id":"H7894","lemma":"שִׁישָׁא","translit":"Shîyshâʼ","pron":"shee-shaw'","derivation":"from the same as H7893 (שַׁיִשׁ); whiteness;","strongs_def":"Shisha, an Israelite","kjv_def":"Shisha."},"H7895":{"id":"H7895","lemma":"שִׁישַׁק","translit":"Shîyshaq","pron":"shee-shak'","derivation":"or שׁוּשַׁק; of Egyptian derivation;","strongs_def":"Shishak, an Egyptian king","kj