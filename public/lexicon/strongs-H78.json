":{"id":"H7822","lemma":"שְׁחִין","translit":"shᵉchîyn","pron":"shekh-een'","derivation":"from an unused root probably meaning to burn;","strongs_def":"inflammation, i.e. an ulcer","kjv_def":"boil, botch.","pos":"masculine noun","usage":"boil(11x), botch(2x)"},"H7823":{"id":"H7823","lemma":"שָׁחִיס","translit":"shâchîyç","pron":"shaw-khece'","derivation":"or סָחִישׁ; from an unused root apparently meaning to sprout;","strongs_def":"aftergrowth","kjv_def":"(that) which springeth of the same.","pos":"masculine noun"},"H7824":{"id":"H7824","lemma":"שָׁחִיף","translit":"shâchîyph","pron":"shaw-kheef'","derivation":"from the same as H7828 (שַׁחַף);","strongs_def":"a board (as chipped thin)","kjv_def":"cieled with.","pos":"adjective, noun","usage":"cieled(1x)"},"H7825":{"id":"H7825","lemma":"שְׁחִית","translit":"shᵉchîyth","pron":"shekh-eeth'","derivation":"from H7812 (שָׁחָה);","strongs_def":"a pit-fall (literally or figuratively)","kjv_def":"destruction, pit.","pos":"feminine noun","usage":"destruction(1x), pit(1x)"},"H7826":{"id":"H7826","lemma":"שַׁחַל","translit":"shachal","pron":"shakh'-al","derivation":"from an unused root probably meaning to roar;","strongs_def":"a lion (from his characteristic roar)","kjv_def":"(fierce) lion.","pos":"masculine noun","usage":"lion(4x)"},"H7827":{"id":"H7827","lemma":"שְׁחֵלֶת","translit":"shᵉchêleth","pron":"shekh-ay'-leth","derivation":"apparently from the same as H7826 (שַׁחַל) through some obscure idea, perhaps that of peeling off by concussion of sound;","strongs_def":"a scale or shell, i.e. the aromatic mussel.","kjv_def":"onycha.","pos":"feminine noun","usage":"onycha(1x)"},"H7828":{"id":"H7828","lemma":"שַׁחַף","translit":"shachaph","pron":"shakh'-af","derivation":"from an unused root meaning to peel, i.e. emaciate;","strongs_def":"the gull (as thin)","kjv_def":"cuckoo.","pos":"masculine noun","usage":"cuckow(2x)"},"H7829":{"id":"H7829","lemma":"שַׁחֶפֶת","translit":"shachepheth","pron":"shakh-eh'-feth","derivation":"from t