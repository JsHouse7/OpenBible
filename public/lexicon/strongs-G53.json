{"G5309":{"id":"G5309","lemma":"ὑψηλοφρονέω","translit":"hypsēlophronéō","derivation":"from a compound of G5308 (ὑψηλός) and G5424 (φρήν);","strongs_def":"to be lofty in mind, i.e. arrogant","kjv_def":"be highminded","pos":"verb"},"G5385":{"id":"G5385","lemma":"φιλοσοφία","translit":"philosophía","derivation":"from G5386 (φιλόσοφος);","strongs_def":"\"philosophy\", i.e. (specially), Jewish sophistry","kjv_def":"philosophy","pos":"feminine noun","usage":"philosophy(1x)"},"G5343":{"id":"G5343","lemma":"φεύγω","translit":"pheúgō","derivation":"apparently a primary verb;","strongs_def":"to run away (literally or figuratively); by implication, to shun; by analogy, to vanish","kjv_def":"escape, flee (away)","pos":"verb","usage":"flee(26x), escape(3x)"},"G5351":{"id":"G5351","lemma":"φθείρω","translit":"phtheírō","derivation":"probably strengthened from (to pine or waste);","strongs_def":"properly, to shrivel or wither, i.e. to spoil (by any process) or (generally) to ruin (especially figuratively, by moral influences, to deprave)","kjv_def":"corrupt (self), defile, destroy","pos":"verb","usage":"corrupt(4x), defile(1x), destroy(1x)"},"G5302":{"id":"G5302","lemma":"ὑστερέω","translit":"hysteréō","derivation":"from G5306 (ὕστερος);","strongs_def":"to be later, i.e. (by implication) to be inferior; generally, to fall short (be deficient)","kjv_def":"come behind (short), be destitute, fail, lack, suffer need, (be in) want, be the worse","pos":"verb","usage":"lack(3x), want(2x), fail(1x)"},"G5386":{"id":"G5386","lemma":"φιλόσοφος","translit":"philósophos","derivation":"from G5384 (φίλος) and G4680 (σοφός);","strongs_def":"fond of wise things, i.e. a \"philosopher\"","kjv_def":"philosopher","pos":"masculine noun","usage":"philosopher(1x)"},"G5316":{"id":"G5316","lemma":"φαίνω","translit":"phaínō","derivation":"prolongation for the base of G5457 (φῶς);","strongs_def":"to lighten (shine), i.e. show (transitive or intransitive, literal or figurative)","kjv_def":"appear, seem, be seen, shine, X think","pos":"verb","usage":"appear(17x), shine(10x), seem(1x), think(1x)"},"G5374":{"id":"G5374","lemma":"Φιλιππήσιος","translit":"Philippḗsios","derivation":"from G5375 (Φίλιπποι);","strongs_def":"a Philippesian (Philippian), i.e. native of Philippi","kjv_def":"Philippian","pos":"proper masculine noun","usage":"Philippians(2x)"},"G5372":{"id":"G5372","lemma":"Φίλητος","translit":"Phílētos","derivation":"from G5368 (φιλέω);","strongs_def":"amiable; Philetus, an opposer of Christianity","kjv_def":"Philetus"},"G5368":{"id":"G5368","lemma":"φιλέω","translit":"philéō","derivation":"from G5384 (φίλος);","strongs_def":"to be a friend to (fond of (an individual or an object)), i.e. have affection for (denoting personal attachment, as a matter of sentiment or feeling; while G25 (ἀγαπάω) is wider, embracing especially the judgment and the deliberate assent of the will as a matter of principle, duty and propriety: the two thus stand related very much as G2309 (θέλω) and G1014 (βούλομαι), or as G2372 (θυμός) and G3563 (νοῦς) respectively; the former being chiefly of the heart and the latter of the head); specially, to kiss (as a mark of tenderness)","kjv_def":"kiss, love","pos":"verb","usage":"love(22x), kiss(3x)"},"G5362":{"id":"G5362","lemma":"φίλανδρος","translit":"phílandros","derivation":"from G5384 (φίλος) and G435 (ἀνήρ);","strongs_def":"fond of man, i.e. affectionate as a wife","kjv_def":"love their husbands","pos":"adjective"},"G5348":{"id":"G5348","lemma":"φθάνω","translit":"phthánō","derivation":"apparently a primary verb;","strongs_def":"to be beforehand, i.e. anticipate or precede; by extension, to have arrived at","kjv_def":"(already) attain, come, prevent","pos":"verb","usage":"come(4x), attain(1x), prevent(1x)"},"G5339":{"id":"G5339","lemma":"φείδομαι","translit":"pheídomai","derivation":"of uncertain affinity;","strongs_def":"to be chary of, i.e. (subjectively) to abstain or (objectively) to treat leniently","kjv_def":"forbear, spare","pos":"verb","usage":"spare(9x), forbear(1x)"},"G5301":{"id":"G5301","lemma":"ὕσσωπος","translit":"hýssōpos","derivation":"of foreign origin (H0231);","strongs_def":"\"hyssop\"","kjv_def":"hyssop","pos":"feminine noun","usage":"hyssop(2x)"},"G5337":{"id":"G5337","lemma":"φαῦλος","translit":"phaûlos","derivation":"apparently a primary word;","strongs_def":"\"foul\" or \"flawy\", i.e. (figuratively) wicked","kjv_def":"evil","pos":"adjective","usage":"evil(4x)"},"G5324":{"id":"G5324","lemma":"φαντάζω","translit":"phantázō","derivation":"from a derivative of G5316 (φαίνω);","strongs_def":"to make apparent, i.e. (passively) to appear (neuter participle as noun, a spectacle)","kjv_def":"sight","pos":"verb","usage":"sight(1x)"},"G5329":{"id":"G5329","lemma":"Φάρες","translit":"Pháres","derivation":"of Hebrew origin (H06557);","strongs_def":"Phares (i.e. Perets), an Israelite","kjv_def":"Phares","pos":"proper masculine noun","usage":"Phares(3x)"},"G5399":{"id":"G5399","lemma":"φοβέω","translit":"phobéō","derivation":"from G5401 (φόβος);","strongs_def":"to frighten, i.e. (passively) to be alarmed; by analogy, to be in awe of, i.e. revere","kjv_def":"be (+ sore) afraid, fear (exceedingly), reverence","pos":"verb","usage":"fear(62x), reverence(1x)"},"G5321":{"id":"G5321","lemma":"φανέρωσις","translit":"phanérōsis","derivation":"from G5319 (φανερόω);","strongs_def":"exhibition, i.e. (figuratively) expression, (by extension) a bestowment","kjv_def":"manifestation"},"G5338":{"id":"G5338","lemma":"φέγγος","translit":"phéngos","derivation":"probably akin to the base of G5457 (φῶς) (compare G5350 (φθέγγομαι));","strongs_def":"brilliancy","kjv_def":"light","pos":"neuter noun","usage":"light(3x)"},"G5327":{"id":"G5327","lemma":"φάραγξ","translit":"pháranx","derivation":"properly, strengthened from the base of G4008 (πέραν) or rather of G4486 (ῥήγνυμι);","strongs_def":"a gap or chasm, i.e. ravine (winter-torrent)","kjv_def":"valley","pos":"feminine noun","usage":"valley(1x)"},"G5314":{"id":"G5314","lemma":"φάγος","translit":"phágos","derivation":"from G5315 (φάγω);","strongs_def":"a glutton","kjv_def":"gluttonous","pos":"masculine noun","usage":"gluttonous(2x)"},"G5311":{"id":"G5311","lemma":"ὕψος","translit":"hýpsos","derivation":"from a derivative of G5228 (ὑπέρ);","strongs_def":"elevation, i.e. (abstractly) altitude, (specially), the sky, or (figuratively) dignity","kjv_def":"be exalted, height, (on) high","pos":"neuter noun","usage":"height(2x), high(1x)"},"G5393":{"id":"G5393","lemma":"Φλέγων","translit":"Phlégōn","derivation":"active participle of the base of G5395 (φλόξ);","strongs_def":"blazing; Phlegon, a Christian","kjv_def":"Phlegon","pos":"proper masculine noun","usage":"Phlegon(1x)"},"G5318":{"id":"G5318","lemma":"φανερός","translit":"phanerós","derivation":"from G5316 (φαίνω);","strongs_def":"shining, i.e. apparent (literally or figuratively); neuter (as adverb) publicly, externally","kjv_def":"abroad, + appear, known, manifest, open (+ -ly), outward (+ -ly)","pos":"adjective","usage":"manifest(9x), known(3x), outward(1x), appear(1x)"},"G5355":{"id":"G5355","lemma":"φθόνος","translit":"phthónos","derivation":"probably akin to the base of G5351 (φθείρω);","strongs_def":"ill-will (as detraction), i.e. jealousy (spite)","kjv_def":"envy","pos":"masculine noun","usage":"envy(8x), envying(1x)"},"G5334":{"id":"G5334","lemma":"φάσις","translit":"phásis","derivation":"from G5346 (φημί) (not the same as \"phase\", which is from G5316 (φαίνω));","strongs_def":"a saying, i.e. report","kjv_def":"tidings","pos":"feminine noun","usage":"tidings(1x)"},"G5369":{"id":"G5369","lemma":"φιλήδονος","translit":"philḗdonos","derivation":"from G5384 (φίλος) and G2237 (ἡδονή);","strongs_def":"fond of pleasure, i.e. voluptuous","kjv_def":"lover of pleasure"},"G5312":{"id":"G5312","lemma":"ὑψόω","translit":"hypsóō","derivation":"from G5311 (ὕψος);","strongs_def":"to elevate (literally or figuratively)","kjv_def":"exalt, lift up","pos":"verb","usage":"exalt(14x)"},"G5376":{"id":"G5376","lemma":"Φίλιππος","translit":"Phílippos","derivation":"from G5384 (φίλος) and G2462 (ἵππος);","strongs_def":"fond of horses; Philippus, the name of four Israelites","kjv_def":"Philip","pos":"proper masculine noun"},"G5322":{"id":"G5322","lemma":"φανός","translit":"phanós","derivation":"from G5316 (φαίνω);","strongs_def":"a lightener, i.e. light; lantern","kjv_def":"lantern","pos":"masculine noun","usage":"lantern(1x)"},"G5383":{"id":"G5383","lemma":"φιλοπρωτεύω","translit":"philoprōteúō","derivation":"from a compound of G5384 (φίλος) and G4413 (πρῶτος);","strongs_def":"to be fond of being first, i.e. ambitious of distinction","kjv_def":"love to have the preeminence"},"G5326":{"id":"G5326","lemma":"φάντασμα","translit":"phántasma","derivation":"from G5324 (φαντάζω);","strongs_def":"(properly concrete) a (mere) show (\"phantasm\"), i.e. spectre","kjv_def":"spirit","pos":"neuter noun","usage":"spirit(2x)"},"G5394":{"id":"G5394","lemma":"φλογίζω","translit":"phlogízō","derivation":"from G5395 (φλόξ);","strongs_def":"to cause a blaze, i.e. ignite (figuratively, to inflame with passion)","kjv_def":"set on fire","pos":"verb"},"G5306":{"id":"G5306","lemma":"ὕστερος","translit":"hýsteros","derivation":"comparative from G5259 (ὑπό) (in the sense of behind);","strongs_def":"later","kjv_def":"latter"},"G5361":{"id":"G5361","lemma":"φιλάδελφος","translit":"philádelphos","derivation":"from G5384 (φίλος) and G80 (ἀδελφός);","strongs_def":"fond of brethren, i.e. fraternal","kjv_def":"love as brethren"},"G5303":{"id":"G5303","lemma":"ὑστέρημα","translit":"hystérēma","derivation":"from G5302 (ὑστερέω);","strongs_def":"a deficit; specially, poverty","kjv_def":"that which is behind, (that which was) lack(-ing), penury, want","pos":"neuter noun","usage":"want(3x), lack(1x), penury(1x)"},"G5307":{"id":"G5307","lemma":"ὑφαντός","translit":"hyphantós","derivation":"from to weave;","strongs_def":"woven, i.e. (perhaps) knitted","kjv_def":"woven","pos":"adjective","usage":"woven(1x)"},"G5304":{"id":"G5304","lemma":"ὑστέρησις","translit":"hystérēsis","derivation":"from G5302 (ὑστερέω);","strongs_def":"a falling short, i.e. (specially), penury","kjv_def":"want","pos":"feminine noun","usage":"want(2x)"},"G5331":{"id":"G5331","lemma":"φαρμακεία","translit":"pharmakeía","derivation":"from G5332 (φαρμακεύς);","strongs_def":"medication (\"pharmacy\"), i.e. (by extension) magic (literally or figuratively)","kjv_def":"sorcery, witchcraft","pos":"feminine noun","usage":"sorcery(2x), witchcraft(1x)"},"G5330":{"id":"G5330","lemma":"Φαρισαῖος","translit":"Pharisaîos","derivation":"of Hebrew origin (compare H06567);","strongs_def":"a separatist, i.e. exclusively religious; a Pharisean, i.e. Jewish sectary","kjv_def":"Pharisee","pos":"masculine noun","usage":"Pharisee(100x)"},"G5356":{"id":"G5356","lemma":"φθορά","translit":"phthorá","derivation":"from G5351 (φθείρω);","strongs_def":"decay, i.e. ruin (spontaneous or inflicted, literally or figuratively)","kjv_def":"corruption, destroy, perish","pos":"feminine noun","usage":"corruption(7x), destroy(1x)"},"G5308":{"id":"G5308","lemma":"ὑψηλός","translit":"hypsēlós","derivation":"from G5311 (ὕψος);","strongs_def":"lofty (in place or character)","kjv_def":"high(-er, -ly) (esteemed)","pos":"adjective","usage":"high(8x), higher(1x)"},"G5320":{"id":"G5320","lemma":"φανερῶς","translit":"phanerōs","derivation":"adverb from G5318 (φανερός);","strongs_def":"plainly, i.e. clearly or publicly","kjv_def":"evidently, openly","pos":"adverb","usage":"openly(2x), evidently(1x)"},"G5341":{"id":"G5341","lemma":"φελόνης","translit":"phelónēs","derivation":"by transposition for a derivative probably of G5316 (φαίνω) (as showing outside the other garments);","strongs_def":"a mantle (surtout)","kjv_def":"cloke"},"G5384":{"id":"G5384","lemma":"φίλος","translit":"phílos","derivation":"properly, dear, i.e. a friend;","strongs_def":"actively, fond, i.e. friendly (still as a noun, an associate, neighbor, etc.)","kjv_def":"friend","pos":"adjective","usage":"friend(29x)"},"G5364":{"id":"G5364","lemma":"φιλανθρώπως","translit":"philanthrṓpōs","derivation":"adverb from a compound of G5384 (φίλος) and G444 (ἄνθρωπος);","strongs_def":"fondly to man (\"philanthropically\"), i.e. humanely","kjv_def":"courteously","pos":"adverb","usage":"courteously(1x)"},"G5392":{"id":"G5392","lemma":"φιμόω","translit":"phimóō","derivation":"from (a muzzle);","strongs_def":"to muzzle","kjv_def":"muzzle","pos":"verb","usage":"muzzle(2x)"},"G5370":{"id":"G5370","lemma":"φίλημα","translit":"phílēma","derivation":"from G5368 (φιλέω);","strongs_def":"a kiss","kjv_def":"kiss","pos":"neuter noun","usage":"kiss(7x)"},"G5387":{"id":"G5387","lemma":"φιλόστοργος","translit":"philóstorgos","derivation":"from G5384 (φίλος) and (cherishing one's kindred, especially parents or children);","strongs_def":"fond of natural relatives, i.e. fraternal towards fellow Christian","kjv_def":"kindly affectioned","pos":"adjective"},"G5349":{"id":"G5349","lemma":"φθαρτός","translit":"phthartós","derivation":"from G5351 (φθείρω);","strongs_def":"decayed, i.e. (by implication) perishable","kjv_def":"corruptible","pos":"adjective","usage":"corruptible(6x)"},"G5335":{"id":"G5335","lemma":"φάσκω","translit":"pháskō","derivation":"prolongation from the same as G5346 (φημί);","strongs_def":"to assert","kjv_def":"affirm, profess, say","pos":"verb","usage":"say(2x), affirm(1x), profess(1x)"},"G5360":{"id":"G5360","lemma":"φιλαδελφία","translit":"philadelphía","derivation":"from G5361 (φιλάδελφος);","strongs_def":"fraternal affection","kjv_def":"brotherly love (kindness), love of the brethren","pos":"feminine noun"},"G5342":{"id":"G5342","lemma":"φέρω","translit":"phérō","derivation":"a primary verb (for which other, and apparently not cognate ones are used in certain tenses only; namely, ; and ;","strongs_def":"to \"bear\" or carry (in a very wide application, literally and figuratively, as follows)","kjv_def":"be, bear, bring (forth), carry, come, + let her drive, be driven, endure, go on, lay, lead, move, reach, rushing, uphold","pos":"verb","usage":"bring(34x), bear(8x), come(3x), reach(2x), endure(2x), carry(1x)"},"G5395":{"id":"G5395","lemma":"φλόξ","translit":"phlóx","derivation":"from a primary (to \"flash\" or \"flame\");","strongs_def":"a blaze","kjv_def":"flame(-ing)","pos":"feminine noun","usage":"flame(6x), flaming(1x)"},"G5377":{"id":"G5377","lemma":"φιλόθεος","translit":"philótheos","derivation":"from G5384 (φίλος) and G2316 (θεός);","strongs_def":"fond of God, i.e. pious","kjv_def":"lover of God"},"G5332":{"id":"G5332","lemma":"φαρμακεύς","translit":"pharmakeús","derivation":"from (a drug, i.e. spell-giving potion);","strongs_def":"a druggist (\"pharmacist\") or poisoner, i.e. (by extension) a magician","kjv_def":"sorcerer","pos":"masculine noun","usage":"sorcerer(1x)"},"G5363":{"id":"G5363","lemma":"φιλανθρωπία","translit":"philanthrōpía","derivation":"from the same as G5364 (φιλανθρώπως);","strongs_def":"fondness of mankind, i.e. benevolence (\"philanthropy\")","kjv_def":"kindness, love towards man","pos":"feminine noun","usage":"kindness(1x)"},"G5313":{"id":"G5313","lemma":"ὕψωμα","translit":"hýpsōma","derivation":"from G5312 (ὑψόω);","strongs_def":"an elevated place or thing, i.e. (abstractly) altitude, or (by implication) a barrier (figuratively)","kjv_def":"height, high thing","pos":"neuter noun","usage":"height(1x)"},"G5333":{"id":"G5333","lemma":"φάρμακος","translit":"phármakos","derivation":"the same as 5332","kjv_def":"sorcerer","pos":"adjective","usage":"sorcerer(1x)"},"G5300":{"id":"G5300","lemma":"ὗς","translit":"hŷs","derivation":"apparently a primary word;","strongs_def":"a hog (\"swine\")","kjv_def":"sow"},"G5375":{"id":"G5375","lemma":"Φίλιπποι","translit":"Phílippoi","derivation":"plural of G5376 (Φίλιππος);","strongs_def":"Philippi, a place in Macedonia","kjv_def":"Philippi","pos":"proper locative noun","usage":"Philippi(6x)"},"G5389":{"id":"G5389","lemma":"φιλοτιμέομαι","translit":"philotiméomai","derivation":"middle voice from a compound of G5384 (φίλος) and G5092 (τιμή);","strongs_def":"to be fond of honor, i.e. emulous (eager or earnest to do something)","kjv_def":"labour, strive, study","pos":"verb","usage":"strive(1x), labour(1x), study(1x)"},"G5346":{"id":"G5346","lemma":"φημί","translit":"phēmí","derivation":"properly, the same as the base of G5457 (φῶς) and G5316 (φαίνω);","strongs_def":"to show or make known one's thoughts, i.e. speak or say","kjv_def":"affirm, say","pos":"verb","usage":"say(57x), affirm(1x)"},"G5397":{"id":"G5397","lemma":"φλύαρος","translit":"phlýaros","derivation":"from (to bubble);","strongs_def":"a garrulous person, i.e. prater","kjv_def":"tattler"},"G5310":{"id":"G5310","lemma":"ὕψιστος","translit":"hýpsistos","derivation":"superlative from the base of G5311 (ὕψος);","strongs_def":"highest, i.e. (masculine singular) the Supreme (God), or (neuter plural) the heavens","kjv_def":"most high, highest","pos":"adjective","usage":"highest(8x)"},"G5328":{"id":"G5328","lemma":"Φαραώ","translit":"Pharaṓ","derivation":"of foreign origin (H06547);","strongs_def":"Pharao (i.e. Pharoh), an Egyptian king","kjv_def":"Pharaoh","pos":"masculine noun","usage":"Pharaoh(5x)"},"G5319":{"id":"G5319","lemma":"φανερόω","translit":"phaneróō","derivation":"from G5318 (φανερός);","strongs_def":"to render apparent (literally or figuratively)","kjv_def":"appear, manifestly declare, (make) manifest (forth), shew (self)","pos":"verb","usage":"appear(12x), manifest(9x), show(3x)"},"G5390":{"id":"G5390","lemma":"φιλοφρόνως","translit":"philophrónōs","derivation":"adverb from G5391 (φιλόφρων);","strongs_def":"with friendliness of mind, i.e. kindly","kjv_def":"courteously"},"G5382":{"id":"G5382","lemma":"φιλόξενος","translit":"philóxenos","derivation":"from G5384 (φίλος) and G3581 (ξένος);","strongs_def":"fond of guests, i.e. hospitable","kjv_def":"given to (lover of, use) hospitality","pos":"adjective"},"G5371":{"id":"G5371","lemma":"Φιλήμων","translit":"Philḗmōn","derivation":"from G5368 (φιλέω);","strongs_def":"friendly; Philemon, a Christian","kjv_def":"Philemon","pos":"proper masculine noun","usage":"Philemon(2x)"},"G5350":{"id":"G5350","lemma":"φθέγγομαι","translit":"phthéngomai","derivation":"probably akin to G5338 (φέγγος) and thus to G5346 (φημί);","strongs_def":"to utter a clear sound, i.e. (generally) to proclaim","kjv_def":"speak","pos":"verb","usage":"speak(3x)"},"G5398":{"id":"G5398","lemma":"φοβερός","translit":"phoberós","derivation":"from G5401 (φόβος);","strongs_def":"frightful, i.e. (objectively) formidable","kjv_def":"fearful, terrible","pos":"adjective","usage":"fearful(2x), terrible(1x)"},"G5378":{"id":"G5378","lemma":"Φιλόλογος","translit":"Philólogos","derivation":"from G5384 (φίλος) and G3056 (λόγος);","strongs_def":"fond of words, i.e. talkative (argumentative, learned, \"philological\"); Philologus, a Christian","kjv_def":"Philologus","pos":"proper masculine noun","usage":"Philologus(1x)"},"G5325":{"id":"G5325","lemma":"φαντασία","translit":"phantasía","derivation":"from a derivative of G5324 (φαντάζω);","strongs_def":"(properly abstract) a (vain) show (\"fantasy\")","kjv_def":"pomp","pos":"feminine noun","usage":"pomp(1x)"},"G5305":{"id":"G5305","lemma":"ὕστερον","translit":"hýsteron","derivation":"neuter of G5306 (ὕστερος) as adverb;","strongs_def":"more lately, i.e. eventually","kjv_def":"afterward, (at the) last (of all)","pos":"adjective","usage":"afterward(8x), last(2x)"},"G5354":{"id":"G5354","lemma":"φθονέω","translit":"phthonéō","derivation":"from G5355 (φθόνος);","strongs_def":"to be jealous of","kjv_def":"envy","pos":"verb","usage":"envy(1x)"},"G5358":{"id":"G5358","lemma":"φιλάγαθος","translit":"philágathos","derivation":"from G5384 (φίλος) and G18 (ἀγαθός);","strongs_def":"fond to good, i.e. a promoter of virtue","kjv_def":"love of good men","pos":"adjective"},"G5352":{"id":"G5352","lemma":"φθινοπωρινός","translit":"phthinopōrinós","derivation":"from derivative of (