om G5384 (φίλος) and G5424 (φρήν);","strongs_def":"friendly of mind, i.e. kind","kjv_def":"courteous"},"G5317":{"id":"G5317","lemma":"Φάλεκ","translit":"Phálek","derivation":"of Hebrew origin (H06389);","strongs_def":"Phalek (i.e. Peleg), a patriarch","kjv_def":"Phalec","pos":"proper masculine noun","usage":"Phalec(1x)"},"G5381":{"id":"G5381","lemma":"φιλονεξία","translit":"philonexía","derivation":"from G5382 (φιλόξενος);","strongs_def":"hospitableness","kjv_def":"entertain stranger, hospitality","pos":"feminine noun","usage":"hospitality(1x)"},"G5359":{"id":"G5359","lemma":"Φιλαδέλφεια","translit":"Philadélpheia","derivation":"from (the same as G5361 (φιλάδελφος)), a king of Pergamos;","strongs_def":"Philadelphia, a place in Asia Minor","kjv_def":"Philadelphia","pos":"proper locative noun","usage":"Philadelphia(2x)"},"G5323":{"id":"G5323","lemma":"Φανουήλ","translit":"Phanouḗl","derivation":"of Hebrew origin (H06439);","strongs_def":"Phanuel (i.e. Penuel), an Israelite","kjv_def":"Phanuel","pos":"proper masculine noun","usage":"Phanuel(1x)"},"G5365":{"id":"G5365","lemma":"φιλαργυρία","translit":"philargyría","derivation":"from G5366 (φιλάργυρος);","strongs_def":"avarice","kjv_def":"love of money"},"G5367":{"id":"G5367","lemma":"φίλαυτος","translit":"phílautos","derivation":"from G5384 (φίλος) and G846 (αὐτός);","strongs_def":"fond of self, i.e. selfish","kjv_def":"lover of own self"},"G5373":{"id":"G5373","lemma":"φιλία","translit":"philía","derivation":"from G5384 (φίλος);","strongs_def":"fondness","kjv_def":"friendship","pos":"feminine noun","usage":"friendship(1x)"},"G5396":{"id":"G5396","lemma":"φλυαρέω","translit":"phlyaréō","derivation":"from G5397 (φλύαρος);","strongs_def":"to be a babbler or trifler, i.e. (by implication) to berate idly or mischievously","kjv_def":"prate against"},"G5315":{"id":"G5315","lemma":"φάγω","translit":"phágō","derivation":"a primary verb (used as an alternate of G2068 (ἐσθίω) in certain tenses);","strongs_def":"to eat (literally 