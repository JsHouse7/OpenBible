{"H4400":{"id":"H4400","lemma":"מַלְאֲכוּת","translit":"malʼăkûwth","pron":"mal-ak-ooth'","derivation":"from the same as H4397 (מֲלְאָךְ);","strongs_def":"a message","kjv_def":"message.","pos":"feminine noun","usage":"message(1x)"},"H4401":{"id":"H4401","lemma":"מַלְאָכִי","translit":"Malʼâkîy","pron":"mal-aw-kee'","derivation":"from the same as H4397 (מֲלְאָךְ); ministrative;","strongs_def":"Malaki, a prophet","kjv_def":"Malachi."},"H4402":{"id":"H4402","lemma":"מִלֵּאת","translit":"millêʼth","pron":"mil-layth'","derivation":"from H4390 (מָלֵא);","strongs_def":"fulness, i.e. (concretely) a plump socket (of the eye)","kjv_def":"[idiom] fitly."},"H4403":{"id":"H4403","lemma":"מַלְבּוּשׁ","translit":"malbûwsh","pron":"mal-boosh'","derivation":"or מַלְבֻּשׁ; from H3847 (לָבַשׁ);","strongs_def":"a garment, or (collectively) clothing","kjv_def":"apparel, raiment, vestment.","pos":"masculine noun","usage":"apparel(4x), raiment(3x), vestments(1x)"},"H4404":{"id":"H4404","lemma":"מַלְבֵּן","translit":"malbên","pron":"mal-bane'","derivation":"from H3835 (לָבַן) (denominative);","strongs_def":"a brickkiln","kjv_def":"brickkiln.","pos":"masculine noun","usage":"brickkiln(3x)"},"H4405":{"id":"H4405","lemma":"מִלָּה","translit":"millâh","pron":"mil-law'","derivation":"from H4448 (מָלַל) (plural masculine as if from מִלֶּה;","strongs_def":"a word; collectively, a discourse; figuratively, a topic","kjv_def":"[phrase] answer, by-word, matter, any thing (what) to say, to speak(-ing), speak, talking, word.","pos":"feminine noun","usage":"word(23x), speech(6x), say(2x), speaking(2x), byword(1x), matter(1x), speak(1x), talking(1x)"},"H4406":{"id":"H4406","lemma":"מִלָּה","translit":"millâh","pron":"mil-law'","derivation":"(Aramaic) corresponding to H4405 (מִלָּה);","strongs_def":"a word, command, discourse, or subject","kjv_def":"commandment, matter, thing. word.","pos":"feminine noun","usage":"thing(11x), word(7x), matter(5x), commandment(1x)"},"H4407":{"id":"H4407","lemma":"מִלּוֹא",