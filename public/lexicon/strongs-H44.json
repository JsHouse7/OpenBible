":"from H4376 (מָכַר);","strongs_def":"merchandise; abstractly, a selling","kjv_def":"[idiom] ought, (that which cometh of) sale, that which...sold, ware.","pos":"masculine noun","usage":"sale(2x), ought(1x), ware(1x), sold(1x)"},"H4466":{"id":"H4466","lemma":"מִמְכֶּרֶת","translit":"mimkereth","pron":"mim-keh'-reth","derivation":"feminine of H4465 (מִמְכָּר);","strongs_def":"a sale","kjv_def":"[phrase] sold as.","pos":"feminine noun","usage":"as(1x)"},"H4467":{"id":"H4467","lemma":"מַמְלָכָה","translit":"mamlâkâh","pron":"mam-law-kaw'","derivation":"from H4427 (מָלַךְ);","strongs_def":"dominion, i.e. (abstractly) the estate (rule) or (concretely) the country (realm)","kjv_def":"kingdom, king's, reign, royal.","pos":"feminine noun","usage":"kingdom(110x), royal(4x), reign(2x), king's(1x)"},"H4468":{"id":"H4468","lemma":"מַמְלָכוּת","translit":"mamlâkûwth","pron":"mam-law-kooth'","derivation":"a form of H4467 (מַמְלָכָה) and equiv. to it","strongs_def":"{dominion, i.e. (abstractly) the estate (rule) or (concretely) the country (realm)}","kjv_def":"kingdom, reign.","pos":"masculine noun","usage":"kingdom(8x), reign(1x)"},"H4469":{"id":"H4469","lemma":"מַמְסָךְ","translit":"mamçâk","pron":"mam-sawk'","derivation":"from H4537 (מָסַךְ);","strongs_def":"mixture, i.e. (specifically) wine mixed (with water or spices)","kjv_def":"drink-offering, mixed wine.","pos":"masculine noun"},"H4470":{"id":"H4470","lemma":"מֶמֶר","translit":"memer","pron":"meh'-mer","derivation":"from an unused root meaning to grieve;","strongs_def":"sorrow","kjv_def":"bitterness.","pos":"masculine noun","usage":"bitterness(1x)"},"H4471":{"id":"H4471","lemma":"מַמְרֵא","translit":"Mamrêʼ","pron":"mam-ray'","derivation":"from H4754 (מָרָא)(in the sense of vigor); lusty;","strongs_def":"Mamre, an Amorite","kjv_def":"Mamre.","pos":"proper locative noun, proper masculine noun","usage":"Mamre(10x)"},"H4472":{"id":"H4472","lemma":"מַמְרֹר","translit":"mamrôr","pron":"mam-rore'","derivation":"from H4843 (מָרַר);","strongs_def":"a bitterness, i.e. (figuratively) calamity","kjv_def":"bitterness."},"H4473":{"id":"H4473","lemma":"מִמְשַׁח","translit":"mimshach","pron":"mim-shakh'","derivation":"from H4886 (מָשַׁח), in the sense of expansion;","strongs_def":"outspread (i.e. with outstretched wings)","kjv_def":"anointed.","pos":"masculine noun","usage":"anointed(1x)"},"H4474":{"id":"H4474","lemma":"מִמְשָׁל","translit":"mimshâl","pron":"mim-shawl'","derivation":"from H4910 (מָשַׁל);","strongs_def":"a ruler or (abstractly) rule","kjv_def":"dominion, that ruled.","pos":"masculine noun","usage":"dominion(2x), ruled(1x)"},"H4475":{"id":"H4475","lemma":"מֶמְשָׁלָה","translit":"memshâlâh","pron":"mem-shaw-law'","derivation":"feminine of H4474 (מִמְשָׁל);","strongs_def":"rule; also (concretely in plural) a realm or a ruler","kjv_def":"dominion, government, power, to rule.","pos":"feminine noun","usage":"dominion(10x), rule(4x), government(1x), power(1x)"},"H4476":{"id":"H4476","lemma":"מִמְשָׁק","translit":"mimshâq","pron":"mim-shawk'","derivation":"from the same as H4943 (מֶשֶׁק);","strongs_def":"a possession","kjv_def":"breeding.","pos":"masculine noun","usage":"breeding(1x)"},"H4477":{"id":"H4477","lemma":"מַמְתַּק","translit":"mamtaq","pron":"mam-tak'","derivation":"from H4985 (מָתַק);","strongs_def":"something sweet (literally or figuratively)","kjv_def":"(most) sweet.","pos":"masculine noun","usage":"sweet(2x)"},"H4478":{"id":"H4478","lemma":"מָן","translit":"mân","pron":"mawn","derivation":"from H4100 (מָה);","strongs_def":"literally a whatness (so to speak), i.e. manna (so called from the question about it)","kjv_def":"manna.","pos":"masculine noun","usage":"manna(14x)"},"H4479":{"id":"H4479","lemma":"מָן","translit":"mân","pron":"mawn","derivation":"(Aramaic) from H4101 (מָה);","strongs_def":"who or what (properly, interrogatively, hence, also indefinitely and relatively)","kjv_def":"what, who(-msoever, [phrase] -so).","pos":"interrogative pronoun","usage":"whomsoever(4x), 