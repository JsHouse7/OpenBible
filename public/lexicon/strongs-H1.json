{"H100":{"id":"H100","lemma":"אַגְמוֹן","translit":"ʼagmôwn","pron":"ag-mone'","derivation":"from the same as H98 (אֲגַם); a marshy pool (others from a different root, a kettle); by implication","strongs_def":"a bulrush (as growing there); collectively a rope of bulrushes","kjv_def":"bulrush, caldron, hook, rush.","pos":"masculine noun","usage":"rush(2x), bulrush(1x), caldron(1x), hook(1x)"},"H101":{"id":"H101","lemma":"אַגָּן","translit":"ʼaggân","pron":"ag-gawn'","derivation":"probably from H5059 (נָגַן);","strongs_def":"a bowl (as pounded out hollow)","kjv_def":"basin, cup, goblet.","pos":"masculine noun","usage":"basons(1x), cups(1x), goblet(1x)"},"H102":{"id":"H102","lemma":"אַגָּף","translit":"ʼaggâph","pron":"ag-gawf'","derivation":"probably from H5062 (נָגַף) (through the idea of impending); a cover or heap; i.e.","strongs_def":"(only plural) wings of an army, or crowds of troops","kjv_def":"bands.","pos":"masculine noun","usage":"bands(7x)"},"H103":{"id":"H103","lemma":"אָגַר","translit":"ʼâgar","pron":"aw-gar'","derivation":"a primitive root;","strongs_def":"to harvest","kjv_def":"gather.","pos":"verb","usage":"gather(3x)"},"H104":{"id":"H104","lemma":"אִגְּרָא","translit":"ʼiggᵉrâʼ","pron":"ig-er-aw'","derivation":"(Aramaic) of Persian origin;","strongs_def":"an epistle (as carried by a state courier or postman)","kjv_def":"letter.","pos":"feminine noun","usage":"letter(3x)"},"H105":{"id":"H105","lemma":"אֲגַרְטָל","translit":"ʼăgarṭâl","pron":"ag-ar-tawl'","derivation":"of uncertain derivation;","strongs_def":"a basin","kjv_def":"charger.","pos":"masculine noun","usage":"chargers(2x)"},"H106":{"id":"H106","lemma":"אֶגְרֹף","translit":"ʼegrôph","pron":"eg-rofe'","derivation":"from H1640 (גָּרַף) (in the sense of grasping);","strongs_def":"the clenched hand","kjv_def":"fist.","pos":"masculine noun","usage":"fist(2x)"},"H107":{"id":"H107","lemma":"אִגֶּרֶת","translit":"ʼiggereth","pron":"ig-eh'-reth","derivation":"feminine of H104 (אִגְּרָא);","strongs_def":"an epistle","kjv_def":"letter.","pos":"feminine noun"},"H108":{"id":"H108","lemma":"אֵד","translit":"ʼêd","pron":"ade","derivation":"from the same as H181 (אוּד) (in the sense of enveloping);","strongs_def":"a fog","kjv_def":"mist, vapor.","pos":"masculine noun","usage":"mist(1x), vapour(1x)"},"H109":{"id":"H109","lemma":"אָדַב","translit":"ʼâdab","pron":"aw-dab'","derivation":"a primitive root;","strongs_def":"to languish","kjv_def":"grieve."},"H110":{"id":"H110","lemma":"אַדְבְּאֵל","translit":"ʼAdbᵉʼêl","pron":"ad-beh-ale'","derivation":"probably from H109 (אָדַב) (in the sense of chastisement) and H410 (אֵל); disciplined of God;","strongs_def":"Adbeel, a son of Ishmael","kjv_def":"Adbeel.","pos":"proper masculine noun","usage":"Adbeel(2x)"},"H111":{"id":"H111","lemma":"אֲדַד","translit":"ʼĂdad","pron":"ad-ad'","derivation":"probably an orthographical variation for H2301 (חֲדַד);","strongs_def":"Adad (or Hadad), an Edomite","kjv_def":"Hadad."},"H112":{"id":"H112","lemma":"אִדּוֹ","translit":"ʼIddôw","pron":"id-do","derivation":"of uncertain derivation;","strongs_def":"Iddo, an Israelite","kjv_def":"Iddo.","pos":"proper masculine noun","usage":"Iddo(2x)"},"H113":{"id":"H113","lemma":"אָדוֹן","translit":"ʼâdôwn","pron":"aw-done'","derivation":"or (shortened) אָדֹן; from an unused root (meaning to rule);","strongs_def":"sovereign, i.e. controller (human or divine)","kjv_def":"lord, master, owner. Compare also names beginning with 'Adoni-'.","pos":"masculine noun","usage":"lord(197x), Lord(31x), owner(1x), sir(1x)"},"H114":{"id":"H114","lemma":"אַדּוֹן","translit":"ʼAddôwn","pron":"ad-done'","derivation":"probably intensive for H113 (אָדוֹן); powerful;","strongs_def":"Addon, apparently an Israelite","kjv_def":"Addon.","pos":"adjective","usage":"Addon(1x)"},"H115":{"id":"H115","lemma":"אֲדוֹרַיִם","translit":"ʼĂdôwrayim","pron":"ad-o-rah'-yim","derivation":"dual from H142 (אָדַר) (in the sense of eminence); double mound;","strongs_def":"Adorajim, a place in Palestine","kjv_def":"Adoraim."},"H116":{"id":"H116","lemma":"אֱדַיִן","translit":"ʼĕdayin","pron":"ed-ah'-yin","derivation":"(Aramaic) of uncertain derivation;","strongs_def":"then (of time)","kjv_def":"now, that time, then.","pos":"adverb","usage":"then(55x), now(1x), time(1x)"},"H117":{"id":"H117","lemma":"אַדִּיר","translit":"ʼaddîyr","pron":"ad-deer'","derivation":"from H142 (אָדַר);","strongs_def":"wide or (generally) large; figuratively, powerful","kjv_def":"excellent, famous, gallant, glorious, goodly, lordly, mighty(-ier one), noble, principal, worthy.","pos":"adjective","usage":"nobles(7x), excellent(4x), mighty(5x), principal(3x), famous(2x), gallant(1x), glorious(1x), goodly(1x), lordly(1x), worthies(1x)"},"H118":{"id":"H118","lemma":"אֲדַלְיָא","translit":"ʼĂdalyâʼ","pron":"ad-al-yaw'","derivation":"of Persian derivation;","strongs_def":"Adalja, a son of Haman","kjv_def":"Adalia.","pos":"proper masculine noun","usage":"Adalia(1x)"},"H119":{"id":"H119","lemma":"אָדַם","translit":"ʼâdam","pron":"aw-dam'","derivation":"to show blood (in the face), i.e.","strongs_def":"flush or turn rosy","kjv_def":"be (dyed, made) red (ruddy).","pos":"verb","usage":"red(4x), ruddy(1x)"},"H120":{"id":"H120","lemma":"אָדָם","translit":"ʼâdâm","pron":"aw-dawm'","derivation":"from H119 (אָדַם);","strongs_def":"ruddy i.e. a human being (an individual or the species, mankind, etc.)","kjv_def":"[idiom] another, [phrase] hypocrite, [phrase] common sort, [idiom] low, man (mean, of low degree), person.","pos":"masculine noun","usage":"man(408x), men(121x), Adam(13x), hypocrite(1x)"},"H121":{"id":"H121","lemma":"אָדָם","translit":"ʼÂdâm","pron":"aw-dawm'","derivation":"the same as H120 (אָדָם);","strongs_def":"Adam the name of the first man, also of a place in Palestine","kjv_def":"Adam.","pos":"proper masculine noun","usage":"Adam(9x)"},"H122":{"id":"H122","lemma":"אָדֹם","translit":"ʼâdôm","pron":"aw-dome'","derivation":"from H119 (אָדַם);","strongs_def":"rosy","kjv_def":"red, ruddy.","pos":"adjective","usage":"red(8x), ruddy(1x)"},"H123":{"id":"H123","lemma":"אֱדֹם","translit":"ʼĔdôm","pron":"ed-ome'","derivation":"or (fully) אֱדוֹם ; from H122 (אָדֹם); red (see Genesis 25:25);","strongs_def":"Edom, the elder twin-brother of Jacob; hence the region (Idumaea) occupied by him","kjv_def":"Edom, Edomites, Idumea.","pos":"proper masculine noun","usage":"Edom(87x), Edomites(9x), Idumea(4x)"},"H124":{"id":"H124","lemma":"אֹדֶם","translit":"ʼôdem","pron":"o'-dem","derivation":"from H119 (אָדַם);","strongs_def":"redness, i.e. the ruby, garnet, or some other red gem","kjv_def":"sardius.","pos":"feminine noun","usage":"sardius(3x)"},"H125":{"id":"H125","lemma":"אֲדַמְדָּם","translit":"ʼădamdâm","pron":"ad-am-dawm'","derivation":"reduplicated from H119 (אָדַם);","strongs_def":"reddish","kjv_def":"(somewhat) reddish.","pos":"adjective","usage":"reddish(6x)"},"H126":{"id":"H126","lemma":"אַדְמָה","translit":"ʼAdmâh","pron":"ad-maw'","derivation":"contracted for H127 (אֲדָמָה); earthy;","strongs_def":"Admah, a place near the Dead Sea","kjv_def":"Admah.","pos":"proper locative noun","usage":"Admah(5x)"},"H127":{"id":"H127","lemma":"אֲדָמָה","translit":"ʼădâmâh","pron":"ad-aw-maw'","derivation":"from H119 (אָדַם);","strongs_def":"soil (from its general redness)","kjv_def":"country, earth, ground, husband(-man) (-ry), land.","pos":"feminine noun","usage":"earth(53x), ground(43x), country(1x), husbandman(2x), husbandry(1x)"},"H128":{"id":"H128","lemma":"אֲדָמָה","translit":"ʼĂdâmâh","pron":"ad-aw-maw'","derivation":"the same as H127 (אֲדָמָה);","strongs_def":"Adamah, a place in Palestine","kjv_def":"Adamah.","pos":"proper locative noun","usage":"Adamah(1x)"},"H129":{"id":"H129","lemma":"אֲדָמִי","translit":"ʼĂdâmîy","pron":"ad-aw-mee'","derivation":"from H127 (אֲדָמָה); earthy;","strongs_def":"Adami, a place in Palestine","kjv_def":"Adami.","pos":"proper locative noun","usage":"Adami(1x)"},"H130":{"id":"H130","lemma":"אֱדֹמִי","translit":"ʼĔdômîy","pron":"ed-o-mee'","