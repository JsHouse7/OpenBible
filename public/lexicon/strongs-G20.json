to illuminate (figuratively)","kjv_def":"give light","pos":"verb"},"G2006":{"id":"G2006","lemma":"ἐπιτήδειος","translit":"epitḗdeios","derivation":"from (enough);","strongs_def":"serviceable, i.e. (by implication) requisite","kjv_def":"things which are needful","pos":"adjective"},"G2013":{"id":"G2013","lemma":"ἐπιτυγχάνω","translit":"epitynchánō","derivation":"from G1909 (ἐπί) and G5177 (τυγχάνω);","strongs_def":"to chance upon, i.e. (by implication) to attain","kjv_def":"obtain","pos":"verb","usage":"obtain(5x)"},"G2028":{"id":"G2028","lemma":"ἐπονομάζω","translit":"eponomázō","derivation":"from G1909 (ἐπί) and G3687 (ὀνομάζω);","strongs_def":"to name further, i.e. denominate","kjv_def":"call","pos":"verb","usage":"call(1x)"},"G2081":{"id":"G2081","lemma":"ἔσωθεν","translit":"ésōthen","derivation":"from G2080 (ἔσω);","strongs_def":"from inside; also used as equivalent to G2080 (ἔσω) (inside)","kjv_def":"inward(-ly), (from) within, without","pos":"adverb","usage":"within(7x), inwardly(1x), without(1x)"},"G2027":{"id":"G2027","lemma":"ἐποκέλλω","translit":"epokéllō","derivation":"from G1909 (ἐπί) and (to urge);","strongs_def":"to drive upon the shore, i.e. to beach a vessel","kjv_def":"run aground","pos":"verb"},"G2075":{"id":"G2075","lemma":"ἐστέ","translit":"esté","derivation":"second person plural present indicative of G1510 (εἰμί);","strongs_def":"ye are","kjv_def":"be, have been, belong","pos":"verb","usage":"are(82x), be(5x), is(2x)"},"G2040":{"id":"G2040","lemma":"ἐργάτης","translit":"ergátēs","derivation":"from G2041 (ἔργον);","strongs_def":"a toiler; figuratively, a teacher","kjv_def":"labourer, worker(-men)","pos":"masculine noun","usage":"labourer(10x), workman(3x), worker(3x)"},"G2098":{"id":"G2098","lemma":"εὐαγγέλιον","translit":"euangélion","derivation":"from the same as G2097 (εὐαγγελίζω);","strongs_def":"a good message, i.e. the gospel","kjv_def":"gospel","pos":"neuter noun","usage":"gospel(46x)"},"G2032":{"id":"G2032","lemma":"ἐπουράνιος","translit":"epouránios","derivation":"from G1909 (ἐπί) and G3772 (οὐρανός);","strongs_def":"above the sky","kjv_def":"celestial, (in) heaven(-ly), high","pos":"adjective","usage":"heavenly(16x), celestial(2x), high(1x)"},"G2080":{"id":"G2080","lemma":"ἔσω","translit":"ésō","derivation":"from G1519 (εἰς);","strongs_def":"inside (as preposition or adjective)","kjv_def":"(with-)in(-ner, -to, -ward)","pos":"adverb","usage":"within(3x), in(1x), into(1x), inward(1x), inner(1x)"},"G2024":{"id":"G2024","lemma":"ἐπιχορηγία","translit":"epichorēgía","derivation":"from G2023 (ἐπιχορηγέω);","strongs_def":"contribution","kjv_def":"supply","pos":"feminine noun","usage":"supply(2x)"},"G2086":{"id":"G2086","lemma":"ἑτεροζυγέω","translit":"heterozygéō","derivation":"from a compound of G2087 (ἕτερος) and G2218 (ζυγός);","strongs_def":"to yoke up differently, i.e. (figuratively) to associate discordantly","kjv_def":"unequally yoke together with"},"G2004":{"id":"G2004","lemma":"ἐπιτάσσω","translit":"epitássō","derivation":"from G1909 (ἐπί) and G5021 (τάσσω);","strongs_def":"to arrange upon, i.e. order","kjv_def":"charge, command, injoin","pos":"verb","usage":"command(8x), charge(1x), enjoin(1x)"},"G2088":{"id":"G2088","lemma":"ἑτέρως","translit":"hetérōs","derivation":"adverb from G2087 (ἕτερος);","strongs_def":"differently","kjv_def":"otherwise","pos":"adverb","usage":"otherwise(1x)"},"G2002":{"id":"G2002","lemma":"ἐπισωρεύω","translit":"episōreúō","derivation":"from G1909 (ἐπί) and G4987 (σωρεύω);","strongs_def":"to accumulate further, i.e. (figuratively) seek additionally","kjv_def":"heap"},"G2053":{"id":"G2053","lemma":"ἔριον","translit":"érion","derivation":"of obscure affinity;","strongs_def":"wool","kjv_def":"wool","pos":"neuter noun","usage":"wool(2x)"},"G2014":{"id":"G2014","lemma":"ἐπιφαίνω","translit":"epiphaínō","derivation":"from G1909 (ἐπί) and G5316 (φαίνω);","strongs_def":"to shine upon, i.e. become (literally) visible or (figuratively) known","kjv_def":"appear, give light","pos":"verb","usage":"appear(3x)"},"G2051":{"id":"G2051","lemma":"ἐρίζω","translit":"erízō","derivation":"from G2054 (ἔρις);","strongs_def":"to wrangle","kjv_def":"strive","pos":"verb","usage":"strive(1x)"},"G2003":{"id":"G2003","lemma":"ἐπιταγή","translit":"epitagḗ","derivation":"from G2004 (ἐπιτάσσω);","strongs_def":"an injunction or decree; by implication, authoritativeness","kjv_def":"authority, commandment","pos":"feminine noun","usage":"commandment(6x), authority(1x)"},"G2015":{"id":"G2015","lemma":"ἐπιφάνεια","translit":"epipháneia","derivation":"from G2016 (ἐπιφανής);","strongs_def":"a manifestation, i.e. (specially) the advent of Christ (past or future)","kjv_def":"appearing, brightness","pos":"feminine noun","usage":"appearing(5x), brightness(1x)"}}