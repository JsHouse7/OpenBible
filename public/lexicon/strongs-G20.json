3","lemma":"ἑσπέρα","translit":"hespéra","derivation":"feminine of an adjective hesperos (evening); the eve (G5610 (ὥρα) being implied)","kjv_def":"evening(-tide)","pos":"feminine noun","usage":"evening(2x), eventide(1x)"},"G2082":{"id":"G2082","lemma":"ἐσώτερος","translit":"esṓteros","derivation":"comparative of G2080 (ἔσω);","strongs_def":"interior","kjv_def":"inner, within","pos":"adjective","usage":"inner(1x), within(1x)"},"G2046":{"id":"G2046","lemma":"ἐρέω","translit":"eréō","derivation":"probably a fuller form of G4483 (ῥέω);","strongs_def":"an alternate for G2036 (ἔπω) in certain tenses; to utter, i.e. speak or say","kjv_def":"call, say, speak (of), tell","pos":"verb","usage":"say(57x), speak(7x), tell(4x), call(1x)"},"G2093":{"id":"G2093","lemma":"ἑτοίμως","translit":"hetoímōs","derivation":"adverb from G2092 (ἕτοιμος);","strongs_def":"in readiness","kjv_def":"ready","pos":"adverb","usage":"ready(3x)"},"G2005":{"id":"G2005","lemma":"ἐπιτελέω","translit":"epiteléō","derivation":"from G1909 (ἐπί) and G5055 (τελέω);","strongs_def":"to fulfill further (or completely), i.e. execute; by implication, to terminate, undergo","kjv_def":"accomplish, do, finish, (make) (perfect), perform(X -ance)","pos":"verb","usage":"perform(3x), perfect(2x), accomplish(2x), finish(1x), performance(1x), make(1x), do(1x)"},"G2052":{"id":"G2052","lemma":"ἐριθεία","translit":"eritheía","derivation":"perhaps as the same as G2042 (ἐρεθίζω);","strongs_def":"properly, intrigue, i.e. (by implication) faction","kjv_def":"contention(-ious), strife","pos":"feminine noun","usage":"strife(5x), contention(1x)"},"G2079":{"id":"G2079","lemma":"ἐσχάτως","translit":"eschátōs","derivation":"adverb from G2078 (ἔσχατος);","strongs_def":"finally, i.e. (with G2192 (ἔχω)) at the extremity of life","kjv_def":"point of death","pos":"adverb"},"G2020":{"id":"G2020","lemma":"ἐπιφώσκω","translit":"epiphṓskō","derivation":"a form of G2017 (ἐπιφαύω);","strongs_def":"to begin to grow light","kjv_def":"begin to dawn,