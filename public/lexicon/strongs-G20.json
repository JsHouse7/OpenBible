038","lemma":"ἐργάζομαι","translit":"ergázomai","derivation":"middle voice from G2041 (ἔργον);","strongs_def":"to toil (as a task, occupation, etc.), (by implication) effect, be engaged in or with, etc.","kjv_def":"commit, do, labor for, minister about, trade (by), work","pos":"verb","usage":"work(22x), wrought(7x), do(3x), labour(1x), commit(1x), trade(1x)"},"G2074":{"id":"G2074","lemma":"Ἐσρώμ","translit":"Esrṓm","derivation":"of Hebrew origin (H02696);","strongs_def":"Esrom (i.e. Chetsron), an Israelite","kjv_def":"Esrom","pos":"proper masculine noun","usage":"Esrom(3x)"},"G2016":{"id":"G2016","lemma":"ἐπιφανής","translit":"epiphanḗs","derivation":"from G2014 (ἐπιφαίνω);","strongs_def":"conspicuous, i.e. (figuratively) memorable","kjv_def":"notable","pos":"adjective","usage":"notable(1x)"},"G2042":{"id":"G2042","lemma":"ἐρεθίζω","translit":"erethízō","derivation":"from a presumed prolonged form of G2054 (ἔρις);","strongs_def":"to stimulate (especially to anger)","kjv_def":"provoke","pos":"verb","usage":"provoke(2x)"},"G2044":{"id":"G2044","lemma":"ἐρεύγομαι","translit":"ereúgomai","derivation":"of uncertain affinity;","strongs_def":"to belch, i.e. (figuratively) to speak out","kjv_def":"utter","pos":"verb","usage":"utter(1x)"},"G2058":{"id":"G2058","lemma":"ἑρμηνεία","translit":"hermēneía","derivation":"from the same as G2059 (ἑρμηνεύω);","strongs_def":"translation","kjv_def":"interpretation"},"G2022":{"id":"G2022","lemma":"ἐπιχέω","translit":"epichéō","derivation":"from G1909 (ἐπί) and (to pour);","strongs_def":"","kjv_def":"--to pour upon:--pour in","pos":"verb"},"G2037":{"id":"G2037","lemma":"Ἔραστος","translit":"Érastos","derivation":"from (to love);","strongs_def":"beloved; Erastus, a Christian","kjv_def":"Erastus","pos":"proper masculine noun","usage":"Erastus(3x)"},"G2012":{"id":"G2012","lemma":"ἐπίτροπος","translit":"epítropos","derivation":"from G1909 (ἐπί) and G5158 (τρόπος) (in the sense of G2011 (ἐπιτροπή));","strongs_def":"a commissioner, i.e. domestic manager, guardian","kjv_def":"steward, tutor","pos":"masculine noun","usage":"steward(2x), tutor(1x)"},"G2010":{"id":"G2010","lemma":"ἐπιτρέπω","translit":"epitrépō","derivation":"from G1909 (ἐπί) and the base of G5157 (τροπή);","strongs_def":"to turn over (transfer), i.e. allow","kjv_def":"give leave (liberty, license), let, permit, suffer","pos":"verb","usage":"suffer(10x), permit(4x), let(1x)"},"G2084":{"id":"G2084","lemma":"ἑτερόγλωσσος","translit":"heteróglōssos","derivation":"from G2087 (ἕτερος) and G1100 (γλῶσσα);","strongs_def":"other- tongued, i.e. a foreigner","kjv_def":"man of other tongue"},"G2059":{"id":"G2059","lemma":"ἑρμηνεύω","translit":"hermēneúō","derivation":"from a presumed derivative of G2060 (Ἑρμῆς) (as the god of language);","strongs_def":"to translate","kjv_def":"interpret","pos":"verb"},"G2021":{"id":"G2021","lemma":"ἐπιχειρέω","translit":"epicheiréō","derivation":"from G1909 (ἐπί) and G5495 (χείρ);","strongs_def":"to put the hand upon, i.e. undertake","kjv_def":"go about, take in hand (upon)","pos":"verb"},"G2085":{"id":"G2085","lemma":"ἑτεροδιδασκαλέω","translit":"heterodidaskaléō","derivation":"from G2087 (ἕτερος) and G1320 (διδάσκαλος);","strongs_def":"to instruct differently","kjv_def":"teach other doctrine(-wise)"},"G2083":{"id":"G2083","lemma":"ἑταῖρος","translit":"hetaîros","derivation":"from (a clansman);","strongs_def":"a comrade","kjv_def":"fellow, friend","pos":"masculine noun","usage":"friend(3x), fellow(1x)"},"G2057":{"id":"G2057","lemma":"Ἑρμᾶς","translit":"Hermâs","derivation":"probably from G2060 (Ἑρμῆς);","strongs_def":"Hermas, a Christian","kjv_def":"Hermas","pos":"proper masculine noun","usage":"Hermas(1x)"},"G2090":{"id":"G2090","lemma":"ἑτοιμάζω","translit":"hetoimázō","derivation":"from G2092 (ἕτοιμος);","strongs_def":"to prepare","kjv_def":"prepare, provide, make ready","pos":"verb","usage":"prepare(29x), provide(1x)"},"G2089":{"id":"G2089","lemma":"ἔτι","translit":"éti","derivation":"perhaps akin to G2094 (ἔτος);","strongs_def":"\"yet,\" still (of time or degree)","kjv_def":"after that, also, ever, (any) further, (t-)henceforth (more), hereafter, (any) longer, (any) more(-one), now, still, yet","pos":"adverb","usage":"yet(51x), more(22x), still(4x), further(4x), longer(3x)"},"G2067":{"id":"G2067","lemma":"ἔσθησις","translit":"ésthēsis","derivation":"from a derivative of G2066 (ἐσθής);","strongs_def":"clothing (concretely)","kjv_def":"government"},"G2034":{"id":"G2034","lemma":"ἑπτάκις","translit":"heptákis","derivation":"adverb from G2033 (ἑπτά);","strongs_def":"seven times","kjv_def":"seven times","pos":"adverb"},"G2049":{"id":"G2049","lemma":"ἐρημόω","translit":"erēmóō","derivation":"from G2048 (ἔρημος);","strongs_def":"to lay waste (literally or figuratively)","kjv_def":"(bring to, make) desolate(-ion), come to nought","pos":"verb","usage":"desolate(1x)"},"G2061":{"id":"G2061","lemma":"Ἑρμογένης","translit":"Hermogénēs","derivation":"from G2060 (Ἑρμῆς) and G1096 (γίνομαι);","strongs_def":"born of Hermes; Hermogenes, an apostate Christian","kjv_def":"Hermogenes"},"G2007":{"id":"G2007","lemma":"ἐπιτίθημι","translit":"epitíthēmi","derivation":"from G1909 (ἐπί) and G5087 (τίθημι);","strongs_def":"to impose (in a friendly or hostile sense)","kjv_def":"add unto, lade, lay upon, put (up) on, set on (up), + surname, X wound","pos":"verb","usage":"lay(7x), put(6x), set(2x)"},"G2068":{"id":"G2068","lemma":"ἐσθίω","translit":"esthíō","derivation":"strengthened for a primary (to eat);","strongs_def":"used only in certain tenses, the rest being supplied by G5315 (φάγω); to eat (usually literal)","kjv_def":"devour, eat, live","pos":"verb","usage":"eat(63x), live(1x), devour(1x)"},"G2092":{"id":"G2092","lemma":"ἕτοιμος","translit":"hétoimos","derivation":"from an old noun (fitness);","strongs_def":"adjusted, i.e. ready","kjv_def":"prepared, (made) ready(-iness, to our hand)","pos":"adjective","usage":"ready(14x), prepared(1x), readiness(1x)"},"G2001":{"id":"G2001","lemma":"ἐπισχύω","tr