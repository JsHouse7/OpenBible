x)"},"H8524":{"id":"H8524","lemma":"תָּלַל","translit":"tâlal","pron":"taw-lal'","derivation":"a primitive root;","strongs_def":"to pile up, i.e. elevate","kjv_def":"eminent. Compare H2048 (הָתַל)."},"H8525":{"id":"H8525","lemma":"תֶּלֶם","translit":"telem","pron":"teh'-lem","derivation":"from an unused root meaning to accumulate;","strongs_def":"a bank or terrace","kjv_def":"furrow, ridge.","pos":"masculine noun","usage":"furrow(4x), ridge(1x)"},"H8526":{"id":"H8526","lemma":"תַּלְמַי","translit":"Talmay","pron":"tal-mah'-ee","derivation":"from H8525 (תֶּלֶם); ridged;","strongs_def":"Talmai, the name of a Canaanite and a Syrian","kjv_def":"Talmai.","pos":"proper masculine noun","usage":"Talmai(6x)"},"H8527":{"id":"H8527","lemma":"תַּלְמִיד","translit":"talmîyd","pron":"tal-meed'","derivation":"from H3925 (לָמַד);","strongs_def":"a pupil","kjv_def":"scholar."},"H8528":{"id":"H8528","lemma":"תֵּל מֶלַח","translit":"Têl Melach","pron":"tale meh'-lakh","derivation":"from H8510 (תֵּל) and H4417 (מֶלַח); mound of salt;","strongs_def":"Tel-Melach, a place in Babylonia","kjv_def":"Tel-melah.","pos":"proper locative noun","usage":"Telmelah(2x)"},"H8529":{"id":"H8529","lemma":"תָּלַע","translit":"tâlaʻ","pron":"taw-law'","derivation":"a denominative from H8438 (תּוֹלָע);","strongs_def":"to crimson, i.e. dye that color","kjv_def":"[idiom] scarlet.","pos":"verb","usage":"scarlet(1x)"},"H8530":{"id":"H8530","lemma":"תַּלְפִּיָּה","translit":"talpîyâh","pron":"tal-pee-yaw'","derivation":"feminine from an unused root meaning to tower;","strongs_def":"something tall, i.e. (plural collective) slenderness","kjv_def":"armoury.","pos":"feminine noun","usage":"armoury(1x)"},"H8531":{"id":"H8531","lemma":"תְּלַת","translit":"tᵉlath","pron":"tel-ath'","derivation":"(Aramaic) from H8532 (תְּלָת);","strongs_def":"a tertiary rank","kjv_def":"third.","pos":"masculine noun","usage":"third(2x)"},"H8532":{"id":"H8532","lemma":"תְּלָת","translit":"tᵉlâth","pron":"tel-awth'","derivation":"(Aramai