:"(ex-) change(-ing), recompense, restitution.","pos":"feminine noun","usage":"exchange(2x), change(1x), changing(1x), recompense(1x), restitution(1x)"},"H8546":{"id":"H8546","lemma":"תְּמוּתָה","translit":"tᵉmûwthâh","pron":"tem-oo-thaw'","derivation":"from H4191 (מוּת);","strongs_def":"execution (as a doom)","kjv_def":"death, die."},"H8547":{"id":"H8547","lemma":"תֶּמַח","translit":"Temach","pron":"teh'-makh","derivation":"of uncertain derivation;","strongs_def":"Temach, one of the Nethinim","kjv_def":"Tamah, Thamah."},"H8548":{"id":"H8548","lemma":"תָּמִיד","translit":"tâmîyd","pron":"taw-meed'","derivation":"from an unused root meaning to stretch;","strongs_def":"properly, continuance (as indefinite extension); but used only (attributively as adjective) constant (or adverbially, constantly); ellipt. the regular (daily) sacrifice","kjv_def":"alway(-s), continual (employment, -ly), daily, (n-)ever(-more), perpetual.","pos":"masculine noun","usage":"continually(53x), continual(26x), daily(7x), always(6x), alway(4x), ever(3x), perpetual(2x), evermore(1x), never(1x)"},"H8549":{"id":"H8549","lemma":"תָּמִים","translit":"tâmîym","pron":"taw-meem'","derivation":"from H8552 (תָּמַם);","strongs_def":"entire (literally, figuratively or morally); also (as noun) integrity, truth","kjv_def":"without blemish, complete, full, perfect, sincerely (-ity), sound, without spot, undefiled, upright(-ly), whole.","pos":"adjective","usage":"perfect(18x), upright(8x), uprightly(4x), whole(4x), sincerely(2x), complete(1x), full(1x)"},"H8550":{"id":"H8550","lemma":"תֻּמִּים","translit":"Tummîym","pron":"toom-meem'","derivation":"plural of H8537 (תֹּם);","strongs_def":"perfections, i.e. (techn.) one of the epithets of the objects in the high-priest's breastplate as an emblem of complete Truth","kjv_def":"Thummim.","pos":"proper masculine noun","usage":"Thummim(5x)"},"H8551":{"id":"H8551","lemma":"תָּמַךְ","translit":"tâmak","pron":"taw-mak'","derivation":"a primitive root;","strongs_def":"to sustain; by implication, to obtain, keep fast; figuratively, to help, follow close","kjv_def":"(take, up-) hold (up), maintain, retain, stay (up).","pos":"verb","usage":"hold(7x), uphold(5x), retain(4x)"},"H8552":{"id":"H8552","lemma":"תָּמַם","translit":"tâmam","pron":"taw-mam'","derivation":"a primitive root;","strongs_def":"to complete, in a good or a bad sense, literal, or figurative, transitive or intransitive","kjv_def":"accomplish, cease, be clean (pass-) ed, consume, have done, (come to an, have an, make an) end, fail, come to the full, be all gone, [idiom] be all here, be (make) perfect, be spent, sum, be (shew self) upright, be wasted, whole.","pos":"verb","usage":"consume(26x), end(9x), finished(4x), clean(3x), upright(3x), spent(3x), perfect(2x), done(2x), failed(2x), accomplish(2x)"},"H8553":{"id":"H8553","lemma":"תִּמְנָה","translit":"Timnâh","pron":"tim-naw'","derivation":"from H4487 (מָנָה); a portion assigned;","strongs_def":"Timnah, the name of two places in Palestine","kjv_def":"Timnah, Timnath, Thimnathah.","pos":"proper locative noun","usage":"Timnath(8x), Timnah(3x), Thimnathah(1x)"},"H8554":{"id":"H8554","lemma":"תִּמְנִי","translit":"Timnîy","pron":"tim-nee'","derivation":"patrial from H8553 (תִּמְנָה);","strongs_def":"a Timnite or inhabitant of Timnah","kjv_def":"Timnite.","pos":"gentilic adjective","usage":"Timnite(1x)"},"H8555":{"id":"H8555","lemma":"תִּמְנָע","translit":"Timnâʻ","pron":"tim-naw'","derivation":"from H4513 (מָנַע); restraint;","strongs_def":"Timna, the name of two Edomites","kjv_def":"Timna, Timnah.","pos":"proper feminine noun, proper masculine noun","usage":"Timna(4x), Timnah(2x)"},"H8556":{"id":"H8556","lemma":"תִּמְנַת חֶרֶס","translit":"Timnath Chereç","pron":"tim-nath kheh'-res","derivation":"or תִּמְנַת סֶרַח; from H8553 (תִּמְנָה) and H2775 (חֶרֶס); portion of (the) sun;","strongs_def":"Timnath-Cheres, a place in Palestine","kjv_def":"Timnath-heres, Timnath-serah.","pos":"proper locative noun","usage":"Timnathsera