{"H2400":{"id":"H2400","lemma":"חַטָּא","translit":"chaṭṭâʼ","pron":"khat-taw'","derivation":"intensively from H2398 (חָטָא);","strongs_def":"a criminal, or one accounted guilty","kjv_def":"offender, sinful, sinner.","pos":"adjective, masculine noun","usage":"sinner(16x), sinful(1x), offender(1x)"},"H2401":{"id":"H2401","lemma":"חֲטָאָה","translit":"chăṭâʼâh","pron":"khat-aw-aw'","derivation":"feminine of H2399 (חֵטְא);","strongs_def":"an offence, or a sacrifice forit","kjv_def":"sin (offering).","pos":"feminine noun","usage":"sin(7x)"},"H2402":{"id":"H2402","lemma":"חַטָּאָה","translit":"chaṭṭâʼâh","pron":"khat-taw-aw'","derivation":"(Aramaic) corresponding to H2401 (חֲטָאָה);","strongs_def":"an offence, and the penalty or sacrifice forit","kjv_def":"sin (offering).","pos":"feminine noun"},"H2403":{"id":"H2403","lemma":"חַטָּאָה","translit":"chaṭṭâʼâh","pron":"khat-taw-aw'","derivation":"or חַטָּאת; from H2398 (חָטָא);","strongs_def":"an offence (sometimes habitual sinfulness), and its penalty, occasion, sacrifice, or expiation; also (concretely) an offender","kjv_def":"punishment (of sin), purifying(-fication for sin), sin(-ner, offering).","pos":"feminine noun","usage":"sin(182x), punishment(3x), purifying(1x), sinful(1x), sinner(1x)"},"H2404":{"id":"H2404","lemma":"חָטַב","translit":"châṭab","pron":"khaw-tab'","derivation":"a primitive root;","strongs_def":"to chop or carve wood","kjv_def":"cut down, hew(-er), polish.","pos":"verb","usage":"hew(7x), polished(1x)"},"H2405":{"id":"H2405","lemma":"חֲטֻבָה","translit":"chăṭubâh","pron":"khat-oo-baw'","derivation":"feminine passive participle of H2404 (חָטַב);","strongs_def":"properly, a carving; hence, a tapestry (as figured)","kjv_def":"carved.","pos":"feminine noun","usage":"carved(1x)"},"H2406":{"id":"H2406","lemma":"חִטָּה","translit":"chiṭṭâh","pron":"khit-taw'","derivation":"of uncertain derivation;","strongs_def":"wheat, whether the grain or the plant","kjv_def":"wheat(-en).","pos":"feminine noun","usage":"wh