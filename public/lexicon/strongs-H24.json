er","derivation":"from an unused root of uncertain signification;","strongs_def":"a twig","kjv_def":"rod.","pos":"masculine noun","usage":"rod(2x)"},"H2416":{"id":"H2416","lemma":"חַי","translit":"chay","pron":"khah'-ee","derivation":"from H2421 (חָיָה);","strongs_def":"alive; hence, raw (flesh); fresh (plant, water, year), strong; also (as noun, especially in the feminine singular and masculine plural) life (or living thing), whether literally or figuratively","kjv_def":"[phrase] age, alive, appetite, (wild) beast, company, congregation, life(-time), live(-ly), living (creature, thing), maintenance, [phrase] merry, multitude, [phrase] (be) old, quick, raw, running, springing, troop.","pos":"adjective, feminine noun, masculine noun","usage":"live(197x), life(144x), beast(76x), alive(31x), creature(15x), running(7x), raw(6x)"},"H2417":{"id":"H2417","lemma":"חַי","translit":"chay","pron":"khah'-ee","derivation":"(Aramaic) from H2418 (חֲיָא);","strongs_def":"alive; also (as noun in plural) life","kjv_def":"life, that liveth, living.","pos":"adjective","usage":"living(4x), life(2x), live(1x)"},"H2418":{"id":"H2418","lemma":"חֲיָא","translit":"chăyâʼ","pron":"khah-yaw'","derivation":"(Aramaic) or חֲיָה; (Aramaic), corresponding to H2421 (חָיָה);","strongs_def":"to live","kjv_def":"live, keep alive.","pos":"verb","usage":"live(5x)"},"H2419":{"id":"H2419","lemma":"חִיאֵל","translit":"Chîyʼêl","pron":"khee-ale'","derivation":"from H2416 (חַי) and H410 (אֵל); living of God;","strongs_def":"Chiel, an Israelite","kjv_def":"Hiel."},"H2420":{"id":"H2420","lemma":"חִידָה","translit":"chîydâh","pron":"khee-daw'","derivation":"from H2330 (חוּד);","strongs_def":"a puzzle, hence, a trick, conundrum, sententious maxim","kjv_def":"dark saying (sentence, speech), hard question, proverb, riddle.","pos":"feminine noun","usage":"riddle(9x), proverb(1x)"},"H2421":{"id":"H2421","lemma":"חָיָה","translit":"châyâh","pron":"khaw-yaw'","derivation":"a primitive root (compare H2331 (חָוָה), H2421 (חָיָה));","strongs_def":"to live, whether literally or figuratively; causatively, to revive","kjv_def":"keep (leave, make) alive, [idiom] certainly, give (promise) life, (let, suffer to) live, nourish up, preserve (alive), quicken, recover, repair, restore (to life), revive, ([idiom] God) save (alive, life, lives), [idiom] surely, be whole.","pos":"verb","usage":"live(153x), alive(34x), save(13x), quicken(14x), revive(12x), surely(10x), life(9x), recover(8x)"},"H2422":{"id":"H2422","lemma":"חָיֶה","translit":"châyeh","pron":"khaw-yeh'","derivation":"from H2421 (חָיָה);","strongs_def":"vigorous","kjv_def":"lively.","pos":"adjective","usage":"lively(1x)"},"H2423":{"id":"H2423","lemma":"חֵיוָא","translit":"chêyvâʼ","pron":"khay-vaw'","derivation":"(Aramaic) from H2418 (חֲיָא);","strongs_def":"an animal","kjv_def":"beast.","pos":"feminine noun","usage":"beast(20x)"},"H2424":{"id":"H2424","lemma":"חַיּוּת","translit":"chayûwth","pron":"khah-yooth'","derivation":"from H2421 (חָיָה);","strongs_def":"life","kjv_def":"[idiom] living."},"H2425":{"id":"H2425","lemma":"חָיַי","translit":"châyay","pron":"khaw-yah'-ee","derivation":"a primitive root (compare H2421 (חָיָה));","strongs_def":"to live; causatively to revive","kjv_def":"live, save life.","pos":"verb","usage":"live(21x), life(1x)"},"H2426":{"id":"H2426","lemma":"חֵיל","translit":"chêyl","pron":"khale","derivation":"or (shortened) חֵל; a collateral form of H2428 (חַיִל);","strongs_def":"an army; also (by analogy,) an intrenchment","kjv_def":"army, bulwark, host, [phrase] poor, rampart, trench, wall.","pos":"masculine noun","usage":"wall(2x), rampart(2x), host(2x), trench(1x), poor(1x), bulwark(1x), army(1x)"},"H2427":{"id":"H2427","lemma":"חִיל","translit":"chîyl","pron":"kheel","derivation":"and (feminine) חִילָה; from H2342 (חוּל);","strongs_def":"a throe (expectant of childbirth)","kjv_def":"pain, pang, sorrow.","pos":"masculine noun","usage":"pain(3x), pang(2x), sorrow(2x)"},"H2428":{"id":"H2428","lemma":"חַיִל","