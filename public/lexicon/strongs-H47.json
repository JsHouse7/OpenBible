{"H4700":{"id":"H4700","lemma":"מְצֵלֶת","translit":"mᵉtsêleth","pron":"mets-ay'-leth","derivation":"from H6750 (צָלַל);","strongs_def":"(only dual) double tinklers, i.e. cymbals","kjv_def":"cymbals.","pos":"dual feminine noun","usage":"cymbal(13x)"},"H4701":{"id":"H4701","lemma":"מִצְנֶפֶת","translit":"mitsnepheth","pron":"mits-neh'-feth","derivation":"from H6801 (צָנַף);","strongs_def":"a tiara, i.e. official turban (of a king or high priest)","kjv_def":"diadem, mitre.","pos":"feminine noun","usage":"mitre(11x), diadem(1x)"},"H4702":{"id":"H4702","lemma":"מַצָּע","translit":"matstsâʻ","pron":"mats-tsaw'","derivation":"from H3331 (יַצַע);","strongs_def":"a couch","kjv_def":"bed.","pos":"masculine noun","usage":"bed(1x)"},"H4703":{"id":"H4703","lemma":"מִצְעָד","translit":"mitsʻâd","pron":"mits-awd'","derivation":"from H6805 (צָעַד);","strongs_def":"a step; figuratively, companionship","kjv_def":"going, step.","pos":"masculine noun","usage":"steps(2x), goings(1x)"},"H4704":{"id":"H4704","lemma":"מִצְּעִירָה","translit":"mitstsᵉʻîyrâh","pron":"mits-tseh-ee-raw'","derivation":"feminine of H4705 (מִצְעָר);","strongs_def":"properly, littleness; concretely, diminutive","kjv_def":"little.","pos":"feminine noun","usage":"little(1x)"},"H4705":{"id":"H4705","lemma":"מִצְעָר","translit":"mitsʻâr","pron":"mits-awr'","derivation":"from H6819 (צָעַר);","strongs_def":"petty (in size or number); adverbially, a short (time)","kjv_def":"little one (while), small.","pos":"masculine noun","usage":"small(2x)"},"H4706":{"id":"H4706","lemma":"מִצְעָר","translit":"Mitsʻâr","pron":"mits-awr'","derivation":"the same as H4705 (מִצְעָר);","strongs_def":"Mitsar, a peak of Lebanon","kjv_def":"Mizar."},"H4707":{"id":"H4707","lemma":"מִצְפֶּה","translit":"mitspeh","pron":"mits-peh'","derivation":"from H6822 (צָפָה);","strongs_def":"an observatory, especially formilitary purposes","kjv_def":"watch tower.","pos":"masculine noun","usage":"watchtower(2x)"},"H4708":{"id":"H4708","lemma":"מִצְפֶּה","translit":"Mitspeh","pron":"mits-peh'","derivation":"the same as H4707 (מִצְפֶּה);","strongs_def":"Mitspeh, the name of five places in Palestine","kjv_def":"Mizpeh, watch tower. Compare H4709 (מִצְפָּה).","pos":"proper locative noun","usage":"Mizpeh(9x), Mizpah(5x)"},"H4709":{"id":"H4709","lemma":"מִצְפָּה","translit":"Mitspâh","pron":"mits-paw'","derivation":"feminine of H4708 (מִצְפֶּה);","strongs_def":"Mitspah, the name of two places in Palestine","kjv_def":"Mitspah. (This seems rather to be only an orthographic variation of H4708 (מִצְפֶּה) when 'in pause'.)","pos":"proper feminine locative noun","usage":"Mizpah(18x), Mizpeh(14x)"},"H4710":{"id":"H4710","lemma":"מִצְפֻּן","translit":"mitspun","pron":"mits-poon'","derivation":"from H6845 (צָפַן);","strongs_def":"a secret (place or thing, perhaps, treasure)","kjv_def":"hidden thing.","pos":"masculine noun"},"H4711":{"id":"H4711","lemma":"מָצַץ","translit":"mâtsats","pron":"maw-tsats'","derivation":"a primitive root;","strongs_def":"to suck","kjv_def":"milk.","pos":"verb"},"H4712":{"id":"H4712","lemma":"מֵצַר","translit":"mêtsar","pron":"may-tsar'","derivation":"from H6896 (קֵבָה);","strongs_def":"something tight, i.e. (figuratively) trouble","kjv_def":"distress, pain, strait.","pos":"masculine noun","usage":"pains(1x), distress(1x), straits(1x)"},"H4713":{"id":"H4713","lemma":"מִצְרִי","translit":"Mitsrîy","pron":"mits-ree'","derivation":"from H4714 (מִצְרַיִם);","strongs_def":"a Mitsrite, or inhabitant of Mitsrajim","kjv_def":"Egyptian, of Egypt.","pos":"adjective","usage":"Egyptian(25x), Egypt(1x)"},"H4714":{"id":"H4714","lemma":"מִצְרַיִם","translit":"Mitsrayim","pron":"mits-rah'-yim","derivation":"dual of H4693 (מָצוֹר);","strongs_def":"Mitsrajim, i.e. Upper and Lower Egypt","kjv_def":"Egypt, Egyptians, Mizraim.","pos":"adjective, proper locative noun","usage":"Egypt(586x), Egyptian(90x), Mizraim(4x)"},"H4715":{"id":"H4715","lemma":"מִצְרֵף","translit":"mitsrêph","pron":"mits-rafe'","derivation":"from H6884 (צָרַף);","strongs_def":"a crucible","kjv_def":"fining pot.","pos":"masculine noun"},"H4716":{"id":"H4716","lemma":"מַק","translit":"maq","pron":"mak","derivation":"from H4743 (מָקַק);","strongs_def":"properly, a melting, i.e. putridity","kjv_def":"rottenness, stink.","pos":"masculine noun","usage":"stink(1x), rottenness(1x)"},"H4717":{"id":"H4717","lemma":"מַקָּבָה","translit":"maqqâbâh","pron":"mak-kaw-baw'","derivation":"from H5344 (נָקַב);","strongs_def":"properly, a perforatrix, i.e. a hammer (as piercing)","kjv_def":"hammer.","pos":"feminine noun","usage":"hammer(3x)"},"H4718":{"id":"H4718","lemma":"מַקֶּבֶת","translit":"maqqebeth","pron":"mak-keh'-beth","derivation":"from H5344 (נָקַב);","strongs_def":"properly, a perforator, i.e. a hammer (as piercing); also (intransitively) a perforation, i.e. a quarry","kjv_def":"hammer, hole.","pos":"feminine noun","usage":"hammer(1x), hole(1x)"},"H4719":{"id":"H4719","lemma":"מַקֵּדָה","translit":"Maqqêdâh","pron":"mak-kay-daw'","derivation":"from the same as H5348 (נָקֹד) in the denominative sense of herding (compare H5349 (נֹקֵד)); fold;","strongs_def":"Makkedah, a place in Palestine","kjv_def":"Makkedah.","pos":"proper locative noun","usage":"Makkedah(9x)"},"H4720":{"id":"H4720","lemma":"מִקְדָּשׁ","translit":"miqdâsh","pron":"mik-dawsh'","derivation":"or מִקְּדָשׁ; (Exodus 15:17), from H6942 (קָדַשׁ);","strongs_def":"a consecrated thing or place, especially, a palace, sanctuary (whether of Jehovah or of idols) or asylum","kjv_def":"chapel, hallowed part, holy place, sanctuary.","pos":"masculine noun","usage":"sanctuary(69x), chapel(1x)"},"H4721":{"id":"H4721","lemma":"מַקְהֵל","translit":"maqhêl","pron":"mak-hale'","derivation":"or (feminine) מַקְהֵלָה; from H6950 (קָהַל);","strongs_def":"an assembly","kjv_def":"congregation.","pos":"masculine noun","usage":"congregation(2x)"},"H4722":{"id":"H4722","lemma":"מַקְהֵלֹת","translit":"Maqhêlôth","pron":"mak-hay-loth'","derivation":"plural of H4721 (מַקְהֵל) (feminine); assemblies;","strongs_def":"Makheloth, a place in the Desert","kjv_def":"Makheloth.","pos":"proper femine locative plural noun","usage":"Makheloth(2x)"},"H4723":{"id":"H4723","lemma":"מִקְוֶה","translit":"miqveh","pron":"mik-veh'","derivation":"or מִקְוֵה; (1 Kings 10:28), or מִקְוֵאlemma מִּקְוֵא extra dagesh, corrected to מִקְוֵא; (2 Chronicles 1:16), from H6960 (קָוָה);","strongs_def":"something waited for, i.e. confidence (objective or subjective); also a collection, i.e. (of water) a pond, or (of men and horses) a caravan or drove","kjv_def":"abiding, gathering together, hope, linen yarn, plenty (of water), pool.","pos":"masculine noun, proper masculine noun","usage":"hope(4x), pool(1x), plenty(1x), abiding(1x)"},"H4724":{"id":"H4724","lemma":"מִקְוָה","translit":"miqvâh","pron":"mik-vaw'","derivation":"feminine of H4723 (מִקְוֶה);","strongs_def":"a collection, i.e. (of water) a reservoir","kjv_def":"ditch.","pos":"feminine noun","usage":"ditch(1x)"},"H4725":{"id":"H4725","lemma":"מָקוֹם","translit":"mâqôwm","pron":"maw-kome'","derivation":"or מָקֹם; also (feminine) מְקוֹמָה; or מְקֹמָה; from H6965 (קוּם);","strongs_def":"properly, a standing, i.e. a spot; but used widely of a locality (general or specific); also (figuratively) of a condition (of body or mind)","kjv_def":"country, [idiom] home, [idiom] open, place, room, space, [idiom] whither(-soever).","pos":"masculine noun","usage":"place(391x), home(3x), room(3x), whithersoever(2x), open(1x), space(1x), country(1x)"},"H4726":{"id":"H4726","lemma":"מָקוֹר","translit":"mâqôwr","pron":"maw-kore'","derivation":"or מָקֹר; from H6979 (קוּר);","strongs_def":"properly, something dug, i.e. a (general) source (of water, even when naturally flowing; also of tears, blood (by euphemism, of the female pudenda); figuratively, of happiness, wisdom, progeny)","kjv_def":"fountain, issue, spring, well(-spring).","pos":"masculine noun","usage":"fountain(11x), spring(3x), wellspring(2x), issue(1x), well(1x)"},"H4727":{"id":"H4727","lemma":"מִקָּח","translit":"miqqâch","pron":"mik-kawkh'","derivation":"from H3947 (לָקַח);","strongs_def":"reception","kjv_def":"taking."},"H4728":{"id":"H4728","lemma":"מַקָּחָה","translit":"maqqâchâh","pron":"mak-kaw-khaw'","derivation":"from H3947 (לָקַח);","strongs_def":"something received, i.e. merchandise (purchased)","kjv_def":"ware.","pos":"feminine noun","usage":"ware(1x)"},"H4729":{"id":"H4729","lemma":"מִקְטָר","translit":"miqṭâr","pron":"mik-tawr'","derivation":"from H6999 (קָטַר);","strongs_def":"something to fume (incense) on i.e. a hearth place","kjv_def":"to burn...upon.","pos":"masculine noun","usage":"burn(1x)"},"H4730":{"id":"H4730","lemma":"מִקְטֶרֶת","translit":"miqṭereth","pron":"mik-teh'-reth","derivation":"feminine of H4729 (מִקְטָר);","strongs_def":"something to fume (incense) in, i.e. a coal-pan","kjv_def":"censer.","pos":"feminine noun","usage":"censer(2x)"},"H4731":{"id":"H4731","lemma":"מַקֵּל","translit":"maqqêl","pron":"mak-kale","derivation":"or (feminine) מַקְּלָה; from an unused root meaning apparently to germinate;","strongs_def":"a shoot, i.e. stick (with leaves on, or for walking, striking, guiding, divining)","kjv_def":"rod, (hand-)staff.","pos":"masculine noun","usage":"rod(8x), staff(7x), stave(2x)"},"H4732":{"id":"H4732","lemma":"מִקְלוֹת","translit":"Miqlôwth","pron":"mik-lohth'","derivation":"(or perhaps mik-kel-ohth') plural of (feminine) H4731 (מַקֵּל); rods;","strongs_def":"Mikloth, a place in the Desert","kjv_def":"Mikloth."},"H4733":{"id":"H4733","lemma":"מִקְלָט","translit":"miqlâṭ","pron":"mik-lawt'","derivation":"from H7038 (קָלַט) in the sense of taking in;","strongs_def":"an asylum (as a receptacle)","kjv_def":"refuge.","pos":"masculine noun","usage":"refuge(20x)"},"H4734":{"id":"H4734","lemma":"מִקְלַעַת","translit":"miqlaʻath","pron":"mik-lah'-ath","derivation":"from H7049 (קָלַע);","strongs_def":"a sculpture (probably in bas-relief)","kjv_def":"carved (figure), carving, graving."},"H4735":{"id":"H4735","lemma":"מִקְנֶה","translit":"miqneh","pron":"mik-neh'","derivation":"from H7069 (קָנָה);","strongs_def":"something bought, i.e. property, but only livestock; abstractly, acquisition","kjv_def":"cattle, flock, herd, possession, purchase, substance.","pos":"masculine noun","usage":"cattle(63x), possession(5x), flocks(3x), substance(2x), herds(1x), purchase(1x)"},"H4736":{"id":"H4736","lemma":"מִקְנָה","translit":"miqnâh","pron":"mik-naw'","derivation":"feminine of H4735 (מִקְנֶה);","strongs_def":"properly, a buying, i.e. acquisition; concretely, a piece of property (land or living); also the sum paid","kjv_def":"(he that is) bought, possession, piece, purchase.","pos":"feminine noun","usage":"bought(7x), purchase(5x), price(2x), possession(1x)"},"H4737":{"id":"H4737","lemma":"מִקְנֵיָהוּ","translit":"Miqnêyâhûw","pron":"mik-nay-yaw'-hoo","derivation":"from H4735 (מִקְנֶה) and H3050 (יָהּ); possession of Jah;","strongs_def":"Miknejah, an Israelite","kjv_def":"Mikneiah."},"H4738":{"id":"H4738","lemma":"מִקְסָם","translit":"miqçâm","pron":"mik-sawn'","derivation":"from H7080 (קָסַם);","strongs_def":"an augury","kjv_def":"divination.","pos":"masculine noun","usage":"divination(2x)"},"H4739":{"id":"H4739","lemma":"מָקַץ","translit":"Mâqats","pron":"maw-kats'","derivation":"from H7112 (קָצַץ); end;","strongs_def":"Makats, a place in Palestine","kjv_def":"Makaz."},"H4740":{"id":"H4740","lemma":"מַקְצוֹעַ","translit":"maqtsôwaʻ","pron":"mak-tso'-ah","derivation":"or מַקְצֹעַ; or (feminine) מַקְצֹעָה; from H7106 (קָצַע) in the denominative sense of bending;","strongs_def":"an angle or recess","kjv_def":"corner, turning.","pos":"masculine noun","usage":"corner(7x), turning(5x)"},"H4741":{"id":"H4741","lemma":"מַקְצֻעָה","translit":"maqtsuʻâh","pron":"mak-tsoo-aw'","derivation":"from H7106 (קָצַע);","strongs_def":"a scraper, i.e. a carving chisel","kjv_def":"plane.","pos":"feminine noun","usage":"plane(1x)"},"H4742":{"id":"H4742","lemma":"מְקֻצְעָה","translit":"mᵉqutsʻâh","pron":"mek-oots-aw'","derivation":"from H7106 (קָצַע) in the denominative sense of bending;","strongs_def":"an angle","kjv_def":"corner.","pos":"feminine noun","usage":"corner(2x)"},"H4743":{"id":"H4743","lemma":"מָקַק","translit":"mâqaq","pron":"maw-kak'","derivation":"' a primitive root;","strongs_def":"to melt; figuratively, to flow, dwindle, vanish","kjv_def":"consume away, be corrupt, dissolve, pine away.","pos":"verb","usage":"corrupt(1x), dissolved(1x)"},"H4744":{"id":"H4744","lemma":"מִקְרָא","translit":"miqrâʼ","pron":"mik-raw'","derivation":"from H7121 (קָרָא);","strongs_def":"something called out, i.e. a public meeting (the act, the persons, or the place); also a rehearsal","kjv_def":"assembly, calling, convocation, reading.","pos":"masculine noun","usage":"convocation(19x), assemblies(2x), calling(1x), reading(1x)"},"H4745":{"id":"H4745","lemma":"מִקְרֶה","translit":"miqreh","pron":"mik-reh'","derivation":"from H7136 (קָרָה);","strongs_def":"something met with, i.e. an accident or fortune","kjv_def":"something befallen, befalleth, chance, event, hap(-peneth).","pos":"masculine noun","usage":"befall(4x), event(3x), hap(1x), chance(1x), happeneth(1x)"},"H4746":{"id":"H4746","lemma":"מְקָרֶה","translit":"mᵉqâreh","pron":"mek-aw-reh'","derivation":"from H7136 (קָרָה);","strongs_def":"properly, something meeting, i.e. a frame (of timbers)","kjv_def":"building.","pos":"masculine noun","usage":"building(1x)"},"H4747":{"id":"H4747","lemma":"מְקֵרָה","translit":"mᵉqêrâh","pron":"mek-ay-raw'","derivation":"from the same as H7119 (קַר);","strongs_def":"a cooling off","kjv_def":"[idiom] summer.","pos":"feminine noun","usage":"summer(2x)"},"H4748":{"id":"H4748","lemma":"מִקְשֶׁה","translit":"miqsheh","pron":"mik-sheh'","derivation":"from H7185 (קָשָׁה) in the sense of knotting up round and hard;","strongs_def":"something turned (rounded), i.e. a curl (of tresses)","kjv_def":"[idiom] well (set) hair.","pos":"masculine noun","usage":"hair(1x)"},"H4749":{"id":"H4749","lemma":"מִקְשָׁה","translit":"miqshâh","pron":"mik-shaw'","derivation":"feminine of H4748 (מִקְשֶׁה);","strongs_def":"rounded work, i.e. moulded by hammering (repousse)","kjv_def":"beaten (out of one piece, work), upright, whole piece.","pos":"feminine noun","usage":"beaten(1x), upright(1x)"},"H4750":{"id":"H4750","lemma":"מִקְשָׁה","translit":"miqshâh","pron":"mik-shaw'","derivation":"denominative from H7180 (קִשֻּׁא);","strongs_def":"literally a cucumbered field, i.e. a cucumber patch","kjv_def":"garden of cucumbers.","pos":"feminine noun"},"H4751":{"id":"H4751","lemma":"מַר","translit":"mar","pron":"mar","derivation":"or (feminine) מָרָה; from H4843 (מָרַר);","strongs_def":"bitter (literally or figuratively); also (as noun) bitterness, or (adverbially) bitterly","kjv_def":"[phrase] angry, bitter(-ly, -ness), chafed, discontented, [idiom] great, heavy.","pos":"adjective, adverb","usage":"bitter(20x), bitterness(10x), bitterly(3x), chafed(1x), angry(1x), discontented(1x), heavy(1x)"},"H4752":{"id":"H4752","lemma":"מַר","translit":"mar","pron":"mar","derivation":"from H4843 (מָרַר) in its original sense of distillation;","strongs_def":"a drop","kjv_def":"drop.","pos":"masculine noun","usage":"drop(1x)"},"H4753":{"id":"H4753","lemma":"מֹר","translit":"môr","pron":"more","derivation":"or מוֹר; from H4843 (מָרַר);","strongs_def":"myrrh (as distilling in drops, and also as bitter)","kjv_def":"myrrh.","pos":"masculine noun","usage":"myrrh(12x)"},"H4754":{"id":"H4754","lemma":"מָרָא","translit":"mârâʼ","pron":"maw-raw'","derivation":"a primitive root;","strongs_def":"to rebel; hence (through the idea of maltreating) to whip, i.e. lash (self with wings, as the ostrich in running)","kjv_def":"be filthy, lift up self.","pos":"verb","usage":"filthy(1x)"},"H4755":{"id":"H4755","lemma":"מָרָא","translit":"Mârâʼ","pron":"maw-raw'","derivation":"for H4751 (מַר) feminine; bitter;","strongs_def":"Mara, a symbolic name of Naomi","kjv_def":"Mara.","pos":"proper feminine noun","usage":"Mara(1x)"},"H4756":{"id":"H4756","lemma":"מָרֵא","translit":"mârêʼ","pron":"maw-ray'","derivation":"(Aramaic) from a root corresponding to H4754 (מָרָא) in the sense of domineering;","strongs_def":"a master","kjv_def":"lord, Lord.","pos":"masculine noun","usage":"lord(2x), Lord(2x)"},"H4757":{"id":"H4757","lemma":"מְרֹאדַךְ בַּלְאָדָן","translit":"Mᵉrôʼdak Balʼâdân","pron":"mer-o-dak' bal-awdawn'","derivation":"of foreign derivation;","strongs_def":"Merodak-Baladan, a Babylonian king","kjv_def":"Merodach-baladan. Compare H4781 (מְרֹדָךְ).","pos":"proper masculine noun","usage":"Merodachbaladan(1x)"},"H4758":{"id":"H4758","lemma":"מַרְאֶה","translit":"marʼeh","pron":"mar-eh'","derivation":"from H7200 (רָאָה);","strongs_def":"a view (the act of seeing); also an appearance (the thing seen), whether (real) a shape (especially if handsome, comeliness; often plural the looks), or (mental) a vision","kjv_def":"[idiom] apparently, appearance(-reth), [idiom] as soon as beautiful(-ly), countenance, fair, favoured, form, goodly, to look (up) on (to), look(-eth), pattern, to see, seem, sight, visage, vision.","pos":"masculine noun","usage":"appearance(35x), sight(18x), countenance(11x), vision(11x), favoured(7x)"},"H4759":{"id":"H4759","lemma":"מַרְאָה","translit":"marʼâh","pron":"mar-aw'","derivation":"feminine of H4758 (מַרְאֶה);","strongs_def":"a vision; also (causatively) a mirror","kjv_def":"looking glass, vision.","pos":"feminine noun","usage":"vision(11x), lookingglasses(1x)"},"H4760":{"id":"H4760","lemma":"מֻרְאָה","translit":"murʼâh","pron":"moor-aw'","derivation":"apparently feminine passive causative participle of H7200 (רָאָה);","strongs_def":"something conspicuous, i.e. the craw of abird (from its prominence)","kjv_def":"crop.","pos":"feminine noun","usage":"crop(1x)"},"H4761":{"id":"H4761","lemma":"מַרְאָשָׁה","translit":"marʼâshâh","pron":"mar-aw-shaw'","derivation":"denominative from H7218 (רֹאשׁ);","strongs_def":"properly, headship, i.e. (plural for collective) dominion","kjv_def":"principality.","pos":"adverb, feminine noun","usage":"principalities(1x)"},"H4762":{"id":"H4762","lemma":"מַרְאֵשָׁה","translit":"Marʼêshâh","pron":"mar-ay-shaw'","derivation":"or מַרֵשָׁה; formed like H4761 (מַרְאָשָׁה); summit;","strongs_def":"Mareshah, the name of two Israelites and of a place in Palestine","kjv_def":"Mareshah.","pos":"proper locative noun","usage":"Mareshah(8x)"},"H4763":{"id":"H4763","lemma":"מְרַאֲשָׁה","translit":"mᵉraʼăshâh","pron":"mer-ah-ash-aw'","derivation":"formed like H4761 (מַרְאָשָׁה);","strongs_def":"properly, a headpiece, i.e. (plural for adverbial) at (or as) the head-rest (or pillow)","kjv_def":"bolster, head, pillow. Compare H4772 (מַרְגְלָה).","pos":"adverb, feminine noun","usage":"bolster(5x), pillow(2x)"},"H4764":{"id":"H4764","lemma":"מֵרָב","translit":"Mêrâb","pron":"may-rawb'","derivation":"from H7231 (רָבַב); increase;","strongs_def":"Merab, a daughter of Saul","kjv_def":"Merab."},"H4765":{"id":"H4765","lemma":"מַרְבַד","translit":"marbad","pron":"mar-bad'","derivation":"from H7234 (רָבַד);","strongs_def":"a coverlet","kjv_def":"covering of tapestry.","pos":"masculine noun"},"H4766":{"id":"H4766","lemma":"מַרְבֶה","translit":"marbeh","pron":"mar-beh'","derivation":"from H7235 (רָבָה);","strongs_def":"properly, increasing; as noun, greatness, or (adverbially) greatly","kjv_def":"great, increase.","pos":"masculine noun","usage":"increase(1x), great(1x)"},"H4767":{"id":"H4767","lemma":"מִרְבָּה","translit":"mirbâh","pron":"meer-baw'","derivation":"from H7235 (רָבָה);","strongs_def":"abundance, i.e. a great quantity","kjv_def":"much."},"H4768":{"id":"H4768","lemma":"מַרְבִּית","translit":"marbîyth","pron":"mar-beeth'","derivation":"from H7235 (רָבָה);","strongs_def":"a multitude; also offspring; specifically interest (on capital)","kjv_def":"greatest part, greatness, increase, multitude."},"H4769":{"id":"H4769","lemma":"מַרְבֵּץ","translit":"marbêts","pron":"mar-bates'","derivation":"from H7257 (רָבַץ);","strongs_de