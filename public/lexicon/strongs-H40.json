,"usage":"discord(1x), strife(1x), variant(1x)"},"H4091":{"id":"H4091","lemma":"מְדָן","translit":"Mᵉdân","pron":"med-awn'","derivation":"the same as H4090 (מְדָן);","strongs_def":"Medan, a son of Abraham","kjv_def":"Medan.","pos":"proper masculine noun","usage":"Medan(2x)"},"H4092":{"id":"H4092","lemma":"מְדָנִי","translit":"Mᵉdânîy","pron":"med-aw-nee'","derivation":"a variation of H4084 (מִדְיָנִי)","strongs_def":"{a Midjanite or descendant (native) of Midjan}","kjv_def":"Midianite.","pos":"adjective","usage":"Midianite(1x)"},"H4093":{"id":"H4093","lemma":"מַדָּע","translit":"maddâʻ","pron":"mad-daw'","derivation":"or מַדַּע; from H3045 (יָדַע);","strongs_def":"intelligence or consciousness","kjv_def":"knowledge, science, thought.","pos":"masculine noun","usage":"knowledge(4x), thought(1x), science(1x)"},"H4094":{"id":"H4094","lemma":"מַדְקָרָה","translit":"madqârâh","pron":"mad-kaw-raw'","derivation":"from H1856 (דָּקַר);","strongs_def":"a wound","kjv_def":"piercing.","pos":"feminine noun","usage":"piercings(1x)"},"H4095":{"id":"H4095","lemma":"מַדְרֵגָה","translit":"madrêgâh","pron":"mad-ray-gaw'","derivation":"from an unused root meaning to step;","strongs_def":"properly, a step; by implication, a steep or inaccessible place","kjv_def":"stair, steep place.","pos":"feminine noun","usage":"stairs(1x)"},"H4096":{"id":"H4096","lemma":"מִדְרָךְ","translit":"midrâk","pron":"mid-rawk'","derivation":"from H1869 (דָּרַךְ);","strongs_def":"a treading, i.e. a place for stepping on","kjv_def":"(foot-) breadth.","pos":"masculine noun","usage":"breadth(1x)"},"H4097":{"id":"H4097","lemma":"מִדְרָשׁ","translit":"midrâsh","pron":"mid-rawsh'","derivation":"from H1875 (דָּרַשׁ);","strongs_def":"properly, an investigation, i.e. (by implication) a treatise or elaborate compilation","kjv_def":"story."},"H4098":{"id":"H4098","lemma":"מְדֻשָּׁה","translit":"mᵉdushshâh","pron":"med-oosh-shaw'","derivation":"from H1758 (דּוּשׁ);","strongs_def":"a threshing, i.e. (concretely and figuratively) down-trodden people","kjv_def":"threshing.","pos":"feminine noun","usage":"threshing(1x)"},"H4099":{"id":"H4099","lemma":"מְדָתָא","translit":"Mᵉdâthâʼ","pron":"med-aw-thaw'","derivation":"of Persian origin;","strongs_def":"Medatha, the father of Haman","kjv_def":"Hammedatha (including the article).","pos":"proper masculine noun","usage":"Hammedatha(5x)"}}