rivation":"from the same as H1314 (בֶּשֶׂם); fragrant;","strongs_def":"Mibsam, the name of an Ishmaelite and of an Israelite","kjv_def":"Mibsam."},"H4018":{"id":"H4018","lemma":"מְבַשְּׁלָה","translit":"mᵉbashshᵉlâh","pron":"meb-ash-shel-aw'","derivation":"from H1310 (בָּשַׁל);","strongs_def":"a cooking hearth","kjv_def":"boiling-place.","pos":"feminine noun"},"H4019":{"id":"H4019","lemma":"מַגְבִּישׁ","translit":"Magbîysh","pron":"mag-beesh'","derivation":"from the same as H1378 (גָּבִישׁ); stiffening;","strongs_def":"Magbish, an Israelite, or a place in Palestine","kjv_def":"Magbish.","pos":"proper masculine noun","usage":"Magbish(1x)"},"H4020":{"id":"H4020","lemma":"מִגְבָּלָה","translit":"migbâlâh","pron":"mig-baw-law'","derivation":"from H1379 (גָּבַל);","strongs_def":"a border","kjv_def":"end.","pos":"feminine noun","usage":"ends(1x)"},"H4021":{"id":"H4021","lemma":"מִגְבָּעָה","translit":"migbâʻâh","pron":"mig-baw-aw'","derivation":"from the same as H1389 (גִּבְעָה);","strongs_def":"a cap (as hemispherical)","kjv_def":"bonnet.","pos":"feminine noun","usage":"bonnet(4x)"},"H4022":{"id":"H4022","lemma":"מֶגֶד","translit":"meged","pron":"meh'-ghed","derivation":"from an unused root probably meaning to be eminent;","strongs_def":"properly, a distinguished thing; hence something valuable, as aproduct or fruit","kjv_def":"pleasant, precious fruit (thing).","pos":"masculine noun","usage":"pleasant(3x)"},"H4023":{"id":"H4023","lemma":"מְגִדּוֹן","translit":"Mᵉgiddôwn","pron":"meg-id-done'","derivation":"(Zechariah H12 (אַבְדָן)) or מְגִדּוֹ; from H1413 (גָּדַד); rendezvous;","strongs_def":"Megiddon or Megiddo, a place in Palestine","kjv_def":"Megiddo, Megiddon.","pos":"proper locative noun","usage":"Megiddo(11x), Megiddon(1x)"},"H4024":{"id":"H4024","lemma":"מִגְדּוֹל","translit":"Migdôwl","pron":"mig-dole'","derivation":"or מִגְדֹּל; probably of Egyptian origin;","strongs_def":"Migdol, a place in Egypt","kjv_def":"Migdol, tower.","pos":"masculine noun, proper masculine noun","usage":"Migdol(4x), tower(2x), variant(1x)"},"H4025":{"id":"H4025","lemma":"מַגְדִּיאֵל","translit":"Magdîyʼêl","pron":"mag-dee-ale'","derivation":"from H4022 (מֶגֶד) and H410 (אֵל); preciousness of God;","strongs_def":"Magdiel, an Idumaean","kjv_def":"Magdiel.","pos":"proper masculine noun","usage":"Magdiel(2x)"},"H4026":{"id":"H4026","lemma":"מִגְדָּל","translit":"migdâl","pron":"mig-dawl'","derivation":"also (in plural) feminine מִגְדָּלָה; from H1431 (גָּדַל);","strongs_def":"a tower (from its size or height); by analogy, a rostrum; figuratively, a (pyramidal) bed of flowers","kjv_def":"castle, flower, tower. Compare the names following.","pos":"masculine noun","usage":"tower(47x), castles(1x), flowers(1x), pulpit(1x)"},"H4027":{"id":"H4027","lemma":"מִגְדַּל־אֵל","translit":"Migdal-ʼÊl","pron":"mig-dal-ale'","derivation":"from H4026 (מִגְדָּל) and H410 (אֵל); tower of God;","strongs_def":"Migdal-El, a place in Palestine","kjv_def":"Migdal-el.","pos":"proper locative noun","usage":"Migdalel(1x)"},"H4028":{"id":"H4028","lemma":"מִגְדַּל־גָּד","translit":"Migdal-Gâd","pron":"migdal-gawd'","derivation":"from H4026 (מִגְדָּל) and H1408 (גַּד); tower of Fortune;","strongs_def":"Migdal-Gad, a place in Palestine","kjv_def":"Migdal-gad."},"H4029":{"id":"H4029","lemma":"מִגְדַּל־עֵדֶר","translit":"Migdal-ʻÊder","pron":"mig-dal'-ay'-der","derivation":"from H4026 (מִגְדָּל) and H5739 (עֵדֶר); tower of a flock;","strongs_def":"Migdal-Eder, a place in Palestine","kjv_def":"Migdal-eder, tower of the flock.","pos":"proper noun","usage":"Edar(1x)"},"H4030":{"id":"H4030","lemma":"מִגְדָּנָה","translit":"migdânâh","pron":"mig-daw-naw'","derivation":"from the same as H4022 (מֶגֶד);","strongs_def":"preciousness, i.e. a gem","kjv_def":"precious thing, present.","pos":"feminine noun","usage":"presents(1x)"},"H4031":{"id":"H4031","lemma":"מָגוֹג","translit":"Mâgôwg","pron":"maw-gogue'","derivation":"from H1463 (גּוֹג);","strongs_def":"Magog, a son of Japheth; also a barbarous northern region","kjv_def":"Magog.","pos":"proper locative noun, proper masculine noun","usage":"Magog(4x)"},"H4032":{"id":"H4032","lemma":"מָגוֹר","translit":"mâgôwr","pron":"maw-gore'","derivation":"or (Lamentations 2:22) מָגוּר; from H1481 (גּוּר) in the sense of fearing;","strongs_def":"a fright (objective or subjective)","kjv_def":"fear, terror. Compare H4036 (מָגוֹר מִסָּבִיב).","pos":"masculine noun","usage":"fear(6x), terror(2x)"},"H4033":{"id":"H4033","lemma":"מָגוּר","translit":"mâgûwr","pron":"maw-goor'","derivation":"or מָגֻר; from H1481 (גּוּר) in the sense of lodging;","strongs_def":"a temporary abode; by extension, a permanent residence","kjv_def":"dwelling, pilgrimage, where sojourn, be a stranger. Compare H4032 (מָגוֹר).","pos":"masculine noun","usage":"pilgrimage(4x), dwellings(2x), sojourn(1x)"},"H4034":{"id":"H4034","lemma":"מְגוֹרַה","translit":"mᵉgôwrah","pron":"meg-o-raw'","derivation":"feminine of H4032 (מָגוֹר);","strongs_def":"affright","kjv_def":"fear.","pos":"feminine noun","usage":"fear(1x)"},"H4035":{"id":"H4035","lemma":"מְגוּרָה","translit":"mᵉgûwrâh","pron":"meg-oo-raw'","derivation":"feminine of H4032 (מָגוֹר) or of H4033 (מָגוּר);","strongs_def":"a fright; also a granary","kjv_def":"barn, fear.","pos":"feminine noun","usage":"fear(2x), barn(1x)"},"H4036":{"id":"H4036","lemma":"מָגוֹר מִסָּבִיב","translit":"Mâgôwr miç-Çâbîyb","pron":"maw-gore' mis-saw-beeb'","derivation":"from H4032 (מָגוֹר) and H5439 (סָבִיב) with the preposition inserted; affright from around;","strongs_def":"Magor-mis-Sabib, a symbolic name of Pashur","kjv_def":"Magormissabib."},"H4037":{"id":"H4037","lemma":"מַגְזֵרָה","translit":"magzêrâh","pron":"mag-zay-raw'","derivation":"from H1504 (גָּזַר);","strongs_def":"a cutting implement, i.e. a blade","kjv_def":"axe."},"H4038":{"id":"H4038","lemma":"מַגָּל","translit":"maggâl","pron":"mag-gawl'","derivation":"from an unused root meaning to reap;","strongs_def":"a sickle","kjv_def":"sickle.","pos":"masculine noun","usage":"sickle(2x)"},"H4039":{"id":"H4039","lemma":"מְגִלָּה","translit":"mᵉgillâh","pron":"meg-il-law'","derivation":"from H1556 (גָּלַל);","strongs_def":"a roll","kjv_def":"roll, volume.","pos":"feminine noun","usage":"roll(20x), volume(1x)"},"H4040":{"id":"H4040","lemma":"מְגִלָּה","translit":"mᵉgillâh","pron":"meg-il-law'","derivation":"(Aramaic) corresponding to H4039 (מְגִלָּה)","strongs_def":"{a roll}","kjv_def":"roll.","pos":"feminine noun","usage":"roll(1x)"},"H4041":{"id":"H4041","lemma":"מְגַמָּה","translit":"mᵉgammâh","pron":"meg-am-maw'","derivation":"from the same as H1571 (גַּם);","strongs_def":"properly, accumulation, i.e. impulse or direction","kjv_def":"sup up.","pos":"feminine noun"},"H4042":{"id":"H4042","lemma":"מָגַן","translit":"mâgan","pron":"maw-gan'","derivation":"a denominative from H4043 (מָגֵן);","strongs_def":"properly, to shield; encompass with; figuratively, to rescue, to hand safely over (i.e. surrender)","kjv_def":"deliver.","pos":"verb","usage":"deliver(3x)"},"H4043":{"id":"H4043","lemma":"מָגֵן","translit":"mâgên","pron":"maw-gane'","derivation":"also (in plural) feminine מְגִנָּה; from H1598 (גָּנַן);","strongs_def":"a shield (i.e. the small one or buckler); figuratively, a protector; also the scaly hide of the crocodile","kjv_def":"[idiom] armed, buckler, defence, ruler, [phrase] scale, shield.","pos":"masculine noun","usage":"shield(48x), buckler(9x), armed(2x), defence(2x), rulers(1x)"},"H4044":{"id":"H4044","lemma":"מְגִנָּה","translit":"mᵉginnâh","pron":"meg-in-naw'","derivation":"from H4042 (מָגַן);","strongs_def":"a covering (in a bad sense), i.e. blindness or obduracy","kjv_def":"sorrow. See also H4043 (מָגֵן).","pos":"feminine noun","usage":"sorrow(1x)"},"H4045":{"id":"H4045","lemma":"מִגְעֶרֶת","translit":"migʻereth","pron":"mig-eh'-reth","derivation":"from H1605 (גָּעַר);","strongs_def":"reproof (i.e. curse)","kjv_def":"rebuke.","pos":"feminine noun","usage":"rebuke(1x)"},"H4046":{"id":"H4046","lemma":"מַגֵּפָה","translit":"maggêphâh","pron":"mag-gay-faw'","derivation":"from H5062 (נָגַף);","strongs_def":"a pestilence; by analogy, defeat","kjv_def":"([idiom] be) plague(-d), slaughter, stroke.","pos":"feminine noun","usage":"plague(21x), slaughter(3x), plagued(1x), stroke(1x)"},"H4047":{"id":"H4047","lemma":"מַגְפִּיעָשׁ","translit":"Magpîyʻâsh","pron":"mag-pee-awsh'","derivation":"apparently from H1479 (גּוּף) or H5062 (נָגַף) and H6211 (עָשׁ); exterminator of (the) moth;","strongs_def":"Magpiash, an Israelite","kjv_def":"Magpiash.","pos":"proper masculine noun","usage":"Magpiash(1x)"},"H4048":{"id":"H4048","lemma":"מָגַר","translit":"mâgar","pron":"maw-gar'","derivation":"a primitive root;","strongs_def":"to yield up; intensively, to precipitate","kjv_def":"cast down, terror.","pos":"verb","usage":"terrors(1x), cast(1x)"},"H4049":{"id":"H4049","lemma":"מְגַר","translit":"mᵉgar","pron":"meg-ar'","derivation":"(Aramaic) corresponding to H4048 (מָגַר);","strongs_def":"to overthrow","kjv_def":"destroy.","pos":"verb","usage":"destroy(1x)"},"H4050":{"id":"H4050","lemma":"מְגֵרָה","translit":"mᵉgêrâh","pron":"meg-ay-raw'","derivation":"from H1641 (גָּרַר);","strongs_def":"a saw","kjv_def":"axe, saw."},"H4051":{"id":"H4051","lemma":"מִגְרוֹן","translit":"Migrôwn","pron":"mig-rone'","derivation":"from H4048 (מָגַר); precipice;","strongs_def":"Migron, a place in Palestine","kjv_def":"Migron.","pos":"proper locative noun","usage":"Migron(2x)"},"H4052":{"id":"H4052","lemma":"מִגְרָעָה","translit":"migrâʻâh","pron":"mig-raw-aw'","derivation":"from H1639 (גָּרַע);","strongs_def":"a ledge or offset","kjv_def":"narrowed rest."},"H4053":{"id":"H4053","lemma":"מִגְרָפָה","translit":"migrâphâh","pron":"mig-raw-faw'","derivation":"from H1640 (גָּרַף);","strongs_def":"something thrown off (by the spade), i.e. a clod","kjv_def":"clod.","pos":"feminine noun","usage":"clod(1x)"},"H4054":{"id":"H4054","lemma":"מִגְרָשׁ","translit":"migrâsh","pron":"mig-rawsh'","derivation":"also (in plural) feminine (Ezekiel 27:28) מִגְרָשָׁה; from H1644 (גָּרַשׁ);","strongs_def":"a suburb (i.e. open country whither flocks are driven from pasture); hence, the area around abuilding, or the margin of the sea","kjv_def":"cast out, suburb.","pos":"masculine noun","usage":"suburbs(110x)"},"H4055":{"id":"H4055","lemma":"מַד","translit":"mad","pron":"mad","derivation":"or מֵד; from H4058 (מָדַד);","strongs_def":"properly, extent, i.e. height; also a measure; by implication, a vesture (as measured); also a carpet","kjv_def":"armour, clothes, garment, judgment, measure, raiment, stature.","pos":"masculine noun","usage":"garment(4x), armour(2x), measure(2x), raiment(1x), judgment(1x), variant(1x), clothes(1x)"},"H4056":{"id":"H4056","lemma":"מַדְבַּח","translit":"madbach","pron":"mad-bakh'","derivation":"(Aramaic) from H1684 (דְּבַח);","strongs_def":"a sacrificial altar","kjv_def":"altar.","pos":"masculine noun","usage":"altar(1x)"},"H4057":{"id":"H4057","lemma":"מִדְבָּר","translit":"midbâr","pron":"mid-bawr'","derivation":"from H1696 (דָבַר) in the sense of driving;","strongs_def":"a pasture (i.e. open field, whither cattle are driven); by implication, a desert; also speech (including its organs)","kjv_def":"desert, south, speech, wilderness.","pos":"masculine noun","usage":"wilderness(255x), desert(13x), south(1x), speech(1x)"},"H4058":{"id":"H4058","lemma":"מָדַד","translit":"mâdad","pron":"maw-dad'","derivation":"a primitive root;","strongs_def":"properly, to stretch; by implication, to measure (as if by stretching a line); figuratively, to be extended","kjv_def":"measure, mete, stretch self.","pos":"verb","usage":"measure(47x), mete(1x), stretched(1x)"},"H4059":{"id":"H4059","lemma":"מִדַּד","translit":"middad","pron":"mid-dad'","derivation":"from H5074 (נָדַד);","strongs_def":"flight","kjv_def":"be gone.","pos":"verb","usage":"gone(1x)"},"H4060":{"id":"H4060","lemma":"מִדָּה","translit":"middâh","pron":"mid-daw'","derivation":"feminine of H4055 (מַד);","strongs_def":"properly, extension, i.e. height or breadth; also a measure (including its standard); hence a portion (as measured) or a vestment; specifically, tribute (as measured)","kjv_def":"garment, measure(-ing, meteyard, piece, size, (great) stature, tribute, wide.","pos":"feminine noun","usage":"measure(37x), piece(7x), stature(4x), size(3x), meteyard(1x), garments(1x), tribute(1x), wide(1x)"},"H4061":{"id":"H4061","lemma":"מִדָּה","translit":"middâh","pron":"mid-daw'","derivation":"(Aramaic) or מִנְדָּה; (Aramaic), corresponding to H4060 (מִדָּה);","strongs_def":"tribute in money","kjv_def":"toll, tribute.","pos":"feminine noun","usage":"toll(3x), tribute(1x)"},"H4062":{"id":"H4062","lemma":"מַדְהֵבָה","translit":"madhêbâh","pron":"mad-hay-baw'","derivation":"perhaps from the equivalent of H1722 (דְּהַב);","strongs_def":"goldmaking, i.e. exactness","kjv_def":"golden city.","pos":"feminine noun"},"H4063":{"id":"H4063","lemma":"מֶדֶו","translit":"medev","pron":"meh'-dev","derivation":"from an unused root meaning to stretch;","strongs_def":"properly, extent, i.e. measure; by implication, a dress (as measured)","kjv_def":"garment."},"H4064":{"id":"H4064","lemma":"מַדְוֶה","translit":"madveh","pron":"mad-veh'","derivation":"from H1738 (דָּוָה);","strongs_def":"sickness","kjv_def":"disease.","pos":"masculine noun","usage":"diseases(2x)"},"H4065":{"id":"H4065","lemma":"מַדּוּחַ","translit":"maddûwach","pron":"mad-doo'akh","derivation":"from H5080 (נָדַח);","strongs_def":"seduction","kjv_def":"cause of banishment."},"H4066":{"id":"H4066","lemma":"מָדוֹן","translit":"mâdôwn","pron":"maw-dohn'","derivation":"from H1777 (דִּין);","strongs_def":"a contest or quarrel","kjv_def":"brawling, contention(-ous), discord, strife. Compare H4079 (מִדְיָן), H4090 (מְדָן).","pos":"masculine noun","usage":"strife(7x), contention(3x), discord(1x), variant(7x)"},"H4067":{"id":"H4067","lemma":"מָדוֹן","translit":"mâdôwn","pron":"maw-dohn'","derivation":"from the same as H4063 (מֶדֶו);","strongs_def":"extensiveness,