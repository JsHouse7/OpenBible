{"H4000":{"id":"H4000","lemma":"מָבוֹן","translit":"mâbôwn","pron":"maw-bone'","derivation":"from H995 (בִּין);","strongs_def":"instructing","kjv_def":"taught."},"H4001":{"id":"H4001","lemma":"מְבוּסָה","translit":"mᵉbûwçâh","pron":"meb-oo-saw'","derivation":"from H947 (בּוּס);","strongs_def":"a trampling","kjv_def":"treading (trodden) down (under foot).","pos":"feminine noun"},"H4002":{"id":"H4002","lemma":"מַבּוּעַ","translit":"mabbûwaʻ","pron":"mab-boo'-ah","derivation":"from H5042 (נָבַע);","strongs_def":"a fountain","kjv_def":"fountain, spring.","pos":"masculine noun","usage":"spring(2x), fountain(1x)"},"H4003":{"id":"H4003","lemma":"מְבוּקָה","translit":"mᵉbûwqâh","pron":"meb-oo-kah'","derivation":"from the same as H950 (בּוּקָה);","strongs_def":"emptiness","kjv_def":"void.","pos":"feminine noun","usage":"void(1x)"},"H4004":{"id":"H4004","lemma":"מִבְחוֹר","translit":"mibchôwr","pron":"mib-khore'","derivation":"from H977 (בָּחַר);","strongs_def":"select, i.e. well fortified","kjv_def":"choice."},"H4005":{"id":"H4005","lemma":"מִבְחָר","translit":"mibchâr","pron":"mib-khawr'","derivation":"from H977 (בָּחַר);","strongs_def":"select, i.e. best","kjv_def":"choice(-st), chosen.","pos":"masculine noun","usage":"choice(7x), chosen(4x), choicest(1x)"},"H4006":{"id":"H4006","lemma":"מִבְחָר","translit":"Mibchâr","pron":"mib-khawr'","derivation":"the same as H4005 (מִבְחָר);","strongs_def":"Mibchar, an Israelite","kjv_def":"Mibhar."},"H4007":{"id":"H4007","lemma":"מַבָּט","translit":"mabbâṭ","pron":"mab-bawt'","derivation":"or מֶבָּט; from H5027 (נָבַט);","strongs_def":"something expected, i.e. (abstractly) expectation","kjv_def":"expectation.","pos":"masculine noun","usage":"expectation(3x)"},"H4008":{"id":"H4008","lemma":"מִבְטָא","translit":"mibṭâʼ","pron":"mib-taw'","derivation":"from H981 (בָּטָא);","strongs_def":"a rash utterance (hasty vow)","kjv_def":"(that which...) uttered (out of).","pos":"masculine noun","usage":"uttered(2x)"},"H4009":{"id":"H4009","lemma":